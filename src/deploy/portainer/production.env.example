# GarajPass production env template.
# Secret values are intentionally blank. Store real values in Portainer or a
# restricted server-side env file; never commit the populated file.

POSTGRES_DB=motorcare
POSTGRES_USER=motorcare_user
POSTGRES_PASSWORD=

JWT_ISSUER=GarajPass
JWT_AUDIENCE=GarajPass.Client
JWT_KEY=
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7

MOTORCARE_COMMIT_SHA=UNSET_DEPLOY_COMMIT
MOTORCARE_BUILD_TIME=UNSET_UTC_ISO8601

ALLOWED_HOSTS=garajpass.com;www.garajpass.com
APP_INTERNAL_API_BASE_URL=http://api:8080
API_HOST_PORT=5002
APP_HOST_PORT=5001

PublicReports__BaseUrl=https://garajpass.com
Seo__SiteName=GarajPass
Seo__SiteBaseUrl=https://garajpass.com
Seo__RobotsIndexEnabled=false
Seo__OgImageUrl=/images/og-garajpass.svg

Email__Provider=Smtp
Email__FromEmail=no-reply@garajpass.com
Email__FromName=GarajPass
Email__SmtpHost=smtp-relay.brevo.com
Email__SmtpPort=587
Email__SmtpUsername=
Email__SmtpPassword=
Email__EnableSsl=true
Email__UseDefaultCredentials=false
Email__AppBaseUrl=https://garajpass.com
Email__SendEmails=true
Email__LogEmailBodyInDevelopment=false

ELASTIC_URI=
ELASTIC_USERNAME=
ELASTIC_PASSWORD=
ELASTIC_INDEX_FORMAT=motorcare-api-prod-{0:yyyy.MM}

API_IMAGE=ghcr.io/yigitcvk/motorcare-api:production
APP_IMAGE=ghcr.io/yigitcvk/motorcare-app:production
MIGRATOR_IMAGE=ghcr.io/yigitcvk/motorcare-migrator:production
