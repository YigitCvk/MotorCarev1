# GarajPass staging env template.
# Secret values are intentionally blank. Store real values in Portainer or a
# restricted server-side env file; never commit the populated file.

POSTGRES_DB=motorcare_staging
POSTGRES_USER=motorcare_user
POSTGRES_PASSWORD=

JWT_ISSUER=BakimSuite
JWT_AUDIENCE=BakimSuite
JWT_KEY=
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7

MOTORCARE_COMMIT_SHA=UNSET_DEPLOY_COMMIT
MOTORCARE_BUILD_TIME=UNSET_UTC_ISO8601

ELASTIC_URI=
ELASTIC_USERNAME=
ELASTIC_PASSWORD=
ELASTIC_INDEX_FORMAT=motorcare-api-staging-{0:yyyy.MM}

APP_INTERNAL_API_BASE_URL=http://api:8080
API_HOST_PORT=5102
APP_HOST_PORT=5101

PublicReports__BaseUrl=https://staging.bakimsuite.com
Seo__SiteName=GarajPass
Seo__SiteBaseUrl=https://staging.bakimsuite.com
Seo__RobotsIndexEnabled=false
Seo__OgImageUrl=/images/og-garajpass.svg

# ---------------------------------------------------------------------------
# Email — Option A: Mailpit (staging smoke / email capture)
# Default when no real SMTP is configured. Mailpit runs as a sidecar container
# and captures all outbound emails. Web UI is at http://SERVER_IP:8025 (or via
# SSH tunnel: ssh -L 8025:localhost:8025 user@server).
# ---------------------------------------------------------------------------
Email__Provider=Smtp
Email__FromEmail=no-reply@bakimsuite.com
Email__FromName=GarajPass
Email__SmtpHost=mailpit
Email__SmtpPort=1025
Email__SmtpUsername=
Email__SmtpPassword=
Email__EnableSsl=false
Email__UseDefaultCredentials=false
Email__AppBaseUrl=https://staging.bakimsuite.com
Email__SendEmails=true
Email__LogEmailBodyInDevelopment=false
MAILPIT_WEB_PORT=8025

# ---------------------------------------------------------------------------
# Email — Option B: Real SMTP (uncomment and fill to send actual emails)
# When switching to real SMTP, update SmtpHost/Port/Username/Password and
# set EnableSsl=true. Keep SendEmails=true.
# ---------------------------------------------------------------------------
# Email__SmtpHost=smtp.yourprovider.com
# Email__SmtpPort=587
# Email__SmtpUsername=
# Email__SmtpPassword=
# Email__EnableSsl=true

API_IMAGE=ghcr.io/yigitcvk/motorcare-api:staging
APP_IMAGE=ghcr.io/yigitcvk/motorcare-app:staging
MIGRATOR_IMAGE=ghcr.io/yigitcvk/motorcare-migrator:staging
