{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "EventLog": {
      "LogLevel": {
        "Default": "None"
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    }
  },
  "Elastic": {
    "Uri": "http://localhost:9200",
    "Username": "",
    "Password": "",
    "IndexFormat": "motorcare-api-{0:yyyy.MM}"
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "MotorCare.Dev",
    "Audience": "MotorCare.Dev.Client",
    "Key": "",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "Email": {
    "Provider": "Smtp",
    "FromEmail": "no-reply@bakimsuite.local",
    "FromName": "GarajPass",
    "SmtpHost": "",
    "SmtpPort": 587,
    "SmtpUsername": "",
    "SmtpPassword": "",
    "EnableSsl": true,
    "UseDefaultCredentials": false,
    "AppBaseUrl": "https://localhost:7086",
    "SendEmails": false,
    "LogEmailBodyInDevelopment": true
  }
}
