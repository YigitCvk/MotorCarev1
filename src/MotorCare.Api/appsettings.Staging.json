{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Elastic": {
    "Uri": "",
    "Username": "",
    "Password": "",
    "IndexFormat": "motorcare-api-staging-{0:yyyy.MM}"
  },
  "DataProtection": {
    "KeysPath": ""
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "BakimSuite.Staging",
    "Audience": "BakimSuite.Staging.Client",
    "Key": "",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "Email": {
    "Provider": "Smtp",
    "FromEmail": "no-reply@bakimsuite.com",
    "FromName": "BakimSuite",
    "SmtpHost": "",
    "SmtpPort": 587,
    "SmtpUsername": "",
    "SmtpPassword": "",
    "EnableSsl": true,
    "UseDefaultCredentials": false,
    "AppBaseUrl": "https://staging.bakimsuite.com",
    "SendEmails": true,
    "LogEmailBodyInDevelopment": false
  },
  "AllowedHosts": "*"
}
