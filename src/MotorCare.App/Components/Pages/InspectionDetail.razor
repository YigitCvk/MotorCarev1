@page "/inspections/{Id:guid}"
@using System.Net
@using MotorCare.App.Components.Shared
@using MotorCare.App.Models.Inspections
@inject InspectionsService InspectionsService
@inject NavigationManager NavigationManager

<PageTitle>@(_inspection?.InspectionNo ?? "Ekspertiz Detayı")</PageTitle>

<div class="page-shell">
    @if (_loading)
    {
        <section class="loading-state">
            <strong>Ekspertiz kaydı yükleniyor</strong>
            <p>Lütfen bekleyin.</p>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <section class="error-state">
            <strong>Ekspertiz detayı alınamadı</strong>
            <p>@_error</p>
        </section>
    }
    else if (_inspection is null)
    {
        <section class="empty-state">
            <strong>Ekspertiz kaydı bulunamadı.</strong>
            <p>Listeye dönüp başka bir kayıt seçebilirsiniz.</p>
        </section>
    }
    else
    {
        <section class="page-header">
            <div>
                <div class="eyebrow">Motosiklet Ekspertiz</div>
                <h1 class="page-title">@_inspection.InspectionNo</h1>
                <p class="page-description">@_inspection.CustomerName · @_inspection.Phone · @_inspection.Plate</p>
            </div>
            <div class="page-header-actions">
                <a href="@($"/inspections/{Id}/print")" class="app-btn-secondary">Yazdır / PDF Al</a>
                <span class="status-badge @GetStatusBadgeClass(_inspection.Status)">@_inspection.StatusText</span>
                <a href="/inspections" class="app-btn-secondary">Listeye Dön</a>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <section class="loading-state">
                <strong>@_message</strong>
            </section>
        }

        <section class="surface-card">
            <div class="section-header">
                <div>
                    <div class="section-title">Ekspertiz Özeti</div>
                    <div class="section-subtitle">Ekspertiz kaydını rapor gibi okuyabileceğiniz özet görünüm.</div>
                </div>
                @if (HasCriticalFindings)
                {
                    <button type="button" class="app-btn-primary" @onclick="NavigateToServiceOrderSuggestion">
                        @(CanCreateServiceOrder ? "Servis Emri Oluştur" : "Servis Önerisi Oluştur")
                    </button>
                }
            </div>

            <div class="content-grid">
                <section class="surface-card">
                    <div class="section-title mb-3">Rapor Kartı</div>
                    <dl class="detail-list">
                        <dt>Ekspertiz No</dt>
                        <dd>@_inspection.InspectionNo</dd>
                        <dt>Müşteri</dt>
                        <dd>@_inspection.CustomerName</dd>
                        <dt>Araç</dt>
                        <dd>@VehicleDisplayText</dd>
                        <dt>Paket</dt>
                        <dd>@_inspection.PackageTypeText</dd>
                        <dt>Oluşturma</dt>
                        <dd>@_inspection.CreatedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</dd>
                        <dt>Durum</dt>
                        <dd>@_inspection.StatusText</dd>
                    </dl>
                </section>

                <section class="surface-card">
                    <div class="section-title mb-3">Durum Özeti</div>
                    <div class="metric-grid">
                        <article class="metric-card mc-success">
                            <div class="metric-label">Orijinal</div>
                            <div class="metric-value">@OriginalCount</div>
                        </article>
                        <article class="metric-card mc-primary">
                            <div class="metric-label">Boyalı</div>
                            <div class="metric-value">@PaintedCount</div>
                        </article>
                        <article class="metric-card mc-warning">
                            <div class="metric-label">Değişen</div>
                            <div class="metric-value">@ChangedCount</div>
                        </article>
                        <article class="metric-card mc-danger">
                            <div class="metric-label">Hasarlı</div>
                            <div class="metric-value">@DamagedCount</div>
                        </article>
                        <article class="metric-card mc-warning">
                            <div class="metric-label">Çizik</div>
                            <div class="metric-value">@ScratchedCount</div>
                        </article>
                    </div>
                </section>
            </div>
        </section>

        <div class="content-grid">
            <section class="surface-card">
                <div class="section-title mb-3">Kritik Bulgular</div>
                @if (CriticalItems.Count == 0)
                {
                    <section class="empty-state">
                        <strong>Kritik bulgu yok</strong>
                        <p>Hasarlı veya değişen olarak işaretlenmiş kalem bulunmuyor.</p>
                    </section>
                }
                else
                {
                    <div class="summary-list">
                        @foreach (var item in CriticalItems)
                        {
                            <div class="summary-list-item">
                                <strong>@item.Name</strong>
                                <span class="status-badge @GetResultBadgeClass(item.Result)">@item.ResultText</span>
                                <span>@item.CategoryText</span>
                                @if (!string.IsNullOrWhiteSpace(item.Notes))
                                {
                                    <span class="small text-muted">@item.Notes</span>
                                }
                            </div>
                        }
                    </div>
                }
            </section>

            <section class="surface-card">
                <div class="section-title mb-3">Servis Önerileri</div>
                @if (ServiceRecommendations.Count == 0)
                {
                    <section class="empty-state">
                        <strong>Servis önerisi yok</strong>
                        <p>Hasarlı, değişen veya çizik bulgulardan öneri üretilemedi.</p>
                    </section>
                }
                else
                {
                    <div class="mobile-card-list">
                        @foreach (var recommendation in ServiceRecommendations)
                        {
                            <label class="selection-item @(recommendation.Selected ? "selected" : string.Empty)">
                                <div class="d-flex flex-column gap-1">
                                    <strong>@recommendation.SourceItemName</strong>
                                    <span class="status-badge @GetRecommendationSeverityBadgeClass(recommendation.Severity)">@recommendation.SeverityText</span>
                                    <span>@recommendation.SuggestedAction</span>
                                </div>
                                <InputCheckbox @bind-Value="recommendation.Selected" />
                            </label>
                        }
                    </div>

                    <div class="action-bar mt-3">
                        <button type="button" class="app-btn-primary" @onclick="CreateServiceOrderWithSelectedRecommendations" disabled="@(!SelectedRecommendations.Any())">
                            Seçilenlerle Servis Emri Oluştur
                        </button>
                        <button type="button" class="app-btn-secondary" @onclick="CreateServiceOrderWithAllRecommendations">
                            Tümünü Servis Emrine Aktar
                        </button>
                    </div>
                }
            </section>
        </div>

        <div class="content-grid">
            <section class="surface-card">
                <div class="section-title mb-3">Kaporta Özeti</div>
                @if (BodySummaryItems.Count == 0)
                {
                    <section class="empty-state">
                        <strong>Kaporta özeti boş</strong>
                        <p>Karenaj / kaporta tarafında işaretlenmiş kalem bulunmuyor.</p>
                    </section>
                }
                else
                {
                    <div class="summary-list">
                        @foreach (var item in BodySummaryItems)
                        {
                            <div class="summary-list-item">
                                <strong>@item.Name</strong>
                                <span class="status-badge @GetResultBadgeClass(item.Result)">@item.ResultText</span>
                                @if (!string.IsNullOrWhiteSpace(item.Notes))
                                {
                                    <span class="small text-muted">@item.Notes</span>
                                }
                            </div>
                        }
                    </div>
                }
            </section>

            <section class="surface-card">
                <div class="section-title mb-3">Test Sürüşü Notları</div>
                @if (string.IsNullOrWhiteSpace(_inspection.TestRideNotes))
                {
                    <section class="empty-state">
                        <strong>Test sürüşü notu girilmemiş</strong>
                        <p>Bu ekspertiz için test sürüşü notu bulunmuyor.</p>
                    </section>
                }
                else
                {
                    <p class="page-description">@_inspection.TestRideNotes</p>
                }
            </section>
        </div>

        <div class="content-grid">
            <section class="surface-card">
                <div class="section-title mb-3">Genel Açıklama</div>
                @if (string.IsNullOrWhiteSpace(_inspection.GeneralNotes))
                {
                    <section class="empty-state">
                        <strong>Genel açıklama girilmemiş</strong>
                        <p>Bu ekspertiz için genel açıklama notu bulunmuyor.</p>
                    </section>
                }
                else
                {
                    <p class="page-description">@_inspection.GeneralNotes</p>
                }
            </section>

            <section class="surface-card">
                <div class="section-title mb-3">Araç Bilgileri / Genel Bilgiler</div>
                <dl class="detail-list">
                    <dt>Müşteri</dt>
                    <dd>@_inspection.CustomerName</dd>
                    <dt>Telefon</dt>
                    <dd>@_inspection.Phone</dd>
                    <dt>Plaka</dt>
                    <dd>@_inspection.Plate</dd>
                    <dt>Marka / Model</dt>
                    <dd>@VehicleDisplayText</dd>
                    <dt>Yıl</dt>
                    <dd>@(_inspection.Year?.ToString() ?? "-")</dd>
                    <dt>Kilometre</dt>
                    <dd>@(_inspection.Mileage?.ToString("N0") ?? "-")</dd>
                    <dt>Şasi No</dt>
                    <dd>@(_inspection.ChassisNumber ?? "-")</dd>
                    <dt>Motor No</dt>
                    <dd>@(_inspection.EngineNumber ?? "-")</dd>
                    <dt>5664 Sorgu</dt>
                    <dd>@(_inspection.Query5664 ?? "-")</dd>
                    <dt>KM Sorgu</dt>
                    <dd>@(_inspection.MileageQuery ?? "-")</dd>
                </dl>
            </section>
        </div>

        <section class="surface-card">
            <div class="section-title mb-3">Paket Özeti</div>
            <dl class="detail-list">
                <dt>Paket</dt>
                <dd>@_inspection.PackageTypeText</dd>
                <dt>Fiyat</dt>
                <dd>@_inspection.PackagePrice.ToString("N2") ₺</dd>
                <dt>Durum</dt>
                <dd>@_inspection.StatusText</dd>
                <dt>Oluşturma</dt>
                <dd>@_inspection.CreatedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</dd>
                <dt>Tamamlanma</dt>
                <dd>@(_inspection.CompletedAt?.LocalDateTime.ToString("dd.MM.yyyy HH:mm") ?? "-")</dd>
            </dl>

            <div class="action-bar mt-4">
                <button type="button" class="app-btn-primary" @onclick="CompleteAsync" disabled="@(!_canEdit || _savingAction)">
                    @(_savingAction ? "Kaydediliyor..." : "Ekspertizi Tamamla")
                </button>
                <button type="button" class="app-btn-secondary" @onclick="CancelAsync" disabled="@(!_canEdit || _savingAction)">
                    İptal Et
                </button>
                <button type="button" class="app-btn-secondary" disabled>
                    Rapor Oluştur Yakında
                </button>
            </div>
        </section>

        <div class="tab-bar mt-4 mb-3">
            @foreach (var tab in _tabs)
            {
                <button type="button" class="tab-item @(_activeTab == tab ? "active" : string.Empty)" @onclick="@(() => _activeTab = tab)">
                    @tab
                </button>
            }
        </div>

        @if (_activeTab == "Mekanik")
        {
            @RenderItems(MotorcycleInspectionCategory.MechanicalAndRunningGear)
        }
        else if (_activeTab == "Karenaj/Kaporta")
        {
            <MotorcycleBodyMap @key="_inspection.Id"
                               Items="@BodyAndFairingItems"
                               CanEdit="@_canEdit"
                               Saving="@_savingAction"
                               OnSave="SaveItemAsync" />
            @RenderItems(MotorcycleInspectionCategory.BodyAndFairing)
        }
        else if (_activeTab == "OBD/Elektronik")
        {
            @RenderItems(MotorcycleInspectionCategory.ObdAndElectrical)
        }
        else if (_activeTab == "Test Sürüşü")
        {
            <section class="surface-card">
                <div class="section-title mb-3">Test Sürüşü İzlenimleri</div>
                <textarea class="form-control" rows="4" disabled="@(!_canEdit)"
                          value="@_inspection.TestRideNotes"
                          @oninput="e => _inspection.TestRideNotes = e.Value?.ToString()"></textarea>
                @RenderItems(MotorcycleInspectionCategory.TestRide)
            </section>
        }
        else
        {
            <section class="surface-card">
                <div class="section-title mb-3">Genel Açıklama</div>
                <div class="form-grid">
                    <div class="full-span">
                        <label class="form-label">Kozmetik Notlar</label>
                        <textarea class="form-control" rows="4" disabled="@(!_canEdit)"
                                  value="@_inspection.CosmeticNotes"
                                  @oninput="e => _inspection.CosmeticNotes = e.Value?.ToString()"></textarea>
                    </div>
                    <div class="full-span">
                        <label class="form-label">Genel Açıklama</label>
                        <textarea class="form-control" rows="4" disabled="@(!_canEdit)"
                                  value="@_inspection.GeneralNotes"
                                  @oninput="e => _inspection.GeneralNotes = e.Value?.ToString()"></textarea>
                    </div>
                </div>
                <div class="action-bar justify-content-end mt-4">
                    <button type="button" class="app-btn-primary" @onclick="SaveHeaderAsync" disabled="@(!_canEdit || _savingAction)">
                        Bilgileri Kaydet
                    </button>
                </div>
            </section>
        }
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private sealed class InspectionServiceRecommendation
    {
        public string SourceItemName { get; init; } = string.Empty;
        public string SuggestedAction { get; init; } = string.Empty;
        public MotorcycleInspectionResult SourceResult { get; init; }
        public string SeverityText { get; init; } = string.Empty;
        public string Severity { get; init; } = string.Empty;
        public bool Selected { get; set; } = true;
    }

    private readonly string[] _tabs = ["Mekanik", "Karenaj/Kaporta", "OBD/Elektronik", "Test Sürüşü", "Genel Açıklama"];
    private MotorcycleInspectionDetail? _inspection;
    private string _activeTab = "Mekanik";
    private bool _loading = true;
    private bool _savingAction;
    private string? _error;
    private string? _message;
    private Guid _loadedId;
    private List<InspectionServiceRecommendation> _serviceRecommendations = [];

    private bool _canEdit => _inspection is not null &&
                             _inspection.Status != MotorcycleInspectionStatus.Completed &&
                             _inspection.Status != MotorcycleInspectionStatus.Cancelled;

    private string VehicleDisplayText => string.Join(" ", new[] { _inspection?.Brand, _inspection?.Model }.Where(x => !string.IsNullOrWhiteSpace(x))).Trim() switch
    {
        "" => _inspection?.Plate ?? "-",
        var text => $"{text} · {_inspection?.Plate}"
    };

    private List<MotorcycleInspectionItem> BodyAndFairingItems => _inspection?.Items?
        .Where(x => x.Category == MotorcycleInspectionCategory.BodyAndFairing)
        .OrderBy(x => x.SortOrder)
        .ToList() ?? [];

    private List<MotorcycleInspectionItem> CriticalItems => _inspection?.Items?
        .Where(x => x.Result is MotorcycleInspectionResult.Damaged or MotorcycleInspectionResult.Changed)
        .OrderByDescending(x => x.Result == MotorcycleInspectionResult.Damaged)
        .ThenBy(x => x.Category)
        .ThenBy(x => x.SortOrder)
        .ToList() ?? [];

    private List<MotorcycleInspectionItem> BodySummaryItems => BodyAndFairingItems
        .Where(x => x.Result is MotorcycleInspectionResult.Original or MotorcycleInspectionResult.Painted or MotorcycleInspectionResult.Changed or MotorcycleInspectionResult.Damaged or MotorcycleInspectionResult.Scratched)
        .ToList();

    private List<InspectionServiceRecommendation> ServiceRecommendations => _serviceRecommendations;
    private IEnumerable<InspectionServiceRecommendation> SelectedRecommendations => _serviceRecommendations.Where(x => x.Selected);

    private bool HasCriticalFindings => CriticalItems.Count > 0;
    private bool CanCreateServiceOrder => _inspection?.CustomerId.HasValue == true && !string.IsNullOrWhiteSpace(_inspection.Plate);

    private int OriginalCount => CountByResult(MotorcycleInspectionResult.Original);
    private int PaintedCount => CountByResult(MotorcycleInspectionResult.Painted);
    private int ChangedCount => CountByResult(MotorcycleInspectionResult.Changed);
    private int DamagedCount => CountByResult(MotorcycleInspectionResult.Damaged);
    private int ScratchedCount => CountByResult(MotorcycleInspectionResult.Scratched);

    protected override async Task OnParametersSetAsync()
    {
        if (Id == Guid.Empty)
        {
            _inspection = null;
            _loading = false;
            _error = "Ekspertiz kaydı bulunamadı.";
            return;
        }

        if (_loadedId == Id && _inspection is not null)
        {
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        _message = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var result = await InspectionsService.GetByIdAsync(Id);
            if (result is null)
            {
                _inspection = null;
                _error = "Ekspertiz kaydı bulunamadı.";
                return;
            }

            result.Items ??= [];
            _inspection = result;
            _loadedId = Id;
            BuildServiceRecommendations();
        }
        catch (ApiException ex) when (ex.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }
        catch (ApiException ex) when (ex.StatusCode == HttpStatusCode.NotFound)
        {
            _inspection = null;
            _error = "Ekspertiz kaydı bulunamadı.";
        }
        catch (ApiException ex)
        {
            _inspection = null;
            _error = BuildApiErrorMessage(ex);
        }
        catch (Exception ex)
        {
            _inspection = null;
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void BuildServiceRecommendations()
    {
        if (_inspection is null)
        {
            _serviceRecommendations = [];
            return;
        }

        var previousSelections = _serviceRecommendations.ToDictionary(x => x.SourceItemName, x => x.Selected, StringComparer.OrdinalIgnoreCase);

        _serviceRecommendations = _inspection.Items
            .Where(x => x.Result is MotorcycleInspectionResult.Damaged or MotorcycleInspectionResult.Changed or MotorcycleInspectionResult.Scratched)
            .Select(x => new InspectionServiceRecommendation
            {
                SourceItemName = x.Name,
                SuggestedAction = GetSuggestedAction(x),
                SourceResult = x.Result,
                Severity = GetSeverityKey(x.Result),
                SeverityText = GetSeverityText(x.Result),
                Selected = previousSelections.TryGetValue(x.Name, out var selected) ? selected : x.Result != MotorcycleInspectionResult.Scratched
            })
            .ToList();
    }

    private void NavigateToServiceOrderSuggestion()
        => NavigateToServiceOrder(SelectedRecommendations.Any() ? SelectedRecommendations : ServiceRecommendations);

    private void CreateServiceOrderWithSelectedRecommendations()
        => NavigateToServiceOrder(SelectedRecommendations);

    private void CreateServiceOrderWithAllRecommendations()
        => NavigateToServiceOrder(ServiceRecommendations);

    private void NavigateToServiceOrder(IEnumerable<InspectionServiceRecommendation> recommendations)
    {
        if (_inspection is null)
        {
            return;
        }

        var selected = recommendations.ToList();
        if (selected.Count == 0)
        {
            _message = "Önce en az bir servis önerisi seçin.";
            return;
        }

        var complaint = BuildComplaintSummary(selected);
        var serializedRecommendations = string.Join("||", selected.Select(x => $"{x.SourceItemName}##{x.SeverityText}##{x.SuggestedAction}"));

        var query = new List<string>();
        if (_inspection.CustomerId.HasValue)
        {
            query.Add($"customerId={_inspection.CustomerId.Value}");
        }

        if (!string.IsNullOrWhiteSpace(_inspection.Plate))
        {
            query.Add($"plate={Uri.EscapeDataString(_inspection.Plate)}");
        }

        query.Add($"complaint={Uri.EscapeDataString(complaint)}");
        query.Add($"recommendations={Uri.EscapeDataString(serializedRecommendations)}");
        NavigationManager.NavigateTo($"/service-orders/create?{string.Join("&", query)}");
    }

    private string BuildComplaintSummary(IReadOnlyList<InspectionServiceRecommendation> recommendations)
        => $"Ekspertiz {_inspection!.InspectionNo}:{Environment.NewLine}" +
           string.Join(Environment.NewLine, recommendations.Select(x => $"- {x.SourceItemName} [{x.SeverityText}] · {x.SuggestedAction}"));

    private static string GetSuggestedAction(MotorcycleInspectionItem item) => item.Result switch
    {
        MotorcycleInspectionResult.Damaged => $"{item.Name} için onarım veya parça değişimi değerlendirin",
        MotorcycleInspectionResult.Changed => $"{item.Name} için değişen parça kontrolü ve uyum incelemesi yapın",
        MotorcycleInspectionResult.Scratched => $"{item.Name} için kozmetik düzeltme / boya işlemi değerlendirin",
        _ => $"{item.Name} için servis değerlendirmesi yapın"
    };

    private static string GetSeverityText(MotorcycleInspectionResult result) => result switch
    {
        MotorcycleInspectionResult.Damaged => "Yüksek",
        MotorcycleInspectionResult.Changed => "Orta",
        MotorcycleInspectionResult.Scratched => "Düşük",
        _ => "Bilgi"
    };

    private static string GetSeverityKey(MotorcycleInspectionResult result) => result switch
    {
        MotorcycleInspectionResult.Damaged => "high",
        MotorcycleInspectionResult.Changed => "medium",
        MotorcycleInspectionResult.Scratched => "low",
        _ => "info"
    };

    private int CountByResult(MotorcycleInspectionResult result)
        => _inspection?.Items?.Count(x => x.Result == result) ?? 0;

    private RenderFragment RenderItems(MotorcycleInspectionCategory category) => builder =>
    {
        if (_inspection is null)
        {
            return;
        }

        var items = _inspection.Items
            .Where(x => x.Category == category)
            .OrderBy(x => x.SortOrder)
            .ToList();

        var seq = 0;
        builder.OpenElement(seq++, "section");
        builder.AddAttribute(seq++, "class", "mobile-card-list");

        if (items.Count == 0)
        {
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "empty-state");
            builder.OpenElement(seq++, "strong");
            builder.AddContent(seq++, "Bu sekmede kontrol kalemi bulunmuyor.");
            builder.CloseElement();
            builder.CloseElement();
        }
        else
        {
            foreach (var item in items)
            {
                builder.OpenElement(seq++, "article");
                builder.AddAttribute(seq++, "class", "surface-card");

                builder.OpenElement(seq++, "div");
                builder.AddAttribute(seq++, "class", "section-header");
                builder.OpenElement(seq++, "div");
                builder.OpenElement(seq++, "div");
                builder.AddAttribute(seq++, "class", "section-title");
                builder.AddContent(seq++, item.Name);
                builder.CloseElement();
                builder.OpenElement(seq++, "div");
                builder.AddAttribute(seq++, "class", "section-subtitle");
                builder.AddContent(seq++, item.CategoryText);
                builder.CloseElement();
                builder.CloseElement();
                builder.CloseElement();

                builder.OpenElement(seq++, "select");
                builder.AddAttribute(seq++, "class", "form-select");
                if (!_canEdit || _savingAction)
                    builder.AddAttribute(seq++, "disabled", true);
                builder.AddAttribute(seq++, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, e =>
                {
                    if (int.TryParse(e.Value?.ToString(), out var intVal))
                        item.Result = (MotorcycleInspectionResult)intVal;
                }));
                foreach (var result in Enum.GetValues<MotorcycleInspectionResult>())
                {
                    builder.OpenElement(seq++, "option");
                    builder.AddAttribute(seq++, "value", (int)result);
                    if (result == item.Result)
                        builder.AddAttribute(seq++, "selected", true);
                    builder.AddContent(seq++, GetResultText(result));
                    builder.CloseElement();
                }
                builder.CloseElement();

                builder.OpenElement(seq++, "textarea");
                builder.AddAttribute(seq++, "class", "form-control mt-3");
                builder.AddAttribute(seq++, "rows", "3");
                if (!_canEdit || _savingAction)
                    builder.AddAttribute(seq++, "disabled", true);
                builder.AddAttribute(seq++, "value", item.Notes ?? string.Empty);
                builder.AddAttribute(seq++, "oninput", EventCallback.Factory.Create<ChangeEventArgs>(this, e => item.Notes = e.Value?.ToString()));
                builder.CloseElement();

                builder.OpenElement(seq++, "div");
                builder.AddAttribute(seq++, "class", "action-bar justify-content-end mt-3");
                builder.OpenElement(seq++, "button");
                builder.AddAttribute(seq++, "type", "button");
                builder.AddAttribute(seq++, "class", "app-btn-secondary");
                if (!_canEdit || _savingAction)
                {
                    builder.AddAttribute(seq++, "disabled", true);
                }
                builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => SaveItemAsync(item)));
                builder.AddContent(seq++, "Kalemi Kaydet");
                builder.CloseElement();
                builder.CloseElement();

                builder.CloseElement();
            }
        }

        builder.CloseElement();
    };

    private async Task SaveHeaderAsync()
    {
        if (_inspection is null)
        {
            return;
        }

        try
        {
            _savingAction = true;
            _message = null;
            _error = null;

            await InspectionsService.UpdateAsync(_inspection.Id, new UpdateMotorcycleInspectionRequest
            {
                CustomerId = _inspection.CustomerId,
                VehicleId = _inspection.VehicleId,
                CustomerName = _inspection.CustomerName,
                Phone = _inspection.Phone,
                Plate = _inspection.Plate,
                Brand = _inspection.Brand,
                Model = _inspection.Model,
                Year = _inspection.Year,
                Mileage = _inspection.Mileage,
                ChassisNumber = _inspection.ChassisNumber,
                EngineNumber = _inspection.EngineNumber,
                Query5664 = _inspection.Query5664,
                MileageQuery = _inspection.MileageQuery,
                PackageType = _inspection.PackageType,
                GeneralNotes = _inspection.GeneralNotes,
                TestRideNotes = _inspection.TestRideNotes,
                CosmeticNotes = _inspection.CosmeticNotes
            });

            _message = "Ekspertiz bilgileri güncellendi.";
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            _error = BuildApiErrorMessage(ex);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _savingAction = false;
        }
    }

    private async Task SaveItemAsync(MotorcycleInspectionItem item)
    {
        try
        {
            _savingAction = true;
            _error = null;
            _message = null;

            await InspectionsService.UpdateItemAsync(Id, item.Id, new UpdateMotorcycleInspectionItemRequest
            {
                Result = item.Result,
                Notes = item.Notes
            });

            _message = $"\"{item.Name}\" kalemi güncellendi.";
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            _error = BuildApiErrorMessage(ex);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _savingAction = false;
        }
    }

    private async Task CompleteAsync()
    {
        try
        {
            _savingAction = true;
            _error = null;
            _message = null;

            await SaveHeaderAsync();
            if (!string.IsNullOrWhiteSpace(_error))
            {
                return;
            }

            await InspectionsService.CompleteAsync(Id);
            _message = "Ekspertiz tamamlandı.";
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            _error = BuildApiErrorMessage(ex);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _savingAction = false;
        }
    }

    private async Task CancelAsync()
    {
        try
        {
            _savingAction = true;
            _error = null;
            _message = null;

            await InspectionsService.CancelAsync(Id);
            _message = "Ekspertiz iptal edildi.";
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            _error = BuildApiErrorMessage(ex);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _savingAction = false;
        }
    }

    private static string BuildApiErrorMessage(ApiException ex)
        => $"İstek başarısız oldu ({(int)ex.StatusCode}) · {ex.Endpoint} · {ex.Message}";

