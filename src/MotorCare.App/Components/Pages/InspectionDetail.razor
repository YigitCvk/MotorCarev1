@page "/inspections/{Id:guid}"
@using System.Net
@using MotorCare.App.Models.Inspections
@using MotorCare.App.Models.PublicRecords
@inject AuthService AuthService
@inject InspectionsService InspectionsService
@inject PublicRecordsService PublicRecordsService
@inject NavigationManager NavigationManager
@inject ILogger<InspectionDetail> Logger

<PageTitle>@(_inspection?.InspectionNo ?? "Ekspertiz Detayi")</PageTitle>

<div class="page-shell inspection-wizard-page">
    @if (_loading)
    {
        <section class="loading-state">
            <strong>Ekspertiz kaydı yükleniyor</strong>
            <p>Lutfen bekleyin.</p>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <section class="error-state">
            <strong>Ekspertiz kaydı acilamadi</strong>
            <p>@_error</p>
        </section>
    }
    else if (_inspection is null)
    {
        <section class="empty-state">
            <strong>Ekspertiz kaydı bulunamadı.</strong>
            <p>Listeye dönüp tekrar deneyin.</p>
        </section>
    }
    else
    {
        <section class="inspection-form-header">
            <div>
                <h1 class="inspection-form-title">Motosiklet Ekspertiz Formu</h1>
                <p class="inspection-form-subtitle">Ekspertizi adim adim ilerleyin. Her adim bir form bolumu gibi davranir ve sadece aktif icerik görünür.</p>
            </div>
            <div class="page-header-actions">
                <a class="app-btn-secondary" href="/inspections">Listeye Dön</a>
                <a class="app-btn-secondary" href="@($"/inspections/{Id}/print")">Yazdir / PDF Al</a>
                <a class="app-btn-secondary" href="@($"/inspections/{Id}/qr-print")">QR Kartı</a>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(_stepError))
        {
            <section class="error-state">
                <strong>Adim kaydedilemedi</strong>
                <p>@_stepError</p>
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(_stepMessage))
        {
            <section class="success-state">
                <strong>Kayıt güncellendi</strong>
                <p>@_stepMessage</p>
            </section>
        }

        <PublicRecordAccessCard Title="Dijital Ekspertiz / QR"
                                Subtitle="Ekspertiz kaydı public doğrulama bağlantısı ve QR çıktısı"
                                RecordTypeLabel="Dijital Ekspertiz Kaydı"
                                PublicPathPrefix="/public/inspection-report"
                                PrintHref="@($"/inspections/{Id}/qr-print")"
                                Plate="@_inspection.Plate"
                                Vehicle="@VehicleDisplay"
                                RecordDate="@(_inspection.CompletedAt ?? _inspection.CreatedAt)"
                                LoadAccess="@LoadInspectionPublicAccessAsync"
                                EnableAccess="@EnableInspectionPublicAccessAsync"
                                DisableAccess="@DisableInspectionPublicAccessAsync" />

        <section class="inspection-form-shell">
            <nav class="inspection-stepper" aria-label="Ekspertiz adimlari">
                @for (var index = 0; index < _steps.Count; index++)
                {
                    var step = _steps[index];
                    var stateClass = index == _activeStepIndex ? "is-active" : index < _activeStepIndex ? "is-completed" : string.Empty;

                    <button type="button"
                            class="inspection-stepper-item @stateClass"
                            @onclick="() => GoToStep(index)">
                        <span class="inspection-stepper-index">@(index + 1)</span>
                        <span class="inspection-stepper-copy">
                            <strong>@step.Title</strong>
                            <small>@(index == _activeStepIndex ? "Aktif adim" : "Adim")</small>
                        </span>
                    </button>
                }
            </nav>

            <section class="inspection-form-paper">
                <header class="inspection-form-paper-header">
                    <div class="inspection-form-paper-copy">
                        <h2>@CurrentStep.Title</h2>
                        <p>@CurrentStep.Subtitle</p>
                    </div>
                    <div class="inspection-form-paper-meta">
                        <span><strong>Ekspertiz:</strong> @_inspection.InspectionNo</span>
                        <span><strong>Paket:</strong> @_inspection.PackageTypeText</span>
                        <span><strong>Durum:</strong> @_inspection.StatusText</span>
                    </div>
                </header>

                @switch (CurrentStep.StepType)
                {
                    case InspectionWizardStepType.VehicleInfo:
                        <section class="inspection-data-sheet">
                            <div class="inspection-data-grid">
                                <div class="inspection-data-field">
                                <label class="form-label">Müşteri</label>
                                <input class="form-control" value="@_inspection.CustomerName" disabled />
                                </div>
                                <div class="inspection-data-field">
                                <label class="form-label">Telefon</label>
                                <input class="form-control" value="@_inspection.Phone" disabled />
                                </div>
                                <div class="inspection-data-field">
                                <label class="form-label">Plaka</label>
                                <InputText class="form-control" @bind-Value="_inspection.Plate" />
                                </div>
                                <div class="inspection-data-field">
                                <label class="form-label">Paket</label>
                                <input class="form-control" value="@_inspection.PackageTypeText" disabled />
                                </div>
                                <div class="inspection-data-field">
                                <label class="form-label">Marka</label>
                                <InputText class="form-control" @bind-Value="_inspection.Brand" />
                                </div>
                                <div class="inspection-data-field">
                                <label class="form-label">Model</label>
                                <InputText class="form-control" @bind-Value="_inspection.Model" />
                                </div>
                                <div class="inspection-data-field">
                                <label class="form-label">Yil</label>
                                <InputNumber class="form-control" @bind-Value="_inspection.Year" />
                                </div>
                                <div class="inspection-data-field">
                                <label class="form-label">Kilometre</label>
                                <InputNumber class="form-control" @bind-Value="_inspection.Mileage" />
                                </div>
                                <div class="inspection-data-field">
                                <label class="form-label">Şasi No</label>
                                <InputText class="form-control" @bind-Value="_inspection.ChassisNumber" />
                                </div>
                                <div class="inspection-data-field">
                                <label class="form-label">Motor No</label>
                                <InputText class="form-control" @bind-Value="_inspection.EngineNumber" />
                                </div>
                                <div class="inspection-data-field">
                                <label class="form-label">5664 Sorgu</label>
                                <InputText class="form-control" @bind-Value="_inspection.Query5664" />
                                </div>
                                <div class="inspection-data-field">
                                <label class="form-label">KM Sorgu</label>
                                <InputText class="form-control" @bind-Value="_inspection.MileageQuery" />
                                </div>
                            </div>
                        </section>
                        break;

                    case InspectionWizardStepType.MechanicalChecklist:
                        @RenderChecklistStep(MechanicalChecklistResponse)
                        break;

                    case InspectionWizardStepType.BodyChecklist:
                        <div class="inspection-body-step">
                            @RenderChecklistStep(BodyChecklistResponse)

                            <section class="inspection-form-subsection">
                                <div class="inspection-form-subsection-header">
                                    <div>
                                        <div class="section-title">Kaporta Haritasi</div>
                                        <div class="section-subtitle">Checklist satirlarini doldurduktan sonra gerekirse kaporta haritasi ile gorsel isaretleme yapin.</div>
                                    </div>
                                </div>
                                <MotorcycleBodyMap Items="@BodyMapItems"
                                                  CanEdit="@CanEdit"
                                                  Saving="@_stepSaving"
                                                  OnSave="SaveBodyMapItemAsync" />
                            </section>
                        </div>
                        break;

                    case InspectionWizardStepType.ObdChecklist:
                        @RenderChecklistStep(ObdChecklistResponse)
                        break;

                    case InspectionWizardStepType.Summary:
                        <div class="inspection-summary-grid">
                            <section class="inspection-form-subsection">
                                <div class="inspection-form-subsection-header">
                                    <div>
                                        <div class="section-title">Durum Ozeti</div>
                                        <div class="section-subtitle">Checklist sonuçunda olusan genel durum dagilimi.</div>
                                    </div>
                                </div>

                                <div class="inspection-summary-stats">
                                    <div class="wizard-meta-card">
                                        <span>Iyi</span>
                                        <strong>@CountChecklistResults(MotorcycleInspectionResult.Good)</strong>
                                    </div>
                                    <div class="wizard-meta-card">
                                        <span>Orta</span>
                                        <strong>@CountChecklistResults(MotorcycleInspectionResult.Medium)</strong>
                                    </div>
                                    <div class="wizard-meta-card">
                                        <span>Kotu</span>
                                        <strong>@CountChecklistResults(MotorcycleInspectionResult.Bad)</strong>
                                    </div>
                                    <div class="wizard-meta-card">
                                        <span>Hasar / Degisen</span>
                                        <strong>@CriticalItems.Count</strong>
                                    </div>
                                </div>
                            </section>

                            <section class="inspection-form-subsection">
                                <div class="inspection-form-subsection-header">
                                    <div>
                                        <div class="section-title">Kritik Bulgular</div>
                                        <div class="section-subtitle">Hasarli, degisen veya kotu durumda isaretlenen kalemler önce listelenir.</div>
                                    </div>
                                </div>

                                @if (CriticalItems.Count == 0)
                                {
                                    <div class="empty-state compact">
                                        <strong>Kritik bulgu yok</strong>
                                        <p>Bu adima kadar kritik seviye bulgu girilmedi.</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="wizard-summary-list">
                                        @foreach (var item in CriticalItems)
                                        {
                                            <article class="wizard-summary-item">
                                                <div>
                                                    <strong>@item.Name</strong>
                                                    <div class="small text-muted">@item.CategoryText</div>
                                                </div>
                                                <div class="text-end">
                                                    <span class="status-badge @GetResultBadgeClass(item.Result)">@GetChecklistLabel(item.Result)</span>
                                                    <div class="small text-muted mt-1">@DisplayNote(item.Notes)</div>
                                                </div>
                                            </article>
                                        }
                                    </div>
                                }
                            </section>
                        </div>

                        @if (BodySummaryItems.Count > 0)
                        {
                            <section class="inspection-form-subsection mt-4">
                                <div class="inspection-form-subsection-header">
                                    <div>
                                        <div class="section-title">Kaporta Ozeti</div>
                                        <div class="section-subtitle">Harita veya kaporta adiminda isaretlenen parçalar.</div>
                                    </div>
                                </div>

                                <div class="wizard-summary-list">
                                    @foreach (var item in BodySummaryItems)
                                    {
                                        <article class="wizard-summary-item">
                                            <div>
                                                <strong>@item.Name</strong>
                                                <div class="small text-muted">@item.CategoryText</div>
                                            </div>
                                            <div class="text-end">
                                                <span class="status-badge @GetResultBadgeClass(item.Result)">@item.ResultText</span>
                                                <div class="small text-muted mt-1">@DisplayNote(item.Notes)</div>
                                            </div>
                                        </article>
                                    }
                                </div>
                            </section>
                        }

                        @if (SummaryChecklistResponse.Sections.Count > 0)
                        {
                            @RenderChecklistStep(SummaryChecklistResponse)
                        }

                        <section class="inspection-form-subsection mt-4">
                            <div class="inspection-form-subsection-header">
                                <div>
                                    <div class="section-title">Test Surusu ve Genel Aciklama</div>
                                    <div class="section-subtitle">Formun sonundaki ortak not alanlarini doldürün.</div>
                                </div>
                            </div>

                            <div class="form-grid">
                                <div class="full-span">
                                    <label class="form-label">Test surusu izlenimleri</label>
                                    <InputTextArea class="form-control" rows="4" @bind-Value="_inspection.TestRideNotes" />
                                </div>
                                <div class="full-span">
                                    <label class="form-label">Kozmetik kontrol</label>
                                    <InputTextArea class="form-control" rows="4" @bind-Value="_inspection.CosmeticNotes" />
                                </div>
                                <div class="full-span">
                                    <label class="form-label">Genel aciklama</label>
                                    <InputTextArea class="form-control" rows="5" @bind-Value="_inspection.GeneralNotes" />
                                </div>
                            </div>
                        </section>
                        break;
                }

                <div class="inspection-form-actions">
                    <button type="button"
                            class="app-btn-secondary"
                            @onclick="GoBack"
                            disabled="@(_activeStepIndex == 0 || _stepSaving)">
                        Geri
                    </button>

                    <div class="d-flex gap-2 flex-wrap justify-content-end">
                        @if (CurrentStep.StepType == InspectionWizardStepType.Summary)
                        {
                            <button type="button"
                                    class="app-btn-secondary"
                                    @onclick="SaveCurrentStepAsync"
                                    disabled="@(_stepSaving || !CanEdit)">
                                @(_stepSaving ? "Kaydediliyor..." : "Taslak Kaydet")
                            </button>
                            <button type="button"
                                    class="app-btn-primary"
                                    @onclick="CompleteInspectionAsync"
                                    disabled="@(_stepSaving || !CanEdit || _inspection.Status == MotorcycleInspectionStatus.Completed)">
                                Ekspertizi Tamamla
                            </button>
                        }
                        else
                        {
                            <button type="button"
                                    class="app-btn-primary"
                                    @onclick="SaveAndContinueAsync"
                                    disabled="@_stepSaving">
                                @(_stepSaving ? "Kaydediliyor..." : "Kaydet ve Devam Et")
                            </button>
                        }
                    </div>
                </div>
            </section>
        </section>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private readonly CancellationTokenSource _lifetimeCts = new();
    private readonly List<InspectionWizardStep> _steps = [];
    private bool _loading = true;
    private bool _stepSaving;
    private bool _isDisposed;
    private bool _initialized;
    private string? _error;
    private string? _stepError;
    private string? _stepMessage;
    private int _activeStepIndex;
    private Guid _loadedInspectionId;
    private MotorcycleInspectionDetail? _inspection;

    private static readonly MotorcycleInspectionResult[] ChecklistResultOptions =
    [
        MotorcycleInspectionResult.NotChecked,
        MotorcycleInspectionResult.Good,
        MotorcycleInspectionResult.Medium,
        MotorcycleInspectionResult.Bad
    ];

    private static readonly HashSet<string> BodyMapKeys = MotorcycleBodyMapDefinitions.LeftParts
        .Concat(MotorcycleBodyMapDefinitions.RightParts)
        .SelectMany(part => part.MatchKeys.Append(part.Label))
        .Select(NormalizeText)
        .Where(key => !string.IsNullOrWhiteSpace(key))
        .ToHashSet(StringComparer.OrdinalIgnoreCase);

    private InspectionWizardStep CurrentStep => _steps[_activeStepIndex];

    private string VehicleDisplay
    {
        get
        {
            if (_inspection is null)
            {
                return "-";
            }

            var parts = new[] { _inspection.Plate, _inspection.Brand, _inspection.Model }
                .Where(value => !string.IsNullOrWhiteSpace(value));
            return string.Join(" / ", parts);
        }
    }

    private bool CanEdit => _inspection?.Status is MotorcycleInspectionStatus.Draft or MotorcycleInspectionStatus.InProgress;

    private Task<PublicRecordAccessResponse?> LoadInspectionPublicAccessAsync()
        => PublicRecordsService.GetForInspectionAsync(Id);

    private Task<PublicRecordAccessResponse?> EnableInspectionPublicAccessAsync()
        => PublicRecordsService.EnableForInspectionAsync(Id);

    private Task DisableInspectionPublicAccessAsync()
        => PublicRecordsService.DisableForInspectionAsync(Id);

    private InspectionChecklistResponse MechanicalChecklistResponse => BuildChecklistResponse(
        "Mekanik ve Yuruyen Aksam Kontrolleri",
        "Mekanik ve yuruyen aksam checklist kalemlerini Iyi / Orta / Kotu secenekleriyle degerlendirin.",
        MotorcycleInspectionCategory.MechanicalAndRunningGear,
        MechanicalItems);

    private InspectionChecklistResponse BodyChecklistResponse => BuildChecklistResponse(
        "Karenaj, Kaporta ve Aksesuar Kontrolleri",
        "Aksesuar, kaporta ve harita disindaki genel karenaj kalemlerini checklist mantigiyla doldürün.",
        MotorcycleInspectionCategory.BodyAndFairing,
        BodyChecklistItems);

    private InspectionChecklistResponse ObdChecklistResponse => BuildChecklistResponse(
        "OBD ve Elektrik-Elektronik Kontrolleri",
        "Elektronik sistemler ve OBD kontrollerini adim adim isaretleyin.",
        MotorcycleInspectionCategory.ObdAndElectrical,
        ObdItems);

    private InspectionChecklistResponse SummaryChecklistResponse => BuildChecklistResponse(
        "Test Surusu ve Genel Kontrol Kalemleri",
        "Ek checklist satirlari varsa bu adimda tamamlayin.",
        MotorcycleInspectionCategory.General,
        SummaryItems);

    private List<MotorcycleInspectionItem> MechanicalItems => GetItems(MotorcycleInspectionCategory.MechanicalAndRunningGear);

    private List<MotorcycleInspectionItem> BodyMapItems => GetItems(MotorcycleInspectionCategory.BodyAndFairing)
        .Where(IsBodyMapItem)
        .ToList();

    private List<MotorcycleInspectionItem> BodyChecklistItems => GetItems(MotorcycleInspectionCategory.BodyAndFairing)
        .Where(item => !IsBodyMapItem(item))
        .ToList();

    private List<MotorcycleInspectionItem> ObdItems => GetItems(MotorcycleInspectionCategory.ObdAndElectrical);

    private List<MotorcycleInspectionItem> SummaryItems => _inspection?.Items
        .Where(item => item.Category is MotorcycleInspectionCategory.TestRide or MotorcycleInspectionCategory.General)
        .OrderBy(item => item.SortOrder)
        .ToList() ?? [];

    private List<MotorcycleInspectionItem> CriticalItems => _inspection?.Items
        .Where(item => item.Result is MotorcycleInspectionResult.Bad or MotorcycleInspectionResult.Damaged or MotorcycleInspectionResult.Changed or MotorcycleInspectionResult.Scratched)
        .OrderByDescending(item => item.Result is MotorcycleInspectionResult.Damaged or MotorcycleInspectionResult.Changed)
        .ThenBy(item => item.SortOrder)
        .ToList() ?? [];

    private List<MotorcycleInspectionItem> BodySummaryItems => _inspection?.Items
        .Where(item => item.Category == MotorcycleInspectionCategory.BodyAndFairing
            && item.Result is MotorcycleInspectionResult.Original or MotorcycleInspectionResult.Painted or MotorcycleInspectionResult.Changed or MotorcycleInspectionResult.Damaged or MotorcycleInspectionResult.Scratched or MotorcycleInspectionResult.Good or MotorcycleInspectionResult.Medium or MotorcycleInspectionResult.Bad)
        .OrderBy(item => item.SortOrder)
        .ToList() ?? [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized)
        {
            return;
        }

        _initialized = true;
        await InitializeAsync(_lifetimeCts.Token);
    }

    private async Task InitializeAsync(CancellationToken cancellationToken)
    {
        if (Id == Guid.Empty)
        {
            _error = "Geçersiz ekspertiz kaydı.";
            _loading = false;
            await SafeStateHasChangedAsync();
            return;
        }

        try
        {
            if (!await AuthService.IsAuthenticatedAsync())
            {
                TryNavigateTo("/login");
                return;
            }

            await LoadAsync(cancellationToken);
        }
        catch (ObjectDisposedException)
        {
        }
    }

    private async Task LoadAsync(CancellationToken cancellationToken)
    {
        try
        {
            _loading = true;
            _error = null;
            _stepError = null;
            _stepMessage = null;
            await SafeStateHasChangedAsync();

            var detail = await InspectionsService.GetByIdAsync(Id, cancellationToken);
            if (IsInactive(cancellationToken))
            {
                return;
            }

            _inspection = detail;
            _loadedInspectionId = detail?.Id ?? Guid.Empty;

            if (_inspection is null)
            {
                _error = "Ekspertiz kaydı bulunamadı.";
                return;
            }

            _inspection.Items ??= [];
            foreach (var item in _inspection.Items)
            {
                item.ResultText = GetResultText(item.Result);
            }

            BuildSteps();
            _activeStepIndex = Math.Min(_activeStepIndex, Math.Max(_steps.Count - 1, 0));
        }
        catch (ApiException ex) when (ex.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
        {
            if (!IsInactive(cancellationToken))
            {
                TryNavigateTo("/login");
            }
        }
        catch (ApiException ex)
        {
            if (!IsInactive(cancellationToken))
            {
                _error = $"İstek başarısız oldu ({(int)ex.StatusCode}) - {ex.Message}";
            }
        }
        catch (Exception ex) when (!IsInactive(cancellationToken))
        {
            Logger.LogError(ex, "Inspection detail wizard load failed for {InspectionId}", Id);
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            await SafeStateHasChangedAsync();
        }
    }

    private void BuildSteps()
    {
        _steps.Clear();
        if (_inspection is null)
        {
            return;
        }

        _steps.Add(new InspectionWizardStep
        {
            StepType = InspectionWizardStepType.VehicleInfo,
            Title = "Araç Bilgileri / Paket",
            Subtitle = "Müşteri, araç ve paket ozetini kontrol edin."
        });

        if (_inspection.PackageType is MotorcycleInspectionPackageType.MechanicalAndRunningGear or MotorcycleInspectionPackageType.Full)
        {
            _steps.Add(new InspectionWizardStep
            {
                StepType = InspectionWizardStepType.MechanicalChecklist,
                Title = "Mekanik ve Yuruyen Aksam",
                Subtitle = "On takim, fren, lastik ve mekanik checklist kalemleri."
            });
        }

        if (_inspection.PackageType is MotorcycleInspectionPackageType.BodyAndFairing or MotorcycleInspectionPackageType.Full)
        {
            _steps.Add(new InspectionWizardStep
            {
                StepType = InspectionWizardStepType.BodyChecklist,
                Title = "Karenaj / Kaporta / Aksesuar",
                Subtitle = "Kaporta haritasi ve aksesuar checklist bolumu."
            });
        }

        if (_inspection.PackageType is MotorcycleInspectionPackageType.ObdAndElectrical or MotorcycleInspectionPackageType.Full)
        {
            _steps.Add(new InspectionWizardStep
            {
                StepType = InspectionWizardStepType.ObdChecklist,
                Title = "OBD ve Elektrik-Elektronik",
                Subtitle = "Far, ABS, surus modlari ve OBD kontrol adimi."
            });
        }

        _steps.Add(new InspectionWizardStep
        {
            StepType = InspectionWizardStepType.Summary,
            Title = "Test Surusu + Genel Aciklama + Ozet",
            Subtitle = "Son notlari tamamlayin ve kritik bulgulari kontrol edin."
        });
    }

    private RenderFragment RenderChecklistStep(InspectionChecklistResponse response) => @<div class="inspection-checklist-stack">
        @if (response.Sections.Count == 0)
        {
            <section class="empty-state compact">
                <strong>Bu adim icin checklist kalemi bulunmuyor.</strong>
                <p>Seçili pakette bu bolume ait bir kontrol listesi uretilmemis olabilir.</p>
            </section>
        }
        else
        {
            @foreach (var checklistSection in response.Sections)
            {
                <section class="inspection-form-subsection checklist-section-card">
                    <div class="inspection-form-subsection-header">
                        <div>
                            <div class="section-title">@checklistSection.SectionTitle</div>
                            <div class="section-subtitle">@checklistSection.SectionDescription</div>
                        </div>
                    </div>

                    <div class="checklist-form-table desktop-only">
                        <div class="checklist-form-head">
                            <span>Kalem</span>
                            <span>Iyi</span>
                            <span>Orta</span>
                            <span>Kotu</span>
                            <span>Aciklama / Not</span>
                        </div>

                        @foreach (var row in checklistSection.Items.OrderBy(item => item.Item.SortOrder))
                        {
                            <div class="checklist-form-row">
                                <div class="checklist-form-item">
                                    <strong>@row.ItemLabel</strong>
                                    <small>@row.Item.CategoryText</small>
                                </div>
                                <label class="checklist-radio-cell">
                                    <input type="radio"
                                           name="@row.ItemCode"
                                           checked="@(row.Item.Result == MotorcycleInspectionResult.Good)"
                                           @onchange="() => SetChecklistResult(row.Item, MotorcycleInspectionResult.Good)" />
                                    <span>Iyi</span>
                                </label>
                                <label class="checklist-radio-cell">
                                    <input type="radio"
                                           name="@row.ItemCode"
                                           checked="@(row.Item.Result == MotorcycleInspectionResult.Medium)"
                                           @onchange="() => SetChecklistResult(row.Item, MotorcycleInspectionResult.Medium)" />
                                    <span>Orta</span>
                                </label>
                                <label class="checklist-radio-cell">
                                    <input type="radio"
                                           name="@row.ItemCode"
                                           checked="@(row.Item.Result == MotorcycleInspectionResult.Bad)"
                                           @onchange="() => SetChecklistResult(row.Item, MotorcycleInspectionResult.Bad)" />
                                    <span>Kotu</span>
                                </label>
                                <div class="checklist-form-note">
                                    <InputTextArea class="form-control" rows="2" @bind-Value="row.Item.Notes" />
                                </div>
                            </div>
                        }
                    </div>

                    <div class="checklist-mobile-list mobile-only">
                        @foreach (var row in checklistSection.Items.OrderBy(item => item.Item.SortOrder))
                        {
                            <article class="checklist-mobile-card">
                                <div class="checklist-mobile-header">
                                    <strong>@row.ItemLabel</strong>
                                    <small>@row.Item.CategoryText</small>
                                </div>

                                <div class="checklist-mobile-options">
                                    <label class="checklist-radio-cell">
                                        <input type="radio"
                                               name="@($"{row.ItemCode}-mobile")"
                                               checked="@(row.Item.Result == MotorcycleInspectionResult.Good)"
                                               @onchange="() => SetChecklistResult(row.Item, MotorcycleInspectionResult.Good)" />
                                        <span>Iyi</span>
                                    </label>
                                    <label class="checklist-radio-cell">
                                        <input type="radio"
                                               name="@($"{row.ItemCode}-mobile")"
                                               checked="@(row.Item.Result == MotorcycleInspectionResult.Medium)"
                                               @onchange="() => SetChecklistResult(row.Item, MotorcycleInspectionResult.Medium)" />
                                        <span>Orta</span>
                                    </label>
                                    <label class="checklist-radio-cell">
                                        <input type="radio"
                                               name="@($"{row.ItemCode}-mobile")"
                                               checked="@(row.Item.Result == MotorcycleInspectionResult.Bad)"
                                               @onchange="() => SetChecklistResult(row.Item, MotorcycleInspectionResult.Bad)" />
                                        <span>Kotu</span>
                                    </label>
                                </div>

                                <InputTextArea class="form-control" rows="3" @bind-Value="row.Item.Notes" />
                            </article>
                        }
                    </div>
                </section>
            }
        }
    </div>;

    private void SetChecklistResult(MotorcycleInspectionItem item, MotorcycleInspectionResult result)
    {
        item.Result = result;
        item.ResultText = GetResultText(result);
    }

    private InspectionChecklistResponse BuildChecklistResponse(
        string title,
        string description,
        MotorcycleInspectionCategory category,
        IEnumerable<MotorcycleInspectionItem> items)
    {
        var rows = items
            .OrderBy(item => item.SortOrder)
            .Select(item => new InspectionChecklistItemRow
            {
                ItemCode = $"{category}:{item.SortOrder}",
                ItemLabel = item.Name,
                Item = item
            })
            .ToList();

        return new InspectionChecklistResponse
        {
            Section = title,
            Sections =
            [
                new InspectionChecklistSection
                {
                    Category = category,
                    SectionTitle = title,
                    SectionDescription = description,
                    Items = rows
                }
            ]
        };
    }

    private List<MotorcycleInspectionItem> GetItems(MotorcycleInspectionCategory category) => _inspection?.Items
        .Where(item => item.Category == category)
        .OrderBy(item => item.SortOrder)
        .ToList() ?? [];

    private bool IsBodyMapItem(MotorcycleInspectionItem item)
    {
        var normalized = NormalizeText(item.Name);
        return BodyMapKeys.Contains(normalized);
    }

    private static string NormalizeText(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return value
            .Trim()
            .ToLowerInvariant()
            .Replace("ı", "i")
            .Replace("ğ", "g")
            .Replace("ü", "u")
            .Replace("ş", "s")
            .Replace("ö", "o")
            .Replace("ç", "c");
    }

    private int CountChecklistResults(MotorcycleInspectionResult result) => _inspection?.Items.Count(item => item.Result == result) ?? 0;

    private static string GetChecklistLabel(MotorcycleInspectionResult result) => result switch
    {
        MotorcycleInspectionResult.Good => "Iyi",
        MotorcycleInspectionResult.Medium => "Orta",
        MotorcycleInspectionResult.Bad => "Kotu",
        MotorcycleInspectionResult.NotChecked => "Seçilmedi",
        MotorcycleInspectionResult.Original => "Orijinal",
        MotorcycleInspectionResult.Painted => "Boyali",
        MotorcycleInspectionResult.Changed => "Degisen",
        MotorcycleInspectionResult.Damaged => "Hasarli",
        MotorcycleInspectionResult.Scratched => "Cizik",
        MotorcycleInspectionResult.Exists => "Var",
        MotorcycleInspectionResult.NotExists => "Yok",
        MotorcycleInspectionResult.NotAvailable => "Kontrol edilemedi",
        MotorcycleInspectionResult.Missing => "Eksik",
        _ => result.ToString()
    };

    private static string GetResultText(MotorcycleInspectionResult result) => GetChecklistLabel(result);

    private static string GetResultBadgeClass(MotorcycleInspectionResult result) => result switch
    {
        MotorcycleInspectionResult.Good or MotorcycleInspectionResult.Original => "badge-completed",
        MotorcycleInspectionResult.Medium or MotorcycleInspectionResult.Painted or MotorcycleInspectionResult.Scratched => "badge-progress",
        MotorcycleInspectionResult.Bad or MotorcycleInspectionResult.Damaged or MotorcycleInspectionResult.Changed => "badge-cancelled",
        _ => "badge-muted"
    };

    private static string DisplayNote(string? note) => string.IsNullOrWhiteSpace(note) ? "Aciklama girilmedi." : note;

    private void GoToStep(int index)
    {
        if (index < 0 || index >= _steps.Count || _stepSaving)
        {
            return;
        }

        _activeStepIndex = index;
        _stepError = null;
        _stepMessage = null;
    }

    private void GoBack()
    {
        if (_activeStepIndex == 0)
        {
            return;
        }

        _activeStepIndex--;
        _stepError = null;
        _stepMessage = null;
    }

    private async Task SaveAndContinueAsync()
    {
        if (await SaveCurrentStepAsync() && _activeStepIndex < _steps.Count - 1)
        {
            _activeStepIndex++;
            await SafeStateHasChangedAsync();
        }
    }

    private async Task<bool> SaveCurrentStepAsync()
    {
        if (_inspection is null || _stepSaving)
        {
            return false;
        }

        _stepSaving = true;
        _stepError = null;
        _stepMessage = null;
        await SafeStateHasChangedAsync();

        try
        {
            switch (CurrentStep.StepType)
            {
                case InspectionWizardStepType.VehicleInfo:
                    await SaveHeaderAsync(_lifetimeCts.Token);
                    break;

                case InspectionWizardStepType.Summary:
                    await SaveHeaderAsync(_lifetimeCts.Token);
                    await SaveItemsAsync(SummaryItems, _lifetimeCts.Token);
                    break;

                case InspectionWizardStepType.MechanicalChecklist:
                    await SaveItemsAsync(MechanicalItems, _lifetimeCts.Token);
                    break;

                case InspectionWizardStepType.BodyChecklist:
                    await SaveItemsAsync(BodyChecklistItems, _lifetimeCts.Token);
                    break;

                case InspectionWizardStepType.ObdChecklist:
                    await SaveItemsAsync(ObdItems, _lifetimeCts.Token);
                    break;
            }

            if (IsInactive(_lifetimeCts.Token))
            {
                return false;
            }

            if (_inspection.Status == MotorcycleInspectionStatus.Draft)
            {
                _inspection.Status = MotorcycleInspectionStatus.InProgress;
                _inspection.StatusText = "Devam Ediyor";
            }

            _stepMessage = "Mevcut adim kaydedildi.";
            return true;
        }
        catch (ApiException ex)
        {
            _stepError = $"İstek başarısız oldu ({(int)ex.StatusCode}) - {ex.Message}";
            return false;
        }
        catch (Exception ex) when (!IsInactive(_lifetimeCts.Token))
        {
            Logger.LogError(ex, "Inspection wizard save failed for {InspectionId} step {StepType}", _inspection.Id, CurrentStep.StepType);
            _stepError = ex.Message;
            return false;
        }
        finally
        {
            _stepSaving = false;
            await SafeStateHasChangedAsync();
        }
    }

    private async Task SaveHeaderAsync(CancellationToken cancellationToken)
    {
        if (_inspection is null)
        {
            return;
        }

        var request = new UpdateMotorcycleInspectionRequest
        {
            CustomerId = _inspection.CustomerId,
            VehicleId = _inspection.VehicleId,
            CustomerName = _inspection.CustomerName,
            Phone = _inspection.Phone,
            Plate = _inspection.Plate,
            Brand = _inspection.Brand,
            Model = _inspection.Model,
            Year = _inspection.Year,
            Mileage = _inspection.Mileage,
            ChassisNumber = _inspection.ChassisNumber,
            EngineNumber = _inspection.EngineNumber,
            Query5664 = _inspection.Query5664,
            MileageQuery = _inspection.MileageQuery,
            PackageType = _inspection.PackageType,
            GeneralNotes = _inspection.GeneralNotes,
            TestRideNotes = _inspection.TestRideNotes,
            CosmeticNotes = _inspection.CosmeticNotes
        };

        await InspectionsService.UpdateAsync(_inspection.Id, request, cancellationToken);
    }

    private async Task SaveItemsAsync(IEnumerable<MotorcycleInspectionItem> items, CancellationToken cancellationToken)
    {
        if (_inspection is null)
        {
            return;
        }

        foreach (var item in items)
        {
            if (IsInactive(cancellationToken))
            {
                return;
            }

            await InspectionsService.UpdateItemAsync(
                _inspection.Id,
                item.Id,
                new UpdateMotorcycleInspectionItemRequest
                {
                    Result = item.Result,
                    Notes = item.Notes
                },
                cancellationToken);

            item.ResultText = GetResultText(item.Result);
        }
    }

    private async Task SaveBodyMapItemAsync(MotorcycleInspectionItem item)
    {
        if (_inspection is null || _stepSaving || IsInactive(_lifetimeCts.Token))
        {
            return;
        }

        _stepError = null;
        _stepMessage = null;

        try
        {
            _stepSaving = true;
            await SafeStateHasChangedAsync();

            await InspectionsService.UpdateItemAsync(
                _inspection.Id,
                item.Id,
                new UpdateMotorcycleInspectionItemRequest
                {
                    Result = item.Result,
                    Notes = item.Notes
                },
                _lifetimeCts.Token);

            item.ResultText = GetResultText(item.Result);
            _stepMessage = $"{item.Name} kaydedildi.";
        }
        catch (ApiException ex)
        {
            _stepError = $"Kaporta kaydı başarısız oldu ({(int)ex.StatusCode}) - {ex.Message}";
        }
        catch (Exception ex) when (!IsInactive(_lifetimeCts.Token))
        {
            Logger.LogError(ex, "Body map save failed for {InspectionId} item {ItemId}", _inspection.Id, item.Id);
            _stepError = ex.Message;
        }
        finally
        {
            _stepSaving = false;
            await SafeStateHasChangedAsync();
        }
    }

    private async Task CompleteInspectionAsync()
    {
        if (_inspection is null || _stepSaving)
        {
            return;
        }

        if (!CanEdit)
        {
            _stepError = "Bu ekspertiz kaydı artik düzenlenemiyor.";
            await SafeStateHasChangedAsync();
            return;
        }

        _stepError = null;
        _stepMessage = null;

        if (!await SaveCurrentStepAsync())
        {
            return;
        }

        try
        {
            _stepSaving = true;
            await SafeStateHasChangedAsync();
            await InspectionsService.CompleteAsync(_inspection.Id, _lifetimeCts.Token);
            _inspection.Status = MotorcycleInspectionStatus.Completed;
            _inspection.StatusText = "Tamamlandı";
            _inspection.CompletedAt = DateTimeOffset.UtcNow;
            _stepMessage = "Ekspertiz tamamlandi.";
        }
        catch (ApiException ex)
        {
            _stepError = $"Tamamlama başarısız oldu ({(int)ex.StatusCode}) - {ex.Message}";
        }
        catch (Exception ex) when (!IsInactive(_lifetimeCts.Token))
        {
            Logger.LogError(ex, "Inspection complete failed for {InspectionId}", _inspection.Id);
            _stepError = ex.Message;
        }
        finally
        {
            _stepSaving = false;
            await SafeStateHasChangedAsync();
        }
    }

    private bool IsInactive(CancellationToken cancellationToken) => _isDisposed || cancellationToken.IsCancellationRequested;

    private async Task SafeStateHasChangedAsync()
    {
        if (_isDisposed)
        {
            return;
        }

        try
        {
            await InvokeAsync(StateHasChanged);
        }
        catch (ObjectDisposedException)
        {
        }
        catch (InvalidOperationException) when (_isDisposed || _lifetimeCts.IsCancellationRequested)
        {
        }
    }

    private void TryNavigateTo(string uri)
    {
        if (_isDisposed || _lifetimeCts.IsCancellationRequested)
        {
            return;
        }

        try
        {
            NavigationManager.NavigateTo(uri);
        }
        catch (ObjectDisposedException)
        {
        }
        catch (InvalidOperationException) when (_isDisposed || _lifetimeCts.IsCancellationRequested)
        {
        }
    }

    public void Dispose()
    {
        _isDisposed = true;
        _lifetimeCts.Cancel();
        _lifetimeCts.Dispose();
    }
}
