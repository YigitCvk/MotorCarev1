@page "/register"
@layout Layout.PublicLayout
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Kayıt Ol - BakımSuite</PageTitle>

<div class="auth-shell">
    <div class="auth-panel auth-panel-brand">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem">
            <div style="width:2.8rem;height:2.8rem;border-radius:14px;background:linear-gradient(135deg,#f97316,#fb923c);display:grid;place-items:center;color:#fff;font-weight:800;font-size:0.95rem;letter-spacing:-0.02em">BS</div>
            <div style="color:#f1f5f9;font-weight:700;font-size:1rem">BakımSuite</div>
        </div>
        <div class="eyebrow" style="color:#fdba74">B2B onboarding</div>
        <h1 class="auth-title">Servisinizi dakikalar içinde dijitale taşıyın</h1>
        <p class="auth-copy">
            BakımSuite; servis kabul, müşteri kaydı, araç takibi, randevu ve günlük tahsilat yönetimini tek akışta birleştirir.
            Eski masaüstü ekranların yoğunluğunu değil, modern ve mobil uyumlu operasyon deneyimini sunar.
        </p>

        <div class="auth-feature-list">
            <div class="auth-feature-item">Servis işlemleri ve iş emri ekranı</div>
            <div class="auth-feature-item">Müşteri, araç ve randevu akışı</div>
            <div class="auth-feature-item">Tahsilat ve günlük özet görünümü</div>
        </div>
    </div>

    <div class="auth-panel auth-panel-form register-card">
        <div class="section-header mb-2">
            <div>
                <div class="section-title">İlk işletme kaydını oluştur</div>
                <div class="section-subtitle">İlk kullanıcı otomatik olarak Owner rolüyle açılır.</div>
            </div>
        </div>

        <EditForm Model="_model" OnValidSubmit="RegisterAsync">
            <DataAnnotationsValidator />

            <div class="form-grid auth-form-grid two-columns register-form-grid">
                <div class="form-field">
                    <label class="form-label">İşletme Kodu</label>
                    <InputText class="form-control" @bind-Value="_model.TenantIdentifier" placeholder="asya-motor" />
                    <div class="form-text form-hint">Küçük harf ve tire ile kullanılır.</div>
                </div>

                <div class="form-field">
                    <label class="form-label">Servis Adı</label>
                    <InputText class="form-control" @bind-Value="_model.TenantName" placeholder="Asya Motor" />
                </div>

                <div class="form-field full-span">
                    <label class="form-label">Yetkili Ad Soyad</label>
                    <InputText class="form-control" @bind-Value="_model.OwnerFullName" placeholder="Yiğit Çevik" />
                </div>

                <div class="form-field">
                    <label class="form-label">E-posta</label>
                    <InputText class="form-control" @bind-Value="_model.OwnerEmail" placeholder="owner@servisiniz.com" autocomplete="email" />
                </div>

                <div class="form-field">
                    <label class="form-label">Şifre</label>
                    <InputText class="form-control" type="password" @bind-Value="_model.OwnerPassword" placeholder="••••••••" autocomplete="new-password" />
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="alert alert-danger mt-3">@_error</div>
            }

            <div class="auth-actions register-actions">
                <button type="submit" class="btn btn-primary btn-lg submit-button" disabled="@_isSubmitting">
                    @(_isSubmitting ? "Kayıt oluşturuluyor..." : "Kayıt Ol")
                </button>
                <a class="auth-link register-link" href="/login">Zaten hesabın var mı? Giriş yap →</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private readonly RegisterRequest _model = new();
    private bool _isSubmitting;
    private string? _error;

    private async Task RegisterAsync()
    {
        _isSubmitting = true;
        _error = null;

        try
        {
            await AuthService.RegisterAsync(_model);
            NavigationManager.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
