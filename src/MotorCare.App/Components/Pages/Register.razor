@page "/register"
@layout Layout.PublicLayout
@using Microsoft.AspNetCore.WebUtilities
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Kayit Ol - GarajPass</PageTitle>

<div class="auth-shell">
    <div class="auth-panel auth-panel-brand">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem">
            <div style="width:2.8rem;height:2.8rem;border-radius:14px;background:#FFCC00;display:grid;place-items:center;color:#1A1A1A;font-weight:800;font-size:0.95rem;letter-spacing:0">GP</div>
            <div style="color:#f1f5f9;font-weight:700;font-size:1rem">GarajPass</div>
        </div>
        <div class="eyebrow" style="color:#fdba74">B2B onboarding</div>
        <h1 class="auth-title">GarajPass isletme hesabini olustur</h1>
        <p class="auth-copy">
            Servis kabul, randevu, musteri ve arac yonetimini dijitallestirmeye baslayin.
        </p>

        <div class="auth-feature-list">
            <div class="auth-feature-item">Servis islemleri ve is emri ekrani</div>
            <div class="auth-feature-item">Musteri, arac ve randevu akisi</div>
            <div class="auth-feature-item">Tahsilat ve gunluk ozet gorunumu</div>
        </div>
    </div>

    <div class="auth-panel auth-panel-form register-card">
        <div class="section-header mb-2">
            <div>
                <div class="section-title">GarajPass isletme kaydi</div>
                <div class="section-subtitle">Ilk kullanici otomatik olarak Owner roluyle acilir.</div>
            </div>
        </div>

        <EditForm Model="_model" OnValidSubmit="RegisterAsync">
            <DataAnnotationsValidator />

            <div class="form-grid auth-form-grid two-columns register-form-grid">
                <div class="form-field">
                    <label class="form-label">Isletme Kodu</label>
                    <InputText class="form-control" @bind-Value="_model.TenantIdentifier" placeholder="asya-motor" />
                    <div class="form-text form-hint">Kucuk harf ve tire ile kullanilir.</div>
                </div>

                <div class="form-field">
                    <label class="form-label">Servis Adi</label>
                    <InputText class="form-control" @bind-Value="_model.TenantName" placeholder="Asya Motor" />
                </div>

                <div class="form-field full-span">
                    <label class="form-label">Yetkili Ad Soyad</label>
                    <InputText class="form-control" @bind-Value="_model.OwnerFullName" placeholder="Yigit Cevik" />
                </div>

                <div class="form-field">
                    <label class="form-label">E-posta</label>
                    <InputText class="form-control" @bind-Value="_model.OwnerEmail" placeholder="owner@servisiniz.com" autocomplete="email" />
                </div>

                <div class="form-field">
                    <label class="form-label">Sifre</label>
                    <InputText class="form-control" type="password" @bind-Value="_model.OwnerPassword" placeholder="********" autocomplete="new-password" />
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="alert alert-danger mt-3">@_error</div>
            }

            @if (!string.IsNullOrWhiteSpace(_success))
            {
                <div class="alert alert-success mt-3">@_success</div>
            }

            <div class="auth-actions register-actions">
                <button type="submit" class="btn btn-primary btn-lg submit-button" disabled="@_isSubmitting">
                    @(_isSubmitting ? "Kayit olusturuluyor..." : "Kayit Ol")
                </button>
                <a class="auth-link register-link" href="/login">Zaten hesabin var mi? Giris yap -></a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private readonly RegisterRequest _model = new();
    private bool _isSubmitting;
    private string? _error;
    private string? _success;

    private async Task RegisterAsync()
    {
        _isSubmitting = true;
        _error = null;
        _success = null;

        try
        {
            var response = await AuthService.RegisterAsync(_model);
            if (response is null)
            {
                _success = "Kayit olusturuldu. Giris yapabilirsiniz.";
                return;
            }

            _success = response.VerificationEmailSent
                ? "Kayit olusturuldu. Dogrulama e-postasi gonderildi."
                : "Kayit olusturuldu. Dogrulama e-postasi gonderilemedi; daha sonra tekrar isteyebilirsiniz.";

            var loginUri = QueryHelpers.AddQueryString("/login", new Dictionary<string, string?>
            {
                ["tenant"] = response.TenantIdentifier,
                ["email"] = response.OwnerEmail,
                ["message"] = _success
            });

            NavigationManager.NavigateTo(loginUri);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
