@page "/"
@layout Layout.PublicLayout

<PageTitle>GarajPass</PageTitle>

<div class="gp-landing">
    <header class="gp-nav">
        <a class="gp-brand" href="/" aria-label="GarajPass ana sayfa">
            <span class="gp-brand-mark">GP</span>
            <span class="gp-brand-copy">
                <strong>GarajPass</strong>
                <small>Servis & Ekspertiz OS</small>
            </span>
        </a>

        <nav class="gp-nav-links" aria-label="GarajPass">
            <a href="#features">Ozellikler</a>
            <a href="#vision">Vizyon</a>
            <a href="/login">Giris Yap</a>
            <a href="/register">Hesap Olustur</a>
        </nav>

        <a class="gp-btn gp-btn-primary" href="/register">Demo Baslat</a>
    </header>

    <main>
        <section class="gp-hero">
            <div class="gp-hero-copy">
                <div class="gp-kicker">Form follows function</div>
                <h1>Servis, ekspertiz ve arac gecmisi tek sistemde.</h1>
                <p>
                    GarajPass; servis operasyonlarini, musteri ve arac kayitlarini, ekspertiz sureclerini
                    ve arac gecmisi raporlamasini tek platformda birlestirir.
                </p>
                <div class="gp-hero-actions">
                    <a class="gp-btn gp-btn-primary gp-btn-large" href="/register">Hemen Basla</a>
                    <a class="gp-btn gp-btn-secondary gp-btn-large" href="/login">Giris Yap</a>
                </div>
            </div>

            <div class="gp-system-board" aria-label="GarajPass operasyon kartlari">
                <div class="gp-board-card gp-yellow gp-wide"><span>01</span><strong>Servis Emri</strong></div>
                <div class="gp-board-card gp-blue"><span>02</span><strong>Arac Pass</strong></div>
                <div class="gp-board-card gp-red"><span>03</span><strong>Ekspertiz Kaydi</strong></div>
                <div class="gp-board-card gp-white"><span>04</span><strong>Randevu</strong></div>
                <div class="gp-board-card gp-black gp-tall"><span>05</span><strong>360 derece gecmis</strong></div>
            </div>
        </section>

        <section class="gp-section" id="features">
            <div class="gp-section-head">
                <span>Ozellikler</span>
                <h2>Servis operasyonu icin net, kayitli ve olculebilir akis.</h2>
            </div>

            <div class="gp-feature-grid">
                <article class="gp-feature-card gp-yellow">
                    <span>01</span>
                    <h3>Servis Yonetimi</h3>
                    <p>Randevu, musteri, arac ve servis emirlerini tek panelden yonetin.</p>
                </article>
                <article class="gp-feature-card gp-blue">
                    <span>02</span>
                    <h3>Ekspertiz Kayitlari</h3>
                    <p>Motosiklet ve arac ekspertiz sureclerini standart checklist yapisiyla kayit altina alin.</p>
                </article>
                <article class="gp-feature-card gp-red">
                    <span>03</span>
                    <h3>Arac Gecmisi</h3>
                    <p>Bugunun servis kayitlarini yarinin dogrulanabilir arac gecmisi raporlarina donusturun.</p>
                </article>
            </div>
        </section>

        <section class="gp-section">
            <div class="gp-workflow">
                <div class="gp-workflow-title">
                    <span>Akis</span>
                    <h2>Operasyon akisi net, kayitlar duzenli.</h2>
                </div>
                <div class="gp-step-grid">
                    <article><strong>01</strong><span>Musteri ve arac kaydi</span></article>
                    <article><strong>02</strong><span>Servis kabul ve is emri</span></article>
                    <article><strong>03</strong><span>Ekspertiz ve islem gecmisi</span></article>
                    <article><strong>04</strong><span>Raporlama ve takip</span></article>
                </div>
            </div>
        </section>

        <section class="gp-vision" id="vision">
            <div class="gp-vision-mark"></div>
            <div>
                <span>Vizyon</span>
                <h2>Bugunun servis operasyonu, yarinin dogrulanabilir arac gecmisi.</h2>
                <p>
                    GarajPass, servislerin operasyonel yukunu azaltirken araclarin bakim ve ekspertiz
                    gecmisini guvenilir kayitlarla takip edilebilir hale getirir.
                </p>
            </div>
        </section>

        <section class="gp-final-cta">
            <h2>Garajini dijitallestir. Kayitlarini guclendir. Gecmisi gorunur kil.</h2>
            <div class="gp-hero-actions">
                <a class="gp-btn gp-btn-primary gp-btn-large" href="/register">GarajPass'e Basla</a>
                <a class="gp-inline-link" href="/login">Zaten hesabin var mi? Giris yap</a>
            </div>
        </section>
    </main>
</div>
