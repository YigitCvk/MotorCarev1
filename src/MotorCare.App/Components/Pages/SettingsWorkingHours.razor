@page "/settings/working-hours"

<PageTitle>Çalışma Saatleri</PageTitle>

<div class="page-shell">
    <section class="page-header">
        <div>
            <div class="eyebrow">Ayarlar</div>
            <h1 class="page-title">Çalışma Saatleri</h1>
            <p class="page-description">Randevu takvimi ve servis kabul pencereleri için işletme çalışma saatlerini planlayın.</p>
        </div>
        <div class="page-header-actions">
            <a class="app-btn-secondary" href="/settings">Ayarlara Dön</a>
            <button type="button" class="app-btn-primary">Düzenle</button>
        </div>
    </section>

    <section class="admin-grid">
        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Haftalık Düzen</div>
                    <div class="section-subtitle">Gün bazlı açık / kapalı saat pencereleri</div>
                </div>
                <span class="status-badge badge-progress">Planlandı</span>
            </div>
            <p class="admin-card-copy">Hafta içi, cumartesi ve özel vardiya saatlerini tenant bazında tanımlamak için hazırlanan alan.</p>
            <div class="admin-card-actions">
                <button type="button" class="app-btn-secondary">Yakında</button>
            </div>
        </article>

        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Özel Günler</div>
                    <div class="section-subtitle">Tatil, bakım günü ve kapasite düşümü</div>
                </div>
                <span class="status-badge status-info">Yakında</span>
            </div>
            <p class="admin-card-copy">Resmî tatil, yarım gün ve özel kapanış kuralları ileride bu modüle eklenecek.</p>
            <div class="admin-card-actions">
                <button type="button" class="app-btn-secondary">Yakında</button>
            </div>
        </article>
    </section>
</div>
