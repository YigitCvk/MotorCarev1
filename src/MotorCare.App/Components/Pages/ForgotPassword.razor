@page "/forgot-password"
@layout Layout.PublicLayout
@inject AuthService AuthService

<PageTitle>Sifremi Unuttum - GarajPass</PageTitle>

<div class="auth-shell auth-shell-login">
    <div class="auth-panel auth-panel-brand">
        <div class="eyebrow" style="color:#fdba74">Hesap guvenligi</div>
        <h1 class="auth-title">Sifreni sifirla</h1>
        <p class="auth-copy">
            E-posta adresini gir, sana 6 haneli dogrulama kodu gonderelim.
        </p>
    </div>

    <div class="auth-panel auth-panel-form auth-panel-narrow">
        <div class="section-header mb-2">
            <div>
                <div class="section-title">Sifremi Unuttum</div>
                <div class="section-subtitle">Guvenlik nedeniyle her durumda ayni bilgi mesaji gosterilir.</div>
            </div>
        </div>

        <EditForm Model="_model" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />

            <div class="form-grid auth-form-grid">
                <div class="full-span">
                    <label class="form-label">E-posta</label>
                    <InputText class="form-control" @bind-Value="_model.Email" autocomplete="email" />
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_message))
            {
                <div class="alert alert-success mt-3">@_message</div>
            }

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="alert alert-danger mt-3">@_error</div>
            }

            <div class="auth-actions">
                <button type="submit" class="btn btn-primary btn-lg" disabled="@_isSubmitting">
                    @(_isSubmitting ? "Gonderiliyor..." : "Kod Gonder")
                </button>
                <a class="auth-link" href="/login">Giris ekranina don</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private readonly ForgotPasswordRequest _model = new();
    private bool _isSubmitting;
    private string? _message;
    private string? _error;

    private async Task SubmitAsync()
    {
        _isSubmitting = true;
        _error = null;

        try
        {
            var response = await AuthService.ForgotPasswordAsync(_model);
            _message = response?.Message ?? "Eger bu e-posta ile kayitli bir hesap varsa 6 haneli sifre sifirlama kodu gonderildi.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
