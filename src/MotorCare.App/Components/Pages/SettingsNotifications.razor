@page "/settings/notifications"

<PageTitle>Bildirim Şablonları</PageTitle>

<div class="page-shell">
    <section class="page-header">
        <div>
            <div class="eyebrow">Ayarlar</div>
            <h1 class="page-title">Bildirim Şablonları</h1>
            <p class="page-description">Randevu, araç hazır ve ödeme bildirimleri için müşteri iletişim dilini yönetin.</p>
        </div>
        <div class="page-header-actions">
            <a class="app-btn-secondary" href="/settings">Ayarlara Dön</a>
            <button type="button" class="app-btn-secondary">Yakında</button>
        </div>
    </section>

    <section class="admin-grid">
        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Randevu Onay Metinleri</div>
                    <div class="section-subtitle">Onay ve hatırlatma mesajları</div>
                </div>
                <span class="status-badge status-info">Yakında</span>
            </div>
            <p class="admin-card-copy">Randevu oluşturma, yaklaşan ziyaret ve no-show önleme mesajları burada tanımlanacak.</p>
            <div class="admin-card-actions">
                <button type="button" class="app-btn-secondary">Yakında</button>
            </div>
        </article>

        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Teslim ve Ödeme Şablonları</div>
                    <div class="section-subtitle">Araç hazır ve tahsilat mesajları</div>
                </div>
                <span class="status-badge status-info">Yakında</span>
            </div>
            <p class="admin-card-copy">Teslime hazır, eksik ödeme ve takip mesajları için tenant iletişim alanı.</p>
            <div class="admin-card-actions">
                <button type="button" class="app-btn-secondary">Yakında</button>
            </div>
        </article>
    </section>
</div>
