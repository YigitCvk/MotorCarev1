            {
                return;
            }

            if (vehicles is not null)
            {
                _customerVehicles.AddRange(vehicles);
            }

            _customerVehiclesMessage = _customerVehicles.Count == 0
                ? "Bu musterinin kayitli araci yok. Asagidan plaka ile arayabilir veya yeni arac ekleyebilirsiniz."
                : null;
        }
        catch (OperationCanceledException) when (IsInactive(cancellationToken))
        {
        }
        catch (ApiException ex)
        {
            if (!IsInactive(cancellationToken))
            {
                _customerVehiclesMessage = ex.Message;
            }
        }
        catch (Exception ex)
        {
            if (!IsInactive(cancellationToken))
            {
                _customerVehiclesMessage = ex.Message;
            }
        }
        finally
        {
            if (!IsInactive(cancellationToken))
            {
                _customerVehiclesLoading = false;
                await SafeStateHasChangedAsync();
            }
        }
