    private async Task CreateServiceOrderAsync()
    {
        var cancellationToken = _lifetimeCts.Token;

        try
        {
            _isSaving = true;
            _error = null;
            _errorEndpoint = null;
            _successMessage = null;
            _createdServiceOrderId = null;
            await SafeStateHasChangedAsync();

            if (_selectedCustomer is null)
            {
                _error = "Musteri secmelisiniz.";
                return;
            }

            if (_selectedVehicle is null)
            {
                _error = "Arac secmelisiniz.";
                return;
            }

            if (_vehicleKm < 0)
            {
                _error = "Arac KM bilgisi gecersiz.";
                return;
            }

            var id = await ServiceOrdersService.CreateServiceOrderAsync(new CreateServiceOrderRequest
            {
                CustomerId = _selectedCustomer.Id,
                VehicleId = _selectedVehicle.Id,
                VehicleKm = _vehicleKm,
                Complaint = _complaint
            }, cancellationToken);

            if (IsInactive(cancellationToken))
            {
                return;
            }

            _createdServiceOrderId = id;

            if (_selectedService is not null)
            {
                try
                {
                    await ServiceOrdersService.AddOperationAsync(
                        id,
                        new AddOperationRequest
                        {
                            Description = _selectedService.Name,
                            Price = _selectedService.DefaultPrice
                        },
                        cancellationToken);
                }
                catch (OperationCanceledException) when (IsInactive(cancellationToken))
                {
                    return;
                }
                catch (ApiException ex)
                {
                    _successMessage = $"Servis emri olusturuldu ancak secilen hizmet operasyon olarak eklenemedi: {ex.Message}";
                    _errorEndpoint = ex.Endpoint;
                    return;
                }
                catch (Exception ex)
                {
                    _successMessage = $"Servis emri olusturuldu ancak secilen hizmet operasyon olarak eklenemedi: {ex.Message}";
                    return;
                }
            }

            if (_prefilledRecommendations.Count > 0)
            {
                foreach (var recommendation in _prefilledRecommendations)
                {
                    try
                    {
                        await ServiceOrdersService.AddOperationAsync(
                            id,
                            new AddOperationRequest
                            {
                                Description = recommendation,
                                Price = 0m
                            },
                            cancellationToken);
                    }
                    catch (OperationCanceledException) when (IsInactive(cancellationToken))
                    {
                        return;
                    }
                    catch (ApiException ex)
                    {
                        _successMessage = $"Servis emri olusturuldu ancak bazi ekspertiz onerileri operasyon olarak eklenemedi: {ex.Message}";
                        _errorEndpoint = ex.Endpoint;
                        TryNavigateTo($"/service-orders/{id}");
                        return;
                    }
                    catch (Exception ex)
                    {
                        _successMessage = $"Servis emri olusturuldu ancak bazi ekspertiz onerileri operasyon olarak eklenemedi: {ex.Message}";
                        TryNavigateTo($"/service-orders/{id}");
                        return;
                    }
                }
            }

            await TrackConsumableSuggestionsAsync(cancellationToken);

            _successMessage = "Servis emri olusturuldu.";
            TryNavigateTo($"/service-orders/{id}");
        }
        catch (OperationCanceledException) when (IsInactive(cancellationToken))
        {
        }
        catch (ApiException ex) when (ex.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
        {
            if (!IsInactive(cancellationToken))
            {
                TryNavigateTo("/login");
            }
        }
        catch (ApiException ex)
        {
            if (!IsInactive(cancellationToken))
            {
                _error = ex.Message;
                _errorEndpoint = ex.Endpoint;
            }
        }
        catch (Exception ex)
        {
            if (!IsInactive(cancellationToken))
            {
                _error = ex.Message;
            }
        }
        finally
        {
            if (!IsInactive(cancellationToken))
            {
                _isSaving = false;
                await SafeStateHasChangedAsync();
            }
        }
    }

    private async Task OnCategoryChangedAsync()
    {
        EnsureBoundStateInitialized();
        _currentConsumable.ProductName = string.Empty;
        _currentConsumable.Brand = string.Empty;
        _currentConsumable.SubCategory = string.Empty;
        _currentConsumable.Specification = string.Empty;
        _currentConsumable.Notes = string.Empty;
        _catalogSearchResults.Clear();
        _isCatalogSearchOpen = false;
        
        await PerformCatalogSearchAsync(string.Empty);
    }

    private Task OnConsumableProductChangedAsync()
        => PerformCatalogSearchAsync(_currentConsumable.ProductName);

    private async Task PerformCatalogSearchAsync(string query)
    {
        EnsureBoundStateInitialized();

        if (string.IsNullOrWhiteSpace(_currentConsumable.Category)) return;

        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;

        try
        {
            await Task.Delay(300, token); // debounce
            var results = await ServiceOrdersService.SearchConsumableCatalogAsync(query, _currentConsumable.Category, 10, token);
            
            if (!token.IsCancellationRequested && results is not null)
            {
                _catalogSearchResults = results.ToList();
                _isCatalogSearchOpen = _catalogSearchResults.Count > 0;
                await SafeStateHasChangedAsync();
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void SelectCatalogItem(ConsumableCatalogItemDto item)
    {
        EnsureBoundStateInitialized();
        _currentConsumable.Brand = item.Brand;
        _currentConsumable.ProductName = item.ProductName;
        _currentConsumable.SubCategory = item.SubCategory;
        _currentConsumable.Specification = item.Specification;
        _currentConsumable.Notes = item.Notes;
        _isCatalogSearchOpen = false;
    }

    private void AddConsumableEntry()
    {
        EnsureBoundStateInitialized();

        if (string.IsNullOrWhiteSpace(_currentConsumable.Category) || 
            string.IsNullOrWhiteSpace(_currentConsumable.Brand) || 
            string.IsNullOrWhiteSpace(_currentConsumable.ProductName))
        {
            return;
        }

        _consumableEntries.Add(new ConsumableCatalogItemDto
        {
            Category = _currentConsumable.Category,
            Brand = _currentConsumable.Brand,
            ProductName = _currentConsumable.ProductName,
            SubCategory = _currentConsumable.SubCategory,
            Specification = _currentConsumable.Specification,
            Notes = _currentConsumable.Notes
        });

        _currentConsumable = new ConsumableCatalogItemDto { Category = _currentConsumable.Category };
        _catalogSearchResults.Clear();
        _isCatalogSearchOpen = false;
    }

    private void EnsureBoundStateInitialized()
    {
        _currentConsumable ??= new ConsumableCatalogItemDto();
    }

    private void RemoveConsumableEntry(ConsumableCatalogItemDto entry)
    {
        _consumableEntries.Remove(entry);
    }

    private async Task TrackConsumableSuggestionsAsync(CancellationToken cancellationToken)
    {
        if (_consumableEntries.Count == 0) return;

        var requestItems = _consumableEntries.Select(e => new TrackConsumableCatalogItemRequest
        {
            Category = e.Category,
            Brand = e.Brand,
            ProductName = e.ProductName,
            SubCategory = e.SubCategory,
            Specification = e.Specification,
            Notes = e.Notes
        }).ToList();

        try
        {
            await ServiceOrdersService.TrackConsumableCatalogUsageAsync(
                new TrackConsumableCatalogUsageRequest { Items = requestItems },
                cancellationToken);
        }
        catch (OperationCanceledException) when (IsInactive(cancellationToken))
        {
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Consumable catalog usages could not be stored after service order create.");
        }
    }

