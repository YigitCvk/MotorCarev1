    private bool IsInactive(CancellationToken cancellationToken)
        => _isDisposed || cancellationToken.IsCancellationRequested;

    private async Task SafeStateHasChangedAsync()
    {
        if (_isDisposed || _lifetimeCts.IsCancellationRequested)
        {
            Logger.LogDebug(
                EventIdStore.ServiceOrder.ServiceOrderCreateRenderSkippedAfterDispose,
                "Service order create render skipped because component is disposed or initialization token is cancelled.");
            return;
        }

        try
        {
            await InvokeAsync(() =>
            {
                if (!_isDisposed && !_lifetimeCts.IsCancellationRequested)
                {
                    StateHasChanged();
                }
            });
        }
        catch (ObjectDisposedException)
        {
            Logger.LogDebug(
                EventIdStore.ServiceOrder.ServiceOrderCreateRenderSkippedAfterDispose,
                "Service order create render skipped after component disposal.");
        }
        catch (InvalidOperationException) when (_isDisposed || _lifetimeCts.IsCancellationRequested)
        {
            Logger.LogDebug(
                EventIdStore.ServiceOrder.ServiceOrderCreateRenderSkippedAfterDispose,
                "Service order create render skipped because renderer is no longer available.");
        }
    }

    private void TryNavigateTo(string uri)
    {
        if (_isDisposed || _lifetimeCts.IsCancellationRequested)
        {
            Logger.LogInformation(
                EventIdStore.Common.NavigationSkippedDueToDisconnectedCircuit,
                "Navigation skipped because service order create component is disposed. Target={Target}",
                uri);
            return;
        }

        try
        {
            NavigationManager.NavigateTo(uri);
        }
        catch (Exception ex) when (ex is ObjectDisposedException or InvalidOperationException or Microsoft.JSInterop.JSDisconnectedException)
        {
            Logger.LogWarning(
                EventIdStore.Common.NavigationSkippedDueToDisconnectedCircuit,
                ex,
                "Navigation skipped because circuit is disconnected. Target={Target}",
                uri);
        }
    }

    public void Dispose()
    {
        if (_isDisposed)
        {
            return;
        }

        _isDisposed = true;

        if (!_initializationCompleted)
        {
            Logger.LogInformation(
                EventIdStore.ServiceOrder.ServiceOrderCreateDisposedBeforeLoadCompleted,
                "Service order create component disposed before initialization completed.");
        }

        _searchCts?.Cancel();
        _searchCts?.Dispose();
        _lifetimeCts.Cancel();
        _lifetimeCts.Dispose();
    }

