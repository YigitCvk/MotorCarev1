@page "/service-orders/create"
@inject AuthService AuthService
@inject ServiceOrdersService ServiceOrdersService
@inject NavigationManager NavigationManager

<PageTitle>Yeni Servis Kaydı</PageTitle>

<div class="page-shell">
    <section class="hero-panel compact">
        <div>
            <div class="eyebrow">Hızlı kabul</div>
            <h1 class="page-title">Yeni Servis Kaydı</h1>
            <p class="page-description">
                Müşteri ve aracı seç, şikayeti kaydet, servisi hızla aç.
            </p>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <section class="error-state">
            <strong>Servis kaydı oluşturulamadı</strong>
            <p>@_error</p>
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <section class="empty-state">
            <strong>İşlem başarılı</strong>
            <p>@_successMessage</p>
        </section>
    }

    <div class="content-grid">
        <section class="surface-card">
            <div class="section-header">
                <div>
                    <div class="section-title">1. Müşteri Seçimi</div>
                    <div class="section-subtitle">Mevcut kayıtlar arasında arama yapın</div>
                </div>
                <a class="app-btn-secondary" href="/customers/create">+ Yeni Müşteri</a>
            </div>
            <div class="mt-3">
                <CustomerQuickSearch @bind-Value="_selectedCustomer" />
            </div>
        </section>

        <section class="surface-card">
            <div class="section-header">
                <div>
                    <div class="section-title">2. Araç Seçimi</div>
                    <div class="section-subtitle">Plakaya göre araç kaydını getirin</div>
                </div>
                <a class="app-btn-secondary" href="/vehicles/create">+ Yeni Araç</a>
            </div>
            <div class="mt-3">
                <VehiclePlateLookup @bind-Value="_selectedVehicle" />
            </div>
        </section>
    </div>

    <section class="surface-card mt-3">
        <div class="section-header">
            <div>
                <div class="section-title">3. Servis Bilgileri</div>
                <div class="section-subtitle">Kabul aşamasında gereken temel alanlar</div>
            </div>
        </div>

        <div class="form-grid">
            <div>
                <label class="form-label">Araç KM</label>
                <InputNumber class="form-control" @bind-Value="_vehicleKm" />
            </div>
            <div>
                <label class="form-label">Tahmini Teslim</label>
                <InputDate class="form-control" @bind-Value="_estimatedDeliveryDate" />
                <div class="form-text">Backend kontratına eklenecek alan.</div>
            </div>
            <div class="full-span">
                <label class="form-label">Şikayet / Açıklama</label>
                <InputTextArea class="form-control" @bind-Value="_complaint" />
            </div>
        </div>

        <div class="action-bar sticky-mobile-action justify-content-end mt-4">
            <button type="button" class="app-btn-primary" @onclick="CreateServiceOrderAsync" disabled="@_isSaving">
                @(_isSaving ? "Kaydediliyor..." : "Servisi Kaydet")
            </button>
        </div>
    </section>
</div>

@code {
    private string? _complaint;
    private int _vehicleKm;
    private DateTime? _estimatedDeliveryDate = DateTime.Today.AddDays(1);
    private CustomerLookupResponse? _selectedCustomer;
    private VehicleLookupResponse? _selectedVehicle;
    private string? _error;
    private string? _successMessage;
    private bool _isSaving;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (!await AuthService.IsAuthenticatedAsync())
        {
            NavigationManager.NavigateTo("/login");
        }
    }

    private async Task CreateServiceOrderAsync()
    {
        try
        {
            _isSaving = true;
            _error = null;
            _successMessage = null;

            if (_selectedCustomer is null)
            {
                _error = "Bir müşteri seçin.";
                return;
            }

            if (_selectedVehicle is null)
            {
                _error = "Bir araç seçin.";
                return;
            }

            if (_vehicleKm <= 0)
            {
                _error = "Geçerli bir araç KM bilgisi girin.";
                return;
            }

            var id = await ServiceOrdersService.CreateServiceOrderAsync(new CreateServiceOrderRequest
            {
                CustomerId = _selectedCustomer.Id,
                VehicleId = _selectedVehicle.Id,
                VehicleKm = _vehicleKm,
                Complaint = _complaint
            });

            _successMessage = $"Servis kaydı oluşturuldu: {id}";
            NavigationManager.NavigateTo($"/service-orders/{id}");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }
}
