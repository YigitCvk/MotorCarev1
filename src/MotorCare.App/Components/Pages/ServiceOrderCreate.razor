@page "/service-orders/create"
@inject AuthService AuthService
@inject ServiceOrdersService ServiceOrdersService
@inject NavigationManager NavigationManager

<PageTitle>Yeni Servis Kaydi</PageTitle>

<div class="page-shell">
    <section class="hero-panel compact">
        <div>
            <div class="eyebrow">Hizli kabul</div>
            <h1 class="page-title">Yeni Servis Kaydi</h1>
            <p class="page-description">
                Musteri ve araci sec, sikayeti kaydet, servisi hizla ac.
            </p>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success">@_successMessage</div>
    }

    <div class="content-grid">
        <section class="surface-card">
            <div class="section-header">
                <div>
                    <div class="section-title">1. Musteri Secimi</div>
                    <div class="section-subtitle">Mevcut kayitlar arasinda arama yapin</div>
                </div>
            </div>

            <div class="input-group mb-3">
                <InputText class="form-control" @bind-Value="_customerSearch" placeholder="Musteri ara" />
                <button type="button" class="btn btn-outline-secondary" @onclick="SearchCustomersAsync">Ara</button>
            </div>

            <div class="selection-list">
                @if (_customerResults.Count == 0)
                {
                    <div class="text-muted small">Arama sonucu burada listelenecek.</div>
                }
                else
                {
                    @foreach (var customer in _customerResults)
                    {
                        <button type="button" class="selection-item @(customer.Id == _selectedCustomer?.Id ? "selected" : string.Empty)" @onclick="() => SelectCustomer(customer)">
                            <strong>@customer.FullName</strong>
                            <span>@customer.Phone</span>
                        </button>
                    }
                }
            </div>
        </section>

        <section class="surface-card">
            <div class="section-header">
                <div>
                    <div class="section-title">2. Arac Secimi</div>
                    <div class="section-subtitle">Plakaya gore arac kaydini getir</div>
                </div>
            </div>

            <div class="input-group mb-3">
                <InputText class="form-control" @bind-Value="_vehiclePlate" placeholder="34ABC123" />
                <button type="button" class="btn btn-outline-secondary" @onclick="LookupVehicleAsync">Bul</button>
            </div>

            @if (_selectedVehicle is not null)
            {
                <div class="selection-item selected static">
                    <strong>@_selectedVehicle.PlateOriginal</strong>
                    <span>@_selectedVehicle.Brand @_selectedVehicle.Model (@_selectedVehicle.Year)</span>
                </div>
            }
            else
            {
                <div class="text-muted small">Arac secilmedi.</div>
            }
        </section>
    </div>

    <section class="surface-card mt-3">
        <div class="section-header">
            <div>
                <div class="section-title">3. Servis Bilgileri</div>
                <div class="section-subtitle">Kabul asamasinda gereken temel alanlar</div>
            </div>
        </div>

        <div class="form-grid">
            <div>
                <label class="form-label">Arac KM</label>
                <InputNumber class="form-control" @bind-Value="_vehicleKm" />
            </div>
            <div>
                <label class="form-label">Tahmini Teslim</label>
                <InputDate class="form-control" @bind-Value="_estimatedDeliveryDate" />
                <div class="form-text">Backend kontratina eklenecek alan. Su an sadece UI seviyesinde tutuluyor.</div>
            </div>
            <div class="full-span">
                <label class="form-label">Sikayet / Aciklama</label>
                <InputTextArea class="form-control" @bind-Value="_complaint" />
            </div>
        </div>

        <div class="d-flex justify-content-end mt-4">
            <button type="button" class="btn btn-primary" @onclick="CreateServiceOrderAsync" disabled="@_isSaving">
                @(_isSaving ? "Kaydediliyor..." : "Servisi Kaydet")
            </button>
        </div>
    </section>
</div>

@code {
    private readonly List<CustomerLookupResponse> _customerResults = [];
    private string? _customerSearch;
    private string? _vehiclePlate;
    private string? _complaint;
    private int _vehicleKm;
    private DateTime? _estimatedDeliveryDate = DateTime.Today.AddDays(1);
    private CustomerLookupResponse? _selectedCustomer;
    private VehicleLookupResponse? _selectedVehicle;
    private string? _error;
    private string? _successMessage;
    private bool _isSaving;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (!await AuthService.IsAuthenticatedAsync())
        {
            NavigationManager.NavigateTo("/login");
        }
    }

    private async Task SearchCustomersAsync()
    {
        try
        {
            _error = null;
            _customerResults.Clear();
            var result = await ServiceOrdersService.SearchCustomersAsync(_customerSearch);
            if (result is not null)
            {
                _customerResults.AddRange(result);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task LookupVehicleAsync()
    {
        try
        {
            _error = null;
            _selectedVehicle = null;

            if (string.IsNullOrWhiteSpace(_vehiclePlate))
            {
                _error = "Plaka girin.";
                return;
            }

            _selectedVehicle = await ServiceOrdersService.GetVehicleByPlateAsync(_vehiclePlate);
            if (_selectedVehicle is null)
            {
                _error = "Arac bulunamadi.";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void SelectCustomer(CustomerLookupResponse customer)
    {
        _selectedCustomer = customer;
    }

    private async Task CreateServiceOrderAsync()
    {
        try
        {
            _isSaving = true;
            _error = null;
            _successMessage = null;

            if (_selectedCustomer is null)
            {
                _error = "Bir musteri secin.";
                return;
            }

            if (_selectedVehicle is null)
            {
                _error = "Bir arac secin.";
                return;
            }

            if (_vehicleKm <= 0)
            {
                _error = "Gecerli bir arac KM bilgisi girin.";
                return;
            }

            var id = await ServiceOrdersService.CreateServiceOrderAsync(new CreateServiceOrderRequest
            {
                CustomerId = _selectedCustomer.Id,
                VehicleId = _selectedVehicle.Id,
                VehicleKm = _vehicleKm,
                Complaint = _complaint
            });

            _successMessage = $"Servis kaydi olusturuldu: {id}";
            NavigationManager.NavigateTo($"/service-orders/{id}");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }
}
