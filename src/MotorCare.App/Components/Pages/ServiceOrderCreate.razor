@page "/service-orders/create"
@using System.Net
@using MotorCare.App.Models.Customers
@using MotorCare.App.Models.ServiceOrders
@using MotorCare.App.Models.Services
@using MotorCare.App.Models.Vehicles
@inject ServiceOrdersService ServiceOrdersService
@inject CustomersService CustomersService
@inject VehiclesService VehiclesService
@inject ServicesService ServicesService
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Yeni Servis Kaydı</PageTitle>

<div class="page-shell">
    <section class="page-header">
        <div>
            <h1 class="page-title">Yeni Servis Kaydı</h1>
            <p class="page-description">Müşteri, araç, kilometre ve şikayet bilgisini girerek servis emrini hızlıca oluşturun.</p>
        </div>
        <a href="/service-orders" class="app-btn-secondary">Listeye Dön</a>
    </section>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <section class="error-state">
            <strong>Servis emri oluşturulamadı</strong>
            <p>@_error</p>
            @if (!string.IsNullOrWhiteSpace(_errorEndpoint))
            {
                <p class="small text-muted mt-2">İstek: @_errorEndpoint</p>
            }
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <section class="loading-state">
            <strong>İşlem başarılı</strong>
            <p>@_successMessage</p>
            @if (_createdServiceOrderId.HasValue)
            {
                <p class="mt-2">
                    <a class="app-btn-secondary" href="@($"/service-orders/{_createdServiceOrderId.Value}")">Servis emrini aç</a>
                </p>
            }
        </section>
    }

    <section class="app-card">
        <div class="content-grid">
            <section class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">1. Müşteri Seçimi</div>
                        <div class="section-subtitle">Ad veya telefon ile müşteri arayın.</div>
                    </div>
                    <a href="/customers/create" class="app-btn-secondary">+ Yeni Müşteri</a>
                </div>

                <div class="d-flex flex-column gap-3">
                    <div>
                        <label class="form-label">Ad veya Telefon ile Ara</label>
                        <div class="d-flex gap-2 flex-wrap">
                            <InputText class="form-control" @bind-Value="_customerSearchText" @bind:event="oninput" placeholder="Ahmet Yılmaz / 05xx..." />
                            <button type="button" class="app-btn-secondary" @onclick="SearchCustomersAsync" disabled="@_customerSearchLoading">
                                @(_customerSearchLoading ? "Aranıyor..." : "Ara")
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_customerSearchMessage))
                    {
                        <p class="small text-muted m-0">@_customerSearchMessage</p>
                    }

                    @if (_customerResults.Count > 0)
                    {
                        <div class="mobile-card-list">
                            @foreach (var customer in _customerResults)
                            {
                                <button type="button" class="selection-item" @onclick="() => SelectCustomerAsync(customer)">
                                    <div>
                                        <strong>@customer.FullName</strong>
                                        <div class="small text-muted">@customer.Phone</div>
                                    </div>
                                    <span class="type-badge">Seç</span>
                                </button>
                            }
                        </div>
                    }

                    @if (_selectedCustomer is not null)
                    {
                        <div class="selection-item selected">
                            <div>
                                <strong>@_selectedCustomer.FullName</strong>
                                <div class="small text-muted">@_selectedCustomer.Phone</div>
                            </div>
                            <button type="button" class="app-btn-secondary" @onclick="ClearCustomerSelectionAsync">Temizle</button>
                        </div>
                    }
                </div>
            </section>

            <section class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">2. Müşteriye Kayıtlı Araçlar</div>
                        <div class="section-subtitle">Seçili müşterinin araçlarından birini seçin.</div>
                    </div>
                    @if (_selectedCustomer is not null)
                    {
                        <a href="@($"/vehicles/create?customerId={_selectedCustomer.Id}")" class="app-btn-secondary">+ Bu Müşteriye Araç Ekle</a>
                    }
                </div>

                @if (_selectedCustomer is null)
                {
                    <section class="empty-state">
                        <strong>Önce müşteri seçin</strong>
                        <p>Seçili müşteriye bağlı araçlar burada listelenecek.</p>
                    </section>
                }
                else if (_customerVehiclesLoading)
                {
                    <section class="loading-state">
                        <strong>Araçlar yükleniyor</strong>
                        <p>Müşteri araçları getiriliyor.</p>
                    </section>
                }
                else if (!string.IsNullOrWhiteSpace(_customerVehiclesMessage))
                {
                    <p class="small text-muted m-0">@_customerVehiclesMessage</p>
                }

                @if (_customerVehicles.Count > 0)
                {
                    <div class="mobile-card-list mt-3">
                        @foreach (var vehicle in _customerVehicles)
                        {
                            <button type="button" class="selection-item @(vehicle.Id == _selectedVehicle?.Id ? "selected" : string.Empty)" @onclick="() => SelectVehicle(vehicle)">
                                <div>
                                    <strong>@vehicle.PlateOriginal</strong>
                                    <div class="small text-muted">@vehicle.Brand @vehicle.Model (@vehicle.Year)</div>
                                </div>
                                <span class="type-badge">@(vehicle.Id == _selectedVehicle?.Id ? "Seçildi" : "Seç")</span>
                            </button>
                        }
                    </div>
                }
            </section>
        </div>

        <div class="content-grid mt-4">
            <section class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">3. Plaka ile Araç Bul / Yeni Araç Ekle</div>
                        <div class="section-subtitle">Plaka ile arayın veya seçili müşteriye yeni araç ekleyin.</div>
                    </div>
                </div>

                <div class="d-flex flex-column gap-3">
                    <div>
                        <label class="form-label">Plaka ile Ara</label>
                        <div class="d-flex gap-2 flex-wrap">
                            <InputText class="form-control" @bind-Value="_vehicleLookupPlate" placeholder="34 ABC 123" />
                            <button type="button" class="app-btn-secondary" @onclick="LookupVehicleAsync" disabled="@_vehicleLookupLoading">
                                @(_vehicleLookupLoading ? "Aranıyor..." : "Bul")
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_vehicleLookupMessage))
                    {
                        <p class="small text-muted m-0">@_vehicleLookupMessage</p>
                    }

                    @if (_selectedVehicle is not null)
                    {
                        <div class="selection-item selected">
                            <div>
                                <strong>@_selectedVehicle.PlateOriginal</strong>
                                <div class="small text-muted">@_selectedVehicle.Brand @_selectedVehicle.Model (@_selectedVehicle.Year)</div>
                            </div>
                            <button type="button" class="app-btn-secondary" @onclick="ClearVehicleSelection">Temizle</button>
                        </div>
                    }

                    <div class="form-grid">
                        <div>
                            <label class="form-label">Plaka</label>
                            <InputText class="form-control" @bind-Value="_plate" placeholder="34 ABC 123" />
                        </div>
                        <div>
                            <label class="form-label">Marka</label>
                            <InputText class="form-control" @bind-Value="_newVehicle.Brand" placeholder="Toyota" />
                        </div>
                        <div>
                            <label class="form-label">Model</label>
                            <InputText class="form-control" @bind-Value="_newVehicle.Model" placeholder="Corolla" />
                        </div>
                        <div>
                            <label class="form-label">Yıl</label>
                            <InputNumber class="form-control" @bind-Value="_newVehicle.Year" />
                        </div>
                    </div>

                    <div class="action-bar justify-content-end">
                        <button type="button" class="app-btn-secondary" @onclick="CreateVehicleForSelectedCustomerAsync" disabled="@(_vehicleCreateLoading || _selectedCustomer is null)">
                            @(_vehicleCreateLoading ? "Kaydediliyor..." : "Seçili Müşteriye Araç Olarak Ekle")
                        </button>
                    </div>
                </div>
            </section>

            <section class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">4. Hizmet Seçimi</div>
                        <div class="section-subtitle">İlk operasyonu hızlı başlatmak için bir hizmet seçin.</div>
                    </div>
                </div>

                @if (_servicesLoading)
                {
                    <section class="loading-state">
                        <strong>Hizmetler yükleniyor</strong>
                        <p>Tanımlı hizmetler getiriliyor.</p>
                    </section>
                }
                else if (_activeServices.Count == 0)
                {
                    <section class="empty-state">
                        <strong>Henüz hizmet tanımlanmamış</strong>
                        <p>Hizmetler ekranından ekleyebilirsiniz.</p>
                    </section>
                }
                else
                {
                    <div class="mobile-card-list">
                        @foreach (var service in _activeServices)
                        {
                            <button type="button" class="selection-item @(service.Id == _selectedService?.Id ? "selected" : string.Empty)" @onclick="() => SelectService(service)">
                                <div>
                                    <strong>@service.Name</strong>
                                    <div class="small text-muted">@service.CategoryText</div>
                                    <div class="small text-muted">Tahmini Süre: @service.DefaultDurationMinutes dk · Varsayılan Fiyat: @service.DefaultPrice.ToString("N2") ₺</div>
                                </div>
                                <span class="type-badge">@(service.Id == _selectedService?.Id ? "Seçildi" : "Seç")</span>
                            </button>
                        }
                    </div>
                }
            </section>
        </div>

        <div class="content-grid mt-4">
            <section class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">5. Servis Bilgileri</div>
                        <div class="section-subtitle">Kilometre ve şikayet bilgisini tamamlayın.</div>
                    </div>
                </div>

                <div class="form-grid">
                    <div>
                        <label class="form-label">Araç KM *</label>
                        <InputNumber class="form-control" @bind-Value="_vehicleKm" />
                    </div>
                    <div>
                        <label class="form-label">Varsayılan Fiyat</label>
                        <InputText class="form-control" Value="@GetSelectedServicePriceText()" disabled />
                    </div>
                    <div>
                        <label class="form-label">Tahmini Süre</label>
                        <InputText class="form-control" Value="@GetSelectedServiceDurationText()" disabled />
                    </div>
                    <div class="full-span">
                        <label class="form-label">Şikayet / Açıklama</label>
                        <InputTextArea class="form-control" @bind-Value="_complaint" rows="4" />
                    </div>
                </div>
            </section>
        </div>

        <div class="action-bar sticky-mobile-action justify-content-end mt-4">
            <button type="button" class="app-btn-primary" @onclick="CreateServiceOrderAsync" disabled="@_isSaving">
                @(_isSaving ? "Kaydediliyor..." : "Servis Emrini Oluştur")
            </button>
        </div>
    </section>
</div>

@code {
    [SupplyParameterFromQuery] public Guid? CustomerId { get; set; }
    [SupplyParameterFromQuery(Name = "plate")] public string? PlateQuery { get; set; }
    [SupplyParameterFromQuery(Name = "complaint")] public string? ComplaintQuery { get; set; }
    [SupplyParameterFromQuery(Name = "recommendations")] public string? RecommendationsQuery { get; set; }

    private readonly List<CustomerLookupResponse> _customerResults = [];
    private readonly List<VehicleLookupResponse> _customerVehicles = [];
    private readonly List<ServiceCatalogItem> _activeServices = [];
    private readonly CreateVehicleRequest _newVehicle = new() { Year = DateTime.Today.Year };
    private CustomerLookupResponse? _selectedCustomer;
    private VehicleLookupResponse? _selectedVehicle;
    private ServiceCatalogItem? _selectedService;
    private string? _customerSearchText;
    private string? _customerSearchMessage;
    private string? _customerVehiclesMessage;
    private string? _vehicleLookupPlate;
    private string? _vehicleLookupMessage;
    private string? _plate;
    private string? _complaint;
    private string? _error;
    private string? _errorEndpoint;
    private string? _successMessage;
    private Guid? _createdServiceOrderId;
    private int _vehicleKm;
    private bool _isSaving;
    private bool _customerSearchLoading;
    private bool _vehicleLookupLoading;
    private bool _vehicleCreateLoading;
    private bool _customerVehiclesLoading;
    private bool _servicesLoading;
    private readonly List<string> _prefilledRecommendations = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (!await AuthService.IsAuthenticatedAsync())
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        await LoadActiveServicesAsync();

        if (CustomerId.HasValue)
        {
            try
            {
                var customer = await CustomersService.GetByIdAsync(CustomerId.Value);
                if (customer is not null)
                {
                    await SelectCustomerAsync(customer);
                }
            }
            catch
            {
            }
        }

        if (!string.IsNullOrWhiteSpace(PlateQuery))
        {
            _vehicleLookupPlate = PlateQuery;
            _plate = PlateQuery;
            await LookupVehicleAsync();
        }

        if (!string.IsNullOrWhiteSpace(ComplaintQuery))
        {
            _complaint = ComplaintQuery;
        }

        ApplyPrefilledRecommendations();
    }

    private void ApplyPrefilledRecommendations()
    {
        _prefilledRecommendations.Clear();

        if (string.IsNullOrWhiteSpace(RecommendationsQuery))
        {
            return;
        }

        var parsed = RecommendationsQuery
            .Split("||", StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(x => x.Split("##", StringSplitOptions.None))
            .Where(parts => parts.Length >= 3)
            .Select(parts => $"{parts[0]} [{parts[1]}] - {parts[2]}")
            .Distinct()
            .ToList();

        if (parsed.Count == 0)
        {
            return;
        }

        _prefilledRecommendations.AddRange(parsed);

        var recommendationBlock = "Servis Önerileri:" + Environment.NewLine +
                                  string.Join(Environment.NewLine, _prefilledRecommendations.Select(x => $"- {x}"));

        if (string.IsNullOrWhiteSpace(_complaint))
        {
            _complaint = recommendationBlock;
            return;
        }

        if (!_complaint.Contains("Servis Önerileri:", StringComparison.OrdinalIgnoreCase))
        {
            _complaint = _complaint.Trim() + Environment.NewLine + Environment.NewLine + recommendationBlock;
        }
    }

    private async Task LoadActiveServicesAsync()
    {
        try
        {
            _servicesLoading = true;
            _activeServices.Clear();
            var services = await ServicesService.GetActiveServicesAsync();
            _activeServices.AddRange(services);
        }
        catch
        {
        }
        finally
        {
            _servicesLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SearchCustomersAsync()
    {
        try
        {
            _customerSearchLoading = true;
            _customerSearchMessage = null;
            _customerResults.Clear();

            if (string.IsNullOrWhiteSpace(_customerSearchText))
            {
                _customerSearchMessage = "Arama yapmak için müşteri adı veya telefon girin.";
                return;
            }

            var result = await CustomersService.SearchCustomersAsync(_customerSearchText);
            if (result is not null)
            {
                _customerResults.AddRange(result.Items);
            }

            if (_customerResults.Count == 0)
            {
                _customerSearchMessage = "Eşleşen müşteri bulunamadı.";
            }
        }
        catch (ApiException ex) when (ex.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
        {
            NavigationManager.NavigateTo("/login");
        }
        catch (ApiException ex)
        {
            _customerSearchMessage = ex.Message;
        }
        catch (Exception ex)
        {
            _customerSearchMessage = ex.Message;
        }
        finally
        {
            _customerSearchLoading = false;
        }
    }

    private async Task SelectCustomerAsync(CustomerLookupResponse customer)
    {
        var previousCustomerId = _selectedCustomer?.Id;
        _selectedCustomer = customer;
        _customerSearchText = customer.FullName;
        _customerResults.Clear();
        _customerSearchMessage = "Müşteri seçildi.";

        if (_selectedVehicle?.CustomerId.HasValue == true && _selectedVehicle.CustomerId != customer.Id && previousCustomerId != customer.Id)
        {
            ClearVehicleSelection();
            _vehicleLookupMessage = "Seçili araç farklı bir müşteriye bağlı olduğu için temizlendi.";
        }

        await LoadCustomerVehiclesAsync(customer.Id);
    }

    private async Task ClearCustomerSelectionAsync()
    {
        _selectedCustomer = null;
        _customerSearchText = null;
        _customerResults.Clear();
        _customerSearchMessage = "Müşteri seçimi temizlendi.";
        _customerVehicles.Clear();
        _customerVehiclesMessage = null;
        ClearVehicleSelection();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadCustomerVehiclesAsync(Guid customerId)
    {
        try
        {
            _customerVehiclesLoading = true;
            _customerVehiclesMessage = null;
            _customerVehicles.Clear();

            var vehicles = await VehiclesService.GetByCustomerIdAsync(customerId);
            if (vehicles is not null)
            {
                _customerVehicles.AddRange(vehicles);
            }

            _customerVehiclesMessage = _customerVehicles.Count == 0
                ? "Bu müşterinin kayıtlı aracı yok. Aşağıdan plaka ile arayabilir veya yeni araç ekleyebilirsiniz."
                : null;
        }
        catch (ApiException ex)
        {
            _customerVehiclesMessage = ex.Message;
        }
        catch (Exception ex)
        {
            _customerVehiclesMessage = ex.Message;
        }
        finally
        {
            _customerVehiclesLoading = false;
        }
    }

    private void SelectVehicle(VehicleLookupResponse vehicle)
    {
        _selectedVehicle = vehicle;
        _plate = vehicle.PlateOriginal;
        _vehicleLookupPlate = vehicle.PlateOriginal;
        _vehicleLookupMessage = "Araç seçildi.";
    }

    private async Task LookupVehicleAsync()
    {
        try
        {
            _vehicleLookupLoading = true;
            _vehicleLookupMessage = null;

            if (string.IsNullOrWhiteSpace(_vehicleLookupPlate))
            {
                _vehicleLookupMessage = "Plaka girin.";
                return;
            }

            var vehicle = await VehiclesService.GetByPlateAsync(_vehicleLookupPlate);
            if (vehicle is null)
            {
                _selectedVehicle = null;
                _plate = _vehicleLookupPlate;
                _vehicleLookupMessage = "Bu plakayla araç bulunamadı. Seçili müşteriye araç olarak ekleyebilirsiniz.";
                return;
            }

            if (vehicle.CustomerId.HasValue &&
                _selectedCustomer is not null &&
                vehicle.CustomerId.Value != _selectedCustomer.Id)
            {
                _vehicleLookupMessage = "Bulunan araç başka bir müşteriye bağlı. Müşteri seçimi araç sahibine göre güncellendi.";
            }

            if (vehicle.CustomerId.HasValue)
            {
                var customer = await CustomersService.GetByIdAsync(vehicle.CustomerId.Value);
                if (customer is not null)
                {
                    await SelectCustomerAsync(customer);
                }
            }

            SelectVehicle(vehicle);
            _newVehicle.Brand = vehicle.Brand;
            _newVehicle.Model = vehicle.Model;
            _newVehicle.Year = vehicle.Year;
        }
        catch (ApiException ex)
        {
            _vehicleLookupMessage = ex.Message;
        }
        catch (Exception ex)
        {
            _vehicleLookupMessage = ex.Message;
        }
        finally
        {
            _vehicleLookupLoading = false;
        }
    }

    private async Task CreateVehicleForSelectedCustomerAsync()
    {
        try
        {
            _vehicleCreateLoading = true;
            _vehicleLookupMessage = null;

            if (_selectedCustomer is null)
            {
                _vehicleLookupMessage = "Müşteri seçmelisiniz.";
                return;
            }

            if (string.IsNullOrWhiteSpace(_plate))
            {
                _vehicleLookupMessage = "Araç eklemek için plaka girin.";
                return;
            }

            if (string.IsNullOrWhiteSpace(_newVehicle.Brand) || string.IsNullOrWhiteSpace(_newVehicle.Model))
            {
                _vehicleLookupMessage = "Marka ve model zorunludur.";
                return;
            }

            _newVehicle.Plate = _plate;
            _newVehicle.CurrentCustomerId = _selectedCustomer.Id;

            await VehiclesService.CreateAsync(_newVehicle);
            var vehicle = await VehiclesService.GetByPlateAsync(_newVehicle.Plate);
            if (vehicle is not null)
            {
                await LoadCustomerVehiclesAsync(_selectedCustomer.Id);
                SelectVehicle(vehicle);
                _vehicleLookupMessage = "Araç seçili müşteriye eklendi ve seçildi.";
            }
        }
        catch (ApiException ex)
        {
            _vehicleLookupMessage = ex.Message;
        }
        catch (Exception ex)
        {
            _vehicleLookupMessage = ex.Message;
        }
        finally
        {
            _vehicleCreateLoading = false;
        }
    }

    private void ClearVehicleSelection()
    {
        _selectedVehicle = null;
        _vehicleLookupPlate = null;
    }

    private void SelectService(ServiceCatalogItem service)
    {
        _selectedService = service;

        if (string.IsNullOrWhiteSpace(_complaint))
        {
            _complaint = service.Name;
        }
    }

    private async Task CreateServiceOrderAsync()
    {
        try
        {
            _isSaving = true;
            _error = null;
            _errorEndpoint = null;
            _successMessage = null;
            _createdServiceOrderId = null;

            if (_selectedCustomer is null)
            {
                _error = "Müşteri seçmelisiniz.";
                return;
            }

            if (_selectedVehicle is null)
            {
                _error = "Araç seçmelisiniz.";
                return;
            }

            if (_vehicleKm < 0)
            {
                _error = "Araç KM bilgisi geçersiz.";
                return;
            }

            var id = await ServiceOrdersService.CreateServiceOrderAsync(new CreateServiceOrderRequest
            {
                CustomerId = _selectedCustomer.Id,
                VehicleId = _selectedVehicle.Id,
                VehicleKm = _vehicleKm,
                Complaint = _complaint
            });

            _createdServiceOrderId = id;

            if (_selectedService is not null)
            {
                try
                {
                    await ServiceOrdersService.AddOperationAsync(id, new AddOperationRequest
                    {
                        Description = _selectedService.Name,
                        Price = _selectedService.DefaultPrice
                    });
                }
                catch (ApiException ex)
                {
                    _successMessage = $"Servis emri oluşturuldu ancak seçilen hizmet operasyon olarak eklenemedi: {ex.Message}";
                    _errorEndpoint = ex.Endpoint;
                    return;
                }
                catch (Exception ex)
                {
                    _successMessage = $"Servis emri oluşturuldu ancak seçilen hizmet operasyon olarak eklenemedi: {ex.Message}";
                    return;
                }
            }

            if (_prefilledRecommendations.Count > 0)
            {
                foreach (var recommendation in _prefilledRecommendations)
                {
                    try
                    {
                        await ServiceOrdersService.AddOperationAsync(id, new AddOperationRequest
                        {
                            Description = recommendation,
                            Price = 0m
                        });
                    }
                    catch (ApiException ex)
                    {
                        _successMessage = $"Servis emri oluşturuldu ancak bazı ekspertiz önerileri operasyon olarak eklenemedi: {ex.Message}";
                        _errorEndpoint = ex.Endpoint;
                        NavigationManager.NavigateTo($"/service-orders/{id}");
                        return;
                    }
                    catch (Exception ex)
                    {
                        _successMessage = $"Servis emri oluşturuldu ancak bazı ekspertiz önerileri operasyon olarak eklenemedi: {ex.Message}";
                        NavigationManager.NavigateTo($"/service-orders/{id}");
                        return;
                    }
                }
            }

            _successMessage = "Servis emri oluşturuldu.";
            NavigationManager.NavigateTo($"/service-orders/{id}");
        }
        catch (ApiException ex) when (ex.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
        {
            NavigationManager.NavigateTo("/login");
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
            _errorEndpoint = ex.Endpoint;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private string GetSelectedServicePriceText()
        => _selectedService is null ? "-" : $"{_selectedService.DefaultPrice:N2} ₺";

    private string GetSelectedServiceDurationText()
        => _selectedService is null ? "-" : $"{_selectedService.DefaultDurationMinutes} dk";
}
