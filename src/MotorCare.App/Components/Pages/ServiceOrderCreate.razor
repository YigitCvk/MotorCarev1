    private async Task SelectCustomerAsync(CustomerLookupResponse customer)
        => await SelectCustomerAsync(customer, _lifetimeCts.Token);

    private async Task SelectCustomerAsync(CustomerLookupResponse customer, CancellationToken cancellationToken)
    {
        if (IsInactive(cancellationToken))
        {
            return;
        }

        var previousCustomerId = _selectedCustomer?.Id;
        _selectedCustomer = customer;
        _customerSearchText = customer.FullName;
        _customerResults.Clear();
        _customerSearchMessage = "Musteri secildi.";

        Logger.LogInformation(
            EventIdStore.ServiceOrder.ServiceOrderCreateCustomerSelected,
            "Customer selected on service order create. CustomerId={CustomerId} CustomerName={CustomerName}",
            customer.Id,
            customer.FullName);

        if (_selectedVehicle?.CustomerId.HasValue == true &&
            _selectedVehicle.CustomerId != customer.Id &&
            previousCustomerId != customer.Id)
        {
            ClearVehicleSelection();
            _vehicleLookupMessage = "Secili arac farkli bir musteriye bagli oldugu icin temizlendi.";
        }

        await LoadCustomerVehiclesAsync(customer.Id, cancellationToken);
        if (!IsInactive(cancellationToken))
        {
            await SafeStateHasChangedAsync();
        }
    }

    private async Task ClearCustomerSelectionAsync()
    {
        _selectedCustomer = null;
        _customerSearchText = null;
        _customerResults.Clear();
        _customerSearchMessage = "Musteri secimi temizlendi.";
        _customerVehicles.Clear();
        _customerVehiclesMessage = null;
        ClearVehicleSelection();
        await SafeStateHasChangedAsync();
    }

    private async Task LoadCustomerVehiclesAsync(Guid customerId, CancellationToken cancellationToken)
    {
        try
        {
            _customerVehiclesLoading = true;
            _customerVehiclesMessage = null;
            _customerVehicles.Clear();
            await SafeStateHasChangedAsync();

            var vehicles = await VehiclesService.GetByCustomerIdAsync(customerId, cancellationToken);
