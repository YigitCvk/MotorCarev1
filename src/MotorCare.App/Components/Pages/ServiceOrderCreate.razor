    private void SelectVehicle(VehicleLookupResponse vehicle)
    {
        if (_isDisposed)
        {
            return;
        }

        _selectedVehicle = vehicle;
        _plate = vehicle.PlateOriginal;
        _vehicleLookupPlate = vehicle.PlateOriginal;
        _vehicleLookupMessage = "Arac secildi ve alanlar otomatik dolduruldu.";
        _newVehicle.Brand = vehicle.Brand;
        _newVehicle.Model = vehicle.Model;
        _newVehicle.Year = vehicle.Year;
        _newVehicle.ChassisNumber = vehicle.ChassisNumber;
        _newVehicle.CurrentKm = vehicle.CurrentKm;

        if (vehicle.CurrentKm.HasValue && vehicle.CurrentKm.Value >= 0)
        {
            _vehicleKm = vehicle.CurrentKm.Value;
        }

        Logger.LogInformation(
            EventIdStore.ServiceOrder.ServiceOrderCreateVehicleAutoFilled,
            "Vehicle selected and form auto-filled. VehicleId={VehicleId} Plate={Plate} Brand={Brand} Model={Model} CurrentKm={CurrentKm}",
            vehicle.Id,
            vehicle.PlateOriginal,
            vehicle.Brand,
            vehicle.Model,
            vehicle.CurrentKm);
    }

    private async Task LookupVehicleAsync()
        => await LookupVehicleAsync(_lifetimeCts.Token);

    private async Task LookupVehicleAsync(CancellationToken cancellationToken)
    {
        try
        {
            _vehicleLookupLoading = true;
            _vehicleLookupMessage = null;
            await SafeStateHasChangedAsync();

            if (string.IsNullOrWhiteSpace(_vehicleLookupPlate))
            {
                _vehicleLookupMessage = "Plaka girin.";
                return;
            }

            var vehicle = await VehiclesService.GetByPlateAsync(_vehicleLookupPlate, cancellationToken);
            if (IsInactive(cancellationToken))
            {
                return;
            }

            if (vehicle is null)
            {
                _selectedVehicle = null;
                _plate = _vehicleLookupPlate;
                _vehicleLookupMessage = "Bu plakayla arac bulunamadi. Secili musteriye arac olarak ekleyebilirsiniz.";
                return;
            }

            if (vehicle.CustomerId.HasValue &&
                _selectedCustomer is not null &&
                vehicle.CustomerId.Value != _selectedCustomer.Id)
            {
                _vehicleLookupMessage = "Bulunan arac baska bir musteriye bagli. Musteri secimi arac sahibine gore guncellendi.";
            }

            if (vehicle.CustomerId.HasValue)
            {
                var customer = await CustomersService.GetByIdAsync(vehicle.CustomerId.Value, cancellationToken);
                if (customer is not null && !IsInactive(cancellationToken))
                {
                    await SelectCustomerAsync(customer, cancellationToken);
                }
            }

            if (IsInactive(cancellationToken))
            {
                return;
            }

            SelectVehicle(vehicle);
        }
        catch (OperationCanceledException) when (IsInactive(cancellationToken))
        {
        }
        catch (ApiException ex)
        {
            if (!IsInactive(cancellationToken))
            {
                _vehicleLookupMessage = ex.Message;
            }
        }
        catch (Exception ex)
        {
            if (!IsInactive(cancellationToken))
            {
                _vehicleLookupMessage = ex.Message;
            }
        }
        finally
        {
            if (!IsInactive(cancellationToken))
            {
                _vehicleLookupLoading = false;
                await SafeStateHasChangedAsync();
            }
        }
    }

    private async Task CreateVehicleForSelectedCustomerAsync()
    {
        var cancellationToken = _lifetimeCts.Token;

        try
        {
            _vehicleCreateLoading = true;
            _vehicleLookupMessage = null;
            await SafeStateHasChangedAsync();

            if (_selectedCustomer is null)
            {
                _vehicleLookupMessage = "Musteri secmelisiniz.";
                return;
            }

            if (string.IsNullOrWhiteSpace(_plate))
            {
                _vehicleLookupMessage = "Arac eklemek icin plaka girin.";
                return;
            }

            if (string.IsNullOrWhiteSpace(_newVehicle.Brand) || string.IsNullOrWhiteSpace(_newVehicle.Model))
            {
                _vehicleLookupMessage = "Marka ve model zorunludur.";
                return;
            }

            _newVehicle.Plate = _plate;
            _newVehicle.CurrentCustomerId = _selectedCustomer.Id;

            await VehiclesService.CreateAsync(_newVehicle, cancellationToken);
            var vehicle = await VehiclesService.GetByPlateAsync(_newVehicle.Plate, cancellationToken);
            if (vehicle is not null && !IsInactive(cancellationToken))
            {
                await LoadCustomerVehiclesAsync(_selectedCustomer.Id, cancellationToken);
                SelectVehicle(vehicle);
                _vehicleLookupMessage = "Arac secili musteriye eklendi ve secildi.";
            }
        }
        catch (OperationCanceledException) when (IsInactive(cancellationToken))
        {
        }
        catch (ApiException ex)
        {
            if (!IsInactive(cancellationToken))
            {
                _vehicleLookupMessage = ex.Message;
            }
        }
        catch (Exception ex)
        {
            if (!IsInactive(cancellationToken))
            {
                _vehicleLookupMessage = ex.Message;
            }
        }
        finally
        {
            if (!IsInactive(cancellationToken))
            {
                _vehicleCreateLoading = false;
                await SafeStateHasChangedAsync();
            }
        }
    }

