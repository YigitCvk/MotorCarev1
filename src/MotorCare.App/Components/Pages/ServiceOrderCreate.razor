@page "/service-orders/create"
@implements IDisposable
@using System.Net
@using MotorCare.Application.Common
@using MotorCare.App.Models.Customers
@using MotorCare.App.Models.ServiceOrders
@using MotorCare.App.Models.Services
@using MotorCare.App.Models.Vehicles
@inject ServiceOrdersService ServiceOrdersService
@inject CustomersService CustomersService
@inject VehiclesService VehiclesService
@inject ServicesService ServicesService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject ILogger<ServiceOrderCreate> Logger

<PageTitle>Yeni Servis Kaydi</PageTitle>

<div class="page-shell">
    <section class="page-header">
        <div>
            <h1 class="page-title">Yeni Servis Kaydi</h1>
            <p class="page-description">Musteri secin, araci otomatik doldurun ve kullanilan sarf malzemelerini onerilerle birlikte kaydedin.</p>
        </div>
        <a href="/service-orders" class="app-btn-secondary">Listeye Don</a>
    </section>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <section class="error-state">
            <strong>Servis emri olusturulamadi</strong>
            <p>@_error</p>
            @if (!string.IsNullOrWhiteSpace(_errorEndpoint))
            {
                <p class="small text-muted mt-2">Istek: @_errorEndpoint</p>
            }
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <section class="loading-state">
            <strong>Islem basarili</strong>
            <p>@_successMessage</p>
            @if (_createdServiceOrderId.HasValue)
            {
                <p class="mt-2">
                    <a class="app-btn-secondary" href="@($"/service-orders/{_createdServiceOrderId.Value}")">Servis emrini ac</a>
                </p>
            }
        </section>
    }

    @if (_isInitializing)
    {
        <section class="loading-state">
            <strong>Servis kaydi hazirlaniyor</strong>
            <p>Musteri, arac, hizmet ve sarf onerileri yukleniyor.</p>
        </section>
    }

    <ServiceOrderCreateErrorBoundary>
        <ErrorContent>
            <section class="error-state">
                <strong>Servis kaydi sayfasi gosterilemedi</strong>
                <p>Form render edilirken bir hata olustu. Sayfayi yenileyip tekrar deneyin.</p>
            </section>
        </ErrorContent>

        <ChildContent>
        <EditForm EditContext="_formEditContext">
    <section class="app-card">
        <div class="content-grid">
            <section class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">1. Musteri Secimi</div>
                        <div class="section-subtitle">Ad veya telefon ile musteri arayin.</div>
                    </div>
                    <a href="/customers/create" class="app-btn-secondary">+ Yeni Musteri</a>
                </div>

                <div class="d-flex flex-column gap-3">
                    <div>
                        <label class="form-label">Ad veya Telefon ile Ara</label>
                        <div class="d-flex gap-2 flex-wrap">
                            <input class="form-control" @bind="_customerSearchText" @bind:event="oninput" placeholder="Ahmet Yilmaz / 05xx..." />
                            <button type="button" class="app-btn-secondary" @onclick="SearchCustomersAsync" disabled="@_customerSearchLoading">
                                @(_customerSearchLoading ? "Araniyor..." : "Ara")
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_customerSearchMessage))
                    {
                        <p class="small text-muted m-0">@_customerSearchMessage</p>
                    }

                    @if (_customerResults.Count > 0)
                    {
                        <div class="mobile-card-list">
                            @foreach (var customer in _customerResults)
                            {
                                <button type="button" class="selection-item" @onclick="() => SelectCustomerAsync(customer)">
                                    <div>
                                        <strong>@customer.FullName</strong>
                                        <div class="small text-muted">@customer.Phone</div>
                                    </div>
                                    <span class="type-badge">Sec</span>
                                </button>
                            }
                        </div>
                    }

                    @if (_selectedCustomer is not null)
                    {
                        <div class="selection-item selected">
                            <div>
                                <strong>@_selectedCustomer.FullName</strong>
                                <div class="small text-muted">@_selectedCustomer.Phone</div>
                            </div>
                            <button type="button" class="app-btn-secondary" @onclick="ClearCustomerSelectionAsync">Temizle</button>
                        </div>
                    }
                </div>
            </section>

            <section class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">2. Musteriye Kayitli Araclar</div>
                        <div class="section-subtitle">Secilen musteriye ait araclar listelenir ve secildiginde form otomatik dolar.</div>
                    </div>
                    @if (_selectedCustomer is not null)
                    {
                        <a href="@($"/vehicles/create?customerId={_selectedCustomer.Id}")" class="app-btn-secondary">+ Bu Musteriye Arac Ekle</a>
                    }
                </div>

                @if (_selectedCustomer is null)
                {
                    <section class="empty-state">
                        <strong>Once musteri secin</strong>
                        <p>Secili musteriye bagli araclar burada listelenecek.</p>
                    </section>
                }
                else if (_customerVehiclesLoading)
                {
                    <section class="loading-state">
                        <strong>Araclar yukleniyor</strong>
                        <p>Musteri araclari getiriliyor.</p>
                    </section>
                }
                else if (!string.IsNullOrWhiteSpace(_customerVehiclesMessage))
                {
                    <p class="small text-muted m-0">@_customerVehiclesMessage</p>
                }

                @if (_customerVehicles.Count > 0)
                {
                    <div class="mobile-card-list mt-3">
                        @foreach (var vehicle in _customerVehicles)
                        {
                            <button type="button"
                                    class="selection-item @(vehicle.Id == _selectedVehicle?.Id ? "selected" : string.Empty)"
                                    @onclick="() => SelectVehicle(vehicle)">
                                <div>
                                    <strong>@vehicle.PlateOriginal</strong>
                                    <div class="small text-muted">@vehicle.Brand @vehicle.Model (@vehicle.Year)</div>
                                    <div class="small text-muted">Sase: @(string.IsNullOrWhiteSpace(vehicle.ChassisNumber) ? "-" : vehicle.ChassisNumber)</div>
                                </div>
                                <span class="type-badge">@(vehicle.Id == _selectedVehicle?.Id ? "Secildi" : "Sec")</span>
                            </button>
                        }
                    </div>
                }
            </section>
        </div>

        <div class="content-grid mt-4">
            <section class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">3. Plaka ile Arac Bul / Yeni Arac Ekle</div>
                        <div class="section-subtitle">Plaka ile arayin veya secili musteriye yeni arac ekleyin.</div>
                    </div>
                </div>

                <div class="d-flex flex-column gap-3">
                    <div>
                        <label class="form-label">Plaka ile Ara</label>
                        <div class="d-flex gap-2 flex-wrap">
                            <InputText class="form-control" @bind-Value="_vehicleLookupPlate" placeholder="34 ABC 123" />
                            <button type="button" class="app-btn-secondary" @onclick="LookupVehicleAsync" disabled="@_vehicleLookupLoading">
                                @(_vehicleLookupLoading ? "Araniyor..." : "Bul")
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_vehicleLookupMessage))
                    {
                        <p class="small text-muted m-0">@_vehicleLookupMessage</p>
                    }

                    @if (_selectedVehicle is not null)
                    {
                        <div class="selection-item selected">
                            <div>
                                <strong>@_selectedVehicle.PlateOriginal</strong>
                                <div class="small text-muted">@_selectedVehicle.Brand @_selectedVehicle.Model (@_selectedVehicle.Year)</div>
                            </div>
                            <button type="button" class="app-btn-secondary" @onclick="ClearVehicleSelection">Temizle</button>
                        </div>
                    }

                    <div class="form-grid">
                        <div>
                            <label class="form-label">Plaka</label>
                            <InputText class="form-control" @bind-Value="_plate" placeholder="34 ABC 123" />
                        </div>
                        <div>
                            <label class="form-label">Marka</label>
                            <InputText class="form-control" @bind-Value="_newVehicle.Brand" placeholder="Honda" />
                        </div>
                        <div>
                            <label class="form-label">Model</label>
                            <InputText class="form-control" @bind-Value="_newVehicle.Model" placeholder="NC750X" />
                        </div>
                        <div>
                            <label class="form-label">Yil</label>
                            <InputNumber class="form-control" @bind-Value="_newVehicle.Year" />
                        </div>
                        <div>
                            <label class="form-label">Sase No</label>
                            <InputText class="form-control" @bind-Value="_newVehicle.ChassisNumber" />
                        </div>
                        <div>
                            <label class="form-label">Kayitli KM</label>
                            <InputNumber class="form-control" @bind-Value="_newVehicle.CurrentKm" />
                        </div>
                    </div>

                    <div class="action-bar justify-content-end">
                        <button type="button" class="app-btn-secondary" @onclick="CreateVehicleForSelectedCustomerAsync" disabled="@(_vehicleCreateLoading || _selectedCustomer is null)">
                            @(_vehicleCreateLoading ? "Kaydediliyor..." : "Secili Musteriye Arac Olarak Ekle")
                        </button>
                    </div>
                </div>
            </section>

            <section class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">4. Hizmet Secimi</div>
                        <div class="section-subtitle">Ilk operasyonu hizli baslatmak icin bir hizmet secin.</div>
                    </div>
                </div>

                @if (_servicesLoading)
                {
                    <section class="loading-state">
                        <strong>Hizmetler yukleniyor</strong>
                        <p>Tanimli hizmetler getiriliyor.</p>
                    </section>
                }
                else if (_activeServices.Count == 0)
                {
                    <section class="empty-state">
                        <strong>Henuz hizmet tanimlanmamis</strong>
                        <p>Hizmetler ekranindan ekleyebilirsiniz.</p>
                    </section>
                }
                else
                {
                    <div class="mobile-card-list">
                        @foreach (var service in _activeServices)
                        {
                            <button type="button" class="selection-item @(service.Id == _selectedService?.Id ? "selected" : string.Empty)" @onclick="() => SelectService(service)">
                                <div>
                                    <strong>@service.Name</strong>
                                    <div class="small text-muted">@service.CategoryText</div>
                                    <div class="small text-muted">Tahmini Sure: @service.DefaultDurationMinutes dk - Varsayilan Fiyat: @service.DefaultPrice.ToString("N2") ₺</div>
                                </div>
                                <span class="type-badge">@(service.Id == _selectedService?.Id ? "Secildi" : "Sec")</span>
                            </button>
                        }
                    </div>
                }
            </section>
        </div>

        <div class="content-grid mt-4">
            <section class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">5. Servis Bilgileri</div>
                        <div class="section-subtitle">Secilen araci kontrol edin, kilometre ve sikayet bilgisini tamamlayin.</div>
                    </div>
                </div>

                <div class="form-grid">
                    <div>
                        <label class="form-label">Secilen Plaka</label>
                        <input class="form-control" value="@(_selectedVehicle?.PlateOriginal ?? _plate ?? "-")" disabled />
                    </div>
                    <div>
                        <label class="form-label">Marka / Model</label>
                        <input class="form-control" value="@GetSelectedVehicleBrandModel()" disabled />
                    </div>
                    <div>
                        <label class="form-label">Yil</label>
                        <input class="form-control" value="@GetSelectedVehicleYearText()" disabled />
                    </div>
                    <div>
                        <label class="form-label">Sase No</label>
                        <input class="form-control" value="@GetSelectedVehicleChassisText()" disabled />
                    </div>
                    <div>
                        <label class="form-label">Motor No</label>
                        <input class="form-control" value="Arac kaydinda yok" disabled />
                    </div>
                    <div>
                        <label class="form-label">Arac KM *</label>
                        <InputNumber class="form-control" @bind-Value="_vehicleKm" />
                    </div>
                    <div>
                        <label class="form-label">Varsayilan Fiyat</label>
                        <input class="form-control" value="@GetSelectedServicePriceText()" disabled />
                    </div>
                    <div>
                        <label class="form-label">Tahmini Sure</label>
                        <input class="form-control" value="@GetSelectedServiceDurationText()" disabled />
                    </div>
                    <div class="full-span">
                        <label class="form-label">Sikayet / Aciklama</label>
                        <InputTextArea class="form-control" @bind-Value="_complaint" rows="4" />
                    </div>
                </div>
            </section>
        </div>

        <div class="content-grid mt-4">
            <section class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">6. Sarf / Kullanilan Urunler</div>
                        <div class="section-subtitle">Yeni girdiginiz marka ve urunler sonraki servis kayitlarinda onerilir.</div>
                    </div>
                </div>

                <div class="consumables-grid">
                    <div class="consumables-list d-flex flex-column gap-3 mb-4">
                        @if (_consumableEntries.Count == 0)
                        {
                            <div class="text-muted small">Henüz sarf malzeme eklenmedi.</div>
                        }
                        else
                        {
                            @foreach (var entry in _consumableEntries)
                            {
                                <div class="surface-card compact">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <div class="fw-semibold">@entry.Brand - @entry.ProductName</div>
                                            <div class="small text-muted">@entry.Category @(string.IsNullOrWhiteSpace(entry.SubCategory) ? "" : $" / {entry.SubCategory}")</div>
                                            @if (!string.IsNullOrWhiteSpace(entry.Specification) || !string.IsNullOrWhiteSpace(entry.Notes))
                                            {
                                                <div class="small text-muted mt-1">
                                                    @(string.IsNullOrWhiteSpace(entry.Specification) ? "" : $"Özellik: {entry.Specification}")
                                                    @(string.IsNullOrWhiteSpace(entry.Notes) ? "" : $" | Not: {entry.Notes}")
                                                </div>
                                            }
                                        </div>
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveConsumableEntry(entry)">Sil</button>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <div class="surface-card bg-light">
                        <h6 class="mb-3">Yeni Sarf / Ürün Ekle</h6>
                        <div class="form-grid">
                            <div>
                                <label class="form-label">Kategori</label>
                                <InputSelect class="form-select" @bind-Value="_currentConsumable.Category" @bind-Value:after="OnCategoryChangedAsync">
                                    <option value="">Seçiniz...</option>
                                    @foreach (var cat in _availableCategories)
                                    {
                                        <option value="@cat">@cat</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="full-span">
                                <label class="form-label">Ürün Ara / Yaz</label>
                                <div class="position-relative">
                                    <input class="form-control" 
                                             @bind="_currentConsumable.ProductName"
                                             @bind:event="oninput"
                                             @bind:after="OnConsumableProductChangedAsync"
                                             placeholder="Motul 7100, NGK CR9EIX vb. yazın..." 
                                             disabled="@string.IsNullOrWhiteSpace(_currentConsumable.Category)" />
                                    
                                    @if (_catalogSearchResults.Count > 0 && _isCatalogSearchOpen)
                                    {
                                        <div class="dropdown-menu show w-100 position-absolute" style="max-height: 200px; overflow-y: auto; z-index: 1000;">
                                            @foreach (var item in _catalogSearchResults)
                                            {
                                                <button type="button" class="dropdown-item" @onclick="() => SelectCatalogItem(item)">
                                                    <div class="fw-semibold">@item.Brand - @item.ProductName</div>
                                                    <div class="small text-muted">@item.SubCategory | @item.Specification</div>
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                            
                            <div>
                                <label class="form-label">Marka</label>
                                <InputText class="form-control" @bind-Value="_currentConsumable.Brand" />
                            </div>
                            <div>
                                <label class="form-label">Alt Kategori</label>
                                <InputText class="form-control" @bind-Value="_currentConsumable.SubCategory" />
                            </div>
                            <div>
                                <label class="form-label">Özellik / Spec</label>
                                <InputText class="form-control" @bind-Value="_currentConsumable.Specification" />
                            </div>
                            <div class="full-span">
                                <label class="form-label">Notlar</label>
                                <InputText class="form-control" @bind-Value="_currentConsumable.Notes" />
                            </div>
                            <div class="full-span d-flex justify-content-end mt-2">
                                <button type="button" class="app-btn-secondary" @onclick="AddConsumableEntry" disabled="@(string.IsNullOrWhiteSpace(_currentConsumable.Category) || string.IsNullOrWhiteSpace(_currentConsumable.Brand) || string.IsNullOrWhiteSpace(_currentConsumable.ProductName))">Listeye Ekle</button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <div class="action-bar sticky-mobile-action justify-content-end mt-4">
            <button type="button" class="app-btn-primary" @onclick="CreateServiceOrderAsync" disabled="@_isSaving">
                @(_isSaving ? "Kaydediliyor..." : "Servis Emrini Olustur")
            </button>
        </div>
    </section>
        </EditForm>
        </ChildContent>
    </ServiceOrderCreateErrorBoundary>
</div>

@code {
    [SupplyParameterFromQuery] public Guid? CustomerId { get; set; }
    [SupplyParameterFromQuery(Name = "plate")] public string? PlateQuery { get; set; }
    [SupplyParameterFromQuery(Name = "complaint")] public string? ComplaintQuery { get; set; }
    [SupplyParameterFromQuery(Name = "recommendations")] public string? RecommendationsQuery { get; set; }

    private readonly List<CustomerLookupResponse> _customerResults = [];
    private readonly List<VehicleLookupResponse> _customerVehicles = [];
    private readonly List<ServiceCatalogItem> _activeServices = [];
    private readonly CreateVehicleRequest _newVehicle = new() { Year = DateTime.Today.Year };
    private readonly List<string> _prefilledRecommendations = [];
    private readonly CancellationTokenSource _lifetimeCts = new();
    private readonly ServiceOrderCreateFormState _formState = new();

    private readonly List<ConsumableCatalogItemDto> _consumableEntries = [];
    private ConsumableCatalogItemDto _currentConsumable = new();
    private readonly List<string> _availableCategories = [
        "Motor Yağı", "Yağ Filtresi", "Hava Filtresi", "Buji", "Zincir", 
        "Ön/Arka Dişli", "Zincir + Dişli Seti", "Fren Balatası", "Fren Diski", 
        "Fren Hidroliği", "Soğutma Sıvısı", "Fork Yağı", "Akü", "Diğer"
    ];
    private List<ConsumableCatalogItemDto> _catalogSearchResults = [];
    private bool _isCatalogSearchOpen;
    private CancellationTokenSource? _searchCts;

    private CustomerLookupResponse? _selectedCustomer;
    private VehicleLookupResponse? _selectedVehicle;
    private ServiceCatalogItem? _selectedService;
    private string? _customerSearchText;
    private string? _customerSearchMessage;
    private string? _customerVehiclesMessage;
    private string? _vehicleLookupPlate;
    private string? _vehicleLookupMessage;
    private string? _plate;
    private string? _complaint;
    private string? _error;
    private string? _errorEndpoint;
    private string? _successMessage;
    private Guid? _createdServiceOrderId;
    private int _vehicleKm;
    private bool _isSaving;
    private bool _customerSearchLoading;
    private bool _vehicleLookupLoading;
    private bool _vehicleCreateLoading;
    private bool _customerVehiclesLoading;
    private bool _servicesLoading;
    private bool _isInitializing = true;
    private bool _isDisposed;
    private bool _initializationStarted;
    private bool _initializationCompleted;
    private EditContext _formEditContext = default!;

    protected override void OnInitialized()
    {
        Logger.LogInformation(
            EventIdStore.ServiceOrder.ServiceOrderCreateRenderStarted,
            "Service order create render started. CustomerId={CustomerId} Plate={Plate}",
            CustomerId,
            PlateQuery);

        _formEditContext = new EditContext(_formState);
        EnsureBoundStateInitialized();
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender || _initializationStarted)
        {
            return;
        }

        _initializationStarted = true;
        _ = InitializeAsync(_lifetimeCts.Token);
        Logger.LogInformation(EventIdStore.ServiceOrder.ServiceOrderCreateRenderCompleted, "Service order create first render completed.");
    }

    private async Task InitializeAsync(CancellationToken cancellationToken)
    {
        try
        {
            Logger.LogInformation(
                EventIdStore.ServiceOrder.ServiceOrderCreatePageOpened,
                "Service order create page opening started. CustomerId={CustomerId} Plate={Plate} HasComplaint={HasComplaint}",
                CustomerId,
                PlateQuery,
                !string.IsNullOrWhiteSpace(ComplaintQuery));

            if (!await AuthService.IsAuthenticatedAsync())
            {
                if (!IsInactive(cancellationToken))
                {
                    TryNavigateTo("/login");
                }

                return;
            }

            Logger.LogInformation(EventIdStore.ServiceOrder.ServiceOrderCreateInitializationStarted, "Service order create initialization started.");

            await LoadActiveServicesAsync(cancellationToken);

            if (IsInactive(cancellationToken))
            {
                return;
            }

            if (CustomerId.HasValue)
            {
                try
                {
                    var customer = await CustomersService.GetByIdAsync(CustomerId.Value, cancellationToken);
                    if (customer is not null && !IsInactive(cancellationToken))
                    {
                        await SelectCustomerAsync(customer, cancellationToken);
                    }
                }
                catch (OperationCanceledException) when (IsInactive(cancellationToken))
                {
                    return;
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Service order create customer prefill failed. CustomerId={CustomerId}", CustomerId);
                }
            }

            if (!string.IsNullOrWhiteSpace(PlateQuery) && !IsInactive(cancellationToken))
            {
                _vehicleLookupPlate = PlateQuery;
                _plate = PlateQuery;
                await LookupVehicleAsync(cancellationToken);
            }

            if (!string.IsNullOrWhiteSpace(ComplaintQuery) && !IsInactive(cancellationToken))
            {
                _complaint = ComplaintQuery;
            }

            if (!IsInactive(cancellationToken))
            {
                ApplyPrefilledRecommendations();
                _initializationCompleted = true;

                Logger.LogInformation(
                    EventIdStore.ServiceOrder.ServiceOrderCreateInitializationCompleted,
                    "Service order create lookups loaded. ActiveServiceCount={ActiveServiceCount} SelectedCustomerId={CustomerId} SelectedVehicleId={VehicleId} RecommendationCount={RecommendationCount}",
                    _activeServices.Count,
                    _selectedCustomer?.Id,
                    _selectedVehicle?.Id,
                    _prefilledRecommendations.Count);
            }
        }
        catch (OperationCanceledException) when (IsInactive(cancellationToken))
        {
            Logger.LogInformation(
                EventIdStore.ServiceOrder.ServiceOrderCreateDisposedBeforeLoadCompleted,
                "Service order create initialization stopped because component was disposed before load completed.");
        }
        catch (Exception ex)
        {
            Logger.LogError(
                EventIdStore.ServiceOrder.ServiceOrderCreateInitializationFailed,
                ex,
                "Service order create initialization failed. CustomerId={CustomerId} Plate={Plate}",
                CustomerId,
                PlateQuery);

            if (!IsInactive(cancellationToken))
            {
                _error = $"Sayfa yuklenirken hata olustu: {ex.Message}";
            }
        }
        finally
        {
            if (!IsInactive(cancellationToken))
            {
                _isInitializing = false;
                await SafeStateHasChangedAsync();
            }
        }
    }

    private void ApplyPrefilledRecommendations()
    {
        _prefilledRecommendations.Clear();

        if (string.IsNullOrWhiteSpace(RecommendationsQuery))
        {
            return;
        }

        var parsed = RecommendationsQuery
            .Split("||", StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(x => x.Split("##", StringSplitOptions.None))
            .Where(parts => parts.Length >= 3)
            .Select(parts => $"{parts[0]} [{parts[1]}] - {parts[2]}")
            .Distinct()
            .ToList();

        if (parsed.Count == 0)
        {
            return;
        }

        _prefilledRecommendations.AddRange(parsed);

        var recommendationBlock = "Servis Onerileri:" + Environment.NewLine +
                                  string.Join(Environment.NewLine, _prefilledRecommendations.Select(x => $"- {x}"));

        if (string.IsNullOrWhiteSpace(_complaint))
        {
            _complaint = recommendationBlock;
            return;
        }

        if (!_complaint.Contains("Servis Onerileri:", StringComparison.OrdinalIgnoreCase))
        {
            _complaint = _complaint.Trim() + Environment.NewLine + Environment.NewLine + recommendationBlock;
        }
    }

    private async Task LoadActiveServicesAsync(CancellationToken cancellationToken)
    {
        try
        {
            _servicesLoading = true;
            _activeServices.Clear();

            var services = await ServicesService.GetActiveServicesAsync(ct: cancellationToken);
            if (IsInactive(cancellationToken))
            {
                return;
            }

            _activeServices.AddRange(services);
        }
        catch (OperationCanceledException) when (IsInactive(cancellationToken))
        {
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Service order create service lookup failed.");
        }
        finally
        {
            if (!IsInactive(cancellationToken))
            {
                _servicesLoading = false;
            }
        }
    }

