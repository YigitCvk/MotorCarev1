@page "/reports"

<PageTitle>Raporlar</PageTitle>

<div class="page-shell">
    <section class="page-header">
        <div>
            <div class="eyebrow">Raporlama</div>
            <h1 class="page-title">Raporlar</h1>
            <p class="page-description">
                Gunluk ciro, servis performansi, randevu doluluk ve parca kullanim gorunumu icin tenant rapor merkezi.
            </p>
        </div>
        <div class="page-header-actions">
            <a class="app-btn-secondary" href="/settings">Ayarlara Don</a>
            <button type="button" class="app-btn-primary">Rapor Olustur</button>
        </div>
    </section>

    <section class="admin-grid">
        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Operasyon Raporlari</div>
                    <div class="section-subtitle">Servis adetleri, durum dagilimi ve teslim sureleri</div>
                </div>
                <span class="status-badge badge-open">Aktif</span>
            </div>
            <p class="admin-card-copy">Dashboard verisinin daha detayli operasyonal rapor kurgusuna acilan tenant modulu.</p>
            <div class="admin-card-actions">
                <button type="button" class="app-btn-primary">Yonet</button>
            </div>
        </article>

        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Musteri ve Randevu Analizi</div>
                    <div class="section-subtitle">Tekrar gelen musteriler ve randevu tipi dagilimi</div>
                </div>
                <span class="status-badge badge-progress">Planlandi</span>
            </div>
            <p class="admin-card-copy">Randevu performansi, no-show oranlari ve sezonluk musteri akislarini gormek icin placeholder.</p>
            <div class="admin-card-actions">
                <button type="button" class="app-btn-secondary">Yakinda</button>
            </div>
        </article>

        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Finansal Ozetler</div>
                    <div class="section-subtitle">Tahsilat, kalan bakiye ve donemsel karsilastirma</div>
                </div>
                <span class="status-badge status-info">Yakinda</span>
            </div>
            <p class="admin-card-copy">Finans / Kasa modulu ile bagli calisacak tenant bazli raporlar icin hazir alan.</p>
            <div class="admin-card-actions">
                <button type="button" class="app-btn-secondary">Yakinda</button>
            </div>
        </article>
    </section>
</div>
