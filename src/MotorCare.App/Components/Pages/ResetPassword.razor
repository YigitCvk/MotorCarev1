@page "/reset-password"
@layout Layout.PublicLayout
@using Microsoft.AspNetCore.WebUtilities
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Sifre Sifirla - BakimSuite</PageTitle>

<div class="auth-shell auth-shell-login">
    <div class="auth-panel auth-panel-brand">
        <div class="eyebrow" style="color:#fdba74">Sifre yenileme</div>
        <h1 class="auth-title">Yeni sifrenizi belirleyin</h1>
        <p class="auth-copy">Baglanti gecerliyse sifreniz guncellenir ve giris ekranina donebilirsiniz.</p>
    </div>

    <div class="auth-panel auth-panel-form auth-panel-narrow">
        <div class="section-header mb-2">
            <div>
                <div class="section-title">Sifre Sifirla</div>
                <div class="section-subtitle">Yeni sifreniz en az 8 karakter olmali.</div>
            </div>
        </div>

        @if (_linkInvalid)
        {
            <div class="alert alert-danger">Gecersiz veya eksik sifre sifirlama baglantisi.</div>
            <div class="auth-actions">
                <a class="auth-link" href="/forgot-password">Yeni baglanti iste</a>
            </div>
        }
        else
        {
            <EditForm Model="_model" OnValidSubmit="SubmitAsync">
                <DataAnnotationsValidator />

                <div class="form-grid auth-form-grid">
                    <div class="full-span">
                        <label class="form-label">E-posta</label>
                        <InputText class="form-control" @bind-Value="_model.Email" autocomplete="email" />
                    </div>

                    <div class="full-span">
                        <label class="form-label">Yeni Sifre</label>
                        <InputText class="form-control" type="password" @bind-Value="_model.NewPassword" autocomplete="new-password" />
                    </div>

                    <div class="full-span">
                        <label class="form-label">Yeni Sifre Tekrar</label>
                        <InputText class="form-control" type="password" @bind-Value="_model.ConfirmPassword" autocomplete="new-password" />
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <div class="alert alert-danger mt-3">@_error</div>
                }

                <div class="auth-actions">
                    <button type="submit" class="btn btn-primary btn-lg" disabled="@_isSubmitting">
                        @(_isSubmitting ? "Guncelleniyor..." : "Sifreyi Guncelle")
                    </button>
                    <a class="auth-link" href="/login">Giris ekranina don</a>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    private readonly ResetPasswordRequest _model = new();
    private bool _isSubmitting;
    private bool _linkInvalid;
    private string? _error;

    [SupplyParameterFromQuery] public string? Email { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }

    protected override void OnParametersSet()
    {
        _model.Email = Email ?? string.Empty;
        _model.Token = Token ?? string.Empty;
        _linkInvalid = string.IsNullOrWhiteSpace(_model.Email) || string.IsNullOrWhiteSpace(_model.Token);
    }

    private async Task SubmitAsync()
    {
        _isSubmitting = true;
        _error = null;

        try
        {
            var response = await AuthService.ResetPasswordAsync(_model);
            var uri = QueryHelpers.AddQueryString("/login", "message", response?.Message ?? "Sifreniz guncellendi. Giris yapabilirsiniz.");
            NavigationManager.NavigateTo(uri);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
