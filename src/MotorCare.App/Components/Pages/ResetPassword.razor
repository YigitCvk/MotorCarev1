@page "/reset-password"
@layout Layout.PublicLayout
@using Microsoft.AspNetCore.WebUtilities
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Şifre Sıfırla - GarajPass</PageTitle>

<div class="auth-shell auth-shell-login">
    <div class="auth-panel auth-panel-brand">
        <div class="eyebrow" style="color:#fdba74">Şifre yenileme</div>
        <h1 class="auth-title">Yeni şifre oluştur</h1>
        <p class="auth-copy">E-posta adresine gönderilen 6 haneli kodu girerek şifreni yenile.</p>
    </div>

    <div class="auth-panel auth-panel-form auth-panel-narrow">
        <div class="section-header mb-2">
            <div>
                <div class="section-title">Şifre Sıfırla</div>
                <div class="section-subtitle">Yeni şifreniz en az 8 karakter olmalı.</div>
            </div>
        </div>

            <EditForm Model="_model" OnValidSubmit="SubmitAsync">
                <DataAnnotationsValidator />

                <div class="form-grid auth-form-grid">
                    <div class="full-span">
                        <label class="form-label">E-posta</label>
                        <InputText class="form-control" @bind-Value="_model.Email" autocomplete="email" />
                    </div>

                    <div class="full-span">
                        <label class="form-label">6 haneli doğrulama kodu</label>
                        <InputText class="form-control" @bind-Value="_model.Code" maxlength="6" inputmode="numeric" autocomplete="one-time-code" />
                    </div>

                    <div class="full-span">
                        <label class="form-label">Yeni Şifre</label>
                        <InputText class="form-control" type="password" @bind-Value="_model.NewPassword" autocomplete="new-password" />
                    </div>

                    <div class="full-span">
                        <label class="form-label">Yeni Şifre Tekrar</label>
                        <InputText class="form-control" type="password" @bind-Value="_model.ConfirmPassword" autocomplete="new-password" />
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <div class="alert alert-danger mt-3">@_error</div>
                }

                <div class="auth-actions">
                    <button type="submit" class="btn btn-primary btn-lg" disabled="@_isSubmitting">
                        @(_isSubmitting ? "Güncelleniyor..." : "Şifreyi Güncelle")
                    </button>
                    <a class="auth-link" href="/login">Giriş ekranına dön</a>
                    <a class="auth-link" href="/forgot-password">Yeni kod iste</a>
                </div>
            </EditForm>
    </div>
</div>

@code {
    private readonly ResetPasswordRequest _model = new();
    private bool _isSubmitting;
    private string? _error;

    [SupplyParameterFromQuery] public string? Email { get; set; }

    protected override void OnParametersSet()
    {
        _model.Email = Email ?? string.Empty;
    }

    private async Task SubmitAsync()
    {
        _isSubmitting = true;
        _error = null;

        try
        {
            if (_model.Code.Length != 6 || !_model.Code.All(char.IsDigit))
            {
                _error = "Kod 6 haneli olmalı.";
                return;
            }

            if (_model.NewPassword != _model.ConfirmPassword)
            {
                _error = "Şifreler eşleşmeli.";
                return;
            }

            var response = await AuthService.ResetPasswordAsync(_model);
            var uri = QueryHelpers.AddQueryString("/login", "message", response?.Message ?? "Şifreniz başarıyla güncellendi. Giriş yapabilirsiniz.");
            NavigationManager.NavigateTo(uri);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
