@page "/public/inspection-report/{Slug}"
@layout Layout.PublicLayout
@using System.Net
@using MotorCare.App.Models.PublicRecords
@using PublicInspectionReportModel = MotorCare.App.Models.PublicRecords.PublicInspectionReport
@inject PublicRecordsService PublicRecordsService

<PageTitle>GarajPass Dijital Ekspertiz Kaydı</PageTitle>
<PublicRecordSeoHead Title="GarajPass Dijital Ekspertiz Kaydı" />

<main class="public-record-page public-record-page--inspection">
    <section class="public-record-shell">
        <header class="public-record-header">
            <a class="public-record-brand" href="/">
                <span>GP</span>
                <strong>GarajPass</strong>
            </a>
            <div class="public-record-badge">Dijital kayıt doğrulaması</div>
        </header>

        @if (_loading)
        {
            <section class="public-record-state">
                <strong>Rapor kontrol ediliyor</strong>
                <p>Lütfen bekleyin.</p>
            </section>
        }
        else if (_report is null)
        {
            <section class="public-record-state public-record-state--error">
                <strong>Rapor bulunamadı</strong>
                <p>Bu dijital ekspertiz kaydı mevcut değil veya public erişim aktif değil.</p>
            </section>
        }
        else
        {
            <article class="public-record-card public-record-document">
                <div class="public-record-verify">
                    <span class="public-record-check">OK</span>
                    <div>
                        <p>Kayıt doğrulandı</p>
                        <h1>GarajPass dijital ekspertiz kaydı</h1>
                    </div>
                </div>

                <dl class="public-record-details">
                    <div>
                        <dt>Ekspertiz no</dt>
                        <dd>@_report.InspectionNo</dd>
                    </div>
                    <div>
                        <dt>Ekspertiz tarihi</dt>
                        <dd>@FormatDateTime(_report.Date)</dd>
                    </div>
                    <div>
                        <dt>Araç</dt>
                        <dd>@VehicleText</dd>
                    </div>
                    <div>
                        <dt>Plaka</dt>
                        <dd>@DisplayText(_report.VehiclePlate)</dd>
                    </div>
                    @if (_report.VehicleYear.HasValue)
                    {
                        <div>
                            <dt>Model yılı</dt>
                            <dd>@_report.VehicleYear</dd>
                        </div>
                    }
                    @if (_report.VehicleMileage.HasValue)
                    {
                        <div>
                            <dt>Kilometre</dt>
                            <dd>@_report.VehicleMileage.Value.ToString("N0") km</dd>
                        </div>
                    }
                    <div>
                        <dt>Paket</dt>
                        <dd>@DisplayText(_report.PackageType)</dd>
                    </div>
                    <div>
                        <dt>Durum</dt>
                        <dd>@DisplayText(_report.Status)</dd>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_report.BusinessName))
                    {
                        <div>
                            <dt>İşletme</dt>
                            <dd>@_report.BusinessName</dd>
                        </div>
                    }
                </dl>

                <div class="public-record-split-grid">
                    <section class="public-record-section">
                        <h2>Sonuç özeti</h2>
                        <p>@DisplayText(_report.ResultSummary)</p>
                    </section>

                    <section class="public-record-section public-record-stat-section">
                        <h2>Kritik bulgular</h2>
                        <div class="public-record-mini-stat">
                            <strong>@_report.CriticalFindingCount</strong>
                            <span>Hasarlı veya değişen kalem</span>
                        </div>
                    </section>
                </div>

                @if (HasNotes)
                {
                    <div class="public-record-notes-grid">
                        @if (!string.IsNullOrWhiteSpace(_report.GeneralNotes))
                        {
                            <section class="public-record-section">
                                <h2>Genel açıklama</h2>
                                <p>@_report.GeneralNotes</p>
                            </section>
                        }
                        @if (!string.IsNullOrWhiteSpace(_report.TestRideNotes))
                        {
                            <section class="public-record-section">
                                <h2>Test sürüşü notları</h2>
                                <p>@_report.TestRideNotes</p>
                            </section>
                        }
                        @if (!string.IsNullOrWhiteSpace(_report.CosmeticNotes))
                        {
                            <section class="public-record-section">
                                <h2>Kozmetik notlar</h2>
                                <p>@_report.CosmeticNotes</p>
                            </section>
                        }
                    </div>
                }

                @if (ItemGroups.Count > 0)
                {
                    <section class="public-record-section">
                        <h2>Kontrol kalemleri</h2>
                        <div class="public-record-item-groups">
                            @foreach (var group in ItemGroups)
                            {
                                <section class="public-record-item-group">
                                    <h3>@group.Key</h3>
                                    <div class="public-record-line-list">
                                        @foreach (var item in group)
                                        {
                                            <article class="public-record-line-item public-record-line-item--inspection">
                                                <div>
                                                    <strong>@item.Name</strong>
                                                    @if (!string.IsNullOrWhiteSpace(item.Notes))
                                                    {
                                                        <span>@item.Notes</span>
                                                    }
                                                </div>
                                                <em>@DisplayText(item.Result)</em>
                                            </article>
                                        }
                                    </div>
                                </section>
                            }
                        </div>
                    </section>
                }

                <footer class="public-record-footer">
                    <strong>Bu rapor GarajPass üzerinden doğrulanmıştır.</strong>
                    <span>@VerificationText</span>
                </footer>
            </article>
        }
    </section>
</main>

@code {
    [Parameter] public string? Slug { get; set; }

    private PublicInspectionReportModel? _report;
    private bool _loading = true;

    private bool HasNotes => _report is not null
        && (!string.IsNullOrWhiteSpace(_report.GeneralNotes)
            || !string.IsNullOrWhiteSpace(_report.TestRideNotes)
            || !string.IsNullOrWhiteSpace(_report.CosmeticNotes));

    private IReadOnlyList<IGrouping<string, PublicInspectionReportItem>> ItemGroups
        => (_report?.Items ?? [])
            .OrderBy(x => x.Category)
            .ThenBy(x => x.SortOrder)
            .GroupBy(x => DisplayText(x.Category))
            .ToList();

    private string VehicleText
    {
        get
        {
            var parts = new[] { _report?.VehicleBrand, _report?.VehicleModel }
                .Where(x => !string.IsNullOrWhiteSpace(x));
            var text = string.Join(" ", parts);
            return DisplayText(text);
        }
    }

    private string VerificationText => string.IsNullOrWhiteSpace(_report?.VerificationText)
        ? "Dijital kayıt public bağlantı üzerinden okunmuştur."
        : _report.VerificationText;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Slug))
        {
            _loading = false;
            return;
        }

        try
        {
            _report = await PublicRecordsService.GetInspectionReportAsync(Slug);
        }
        catch (ApiException ex) when (ex.StatusCode == HttpStatusCode.NotFound)
        {
            _report = null;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string DisplayText(string? value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatDateTime(DateTimeOffset? value)
        => value?.LocalDateTime.ToString("dd.MM.yyyy HH:mm") ?? "-";
}
