@page "/settings/business"

<PageTitle>İşletme Bilgileri</PageTitle>

<div class="page-shell">
    <section class="page-header">
        <div>
            <div class="eyebrow">Ayarlar</div>
            <h1 class="page-title">İşletme Bilgileri</h1>
            <p class="page-description">BakımSuite içindeki işletme profili, iletişim ve teslim bilgileri için başlangıç alanı.</p>
        </div>
        <div class="page-header-actions">
            <a class="app-btn-secondary" href="/settings">Ayarlara Dön</a>
            <button type="button" class="app-btn-primary">Düzenle</button>
        </div>
    </section>

    <section class="admin-grid">
        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Kurumsal Profil</div>
                    <div class="section-subtitle">İşletme adı, unvan ve görünür marka bilgileri</div>
                </div>
                <span class="status-badge badge-open">Aktif</span>
            </div>
            <p class="admin-card-copy">İşletme adı, logo, kısa açıklama ve servis kabul metinlerini bu alandan yöneteceksiniz.</p>
            <div class="admin-card-actions">
                <button type="button" class="app-btn-primary">Yönet</button>
            </div>
        </article>

        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">İletişim ve Adres</div>
                    <div class="section-subtitle">Telefon, e-posta, konum ve çalışma notları</div>
                </div>
                <span class="status-badge badge-open">Aktif</span>
            </div>
            <p class="admin-card-copy">Müşteriye görünen telefon, adres ve navigasyon açıklamalarını tenant bazında tutun.</p>
            <div class="admin-card-actions">
                <button type="button" class="app-btn-secondary">Düzenle</button>
            </div>
        </article>

        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Vergi ve Fatura</div>
                    <div class="section-subtitle">Resmî bilgiler ve belge üst bilgileri</div>
                </div>
                <span class="status-badge badge-progress">Planlandı</span>
            </div>
            <p class="admin-card-copy">Vergi dairesi, vergi numarası ve fatura çıktıları için ileride kullanılacak alan.</p>
            <div class="admin-card-actions">
                <button type="button" class="app-btn-secondary">Yakında</button>
            </div>
        </article>
    </section>
</div>
