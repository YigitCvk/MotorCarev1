@page "/service-orders/{Id:guid}/print"
@layout MotorCare.App.Components.Layout.PrintLayout
@using System.Net
@using ServiceOrderPrintModel = MotorCare.App.Models.ServiceOrders.ServiceOrderDetail
@inject AuthService AuthService
@inject ServiceOrdersService ServiceOrdersService
@inject NavigationManager NavigationManager

<PageTitle>@(_order?.OrderNo ?? "Servis Raporu")</PageTitle>

<div class="print-page-shell">
    @if (_loading)
    {
        <section class="loading-state">
            <strong>Servis raporu hazırlanıyor</strong>
            <p>Lütfen bekleyin.</p>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <section class="error-state">
            <strong>Servis raporu alınamadı</strong>
            <p>@_error</p>
        </section>
    }
    else if (_order is not null)
    {
        <div class="print-toolbar no-print">
            <a class="app-btn-secondary" href="@($"/service-orders/{Id}")">← Detaya Dön</a>
            <button type="button" class="app-btn-primary" onclick="window.print()">Yazdır / PDF Al</button>
        </div>

        <article class="print-report">

            <header class="print-header">
                <div>
                    <div class="print-brand">GarajPass</div>
                    <h1>Servis Emri Raporu</h1>
                    <p>@(_currentUser?.TenantIdentifier ?? "İşletme") · @_order.OpenedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</p>
                </div>
                <div class="print-header-meta">
                    <strong class="print-doc-no">@_order.OrderNo</strong>
                    <span class="status-badge @GetStatusBadgeClass(_order.Status)">@GetStatusLabel(_order.Status)</span>
                </div>
            </header>

            <div class="print-grid print-grid--two">
                <section class="print-card">
                    <h2>Müşteri ve Araç Bilgileri</h2>
                    <dl class="detail-list">
                        <dt>Müşteri</dt>
                        <dd>@(_order.CustomerName ?? "—")</dd>
                        <dt>Plaka</dt>
                        <dd>@(_order.VehiclePlate ?? "—")</dd>
                        <dt>Araç</dt>
                        <dd>@(_order.VehicleDisplay ?? "—")</dd>
                        <dt>Araç KM</dt>
                        <dd>@_order.VehicleKm.ToString("N0") km</dd>
                        <dt>Açılış Tarihi</dt>
                        <dd>@_order.OpenedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</dd>
                        <dt>Kapanış Tarihi</dt>
                        <dd>@(_order.ClosedAt?.LocalDateTime.ToString("dd.MM.yyyy HH:mm") ?? "—")</dd>
                    </dl>
                </section>

                <section class="print-card">
                    <h2>Finansal Özet</h2>
                    <div class="print-totals-table">
                        <div class="print-totals-row">
                            <span>İşçilik</span>
                            <span>@_order.LaborTotal.ToString("N2") ₺</span>
                        </div>
                        <div class="print-totals-row">
                            <span>Parça</span>
                            <span>@_order.PartsTotal.ToString("N2") ₺</span>
                        </div>
                        @if (_order.DiscountTotal > 0)
                        {
                            <div class="print-totals-row print-totals-row--discount">
                                <span>İndirim</span>
                                <span>-@_order.DiscountTotal.ToString("N2") ₺</span>
                            </div>
                        }
                        <div class="print-totals-row print-totals-row--total">
                            <span>Genel Toplam</span>
                            <span>@_order.GrandTotal.ToString("N2") ₺</span>
                        </div>
                        <div class="print-totals-row">
                            <span>Tahsil Edilen</span>
                            <span>@_order.PaidTotal.ToString("N2") ₺</span>
                        </div>
                        <div class="print-totals-row @(_order.RemainingTotal > 0 ? "print-totals-row--remaining" : "")">
                            <span>Kalan Bakiye</span>
                            <span>@Math.Max(0, _order.RemainingTotal).ToString("N2") ₺</span>
                        </div>
                    </div>
                </section>
            </div>

            <section class="print-card">
                <h2>Şikayet / Müşteri Talebi</h2>
                <p>@(string.IsNullOrWhiteSpace(_order.Complaint) ? "Şikayet girilmemiş." : _order.Complaint)</p>
                @if (!string.IsNullOrWhiteSpace(_order.WorkDescription))
                {
                    <h2 class="print-sub-title">Yapılan İş / Açıklama</h2>
                    <p>@_order.WorkDescription</p>
                }
            </section>

            <div class="print-grid print-grid--two">
                <section class="print-card">
                    <h2>İşçilik / Operasyonlar</h2>
                    @if (_order.Operations.Count == 0)
                    {
                        <p class="print-empty-note">Operasyon kaydı bulunmamaktadır.</p>
                    }
                    else
                    {
                        <div class="print-table">
                            <div class="print-table-row print-table-head">
                                <span>Açıklama</span>
                                <span>Tutar</span>
                            </div>
                            @foreach (var op in _order.Operations)
                            {
                                <div class="print-table-row">
                                    <span>@op.Description</span>
                                    <span>@op.Price.ToString("N2") ₺</span>
                                </div>
                            }
                            <div class="print-table-row print-table-subtotal">
                                <span>Toplam</span>
                                <span>@_order.LaborTotal.ToString("N2") ₺</span>
                            </div>
                        </div>
                    }
                </section>

                <section class="print-card">
                    <h2>Kullanılan Parçalar</h2>
                    @if (_order.Parts.Count == 0)
                    {
                        <p class="print-empty-note">Parça kaydı bulunmamaktadır.</p>
                    }
                    else
                    {
                        <div class="print-table">
                            <div class="print-table-row print-table-head print-table-parts-head">
                                <span>Parça</span>
                                <span>Adet</span>
                                <span>Birim</span>
                                <span>Toplam</span>
                            </div>
                            @foreach (var part in _order.Parts)
                            {
                                <div class="print-table-row print-table-parts-row">
                                    <span>@part.PartName@(string.IsNullOrWhiteSpace(part.PartNumber) ? "" : $" ({part.PartNumber})")</span>
                                    <span>@part.Quantity</span>
                                    <span>@part.UnitPrice.ToString("N2") ₺</span>
                                    <span>@part.TotalPrice.ToString("N2") ₺</span>
                                </div>
                            }
                            <div class="print-table-row print-table-subtotal">
                                <span>Toplam</span>
                                <span>@_order.PartsTotal.ToString("N2") ₺</span>
                            </div>
                        </div>
                    }
                </section>
            </div>

            <section class="print-card">
                <h2>Tahsilatlar</h2>
                @if (_order.Payments.Count == 0)
                {
                    <p class="print-empty-note">Ödeme kaydı bulunmamaktadır.</p>
                }
                else
                {
                    <div class="print-table">
                        <div class="print-table-row print-table-head">
                            <span>Tarih</span>
                            <span>Yöntem</span>
                            <span>Tutar</span>
                        </div>
                        @foreach (var payment in _order.Payments)
                        {
                            <div class="print-table-row">
                                <span>@payment.PaymentDate.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</span>
                                <span>@GetPaymentLabel(payment.Method)</span>
                                <span>@payment.Amount.ToString("N2") ₺</span>
                            </div>
                        }
                    </div>
                }
            </section>

            @if (!string.IsNullOrWhiteSpace(_order.InternalNote))
            {
                <section class="print-card">
                    <h2>Notlar</h2>
                    <p>@_order.InternalNote</p>
                </section>
            }

            <div class="print-signature-row">
                <div class="print-signature-box">
                    <div class="print-signature-label">Teslim Eden (Yetkili Adı / İmzası)</div>
                    <div class="print-signature-line"></div>
                    <div class="print-signature-date">Tarih: _______ / _______ / ___________</div>
                </div>
                <div class="print-signature-box">
                    <div class="print-signature-label">Teslim Alan (Müşteri Adı / İmzası)</div>
                    <div class="print-signature-line"></div>
                    <div class="print-signature-date">Tarih: _______ / _______ / ___________</div>
                </div>
            </div>

            <footer class="print-footer">
                <span>GarajPass · Motosiklet Servis Yönetim Sistemi</span>
                <span>@_order.OrderNo · @_order.OpenedAt.LocalDateTime.ToString("dd.MM.yyyy")</span>
            </footer>

        </article>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private ServiceOrderPrintModel? _order;
    private CurrentUserResponse? _currentUser;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!await AuthService.IsAuthenticatedAsync())
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        _currentUser = await AuthService.GetCurrentUserAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _loading = true;
            _error = null;
            await InvokeAsync(StateHasChanged);
            _order = await ServiceOrdersService.GetServiceOrderByIdAsync(Id);
            if (_order is null)
                _error = "Servis raporu bulunamadı.";
        }
        catch (ApiException ex) when (ex.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string GetStatusLabel(string status) => status switch
    {
        "Open" => "Açık",
        "InProgress" => "İşlemde",
        "WaitingForParts" => "Parça Bekliyor",
        "Completed" => "Tamamlandı",
        "Delivered" => "Teslim Edildi",
        "Cancelled" => "İptal",
        _ => status
    };

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "Open" => "badge-progress",
        "InProgress" => "badge-progress",
        "WaitingForParts" => "badge-muted",
        "Completed" => "badge-completed",
        "Delivered" => "badge-completed",
        "Cancelled" => "badge-cancelled",
        _ => "badge-muted"
    };

    private static string GetPaymentLabel(string method) => method switch
    {
        "Cash" => "Nakit",
        "CreditCard" => "Kredi Kartı",
        "BankTransfer" => "Havale / EFT",
        _ => method
    };
}
