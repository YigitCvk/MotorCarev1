@page "/login"
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Giriş Yap — MotorCare</PageTitle>

<div class="auth-shell auth-shell-login">
    <div class="auth-panel auth-panel-brand">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem">
            <div style="width:2.8rem;height:2.8rem;border-radius:14px;background:linear-gradient(135deg,#4f46e5,#6366f1);display:grid;place-items:center;color:#fff;font-weight:800;font-size:0.95rem;letter-spacing:-0.02em">MC</div>
            <div style="color:#f1f5f9;font-weight:700;font-size:1rem">MotorCare</div>
        </div>
        <div class="eyebrow" style="color:#a5b4fc">Servis yönetimi</div>
        <h1 class="auth-title">Günün operasyonunu tek panelden başlatın</h1>
        <p class="auth-copy">
            Servis kabul, tahsilat ve günlük özet ekranlarına hızlı erişim için giriş yapın.
            MotorCare, masaüstü yazılımlardaki dağınık menü yapısını modern web deneyimine taşır.
        </p>

        <div class="auth-feature-list">
            <div class="auth-feature-item">⚙ Servis işlemleri ve araç kabul akışı</div>
            <div class="auth-feature-item">◎ Müşteri ve araç kayıt yönetimi</div>
            <div class="auth-feature-item">◇ Tahsilat ve günlük özet görünümü</div>
        </div>
    </div>

    <div class="auth-panel auth-panel-form auth-panel-narrow">
        <div class="section-header mb-2">
            <div>
                <div class="section-title">Giriş Yap</div>
                <div class="section-subtitle">Tenant, kullanıcı ve şifre ile devam edin.</div>
            </div>
        </div>

        <EditForm Model="_model" OnValidSubmit="LoginAsync">
            <DataAnnotationsValidator />

            <div class="form-grid auth-form-grid">
                <div class="full-span">
                    <label class="form-label">Tenant Identifier</label>
                    <InputText class="form-control" @bind-Value="_model.TenantIdentifier" placeholder="asya-motor" autocomplete="organization" />
                    <ValidationMessage For="@(() => _model.TenantIdentifier)" />
                </div>

                <div class="full-span">
                    <label class="form-label">E-posta</label>
                    <InputText class="form-control" @bind-Value="_model.Email" placeholder="owner@servisiniz.com" autocomplete="email" />
                    <ValidationMessage For="@(() => _model.Email)" />
                </div>

                <div class="full-span">
                    <label class="form-label">Şifre</label>
                    <InputText class="form-control" type="password" @bind-Value="_model.Password" placeholder="••••••••" autocomplete="current-password" />
                    <ValidationMessage For="@(() => _model.Password)" />
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="alert alert-danger mt-3">@_error</div>
            }

            <div class="auth-actions">
                <button type="submit" class="btn btn-primary btn-lg" disabled="@_isSubmitting">
                    @(_isSubmitting ? "Giriş yapılıyor..." : "Giriş Yap")
                </button>
                <a class="auth-link" href="/register">İlk servisini oluşturmak için kayıt ol →</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private readonly LoginRequest _model = new();
    private bool _isSubmitting;
    private string? _error;

    private async Task LoginAsync()
    {
        _isSubmitting = true;
        _error = null;

        try
        {
            await AuthService.LoginAsync(_model);
            NavigationManager.NavigateTo("/dashboard");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
