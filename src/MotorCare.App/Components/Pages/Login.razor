@page "/login"
@layout Layout.PublicLayout
@using Microsoft.AspNetCore.WebUtilities
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Giriş Yap — GarajPass</PageTitle>

<div class="auth-shell auth-shell-login">
    <div class="auth-panel auth-panel-brand">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem">
            <div style="width:2.8rem;height:2.8rem;border-radius:14px;background:linear-gradient(145deg,#f59e0b,#facc15);display:grid;place-items:center;color:#101828;font-weight:900;font-size:0.92rem;box-shadow:0 8px 20px rgba(245,158,11,0.28)">GP</div>
            <div style="color:#f1f5f9;font-weight:800;font-size:1rem;letter-spacing:-0.02em">GarajPass</div>
        </div>
        <div class="eyebrow" style="color:#fb923c">Servis Yönetimi</div>
        <h1 class="auth-title">GarajPass'e giriş yap</h1>
        <p class="auth-copy">
            Servis operasyonlarını, araç kayıtlarını ve ekspertiz süreçlerini
            tek panelden yönetin.
        </p>

        <div class="auth-feature-list">
            <div class="auth-feature-item">Hızlı servis kabul ve iş emri akışı</div>
            <div class="auth-feature-item">Müşteri, araç ve randevu takibi</div>
            <div class="auth-feature-item">Tahsilat ve günlük operasyon özeti</div>
        </div>
    </div>

    <div class="auth-panel auth-panel-form auth-panel-narrow">
        <div class="section-header mb-2">
            <div>
                <div class="section-title">Giriş Yap</div>
                <div class="section-subtitle">İşletme kodu, e-posta ve şifre ile devam edin.</div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_info))
        {
            <div class="alert alert-success mt-3">@_info</div>
        }

        <EditForm Model="_model" OnValidSubmit="LoginAsync">
            <DataAnnotationsValidator />

            <div class="form-grid auth-form-grid">
                <div class="full-span">
                    <label class="form-label">İşletme Kodu</label>
                    <InputText class="form-control" @bind-Value="_model.TenantIdentifier" placeholder="asya-motor" autocomplete="organization" />
                </div>

                <div class="full-span">
                    <label class="form-label">E-posta</label>
                    <InputText class="form-control" @bind-Value="_model.Email" placeholder="owner@servisiniz.com" autocomplete="email" />
                </div>

                <div class="full-span">
                    <label class="form-label">Şifre</label>
                    <InputText class="form-control" type="password" @bind-Value="_model.Password" placeholder="••••••••" autocomplete="current-password" />
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="alert alert-danger mt-3">@_error</div>
            }

            @if (_canResendVerification)
            {
                <div class="alert alert-warning mt-3">
                    <div>Doğrulama e-postasını yeniden gönderebilirsiniz.</div>
                    <button type="button" class="app-btn-secondary mt-2" style="width:100%" @onclick="ResendVerificationAsync" disabled="@_isSubmitting">
                        Doğrulama e-postasını tekrar gönder
                    </button>
                </div>
            }

            <div class="auth-actions">
                <button type="submit" class="app-btn-primary" style="width:100%;min-height:3rem" disabled="@_isSubmitting">
                    @(_isSubmitting ? "Giriş yapılıyor..." : "Giriş Yap")
                </button>
                <a class="auth-link" href="/forgot-password">Şifremi unuttum</a>
                <a class="auth-link" href="/register">GarajPass işletme hesabı oluştur →</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private readonly LoginRequest _model = new();
    private bool _isSubmitting;
    private bool _canResendVerification;
    private string? _error;
    private string? _info;

    [SupplyParameterFromQuery(Name = "tenant")] public string? TenantQuery { get; set; }
    [SupplyParameterFromQuery(Name = "email")] public string? EmailQuery { get; set; }
    [SupplyParameterFromQuery(Name = "message")] public string? MessageQuery { get; set; }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(TenantQuery))
        {
            _model.TenantIdentifier = TenantQuery;
        }

        if (!string.IsNullOrWhiteSpace(EmailQuery))
        {
            _model.Email = EmailQuery;
        }

        _info = MessageQuery;
    }

    private async Task LoginAsync()
    {
        _isSubmitting = true;
        _error = null;
        _canResendVerification = false;

        try
        {
            var response = await AuthService.LoginAsync(_model);
            if (response?.RequiresTwoFactor == true && !string.IsNullOrWhiteSpace(response.TwoFactorToken))
            {
                var uri = QueryHelpers.AddQueryString("/two-factor", new Dictionary<string, string?>
                {
                    ["ticket"] = response.TwoFactorToken,
                    ["tenant"] = response.TenantIdentifier,
                    ["email"] = response.Email
                });

                NavigationManager.NavigateTo(uri);
                return;
            }

            NavigationManager.NavigateTo("/dashboard");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _canResendVerification =
                !string.IsNullOrWhiteSpace(_model.TenantIdentifier) &&
                !string.IsNullOrWhiteSpace(_model.Email) &&
                ex.Message.Contains("doğrula", StringComparison.OrdinalIgnoreCase);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task ResendVerificationAsync()
    {
        _isSubmitting = true;
        _error = null;
        _info = null;

        try
        {
            var response = await AuthService.ResendEmailVerificationAsync(new ResendEmailVerificationRequest
            {
                TenantIdentifier = _model.TenantIdentifier,
                Email = _model.Email
            });

            _info = response?.Message ?? "Doğrulama e-postası gönderildi.";
            _canResendVerification = false;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
