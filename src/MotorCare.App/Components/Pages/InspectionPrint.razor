@page "/inspections/{Id:guid}/print"
@layout MotorCare.App.Components.Layout.PrintLayout
@using System.Net
@using MotorCare.App.Models.Auth
@using MotorCare.App.Models.Inspections
@inject AuthService AuthService
@inject InspectionsService InspectionsService
@inject NavigationManager NavigationManager

<PageTitle>@(_inspection?.InspectionNo ?? "Ekspertiz Raporu")</PageTitle>

<div class="print-page-shell">
    @if (_loading)
    {
        <section class="loading-state">
            <strong>Ekspertiz raporu hazırlanıyor</strong>
            <p>Lütfen bekleyin.</p>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <section class="error-state">
            <strong>Ekspertiz raporu alınamadı</strong>
            <p>@_error</p>
        </section>
    }
    else if (_inspection is not null)
    {
        <div class="print-toolbar no-print">
            <a class="app-btn-secondary" href="@($"/inspections/{Id}")">Detaya Dön</a>
            <button type="button" class="app-btn-primary" onclick="window.print()">Yazdır / PDF Al</button>
        </div>

        <article class="print-report">
            <header class="print-header">
                <div>
                    <div class="print-brand">BakımSuite</div>
                    <h1>Motosiklet Ekspertiz Raporu</h1>
                    <p>@(_currentUser?.TenantIdentifier ?? "İşletme") · @DateTime.Now.ToString("dd.MM.yyyy HH:mm")</p>
                </div>
                <div class="print-header-meta">
                    <strong>@_inspection.InspectionNo</strong>
                    <span>@_inspection.StatusText</span>
                </div>
            </header>

            <section class="print-grid print-grid--two">
                <section class="print-card">
                    <h2>Genel Bilgiler</h2>
                    <dl class="detail-list">
                        <dt>Müşteri</dt>
                        <dd>@_inspection.CustomerName</dd>
                        <dt>Telefon</dt>
                        <dd>@_inspection.Phone</dd>
                        <dt>Araç</dt>
                        <dd>@VehicleText</dd>
                        <dt>Paket</dt>
                        <dd>@_inspection.PackageTypeText</dd>
                        <dt>Oluşturma</dt>
                        <dd>@_inspection.CreatedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</dd>
                    </dl>
                </section>

                <section class="print-card">
                    <h2>Durum Özeti</h2>
                    <div class="print-stat-grid">
                        <div><strong>@Count(MotorcycleInspectionResult.Original)</strong><span>Orijinal</span></div>
                        <div><strong>@Count(MotorcycleInspectionResult.Painted)</strong><span>Boyalı</span></div>
                        <div><strong>@Count(MotorcycleInspectionResult.Changed)</strong><span>Değişen</span></div>
                        <div><strong>@Count(MotorcycleInspectionResult.Damaged)</strong><span>Hasarlı</span></div>
                        <div><strong>@Count(MotorcycleInspectionResult.Scratched)</strong><span>Çizik</span></div>
                    </div>
                </section>
            </section>

            <section class="print-card">
                <h2>Kritik Bulgular</h2>
                @if (CriticalItems.Count == 0)
                {
                    <p>Kritik bulgu yok.</p>
                }
                else
                {
                    <div class="print-list">
                        @foreach (var item in CriticalItems)
                        {
                            <div class="print-list-item">
                                <strong>@item.Name</strong>
                                <span>@item.ResultText</span>
                                @if (!string.IsNullOrWhiteSpace(item.Notes))
                                {
                                    <small>@item.Notes</small>
                                }
                            </div>
                        }
                    </div>
                }
            </section>

            <section class="print-grid print-grid--two">
                <section class="print-card">
                    <h2>Kaporta Özeti</h2>
                    @if (BodyItems.Count == 0)
                    {
                        <p>Kaporta tarafında işaretlenmiş bulgu yok.</p>
                    }
                    else
                    {
                        <div class="print-list">
                            @foreach (var item in BodyItems)
                            {
                                <div class="print-list-item">
                                    <strong>@item.Name</strong>
                                    <span>@item.ResultText</span>
                                    @if (!string.IsNullOrWhiteSpace(item.Notes))
                                    {
                                        <small>@item.Notes</small>
                                    }
                                </div>
                            }
                        </div>
                    }
                </section>

                <section class="print-card">
                    <h2>Test Sürüşü Notları</h2>
                    <p>@(string.IsNullOrWhiteSpace(_inspection.TestRideNotes) ? "Not girilmemiş." : _inspection.TestRideNotes)</p>
                    <h2 class="mt-4">Genel Açıklama</h2>
                    <p>@(string.IsNullOrWhiteSpace(_inspection.GeneralNotes) ? "Açıklama girilmemiş." : _inspection.GeneralNotes)</p>
                </section>
            </section>
        </article>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private MotorcycleInspectionDetail? _inspection;
    private CurrentUserResponse? _currentUser;
    private bool _loading = true;
    private string? _error;

    private string VehicleText => string.Join(" ", new[] { _inspection?.Brand, _inspection?.Model }.Where(x => !string.IsNullOrWhiteSpace(x))).Trim() switch
    {
        "" => _inspection?.Plate ?? "-",
        var text => $"{text} · {_inspection?.Plate}"
    };

    private List<MotorcycleInspectionItem> CriticalItems => _inspection?.Items?
        .Where(x => x.Result is MotorcycleInspectionResult.Damaged or MotorcycleInspectionResult.Changed)
        .OrderByDescending(x => x.Result == MotorcycleInspectionResult.Damaged)
        .ThenBy(x => x.SortOrder)
        .ToList() ?? [];

    private List<MotorcycleInspectionItem> BodyItems => _inspection?.Items?
        .Where(x => x.Category == MotorcycleInspectionCategory.BodyAndFairing &&
                    x.Result is MotorcycleInspectionResult.Original or MotorcycleInspectionResult.Painted or MotorcycleInspectionResult.Changed or MotorcycleInspectionResult.Damaged or MotorcycleInspectionResult.Scratched)
        .OrderBy(x => x.SortOrder)
        .ToList() ?? [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (!await AuthService.IsAuthenticatedAsync())
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        _currentUser = await AuthService.GetCurrentUserAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _loading = true;
            _error = null;
            await InvokeAsync(StateHasChanged);

            _inspection = await InspectionsService.GetByIdAsync(Id);
            if (_inspection is null)
            {
                _error = "Ekspertiz raporu bulunamadı.";
            }
        }
        catch (ApiException ex) when (ex.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private int Count(MotorcycleInspectionResult result)
        => _inspection?.Items?.Count(x => x.Result == result) ?? 0;
}
