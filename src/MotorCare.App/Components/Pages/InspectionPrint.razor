@page "/inspections/{Id:guid}/print"
@layout MotorCare.App.Components.Layout.PrintLayout
@using Microsoft.Extensions.Options
@using System.Net
@using MotorCare.App.Configuration
@using MotorCare.App.Models.Inspections
@using MotorCare.App.Models.PublicRecords
@inject AuthService AuthService
@inject InspectionsService InspectionsService
@inject PublicRecordsService PublicRecordsService
@inject QrCodeSvgService QrCodeSvgService
@inject IOptions<PublicReportOptions> PublicReportOptions
@inject NavigationManager NavigationManager

<PageTitle>@(_inspection?.InspectionNo ?? "Ekspertiz Raporu")</PageTitle>

<div class="print-page-shell">
    @if (_loading)
    {
        <section class="loading-state">
            <strong>Ekspertiz raporu hazırlanıyor</strong>
            <p>Lütfen bekleyin.</p>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <section class="error-state">
            <strong>Ekspertiz raporu alınamadı</strong>
            <p>@_error</p>
        </section>
    }
    else if (_inspection is not null)
    {
        <div class="print-toolbar no-print">
            <a class="app-btn-secondary" href="@($"/inspections/{Id}")">← Detaya Dön</a>
            <button type="button" class="app-btn-primary" onclick="window.print()">Yazdır / PDF Al</button>
        </div>

        <article class="print-report">

            <header class="print-header">
                <div>
                    <div class="print-brand">GarajPass</div>
                    <h1>Motosiklet Ekspertiz Raporu</h1>
                    <p>@(_currentUser?.TenantIdentifier ?? "İşletme") · @_inspection.CreatedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</p>
                </div>
                <div class="print-header-meta">
                    <strong class="print-doc-no">@_inspection.InspectionNo</strong>
                    <span>@_inspection.PackageTypeText</span>
                    <span class="status-badge @GetStatusBadgeClass(_inspection.Status)">@_inspection.StatusText</span>
                    @if (!string.IsNullOrWhiteSpace(_qrSvg))
                    {
                        <section class="print-qr-box">
                            <div class="print-qr-code">@((MarkupString)_qrSvg)</div>
                            <div class="print-qr-copy">
                                <strong>Dijital kayıt doğrulaması için QR'ı okutun.</strong>
                                <span>GarajPass ile doğrulanabilir kayıt</span>
                                <small>@_publicPath</small>
                            </div>
                        </section>
                    }
                </div>
            </header>

            <div class="print-grid print-grid--two">
                <section class="print-card">
                    <h2>Müşteri ve Araç Bilgileri</h2>
                    <dl class="detail-list">
                        <dt>Müşteri</dt>
                        <dd>@_inspection.CustomerName</dd>
                        <dt>Telefon</dt>
                        <dd>@_inspection.Phone</dd>
                        <dt>Plaka</dt>
                        <dd>@_inspection.Plate</dd>
                        @if (!string.IsNullOrWhiteSpace(_inspection.Brand) || !string.IsNullOrWhiteSpace(_inspection.Model))
                        {
                            <dt>Marka / Model</dt>
                            <dd>@BrandModelText</dd>
                        }
                        @if (_inspection.Year.HasValue)
                        {
                            <dt>Model Yılı</dt>
                            <dd>@_inspection.Year</dd>
                        }
                        @if (_inspection.Mileage.HasValue)
                        {
                            <dt>Kilometre</dt>
                            <dd>@_inspection.Mileage.Value.ToString("N0") km</dd>
                        }
                        @if (!string.IsNullOrWhiteSpace(_inspection.ChassisNumber))
                        {
                            <dt>Şasi No</dt>
                            <dd>@_inspection.ChassisNumber</dd>
                        }
                        @if (!string.IsNullOrWhiteSpace(_inspection.EngineNumber))
                        {
                            <dt>Motor No</dt>
                            <dd>@_inspection.EngineNumber</dd>
                        }
                        @if (!string.IsNullOrWhiteSpace(_inspection.Query5664))
                        {
                            <dt>5664 Sorgu</dt>
                            <dd>@_inspection.Query5664</dd>
                        }
                        @if (!string.IsNullOrWhiteSpace(_inspection.MileageQuery))
                        {
                            <dt>KM Sorgu</dt>
                            <dd>@_inspection.MileageQuery</dd>
                        }
                        <dt>Paket Fiyatı</dt>
                        <dd>@_inspection.PackagePrice.ToString("N2") ₺</dd>
                    </dl>
                </section>

                <section class="print-card">
                    <h2>Kaporta Durumu Özeti</h2>
                    <div class="print-stat-grid">
                        <div>
                            <strong>@Count(MotorcycleInspectionResult.Original)</strong>
                            <span>Orijinal</span>
                        </div>
                        <div>
                            <strong>@Count(MotorcycleInspectionResult.Painted)</strong>
                            <span>Boyalı</span>
                        </div>
                        <div>
                            <strong>@Count(MotorcycleInspectionResult.Changed)</strong>
                            <span>Değişen</span>
                        </div>
                        <div>
                            <strong>@Count(MotorcycleInspectionResult.Damaged)</strong>
                            <span>Hasarlı</span>
                        </div>
                        <div>
                            <strong>@Count(MotorcycleInspectionResult.Scratched)</strong>
                            <span>Çizik</span>
                        </div>
                    </div>
                </section>
            </div>

            @if (BodyMapItems.Count > 0)
            {
                <section class="print-card print-body-map-card">
                    <div class="print-section-title-row">
                        <h2>Görsel Ekspertiz / Body Map</h2>
                        <span class="print-count-badge">@MarkedBodyMapEntries.Count işaretli bölge</span>
                    </div>

                    <div class="print-body-map-legend">
                        @foreach (var option in MotorcycleBodyMapDefinitions.StatusOptions)
                        {
                            <span>
                                <i style="@($"background:{MotorcycleBodyMapDefinitions.GetStatusColor(option.Status)}")"></i>
                                @option.Label
                            </span>
                        }
                    </div>

                    <div class="print-body-map-grid">
                        @RenderPrintBodyMap(MotorcycleViewType.Left)
                        @RenderPrintBodyMap(MotorcycleViewType.Right)
                    </div>

                    @if (MarkedBodyMapEntries.Count == 0)
                    {
                        <p class="print-empty-note">Body map üzerinde işaretlenmiş parça bulunmamaktadır.</p>
                    }
                    else
                    {
                        <div class="print-body-map-list">
                            @foreach (var entry in MarkedBodyMapEntries)
                            {
                                <div class="print-body-map-list-item">
                                    <span class="print-body-map-list-no" style="@($"--map-color:{MotorcycleBodyMapDefinitions.GetStatusColor(entry.Status)}")">
                                        @entry.Definition.Number
                                    </span>
                                    <div>
                                        <strong>@GetViewText(entry.Definition.ViewType) - @entry.Definition.Label</strong>
                                        <span>@MotorcycleBodyMapDefinitions.GetStatusText(entry.Status)</span>
                                        @if (!string.IsNullOrWhiteSpace(entry.Item.Notes))
                                        {
                                            <small>@entry.Item.Notes</small>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </section>
            }

            <section class="print-card">
                <h2>Kritik Bulgular <span class="print-count-badge">@CriticalItems.Count adet</span></h2>
                @if (CriticalItems.Count == 0)
                {
                    <p class="print-empty-note">Kritik bulgu (hasar / değişen parça) tespit edilmemiştir.</p>
                }
                else
                {
                    <div class="print-items-table">
                        <div class="print-items-row print-items-head">
                            <span>Kalem</span>
                            <span>Kategori</span>
                            <span>Durum</span>
                            <span>Not</span>
                        </div>
                        @foreach (var item in CriticalItems)
                        {
                            <div class="print-items-row @(item.Result == MotorcycleInspectionResult.Damaged ? "row-damaged" : "row-changed")">
                                <span><strong>@item.Name</strong></span>
                                <span>@item.CategoryText</span>
                                <span>@item.ResultText</span>
                                <span>@(string.IsNullOrWhiteSpace(item.Notes) ? "—" : item.Notes)</span>
                            </div>
                        }
                    </div>
                }
            </section>

            @{
                var bodyItems = BodyAndFairingItems;
                var otherItems = OtherCheckedItems;
            }

            @if (bodyItems.Count > 0)
            {
                <section class="print-card">
                    <h2>Kaporta / Fairing Detayı</h2>
                    <div class="print-items-table">
                        <div class="print-items-row print-items-head">
                            <span>Kalem</span>
                            <span>Durum</span>
                            <span>Not</span>
                        </div>
                        @foreach (var item in bodyItems)
                        {
                            <div class="print-items-row">
                                <span>@item.Name</span>
                                <span>@item.ResultText</span>
                                <span>@(string.IsNullOrWhiteSpace(item.Notes) ? "—" : item.Notes)</span>
                            </div>
                        }
                    </div>
                </section>
            }

            @if (otherItems.Count > 0)
            {
                <section class="print-card">
                    <h2>Diğer Değerlendirilen Kalemler</h2>
                    <div class="print-items-table">
                        <div class="print-items-row print-items-head">
                            <span>Kalem</span>
                            <span>Kategori</span>
                            <span>Durum</span>
                            <span>Not</span>
                        </div>
                        @foreach (var item in otherItems)
                        {
                            <div class="print-items-row">
                                <span>@item.Name</span>
                                <span>@item.CategoryText</span>
                                <span>@item.ResultText</span>
                                <span>@(string.IsNullOrWhiteSpace(item.Notes) ? "—" : item.Notes)</span>
                            </div>
                        }
                    </div>
                </section>
            }

            <div class="print-grid print-grid--two">
                <section class="print-card">
                    <h2>Genel Açıklama</h2>
                    <p>@(string.IsNullOrWhiteSpace(_inspection.GeneralNotes) ? "Açıklama girilmemiş." : _inspection.GeneralNotes)</p>
                    @if (!string.IsNullOrWhiteSpace(_inspection.CosmeticNotes))
                    {
                        <h2 class="print-sub-title">Kaporta / Kozmetik Notlar</h2>
                        <p>@_inspection.CosmeticNotes</p>
                    }
                </section>

                <section class="print-card">
                    <h2>Test Sürüşü Notları</h2>
                    <p>@(string.IsNullOrWhiteSpace(_inspection.TestRideNotes) ? "Test sürüşü notu girilmemiş." : _inspection.TestRideNotes)</p>
                </section>
            </div>

            <div class="print-signature-row">
                <div class="print-signature-box">
                    <div class="print-signature-label">Eksperin Adı Soyadı ve İmzası</div>
                    <div class="print-signature-line"></div>
                    <div class="print-signature-date">Tarih: _______ / _______ / ___________</div>
                </div>
                <div class="print-signature-box">
                    <div class="print-signature-label">Müşteri Adı Soyadı, İmzası ve Onayı</div>
                    <div class="print-signature-line"></div>
                    <div class="print-signature-date">Tarih: _______ / _______ / ___________</div>
                </div>
            </div>

            <footer class="print-footer">
                <span>GarajPass · Motosiklet Ekspertiz Yönetim Sistemi</span>
                <span>@_inspection.InspectionNo · @_inspection.CreatedAt.LocalDateTime.ToString("dd.MM.yyyy")</span>
            </footer>

        </article>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private MotorcycleInspectionDetail? _inspection;
    private CurrentUserResponse? _currentUser;
    private PublicRecordAccessResponse? _publicAccess;
    private string? _publicUrl;
    private string? _publicPath;
    private string? _qrSvg;
    private bool _loading = true;
    private string? _error;

    private static readonly HashSet<string> BodyMapKeys = MotorcycleBodyMapDefinitions.LeftParts
        .Concat(MotorcycleBodyMapDefinitions.RightParts)
        .SelectMany(part => part.MatchKeys.Append(part.Label))
        .Select(NormalizeText)
        .Where(key => !string.IsNullOrWhiteSpace(key))
        .ToHashSet(StringComparer.OrdinalIgnoreCase);

    private string BrandModelText
    {
        get
        {
            var parts = new[] { _inspection?.Brand, _inspection?.Model }
                .Where(x => !string.IsNullOrWhiteSpace(x));
            var text = string.Join(" ", parts);
            return string.IsNullOrWhiteSpace(text) ? "-" : text;
        }
    }

    private List<MotorcycleInspectionItem> CriticalItems => _inspection?.Items?
        .Where(x => x.Result is MotorcycleInspectionResult.Damaged or MotorcycleInspectionResult.Changed)
        .OrderByDescending(x => x.Result == MotorcycleInspectionResult.Damaged)
        .ThenBy(x => x.SortOrder)
        .ToList() ?? [];

    private List<MotorcycleInspectionItem> BodyAndFairingItems => _inspection?.Items?
        .Where(x => x.Category == MotorcycleInspectionCategory.BodyAndFairing
                    && x.Result is not MotorcycleInspectionResult.NotChecked)
        .OrderBy(x => x.SortOrder)
        .ToList() ?? [];

    private List<MotorcycleInspectionItem> BodyMapItems => _inspection?.Items?
        .Where(x => x.Category == MotorcycleInspectionCategory.BodyAndFairing && IsBodyMapItem(x))
        .OrderBy(x => x.SortOrder)
        .ToList() ?? [];

    private List<PrintBodyMapEntry> MarkedBodyMapEntries => MotorcycleBodyMapDefinitions.LeftParts
        .Concat(MotorcycleBodyMapDefinitions.RightParts)
        .Select(definition =>
        {
            var item = ResolveBodyMapItem(definition);
            var status = item is null ? MotorcyclePartStatus.Unmarked : MapToPartStatus(item.Result);
            return item is null || status == MotorcyclePartStatus.Unmarked
                ? null
                : new PrintBodyMapEntry(definition, item, status);
        })
        .Where(entry => entry is not null)
        .Cast<PrintBodyMapEntry>()
        .OrderBy(entry => entry.Definition.ViewType)
        .ThenBy(entry => entry.Definition.Number)
        .ToList();

    private List<MotorcycleInspectionItem> OtherCheckedItems => _inspection?.Items?
        .Where(x => x.Category != MotorcycleInspectionCategory.BodyAndFairing
                    && x.Result is not MotorcycleInspectionResult.NotChecked)
        .OrderBy(x => x.Category)
        .ThenBy(x => x.SortOrder)
        .ToList() ?? [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!await AuthService.IsAuthenticatedAsync())
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        _currentUser = await AuthService.GetCurrentUserAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _loading = true;
            _error = null;
            await InvokeAsync(StateHasChanged);
            _inspection = await InspectionsService.GetByIdAsync(Id);
            if (_inspection is not null)
            {
                await LoadPublicQrAsync();
            }
            if (_inspection is null)
                _error = "Ekspertiz raporu bulunamadı.";
        }
        catch (ApiException ex) when (ex.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private int Count(MotorcycleInspectionResult result)
        => _inspection?.Items?.Count(x => x.Result == result) ?? 0;

    private RenderFragment RenderPrintBodyMap(MotorcycleViewType viewType) => @<section class="print-body-map-view">
        <header>
            <strong>@GetViewText(viewType) Görünüm</strong>
            <span>@MotorcycleBodyMapDefinitions.GetParts(viewType).Count(definition => GetBodyMapStatus(definition) != MotorcyclePartStatus.Unmarked) işaret</span>
        </header>
        <div class="print-body-map-stage">
            <img src="@MotorcycleBodyMapDefinitions.GetImagePath(viewType)" alt="@($"{GetViewText(viewType)} motosiklet görünümü")" />
            @foreach (var definition in MotorcycleBodyMapDefinitions.GetParts(viewType))
            {
                var status = GetBodyMapStatus(definition);
                if (status == MotorcyclePartStatus.Unmarked)
                {
                    continue;
                }

                <span class="print-body-map-marker"
                      style="@GetBodyMapMarkerStyle(definition, status)"
                      title="@definition.Label">
                    @definition.Number
                </span>
            }
        </div>
    </section>;

    private MotorcyclePartStatus GetBodyMapStatus(MotorcyclePartDefinition definition)
    {
        var item = ResolveBodyMapItem(definition);
        return item is null ? MotorcyclePartStatus.Unmarked : MapToPartStatus(item.Result);
    }

    private MotorcycleInspectionItem? ResolveBodyMapItem(MotorcyclePartDefinition definition)
        => BodyMapItems.FirstOrDefault(item => definition.MatchKeys.Any(key => string.Equals(NormalizeText(key), NormalizeText(item.Name), StringComparison.OrdinalIgnoreCase)));

    private bool IsBodyMapItem(MotorcycleInspectionItem item)
        => BodyMapKeys.Contains(NormalizeText(item.Name));

    private static string GetBodyMapMarkerStyle(MotorcyclePartDefinition definition, MotorcyclePartStatus status)
        => $"left:{definition.HotspotLeftPercent:F2}%;top:{definition.HotspotTopPercent:F2}%;--map-color:{MotorcycleBodyMapDefinitions.GetStatusColor(status)};";

    private static MotorcyclePartStatus MapToPartStatus(MotorcycleInspectionResult result) => result switch
    {
        MotorcycleInspectionResult.Original => MotorcyclePartStatus.Original,
        MotorcycleInspectionResult.Painted => MotorcyclePartStatus.Painted,
        MotorcycleInspectionResult.Changed => MotorcyclePartStatus.Replaced,
        MotorcycleInspectionResult.Damaged => MotorcyclePartStatus.Damaged,
        MotorcycleInspectionResult.Scratched => MotorcyclePartStatus.Scratched,
        _ => MotorcyclePartStatus.Unmarked
    };

    private static string GetViewText(MotorcycleViewType viewType)
        => viewType == MotorcycleViewType.Left ? "Sol" : "Sağ";

    private static string NormalizeText(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return value
            .Trim()
            .ToLowerInvariant()
            .Replace("ı", "i")
            .Replace("ğ", "g")
            .Replace("ü", "u")
            .Replace("ş", "s")
            .Replace("ö", "o")
            .Replace("ç", "c");
    }

    private static string GetStatusBadgeClass(MotorcycleInspectionStatus status) => status switch
    {
        MotorcycleInspectionStatus.Draft => "badge-muted",
        MotorcycleInspectionStatus.InProgress => "badge-progress",
        MotorcycleInspectionStatus.Completed => "badge-completed",
        MotorcycleInspectionStatus.Cancelled => "badge-cancelled",
        _ => "badge-muted"
    };

    private sealed record PrintBodyMapEntry(
        MotorcyclePartDefinition Definition,
        MotorcycleInspectionItem Item,
        MotorcyclePartStatus Status);

    private async Task LoadPublicQrAsync()
    {
        try
        {
            _publicAccess = await PublicRecordsService.GetOrCreateForInspectionAsync(Id);
            if (_publicAccess is null || !_publicAccess.IsActive || string.IsNullOrWhiteSpace(_publicAccess.Slug))
            {
                return;
            }

            _publicPath = $"/public/inspection-report/{_publicAccess.Slug}";
            _publicUrl = BuildPublicUrl(_publicPath);
            _qrSvg = QrCodeSvgService.GenerateSvg(_publicUrl);
        }
        catch
        {
            _publicAccess = null;
            _publicUrl = null;
            _publicPath = null;
            _qrSvg = null;
        }
    }

    private string BuildPublicUrl(string path)
    {
        var configuredBaseUrl = PublicReportOptions.Value.BaseUrl;
        var baseUrl = string.IsNullOrWhiteSpace(configuredBaseUrl)
            ? NavigationManager.BaseUri
            : configuredBaseUrl.Trim();

        if (!baseUrl.EndsWith("/", StringComparison.Ordinal))
        {
            baseUrl += "/";
        }

        return new Uri(new Uri(baseUrl), path.TrimStart('/')).ToString();
    }
}
