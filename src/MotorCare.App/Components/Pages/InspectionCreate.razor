@page "/inspections/create"
@using MotorCare.App.Models.Customers
@using MotorCare.App.Models.Inspections
@using MotorCare.App.Models.Vehicles
@inject AuthService AuthService
@inject CustomersService CustomersService
@inject VehiclesService VehiclesService
@inject InspectionsService InspectionsService
@inject NavigationManager NavigationManager

<PageTitle>Yeni Ekspertiz</PageTitle>

<div class="page-shell">
    <section class="page-header">
        <div>
            <h1 class="page-title">Yeni Ekspertiz</h1>
            <p class="page-description">Müşteri, araç ve ekspertiz paketini seçerek yeni bir motosiklet ekspertiz kaydı başlatın.</p>
        </div>
        <a href="/inspections" class="app-btn-secondary">Listeye Dön</a>
    </section>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <section class="error-state">
            <strong>Ekspertiz oluşturulamadı</strong>
            <p>@_error</p>
        </section>
    }

    <section class="app-card">
        <div class="content-grid">
            <section class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">1. Müşteri Seçimi</div>
                        <div class="section-subtitle">Mevcut müşteriyi seçin veya bilgileri manuel girin.</div>
                    </div>
                    <a href="/customers/create" class="app-btn-secondary">+ Yeni Müşteri</a>
                </div>

                <div class="d-flex flex-column gap-3">
                    <div>
                        <label class="form-label">Ad veya telefon ile ara</label>
                        <div class="d-flex gap-2 flex-wrap">
                            <InputText class="form-control" @bind-Value="_customerSearchText" @bind:event="oninput" placeholder="Ahmet Yılmaz / 05xx..." />
                            <button type="button" class="app-btn-secondary" @onclick="SearchCustomersAsync" disabled="@_customerSearchLoading">
                                @(_customerSearchLoading ? "Aranıyor..." : "Ara")
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_customerSearchMessage))
                    {
                        <p class="small text-muted m-0">@_customerSearchMessage</p>
                    }

                    @if (_customerResults.Count > 0)
                    {
                        <div class="mobile-card-list">
                            @foreach (var customer in _customerResults)
                            {
                                <button type="button" class="selection-item" @onclick="() => SelectCustomerAsync(customer)">
                                    <div>
                                        <strong>@customer.FullName</strong>
                                        <div class="small text-muted">@customer.Phone</div>
                                    </div>
                                    <span class="type-badge">Seç</span>
                                </button>
                            }
                        </div>
                    }

                    @if (_selectedCustomer is not null)
                    {
                        <div class="selection-item selected">
                            <div>
                                <strong>@_selectedCustomer.FullName</strong>
                                <div class="small text-muted">@_selectedCustomer.Phone</div>
                            </div>
                            <button type="button" class="app-btn-secondary" @onclick="ClearCustomerSelectionAsync">Temizle</button>
                        </div>
                    }

                    <div class="form-grid">
                        <div>
                            <label class="form-label">Müşteri Adı *</label>
                            <InputText class="form-control" @bind-Value="_form.CustomerName" />
                        </div>
                        <div>
                            <label class="form-label">Telefon *</label>
                            <InputText class="form-control" @bind-Value="_form.Phone" />
                        </div>
                    </div>
                </div>
            </section>

            <section class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">2. Araç Seçimi</div>
                        <div class="section-subtitle">Seçili müşterinin araçlarını kullanın veya plaka ile araç bulun.</div>
                    </div>
                </div>

                @if (_selectedCustomer is not null)
                {
                    @if (_customerVehiclesLoading)
                    {
                        <section class="loading-state">
                            <strong>Araçlar yükleniyor</strong>
                            <p>Müşteri araçları getiriliyor.</p>
                        </section>
                    }
                    else if (_customerVehicles.Count > 0)
                    {
                        <div class="mobile-card-list">
                            @foreach (var vehicle in _customerVehicles)
                            {
                                <button type="button" class="selection-item @(vehicle.Id == _selectedVehicle?.Id ? "selected" : string.Empty)" @onclick="() => SelectVehicle(vehicle)">
                                    <div>
                                        <strong>@vehicle.PlateOriginal</strong>
                                        <div class="small text-muted">@vehicle.VehicleDisplay</div>
                                    </div>
                                    <span class="type-badge">@(vehicle.Id == _selectedVehicle?.Id ? "Seçildi" : "Seç")</span>
                                </button>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="small text-muted m-0">Bu müşteriye kayıtlı araç bulunamadı.</p>
                    }
                }

                <div class="d-flex flex-column gap-3 mt-3">
                    <div>
                        <label class="form-label">Plaka ile bul</label>
                        <div class="d-flex gap-2 flex-wrap">
                            <InputText class="form-control" @bind-Value="_vehicleLookupPlate" placeholder="34 ABC 123" />
                            <button type="button" class="app-btn-secondary" @onclick="LookupVehicleAsync" disabled="@_vehicleLookupLoading">
                                @(_vehicleLookupLoading ? "Aranıyor..." : "Bul")
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_vehicleLookupMessage))
                    {
                        <p class="small text-muted m-0">@_vehicleLookupMessage</p>
                    }

                    <div class="form-grid">
                        <div>
                            <label class="form-label">Plaka *</label>
                            <InputText class="form-control" @bind-Value="_form.Plate" />
                        </div>
                        <div>
                            <label class="form-label">Marka</label>
                            <InputText class="form-control" @bind-Value="_form.Brand" />
                        </div>
                        <div>
                            <label class="form-label">Model</label>
                            <InputText class="form-control" @bind-Value="_form.Model" />
                        </div>
                        <div>
                            <label class="form-label">Yıl</label>
                            <InputNumber class="form-control" @bind-Value="_form.Year" />
                        </div>
                        <div>
                            <label class="form-label">Kilometre</label>
                            <InputNumber class="form-control" @bind-Value="_form.Mileage" />
                        </div>
                        <div>
                            <label class="form-label">Şasi No</label>
                            <InputText class="form-control" @bind-Value="_form.ChassisNumber" />
                        </div>
                        <div>
                            <label class="form-label">Motor No</label>
                            <InputText class="form-control" @bind-Value="_form.EngineNumber" />
                        </div>
                        <div>
                            <label class="form-label">5664 Sorgu</label>
                            <InputText class="form-control" @bind-Value="_form.Query5664" />
                        </div>
                        <div>
                            <label class="form-label">KM Sorgu</label>
                            <InputText class="form-control" @bind-Value="_form.MileageQuery" />
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <div class="content-grid mt-4">
            <section class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">3. Paket Seçimi</div>
                        <div class="section-subtitle">Ekspertiz kapsamını ve paket ücretini belirleyin.</div>
                    </div>
                </div>

                <div class="mobile-card-list">
                    @foreach (var package in _packages)
                    {
                        <button type="button" class="selection-item @(_form.PackageType == package.PackageType ? "selected" : string.Empty)" @onclick="@(() => SelectPackage(package.PackageType))">
                            <div>
                                <strong>@package.DisplayName</strong>
                                <div class="small text-muted">@package.Price.ToString("N0") ₺</div>
                            </div>
                            <span class="type-badge">@(_form.PackageType == package.PackageType ? "Seçildi" : "Seç")</span>
                        </button>
                    }
                </div>
            </section>

            <section class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">4. Notlar</div>
                        <div class="section-subtitle">Ön notları girin. Kontrol kalemleri ekspertiz detayında açılacaktır.</div>
                    </div>
                </div>

                <div class="form-grid">
                    <div class="full-span">
                        <label class="form-label">Test Sürüşü İzlenimi</label>
                        <InputTextArea class="form-control" @bind-Value="_form.TestRideNotes" rows="4" />
                    </div>
                    <div class="full-span">
                        <label class="form-label">Karenaj / Kozmetik Notları</label>
                        <InputTextArea class="form-control" @bind-Value="_form.CosmeticNotes" rows="4" />
                    </div>
                    <div class="full-span">
                        <label class="form-label">Genel Açıklama</label>
                        <InputTextArea class="form-control" @bind-Value="_form.GeneralNotes" rows="4" />
                    </div>
                </div>
            </section>
        </div>

        <div class="action-bar sticky-mobile-action justify-content-end mt-4">
            <button type="button" class="app-btn-primary" @onclick="SaveAsync" disabled="@_saving">
                @(_saving ? "Kaydediliyor..." : "Ekspertiz Oluştur")
            </button>
        </div>
    </section>
</div>

@code {
    private readonly CreateMotorcycleInspectionRequest _form = new();
    private readonly List<CustomerLookupResponse> _customerResults = [];
    private readonly List<VehicleLookupResponse> _customerVehicles = [];
    private readonly (MotorcycleInspectionPackageType PackageType, string DisplayName, decimal Price)[] _packages =
    [
        (MotorcycleInspectionPackageType.MechanicalAndRunningGear, "Mekanik ve Yürüyen Aksam", 1000m),
        (MotorcycleInspectionPackageType.BodyAndFairing, "Karenaj ve Kaporta", 1000m),
        (MotorcycleInspectionPackageType.ObdAndElectrical, "OBD Test ve Elektrik/Elektronik", 1000m),
        (MotorcycleInspectionPackageType.Full, "Full Ekspertiz", 2500m)
    ];

    private CustomerLookupResponse? _selectedCustomer;
    private VehicleLookupResponse? _selectedVehicle;
    private string? _customerSearchText;
    private string? _customerSearchMessage;
    private string? _vehicleLookupPlate;
    private string? _vehicleLookupMessage;
    private bool _customerSearchLoading;
    private bool _customerVehiclesLoading;
    private bool _vehicleLookupLoading;
    private bool _saving;
    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (!await AuthService.IsAuthenticatedAsync())
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        _form.PackageType = MotorcycleInspectionPackageType.Full;
        await InvokeAsync(StateHasChanged);
    }

    private async Task SearchCustomersAsync()
    {
        try
        {
            _customerSearchLoading = true;
            _customerResults.Clear();
            _customerSearchMessage = null;

            if (string.IsNullOrWhiteSpace(_customerSearchText))
            {
                _customerSearchMessage = "Arama yapmak için müşteri adı veya telefon girin.";
                return;
            }

            var result = await CustomersService.SearchCustomersAsync(_customerSearchText);
            if (result is not null)
            {
                _customerResults.AddRange(result.Items);
            }

            if (_customerResults.Count == 0)
            {
                _customerSearchMessage = "Eşleşen müşteri bulunamadı.";
            }
        }
        catch (Exception ex)
        {
            _customerSearchMessage = ex.Message;
        }
        finally
        {
            _customerSearchLoading = false;
        }
    }

    private async Task SelectCustomerAsync(CustomerLookupResponse customer)
    {
        _selectedCustomer = customer;
        _form.CustomerId = customer.Id;
        _form.CustomerName = customer.FullName;
        _form.Phone = customer.Phone ?? _form.Phone;
        _customerSearchText = customer.FullName;
        _customerResults.Clear();
        _customerSearchMessage = "Müşteri bilgileri forma aktarıldı.";
        ClearVehicleSelection();
        await LoadCustomerVehiclesAsync(customer.Id);
    }

    private async Task ClearCustomerSelectionAsync()
    {
        _selectedCustomer = null;
        _form.CustomerId = null;
        _customerSearchText = null;
        _customerResults.Clear();
        _customerVehicles.Clear();
        ClearVehicleSelection();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadCustomerVehiclesAsync(Guid customerId)
    {
        try
        {
            _customerVehiclesLoading = true;
            _customerVehicles.Clear();
            var vehicles = await VehiclesService.GetByCustomerIdAsync(customerId);
            if (vehicles is not null)
            {
                _customerVehicles.AddRange(vehicles);
            }
        }
        catch (Exception ex)
        {
            _vehicleLookupMessage = ex.Message;
        }
        finally
        {
            _customerVehiclesLoading = false;
        }
    }

    private void SelectVehicle(VehicleLookupResponse vehicle)
    {
        _selectedVehicle = vehicle;
        _form.VehicleId = vehicle.Id;
        _form.Plate = vehicle.PlateOriginal;
        _form.Brand = vehicle.Brand;
        _form.Model = vehicle.Model;
        _form.Year = vehicle.Year;
        _vehicleLookupPlate = vehicle.PlateOriginal;
    }

    private async Task LookupVehicleAsync()
    {
        try
        {
            _vehicleLookupLoading = true;
            _vehicleLookupMessage = null;

            if (string.IsNullOrWhiteSpace(_vehicleLookupPlate))
            {
                _vehicleLookupMessage = "Plaka girin.";
                return;
            }

            var vehicle = await VehiclesService.GetByPlateAsync(_vehicleLookupPlate);
            if (vehicle is null)
            {
                _form.VehicleId = null;
                _form.Plate = _vehicleLookupPlate;
                _vehicleLookupMessage = "Bu plakayla araç bulunamadı. Bilgileri manuel girebilirsiniz.";
                return;
            }

            if (vehicle.CustomerId.HasValue)
            {
                var customer = await CustomersService.GetByIdAsync(vehicle.CustomerId.Value);
                if (customer is not null)
                {
                    await SelectCustomerAsync(customer);
                }
            }

            SelectVehicle(vehicle);
            _vehicleLookupMessage = "Araç bilgileri aktarıldı.";
        }
        catch (Exception ex)
        {
            _vehicleLookupMessage = ex.Message;
        }
        finally
        {
            _vehicleLookupLoading = false;
        }
    }

    private void ClearVehicleSelection()
    {
        _selectedVehicle = null;
        _form.VehicleId = null;
    }

    private void SelectPackage(MotorcycleInspectionPackageType packageType)
        => _form.PackageType = packageType;

    private async Task SaveAsync()
    {
        try
        {
            _saving = true;
            _error = null;

            if (string.IsNullOrWhiteSpace(_form.CustomerName))
            {
                _error = "Müşteri adı zorunludur.";
                return;
            }

            if (string.IsNullOrWhiteSpace(_form.Phone))
            {
                _error = "Telefon zorunludur.";
                return;
            }

            if (string.IsNullOrWhiteSpace(_form.Plate))
            {
                _error = "Plaka zorunludur.";
                return;
            }

            var id = await InspectionsService.CreateAsync(_form);
            NavigationManager.NavigateTo($"/inspections/{id}");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }
}
