@page "/verify-email"
@layout Layout.PublicLayout
@using Microsoft.AspNetCore.WebUtilities
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>E-posta Doğrulama - GarajPass</PageTitle>

<div class="auth-shell auth-shell-login">
    <div class="auth-panel auth-panel-brand">
        <div class="eyebrow" style="color:#fdba74">Hesap aktivasyonu</div>
        <h1 class="auth-title">E-posta doğrulama</h1>
        <p class="auth-copy">Doğrulama bağlantısı geçerliyse GarajPass hesabını aktif hale getiririz.</p>
    </div>

    <div class="auth-panel auth-panel-form auth-panel-narrow">
        <div class="section-header mb-2">
            <div>
                <div class="section-title">Doğrulama Durumu</div>
                <div class="section-subtitle">Sonuç burada görünür.</div>
            </div>
        </div>

        @if (_isLoading)
        {
            <div class="state-loading">Doğrulama yapılıyor...</div>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert alert-danger">@_error</div>
            <div class="auth-actions">
                <a class="auth-link" href="/login">Giriş ekranına dön</a>
            </div>
        }
        else
        {
            <div class="alert alert-success">@_message</div>
            <div class="auth-actions">
                <a class="btn btn-primary btn-lg" href="/login">Giriş Yap</a>
            </div>
        }
    </div>
</div>

@code {
    private bool _isLoading = true;
    private string? _message;
    private string? _error;

    [SupplyParameterFromQuery] public string? Email { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (!_isLoading)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Token))
        {
            _error = "Geçersiz doğrulama bağlantısı.";
            _isLoading = false;
            return;
        }

        try
        {
            var response = await AuthService.VerifyEmailAsync(new VerifyEmailRequest
            {
                Email = Email,
                Token = Token
            });

            _message = response?.Message ?? "E-posta adresin doğrulandi. GarajPass'e giriş yapabilirsin.";
            var uri = QueryHelpers.AddQueryString("/login", new Dictionary<string, string?>
            {
                ["email"] = Email,
                ["message"] = _message
            });
            NavigationManager.NavigateTo(uri);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
