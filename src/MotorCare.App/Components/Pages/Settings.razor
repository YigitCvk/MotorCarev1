@page "/settings"

<PageTitle>Ayarlar</PageTitle>

<div class="page-shell">
    <section class="page-header">
        <div>
            <div class="eyebrow">Tenant yönetimi</div>
            <h1 class="page-title">Ayarlar ve Yönetim</h1>
            <p class="page-description">
                İşletmenizin profilini, kullanicilarini, guvenlik akislarini ve bildirim tercihlerini buradan yönetin.
            </p>
        </div>
        <div class="page-header-actions">
            <a class="app-btn-secondary" href="/dashboard">Panele Dön</a>
            <a class="app-btn-primary" href="/services">Hizmetleri Yönet</a>
        </div>
    </section>

    <section class="metric-grid">
        <div class="metric-card mc-primary">
            <div class="metric-label">Aktif Modul</div>
            <div class="metric-value">8</div>
            <div class="metric-sub">Tenant tarafinda kullanima hazir alanlar</div>
        </div>
        <div class="metric-card mc-success">
            <div class="metric-label">Hazır Ayarlar</div>
            <div class="metric-value">5</div>
            <div class="metric-sub">Hemen düzenlenebilir temel basliklar</div>
        </div>
        <div class="metric-card mc-warning">
            <div class="metric-label">Planlanan Alan</div>
            <div class="metric-value">3</div>
            <div class="metric-sub">Bir sonraki sprintte derinlesecek moduller</div>
        </div>
        <div class="metric-card mc-teal">
            <div class="metric-label">GarajPass Durumu</div>
            <div class="metric-value">MVP</div>
            <div class="metric-sub">Tenant yönetim kabugu aktif</div>
        </div>
    </section>

    <section class="admin-grid">
        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">İşletme Bilgileri</div>
                    <div class="section-subtitle">Unvan, iletisim, adres ve servis kabul bilgileri</div>
                </div>
                <span class="status-badge badge-open">Aktif</span>
            </div>
            <p class="admin-card-copy">
                İşletme adi, telefon, adres, vergi bilgileri ve teslim metinleri gibi temel tenant verilerini düzenleyin.
            </p>
            <div class="admin-card-meta">
                <span class="type-badge">Profil</span>
                <span class="type-badge">Iletisim</span>
                <span class="type-badge">Fatura</span>
            </div>
            <div class="admin-card-actions">
                <a class="app-btn-primary" href="/settings/business">Yönet</a>
                <a class="app-btn-secondary" href="/settings/business">Duzenle</a>
            </div>
        </article>

        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Kullanicilar ve Roller</div>
                    <div class="section-subtitle">Owner, personel ve yetki dagilimi</div>
                </div>
                <span class="status-badge badge-progress">Planlandı</span>
            </div>
            <p class="admin-card-copy">
                Ekip uyeleri, rol bazli erişim ve operasyon yetkileri icin tenant yönetim alani.
            </p>
            <div class="admin-card-meta">
                <span class="type-badge">Roller</span>
                <span class="type-badge">Yetkiler</span>
            </div>
            <div class="admin-card-actions">
                <a class="app-btn-primary" href="/settings/users">Yönet</a>
                <a class="app-btn-secondary" href="/settings/users">Duzenle</a>
            </div>
        </article>

        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Güvenlik</div>
                    <div class="section-subtitle">E-posta doğrulamasi ve iki aşamalı giriş</div>
                </div>
                <span class="status-badge badge-open">Aktif</span>
            </div>
            <p class="admin-card-copy">
                Hesap guvenligi, e-posta doğrulama durumu ve 2FA ayarlarinizi tek yerden yönetin.
            </p>
            <div class="admin-card-meta">
                <span class="type-badge">E-posta</span>
                <span class="type-badge">2FA</span>
                <span class="type-badge">OTP</span>
            </div>
            <div class="admin-card-actions">
                <a class="app-btn-primary" href="/settings/security">Yönet</a>
                <a class="app-btn-secondary" href="/settings/security">Detay</a>
            </div>
        </article>

        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Randevu Tipleri</div>
                    <div class="section-subtitle">Bakım, onarım, yıkama ve kontrol tanımları</div>
                </div>
                <span class="status-badge badge-open">Aktif</span>
            </div>
            <p class="admin-card-copy">
                Kullanilan randevu tiplerini, operasyon karsiliklarini ve görünür etiketleri tenant bazinda yönetin.
            </p>
            <div class="admin-card-meta">
                <span class="type-badge">Bakım</span>
                <span class="type-badge">Onarım</span>
                <span class="type-badge">Yıkama</span>
            </div>
            <div class="admin-card-actions">
                <a class="app-btn-primary" href="/settings/appointment-types">Yönet</a>
                <a class="app-btn-secondary" href="/settings/appointment-types">Duzenle</a>
            </div>
        </article>

        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Hizmetler</div>
                    <div class="section-subtitle">Bakım, yıkama, detailing ve servis katalogları</div>
                </div>
                <span class="status-badge badge-open">Aktif</span>
            </div>
            <p class="admin-card-copy">
                Hizmet katalogu modulu hazir. Servis kabul ve randevu akisinda kullanilacak standart hizmetleri düzenleyin.
            </p>
            <div class="admin-card-meta">
                <span class="type-badge">Katalog</span>
                <span class="type-badge">Fiyat</span>
                <span class="type-badge">Sure</span>
            </div>
            <div class="admin-card-actions">
                <a class="app-btn-primary" href="/services">Yönet</a>
                <a class="app-btn-secondary" href="/services/create">Yeni Hizmet</a>
            </div>
        </article>

        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Calisma Saatleri</div>
                    <div class="section-subtitle">Servis kabul pencereleri ve kapasite kurallari</div>
                </div>
                <span class="status-badge badge-progress">Planlandı</span>
            </div>
            <p class="admin-card-copy">
                Gunluk calisma saatleri, ozel tatil gunleri ve randevu kapasite pencereleri icin baslangic alani.
            </p>
            <div class="admin-card-actions">
                <a class="app-btn-primary" href="/settings/working-hours">Yönet</a>
                <a class="app-btn-secondary" href="/settings/working-hours">Duzenle</a>
            </div>
        </article>

        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Bildirim Sablonlari</div>
                    <div class="section-subtitle">Randevu, teslim ve ödeme mesajlari</div>
                </div>
                <span class="status-badge status-info">Yakinda</span>
            </div>
            <p class="admin-card-copy">
                SMS, WhatsApp veya e-posta metinlerini işletme tonunuza gore ozellestirmek icin hazirlanan alan.
            </p>
            <div class="admin-card-actions">
                <a class="app-btn-secondary" href="/settings/notifications">Yakinda</a>
            </div>
        </article>

        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Abonelik / Paket</div>
                    <div class="section-subtitle">Plan bilgisi, limitler ve kullanim ozeti</div>
                </div>
                <span class="status-badge status-info">Yakinda</span>
            </div>
            <p class="admin-card-copy">
                Paket detaylari, modul limitleri ve faturalama gorunumu bu tenant alaninda ozetlenecek.
            </p>
            <div class="admin-card-actions">
                <a class="app-btn-secondary" href="/settings/subscription">Yakinda</a>
            </div>
        </article>
    </section>
</div>
