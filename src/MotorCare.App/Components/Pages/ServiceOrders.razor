@page "/service-orders"
@implements IDisposable
@using MotorCare.Application.Common
@inject AuthService AuthService
@inject ServiceOrdersService ServiceOrdersService
@inject NavigationManager NavigationManager
@inject ILogger<ServiceOrders> Logger

<PageTitle>Servis İşlemleri</PageTitle>

<div class="page-shell">
    <section class="hero-panel compact">
        <div>
            <div class="eyebrow">Ana ekran</div>
            <h1 class="page-title">Servis İşlemleri</h1>
            <p class="page-description">
                Plaka, müşteri veya order numarasına göre ara. Durum ve tarih filtreleri ile kayıt kabul akışını hızlandır.
            </p>
        </div>

        <div class="quick-actions action-bar">
            <button type="button" class="app-btn-primary" @onclick="OpenCreate">Yeni Servis Kaydı</button>
        </div>
    </section>

    <section class="filter-card">
        <div class="filter-grid">
            <div>
                <label class="form-label">Arama</label>
                <InputText class="form-control" @bind-Value="_searchText" placeholder="Plaka, müşteri veya servis no ara" />
            </div>
            <div>
                <label class="form-label">Durum</label>
                <InputSelect class="form-select" @bind-Value="_status">
                    <option value="">Tüm durumlar</option>
                    <option value="Open">Açık</option>
                    <option value="InProgress">İşlemde</option>
                    <option value="WaitingForParts">Parça Bekliyor</option>
                    <option value="Completed">Tamamlandı</option>
                    <option value="Cancelled">İptal</option>
                    <option value="Delivered">Teslim Edildi</option>
                </InputSelect>
            </div>
            <div>
                <label class="form-label">Başlangıç</label>
                <InputDate class="form-control" @bind-Value="_openedFrom" />
            </div>
            <div>
                <label class="form-label">Bitiş</label>
                <InputDate class="form-control" @bind-Value="_openedTo" />
            </div>
            <div class="filter-actions">
                <button type="button" class="app-btn-primary" @onclick="FilterAsync" disabled="@_isLoading">
                    @(_isLoading ? "Yükleniyor..." : "Filtrele")
                </button>
                <button type="button" class="app-btn-secondary" @onclick="ResetFiltersAsync" disabled="@_isLoading">
                    Temizle
                </button>
                <select class="form-select page-size-select" @bind="_pageSize" @bind:after="FilterAsync">
                    <option value="10">10 / sayfa</option>
                    <option value="20">20 / sayfa</option>
                    <option value="50">50 / sayfa</option>
                </select>
            </div>
        </div>
    </section>

    @if (_isLoading)
    {
        <div class="surface-card mt-3 text-muted">Servis kayıtları yükleniyor...</div>
    }

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger mt-3">@_error</div>
    }

    <section class="surface-card mt-3 desktop-only">
        <div class="responsive-table">
            <table class="table modern-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Order No</th>
                        <th>Müşteri / Araç</th>
                        <th>Durum</th>
                        <th>Kabul</th>
                        <th>KM</th>
                        <th>Şikayet</th>
                        <th>Tutar</th>
                        <th>Kalan</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_orders.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="text-muted py-4">Kayıt bulunamadı.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var order in _orders)
                        {
                            <tr class="clickable-row" @onclick="@(() => OpenDetail(order.Id))">
                                <td class="fw-semibold">@order.OrderNo</td>
                                <td>
                                    <div class="fw-semibold">@(string.IsNullOrWhiteSpace(order.CustomerName) ? "-" : order.CustomerName)</div>
                                    <div class="text-muted small">@(string.IsNullOrWhiteSpace(order.VehiclePlate) ? order.VehicleDisplay ?? "-" : order.VehiclePlate)</div>
                                </td>
                                <td><span class="@GetStatusBadgeClass(order.Status)">@GetStatusLabel(order.Status)</span></td>
                                <td>@order.OpenedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@order.VehicleKm</td>
                                <td>@(string.IsNullOrWhiteSpace(order.Complaint) ? "-" : order.Complaint)</td>
                                <td>@order.GrandTotal.ToString("N2")</td>
                                <td>@order.RemainingTotal.ToString("N2")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="mobile-card-list mobile-only">
        @if (_orders.Count == 0)
        {
            <div class="surface-card text-muted">Kayıt bulunamadı.</div>
        }
        else
        {
            @foreach (var order in _orders)
            {
                <div class="surface-card order-card clickable-card" @onclick="@(() => OpenDetail(order.Id))">
                    <div class="order-card-top">
                        <div>
                            <div class="order-no">@order.OrderNo</div>
                            <div class="text-muted small">
                                @(string.IsNullOrWhiteSpace(order.CustomerName) ? "-" : order.CustomerName)
                                @if (!string.IsNullOrWhiteSpace(order.VehiclePlate))
                                {
                                    <span> · @order.VehiclePlate</span>
                                }
                            </div>
                            <div class="text-muted small">@order.OpenedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</div>
                        </div>
                        <span class="@GetStatusBadgeClass(order.Status)">@GetStatusLabel(order.Status)</span>
                    </div>
                    <div class="order-card-body">
                        <div><strong>KM:</strong> @order.VehicleKm</div>
                        <div><strong>Şikayet:</strong> @(string.IsNullOrWhiteSpace(order.Complaint) ? "-" : order.Complaint)</div>
                        <div class="order-money-row">
                            <span>Tutar @order.GrandTotal.ToString("N2")</span>
                            <span>Kalan @order.RemainingTotal.ToString("N2")</span>
                        </div>
                    </div>
                </div>
            }
        }
    </section>

    @if (_totalPages > 1 || _totalCount > 0)
    {
        <div class="pagination-bar">
            <div class="pagination-info">
                Toplam kayıt: <strong>@_totalCount</strong> &nbsp;·&nbsp; Sayfa <strong>@_pageNumber</strong> / <strong>@_totalPages</strong>
            </div>
            <div class="pagination-actions">
                <button class="app-btn-secondary" @onclick="PrevPageAsync" disabled="@(!_hasPreviousPage || _isLoading)">Önceki</button>
                <button class="app-btn-secondary" @onclick="NextPageAsync" disabled="@(!_hasNextPage || _isLoading)">Sonraki</button>
            </div>
        </div>
    }
</div>

@code {
    private readonly List<ServiceOrderListItem> _orders = [];
    private bool _isLoading = true;
    private string? _searchText;
    private string? _status;
    private DateTime? _openedFrom;
    private DateTime? _openedTo;
    private string? _error;

    private int _pageNumber = 1;
    private int _pageSize = 20;
    private int _totalCount;
    private int _totalPages;
    private bool _hasPreviousPage;
    private bool _hasNextPage;
    private bool _isDisposed;
    private readonly CancellationTokenSource _lifetimeCts = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (!await AuthService.IsAuthenticatedAsync())
        {
            TryNavigateTo("/login");
            return;
        }

        await LoadOrdersAsync(_lifetimeCts.Token);
    }

    private async Task LoadOrdersAsync()
        => await LoadOrdersAsync(_lifetimeCts.Token);

    private async Task LoadOrdersAsync(CancellationToken cancellationToken)
    {
        try
        {
            _isLoading = true;
            _error = null;
            _orders.Clear();
            await SafeStateHasChangedAsync();

            var response = await ServiceOrdersService.GetServiceOrdersAsync(_searchText, _status, _openedFrom, _openedTo, pageNumber: _pageNumber, pageSize: _pageSize, cancellationToken: cancellationToken);
            if (IsInactive(cancellationToken))
            {
                return;
            }

            if (response is not null)
            {
                _orders.AddRange(response.Items);
                _totalCount = response.TotalCount;
                _totalPages = response.TotalPages;
                _hasPreviousPage = response.HasPreviousPage;
                _hasNextPage = response.HasNextPage;
            }
        }
        catch (OperationCanceledException) when (IsInactive(cancellationToken))
        {
        }
        catch (Exception ex)
        {
            if (!IsInactive(cancellationToken))
            {
                _error = ex.Message;
            }
        }
        finally
        {
            if (!IsInactive(cancellationToken))
            {
                _isLoading = false;
            }
        }

        if (!IsInactive(cancellationToken))
        {
            await SafeStateHasChangedAsync();
        }
    }

    private async Task FilterAsync()
    {
        _pageNumber = 1;
        await LoadOrdersAsync();
    }

    private async Task ResetFiltersAsync()
    {
        _searchText = null;
        _status = null;
        _openedFrom = null;
        _openedTo = null;
        _pageNumber = 1;
        await LoadOrdersAsync();
    }

    private async Task PrevPageAsync()
    {
        if (_pageNumber > 1)
        {
            _pageNumber--;
            await LoadOrdersAsync();
        }
    }

    private async Task NextPageAsync()
    {
        if (_hasNextPage)
        {
            _pageNumber++;
            await LoadOrdersAsync();
        }
    }

    private void OpenDetail(Guid id)
    {
        TryNavigateTo($"/service-orders/{id}");
    }

    private void OpenCreate()
    {
        TryNavigateTo("/service-orders/create");
    }

    private bool IsInactive(CancellationToken cancellationToken)
        => _isDisposed || cancellationToken.IsCancellationRequested;

    private async Task SafeStateHasChangedAsync()
    {
        if (_isDisposed || _lifetimeCts.IsCancellationRequested)
        {
            return;
        }

        try
        {
            await InvokeAsync(() =>
            {
                if (!_isDisposed && !_lifetimeCts.IsCancellationRequested)
                {
                    StateHasChanged();
                }
            });
        }
        catch (ObjectDisposedException)
        {
        }
        catch (InvalidOperationException) when (_isDisposed || _lifetimeCts.IsCancellationRequested)
        {
        }
    }

    public void Dispose()
    {
        if (_isDisposed)
        {
            return;
        }

        _isDisposed = true;
        _lifetimeCts.Cancel();
        _lifetimeCts.Dispose();
    }

    private void TryNavigateTo(string uri)
    {
        if (_isDisposed || _lifetimeCts.IsCancellationRequested)
        {
            Logger.LogDebug(EventIdStore.Common.NavigationSkippedDueToDisconnectedCircuit,
                "Navigation skipped because service orders component is disposed. Target={Target}", uri);
            return;
        }

        try
        {
            NavigationManager.NavigateTo(uri);
        }
        catch (Exception ex) when (ex is ObjectDisposedException or InvalidOperationException or Microsoft.JSInterop.JSDisconnectedException or TaskCanceledException or OperationCanceledException)
        {
            Logger.LogDebug(EventIdStore.Common.NavigationSkippedDueToDisconnectedCircuit,
                "Navigation skipped because service orders circuit is disconnected. Target={Target} ExceptionType={ExceptionType}",
                uri,
                ex.GetType().Name);
        }
    }

    private static string GetStatusBadgeClass(string status) =>
        status switch
        {
            "Open" => "status-badge badge-open",
            "InProgress" => "status-badge badge-progress",
            "WaitingForParts" => "status-badge badge-waiting",
            "Completed" => "status-badge badge-completed",
            "Delivered" => "status-badge badge-delivered",
            "Cancelled" => "status-badge badge-cancelled",
            _ => "status-badge"
        };

    private static string GetStatusLabel(string status) =>
        status switch
        {
            "Open" => "Açık",
            "InProgress" => "İşlemde",
            "WaitingForParts" => "Parça Bekliyor",
            "Completed" => "Tamamlandı",
            "Delivered" => "Teslim Edildi",
            "Cancelled" => "İptal",
            _ => status
        };
}
