@page "/settings/users"
@inject AuthService AuthService
@inject UsersService UsersService
@inject NavigationManager NavigationManager

<PageTitle>Kullanıcılar ve Roller</PageTitle>

<div class="page-shell">
    <section class="page-header">
        <div>
            <div class="eyebrow">Ayarlar</div>
            <h1 class="page-title">Kullanıcılar ve Roller</h1>
            <p class="page-description">Ekip üyelerini yönetin, rol atayın ve hesapları devre dışı bırakın.</p>
        </div>
        <div class="page-header-actions">
            <a class="app-btn-secondary" href="/settings">Ayarlara Dön</a>
            <button type="button" class="app-btn-primary" @onclick="ToggleCreateForm">
                @(_showCreateForm ? "Formu Kapat" : "+ Kullanıcı Davet Et")
            </button>
        </div>
    </section>

    @if (_showCreateForm)
    {
        <section class="app-card mb-4">
            <div class="section-title mb-3">Kullanıcı Davet Et</div>
            <p class="text-muted small mb-3">Kullanıcıya davet e-postası gönderilir. Kullanıcı kendi şifresini belirler.</p>

            @if (!string.IsNullOrWhiteSpace(_createError))
            {
                <div class="alert-error mb-3">@_createError</div>
            }
            @if (!string.IsNullOrWhiteSpace(_inviteSuccess))
            {
                <div class="alert-success mb-3">@_inviteSuccess</div>
            }

            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">Ad Soyad</label>
                    <input type="text" class="form-control" @bind="_createFullName" placeholder="Opsiyonel" />
                </div>
                <div class="form-group">
                    <label class="form-label">E-posta <span class="text-danger">*</span></label>
                    <input type="email" class="form-control" @bind="_createEmail" placeholder="ornek@sirket.com" />
                </div>
                <div class="form-group">
                    <label class="form-label">Rol <span class="text-danger">*</span></label>
                    <select class="form-select" @bind="_createRole">
                        <option value="">Rol Seçin</option>
                        <option value="Admin">Yönetici</option>
                        <option value="Receptionist">Danışman</option>
                        <option value="Technician">Teknisyen</option>
                        <option value="Inspector">Ekspertiz</option>
                        <option value="Accountant">Muhasebe</option>
                        <option value="ReadOnly">Sadece Okuma</option>
                        <option value="Manager">Müdür</option>
                    </select>
                </div>
            </div>

            <div class="form-actions mt-3">
                <button type="button" class="app-btn-primary" @onclick="InviteUserAsync" disabled="@_isCreating">
                    @(_isCreating ? "Gönderiliyor..." : "Davet Gönder")
                </button>
                <button type="button" class="app-btn-secondary" @onclick="ToggleCreateForm" disabled="@_isCreating">
                    Vazgeç
                </button>
            </div>
        </section>
    }

    @if (_isLoading)
    {
        <section class="loading-state">
            <strong>Kullanıcılar yükleniyor</strong>
            <p>Lütfen bekleyin.</p>
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <section class="error-state">
            <strong>Kullanıcılar alınamadı</strong>
            <p>@_error</p>
            <button type="button" class="app-btn-secondary mt-2" @onclick="LoadUsersAsync">Tekrar Dene</button>
        </section>
    }

    @if (!_isLoading && string.IsNullOrWhiteSpace(_error) && _users.Count == 0)
    {
        <section class="empty-state">
            <strong>Henüz kullanıcı yok</strong>
            <p>Yeni kullanıcı eklemek için "Yeni Kullanıcı" butonunu kullanın.</p>
        </section>
    }

    @if (_users.Count > 0)
    {
        <section class="surface-card mt-3 desktop-only">
            <div class="responsive-table">
                <table class="table modern-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Ad Soyad</th>
                            <th>E-posta</th>
                            <th>Rol</th>
                            <th>Durum</th>
                            <th>Son Giriş</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in _users)
                        {
                            var isOwner = user.Role == "Owner";
                            <tr>
                                <td class="fw-semibold">@user.FullName</td>
                                <td>@user.Email</td>
                                <td>
                                    @if (isOwner)
                                    {
                                        <span class="status-badge badge-open">@user.RoleText</span>
                                    }
                                    else
                                    {
                                        <select class="form-select form-select-sm"
                                                value="@user.Role"
                                                disabled="@(!user.IsActive)"
                                                @onchange="(e) => ChangeRoleAsync(user.Id, e.Value?.ToString())">
                                            <option value="Admin" selected="@(user.Role == "Admin")">Yönetici</option>
                                            <option value="Receptionist" selected="@(user.Role == "Receptionist")">Danışman</option>
                                            <option value="Technician" selected="@(user.Role == "Technician")">Teknisyen</option>
                                            <option value="Inspector" selected="@(user.Role == "Inspector")">Ekspertiz</option>
                                            <option value="Accountant" selected="@(user.Role == "Accountant")">Muhasebe</option>
                                            <option value="ReadOnly" selected="@(user.Role == "ReadOnly")">Sadece Okuma</option>
                                            <option value="Manager" selected="@(user.Role == "Manager")">Müdür</option>
                                        </select>
                                    }
                                </td>
                                <td>
                                    @if (user.IsActive)
                                    {
                                        <span class="status-badge badge-open">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge badge-cancelled">Pasif</span>
                                    }
                                    @if (!user.IsEmailVerified)
                                    {
                                        <span class="status-badge status-info ms-1">E-posta Doğrulanmadı</span>
                                    }
                                </td>
                                <td class="text-muted small">
                                    @(user.LastLoginAt.HasValue ? user.LastLoginAt.Value.LocalDateTime.ToString("dd.MM.yyyy HH:mm") : "-")
                                </td>
                                <td>
                                    @if (!isOwner && user.IsActive)
                                    {
                                        <button type="button"
                                                class="app-btn-secondary btn-sm"
                                                @onclick="() => DeactivateUserAsync(user.Id, user.FullName)">
                                            Devre Dışı Bırak
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="mobile-card-list mobile-only">
            @foreach (var user in _users)
            {
                var isOwner = user.Role == "Owner";
                <article class="app-card">
                    <div class="fw-semibold">@user.FullName</div>
                    <div class="text-muted small">@user.Email</div>
                    <div class="mt-1">
                        <span class="status-badge @(user.IsActive ? "badge-open" : "badge-cancelled")">
                            @(user.IsActive ? "Aktif" : "Pasif")
                        </span>
                        <span class="status-badge status-info ms-1">@user.RoleText</span>
                    </div>
                    @if (!isOwner && user.IsActive)
                    {
                        <div class="mt-2">
                            <button type="button"
                                    class="app-btn-secondary btn-sm"
                                    @onclick="() => DeactivateUserAsync(user.Id, user.FullName)">
                                Devre Dışı Bırak
                            </button>
                        </div>
                    }
                </article>
            }
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(_actionMessage))
    {
        <div class="alert-success mt-3">@_actionMessage</div>
    }
</div>

@code {
    private readonly List<UserListItem> _users = [];
    private bool _isLoading;
    private string? _error;
    private string? _actionMessage;

    private bool _showCreateForm;
    private bool _isCreating;
    private string? _createError;
    private string? _inviteSuccess;
    private string _createFullName = string.Empty;
    private string _createEmail = string.Empty;
    private string _createRole = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!await AuthService.IsAuthenticatedAsync())
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        try
        {
            _isLoading = true;
            _error = null;
            _users.Clear();
            await InvokeAsync(StateHasChanged);

            var result = await UsersService.GetUsersAsync();
            if (result is not null)
                _users.AddRange(result);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void ToggleCreateForm()
    {
        _showCreateForm = !_showCreateForm;
        _createError = null;
        _inviteSuccess = null;
        if (!_showCreateForm)
        {
            _createFullName = string.Empty;
            _createEmail = string.Empty;
            _createRole = string.Empty;
        }
    }

    private async Task InviteUserAsync()
    {
        _createError = null;
        _inviteSuccess = null;

        if (string.IsNullOrWhiteSpace(_createEmail))
        {
            _createError = "E-posta alanı zorunludur.";
            return;
        }
        if (string.IsNullOrWhiteSpace(_createRole))
        {
            _createError = "Lütfen bir rol seçin.";
            return;
        }

        try
        {
            _isCreating = true;
            await InvokeAsync(StateHasChanged);

            await UsersService.InviteUserAsync(_createEmail, _createRole, _createFullName);

            _inviteSuccess = $"{_createEmail} adresine davet e-postası gönderildi.";
            _createFullName = string.Empty;
            _createEmail = string.Empty;
            _createRole = string.Empty;

            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            _createError = ex.Message;
        }
        finally
        {
            _isCreating = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task ChangeRoleAsync(Guid userId, string? role)
    {
        if (string.IsNullOrWhiteSpace(role)) return;

        try
        {
            await UsersService.UpdateRoleAsync(userId, role);
            _actionMessage = "Kullanıcı rolü güncellendi.";
            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task DeactivateUserAsync(Guid userId, string fullName)
    {
        try
        {
            await UsersService.DeactivateAsync(userId);
            _actionMessage = $"{fullName} hesabı devre dışı bırakıldı.";
            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }

        await InvokeAsync(StateHasChanged);
    }
}
