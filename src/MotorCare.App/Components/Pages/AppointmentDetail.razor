@page "/appointments/{Id:guid}"
@using System.Net
@inject AppointmentsService AppointmentsService
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Randevu Detayi</PageTitle>

<div class="page-shell">
    @if (_loading)
    {
        <section class="loading-state">
            <strong>Randevu yukleniyor</strong>
            <p>Lutfen bekleyin.</p>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <section class="error-state">
            <strong>Randevu detayi alinamadi</strong>
            <p>@_error</p>
            @if (!string.IsNullOrWhiteSpace(_errorEndpoint))
            {
                <p class="small text-muted mt-2">Istek: @_errorEndpoint</p>
            }
        </section>
    }
    else if (_appointment is null)
    {
        <section class="empty-state">
            <strong>Randevu bulunamadi</strong>
            <p>Listeye donup tekrar deneyin.</p>
        </section>
    }
    else
    {
        <section class="page-header">
            <div>
                <h1 class="page-title">@_appointment.CustomerName</h1>
                <p class="page-description">
                    <span class="status-badge @GetStatusClass(_appointment.Status)">@GetStatusText(_appointment.Status)</span>
                    <span class="ms-2 type-badge">@GetTypeText(_appointment.Type)</span>
                </p>
            </div>
            <div class="action-bar">
                <a href="/appointments" class="app-btn-secondary">Listeye Don</a>
                @if (_appointment.ServiceOrderId.HasValue)
                {
                    <a href="@($"/service-orders/{_appointment.ServiceOrderId}")" class="app-btn-primary">Is Emrini Ac</a>
                }
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(_successMessage))
        {
            <section class="empty-state">
                <strong>Islem basarili</strong>
                <p>@_successMessage</p>
            </section>
        }

        <div class="content-grid">
            <section class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">Randevu Ozeti</div>
                        <div class="section-subtitle">Musteri, arac ve planlama bilgileri</div>
                    </div>
                </div>

                <dl class="detail-list">
                    <dt>Musteri</dt>
                    <dd>@_appointment.CustomerName</dd>
                    <dt>Telefon</dt>
                    <dd>@_appointment.Phone</dd>
                    <dt>Plaka</dt>
                    <dd>@(string.IsNullOrWhiteSpace(_appointment.Plate) ? "-" : _appointment.Plate)</dd>
                    <dt>Baslangic</dt>
                    <dd>@_appointment.StartAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
                    <dt>Bitis</dt>
                    <dd>@_appointment.EndAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
                    <dt>Sikayet</dt>
                    <dd>@(string.IsNullOrWhiteSpace(_appointment.Complaint) ? "-" : _appointment.Complaint)</dd>
                    <dt>Not</dt>
                    <dd>@(string.IsNullOrWhiteSpace(_appointment.Note) ? "-" : _appointment.Note)</dd>
                </dl>
            </section>

            <section class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">Aksiyonlar</div>
                        <div class="section-subtitle">Durum guncelle veya is emrine donustur</div>
                    </div>
                </div>

                <div class="d-flex flex-column gap-3 sticky-mobile-action">
                    <div>
                        <label class="form-label">Yeni durum</label>
                        <div class="action-bar">
                            <InputSelect class="form-select" @bind-Value="_statusRequest.Status">
                                @foreach (var status in Enum.GetValues<AppointmentStatus>())
                                {
                                    <option value="@status">@GetStatusText(status)</option>
                                }
                            </InputSelect>
                            <button type="button" class="app-btn-secondary" @onclick="UpdateStatusAsync" disabled="@_working">
                                Durumu Guncelle
                            </button>
                        </div>
                    </div>

                    <div>
                        <label class="form-label">Arac KM</label>
                        <InputNumber class="form-control" @bind-Value="_vehicleKm" />
                    </div>

                    @if (!_hasRequiredLinksForConversion)
                    {
                        <p class="text-muted small mb-0">Randevuyu is emrine donusturmek icin musteri ve arac baglantisi zorunludur.</p>
                    }

                    <button type="button" class="app-btn-primary" @onclick="ConvertAsync" disabled="@_working || _appointment.ServiceOrderId.HasValue || !_hasRequiredLinksForConversion">
                        Is Emrine Donustur
                    </button>
                </div>
            </section>
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private AppointmentDto? _appointment;
    private bool _loading = true;
    private bool _working;
    private bool _hasRequiredLinksForConversion;
    private string? _error;
    private string? _errorEndpoint;
    private string? _successMessage;
    private readonly UpdateAppointmentStatusRequest _statusRequest = new();
    private int _vehicleKm;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (!await AuthService.IsAuthenticatedAsync())
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        await LoadAsync(resetMessages: true);
    }

    private async Task LoadAsync(bool resetMessages)
    {
        try
        {
            _loading = true;
            _error = null;
            _errorEndpoint = null;
            if (resetMessages)
            {
                _successMessage = null;
            }

            _appointment = await AppointmentsService.GetByIdAsync(Id);
            if (_appointment is not null)
            {
                _statusRequest.Status = _appointment.Status;
                _hasRequiredLinksForConversion = _appointment.CustomerId.HasValue && _appointment.VehicleId.HasValue;
                if (_vehicleKm <= 0)
                {
                    _vehicleKm = 0;
                }
            }
        }
        catch (ApiException ex) when (ex.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
            _errorEndpoint = ex.Endpoint;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task UpdateStatusAsync()
    {
        var selectedStatusText = GetStatusText(_statusRequest.Status);

        await ExecuteAsync(
            async () => await AppointmentsService.UpdateStatusAsync(Id, _statusRequest.Status),
            $"Randevu durumu \"{selectedStatusText}\" olarak guncellendi.");
    }

    private async Task ConvertAsync()
    {
        try
        {
            _working = true;
            _error = null;
            _errorEndpoint = null;
            _successMessage = null;

            if (_vehicleKm < 0)
            {
                _error = "Arac KM degeri negatif olamaz.";
                return;
            }

            if (_appointment is null || !_hasRequiredLinksForConversion)
            {
                _error = "Randevuyu is emrine donusturmek icin musteri ve arac secili olmalidir.";
                return;
            }

            var result = await AppointmentsService.ConvertToServiceOrderAsync(Id, _vehicleKm);
            var serviceOrderId = result?.ResolveServiceOrderId() ?? Guid.Empty;

            if (serviceOrderId != Guid.Empty)
            {
                NavigationManager.NavigateTo($"/service-orders/{serviceOrderId}");
                return;
            }

            _successMessage = "Randevu is emrine donusturuldu.";
            NavigationManager.NavigateTo("/service-orders");
        }
        catch (ApiException ex) when (ex.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
        {
            NavigationManager.NavigateTo("/login");
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
            _errorEndpoint = ex.Endpoint;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _working = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ExecuteAsync(Func<Task> action, string? successMessage = null)
    {
        try
        {
            _working = true;
            _error = null;
            _errorEndpoint = null;
            _successMessage = null;

            await action();

            _successMessage = successMessage;
            await LoadAsync(resetMessages: false);
        }
        catch (ApiException ex) when (ex.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
        {
            NavigationManager.NavigateTo("/login");
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
            _errorEndpoint = ex.Endpoint;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _working = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string GetTypeText(AppointmentType type) => type switch
    {
        AppointmentType.Maintenance => "Bakim",
        AppointmentType.Repair => "Onarim",
        AppointmentType.Cleaning => "Temizlik",
        AppointmentType.Washing => "Yikama",
        AppointmentType.Inspection => "Kontrol",
        AppointmentType.TireChange => "Lastik Degisimi",
        _ => "Diger"
    };

    private static string GetStatusText(AppointmentStatus status) => status switch
    {
        AppointmentStatus.Scheduled => "Planlandi",
        AppointmentStatus.Confirmed => "Onaylandi",
        AppointmentStatus.CheckedIn => "Servise Geldi",
        AppointmentStatus.ConvertedToOrder => "Is Emrine Donustu",
        AppointmentStatus.Cancelled => "Iptal",
        AppointmentStatus.NoShow => "Gelmedi",
        AppointmentStatus.Completed => "Tamamlandi",
        _ => status.ToString()
    };

    private static string GetStatusClass(AppointmentStatus status) => status switch
    {
        AppointmentStatus.Scheduled => "appt-scheduled",
        AppointmentStatus.Confirmed => "appt-confirmed",
        AppointmentStatus.CheckedIn => "appt-checkedin",
        AppointmentStatus.ConvertedToOrder => "appt-converted",
        AppointmentStatus.Cancelled => "appt-cancelled",
        AppointmentStatus.NoShow => "appt-noshow",
        AppointmentStatus.Completed => "appt-completed",
        _ => string.Empty
    };
}
