@page "/vehicles/create"
@inject AuthService AuthService
@inject VehiclesService VehiclesService
@inject CustomersService CustomersService
@inject NavigationManager NavigationManager

<PageTitle>Yeni Araç</PageTitle>

<div class="page-shell">
    <section class="hero-panel compact">
        <div>
            <div class="eyebrow">Araç Ekle</div>
            <h1 class="page-title">Yeni Araç</h1>
        </div>
        <div class="quick-actions">
            <a class="btn btn-outline-secondary" href="/vehicles">Geri</a>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    <div class="content-grid">
        <section class="surface-card">
            <div class="section-title">Araç Bilgileri</div>
            <div class="form-grid mt-3">
                <div>
                    <label class="form-label">Plaka *</label>
                    <InputText class="form-control" @bind-Value="_form.Plate" placeholder="34ABC123" />
                </div>
                <div>
                    <label class="form-label">Marka *</label>
                    <InputText class="form-control" @bind-Value="_form.Brand" placeholder="Toyota" />
                </div>
                <div>
                    <label class="form-label">Model *</label>
                    <InputText class="form-control" @bind-Value="_form.Model" placeholder="Corolla" />
                </div>
                <div>
                    <label class="form-label">Yıl *</label>
                    <InputNumber class="form-control" @bind-Value="_form.Year" />
                </div>
                <div>
                    <label class="form-label">Renk</label>
                    <InputText class="form-control" @bind-Value="_form.Color" placeholder="Beyaz" />
                </div>
                <div>
                    <label class="form-label">Güncel KM</label>
                    <InputNumber class="form-control" @bind-Value="_form.CurrentKm" />
                </div>
                <div class="full-span">
                    <label class="form-label">Şasi No</label>
                    <InputText class="form-control" @bind-Value="_form.ChassisNumber" placeholder="Opsiyonel" />
                </div>
            </div>
        </section>

        <section class="surface-card">
            <div class="section-title">Müşteri Ata</div>
            <p class="text-muted small mt-1 mb-3">Aracın sahibi olan müşteriyi seçin (opsiyonel)</p>
            <CustomerQuickSearch @bind-Value="_selectedCustomer" />
        </section>
    </div>

    <div class="d-flex justify-content-end mt-3">
        <button type="button" class="btn btn-primary" @onclick="SaveAsync" disabled="@_isSaving">
            @(_isSaving ? "Kaydediliyor..." : "Araç Kaydet")
        </button>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public Guid? CustomerId { get; set; }

    private readonly CreateVehicleRequest _form = new() { Year = DateTime.Now.Year };
    private CustomerLookupResponse? _selectedCustomer;
    private string? _error;
    private bool _isSaving;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!await AuthService.IsAuthenticatedAsync())
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        if (CustomerId.HasValue)
        {
            try
            {
                _selectedCustomer = await CustomersService.GetByIdAsync(CustomerId.Value);
                await InvokeAsync(StateHasChanged);
            }
            catch { }
        }
    }

    private async Task SaveAsync()
    {
        try
        {
            _isSaving = true;
            _error = null;

            if (string.IsNullOrWhiteSpace(_form.Plate))
            {
                _error = "Plaka zorunludur.";
                return;
            }

            if (string.IsNullOrWhiteSpace(_form.Brand))
            {
                _error = "Marka zorunludur.";
                return;
            }

            if (string.IsNullOrWhiteSpace(_form.Model))
            {
                _error = "Model zorunludur.";
                return;
            }

            if (_form.Year < 1900 || _form.Year > DateTime.Now.Year + 1)
            {
                _error = "Geçerli bir yıl giriniz.";
                return;
            }

            _form.CurrentCustomerId = _selectedCustomer?.Id;
            await VehiclesService.CreateAsync(_form);
            NavigationManager.NavigateTo("/vehicles");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }
}
