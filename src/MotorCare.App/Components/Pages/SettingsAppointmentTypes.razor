@page "/settings/appointment-types"

<PageTitle>Randevu Tipleri</PageTitle>

<div class="page-shell">
    <section class="page-header">
        <div>
            <div class="eyebrow">Ayarlar</div>
            <h1 class="page-title">Randevu Tipleri</h1>
            <p class="page-description">Bakım, onarım, yıkama ve kontrol gibi randevu tiplerini işletme akışınıza göre yönetin.</p>
        </div>
        <div class="page-header-actions">
            <a class="app-btn-secondary" href="/settings">Ayarlara Dön</a>
            <button type="button" class="app-btn-primary">Tip Ekle</button>
        </div>
    </section>

    <section class="admin-grid">
        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Varsayılan Tipler</div>
                    <div class="section-subtitle">MVP içinde kullanılan ana randevu kategorileri</div>
                </div>
                <span class="status-badge badge-open">Aktif</span>
            </div>
            <p class="admin-card-copy">Bakım, onarım, yıkama ve detailing gibi tipler şimdiden operasyon akışında kullanılabiliyor.</p>
            <div class="admin-card-actions">
                <button type="button" class="app-btn-primary">Yönet</button>
            </div>
        </article>

        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Renk ve Kural Eşlemesi</div>
                    <div class="section-subtitle">Takvim görünümü ve kapasite davranışı</div>
                </div>
                <span class="status-badge badge-progress">Planlandı</span>
            </div>
            <p class="admin-card-copy">Randevu tipi bazlı renk, süre ve kapasite eşlemesi bir sonraki aşamada burada tanımlanacak.</p>
            <div class="admin-card-actions">
                <button type="button" class="app-btn-secondary">Yakında</button>
            </div>
        </article>
    </section>
</div>
