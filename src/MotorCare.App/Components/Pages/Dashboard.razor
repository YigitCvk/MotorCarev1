@page "/dashboard"
@using System.Globalization
@using System.Net
@using MotorCare.App.Authorization
@inject AuthService AuthService
@inject DashboardService DashboardService
@inject NavigationManager NavigationManager

<PageTitle>Dashboard - GarajPass</PageTitle>

@if (_isLoading)
{
    <div class="page-shell">
        <section class="loading-state">
            <strong>Dashboard yükleniyor</strong>
            <p>Lütfen bekleyin.</p>
        </section>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="page-shell">
        <section class="error-state">
            <strong>Dashboard alınamadı</strong>
            <p>@_error</p>
        </section>
    </div>
}
else if (_user is null || _summary is null)
{
    <div class="page-shell">
        <section class="empty-state">
            <strong>Dashboard verisi bulunamadı</strong>
            <p>Devam etmek için sayfayı yenileyin veya tekrar giriş yapın.</p>
        </section>
    </div>
}
else
{
    <div class="page-shell">
        <section class="page-header">
            <div>
                <div class="eyebrow">@_today.ToString("dd MMMM yyyy", TurkishCulture)</div>
                <h1 class="page-title">Operasyon Özeti</h1>
                <p class="page-description">
                    <strong>@_user.TenantIdentifier</strong>
                    - @RoleText(_user.Role)
                </p>
            </div>
            @if (AppRoleAccess.CanWriteServiceOrders(_user.Role))
            {
                <div class="page-header-actions">
                    <a class="app-btn-primary" href="/service-orders/create">+ Yeni Servis</a>
                </div>
            }
        </section>

        <section class="metric-grid">
            <div class="metric-card mc-primary">
                <div class="metric-label">Toplam Müşteri</div>
                <div class="metric-value">@_summary.TotalCustomerCount</div>
            </div>
            <div class="metric-card mc-success">
                <div class="metric-label">Toplam Araç</div>
                <div class="metric-value">@_summary.TotalVehicleCount</div>
            </div>
            <div class="metric-card mc-warning">
                <div class="metric-label">Açık Servis Emri</div>
                <div class="metric-value">@_summary.OpenServiceOrderCount</div>
            </div>
            <div class="metric-card mc-teal">
                <div class="metric-label">Bugünkü Randevu</div>
                <div class="metric-value">@_summary.TodayAppointmentCount</div>
            </div>
            <div class="metric-card mc-success">
                <div class="metric-label">Bu Ay Tamamlanan</div>
                <div class="metric-value">@_summary.CompletedServiceCountThisMonth</div>
            </div>
            <div class="metric-card mc-primary">
                <div class="metric-label">Bu Ay Tahsilat</div>
                <div class="metric-value">@FormatMoney(_summary.TotalPaymentsThisMonth)</div>
            </div>
            <div class="metric-card mc-danger">
                <div class="metric-label">Kritik Ekspertiz</div>
                <div class="metric-value">@_summary.CriticalInspectionCount</div>
            </div>
        </section>

        @if (IsCompletelyEmpty(_summary))
        {
            <section class="empty-state">
                <strong>Henüz operasyon verisi yok</strong>
                <p>Müşteri, araç, servis veya randevu eklendiğinde dashboard burada dolacak.</p>
            </section>
        }
        else
        {
            <section class="public-record-split-grid">
                <article class="app-card">
                    <div class="section-title">Bugün</div>
                    <dl class="public-record-totals mt-3">
                        <div>
                            <dt>Açılan servis</dt>
                            <dd>@_summary.TotalServiceOrdersToday</dd>
                        </div>
                        <div>
                            <dt>Tamamlanan servis</dt>
                            <dd>@_summary.CompletedServiceOrdersToday</dd>
                        </div>
                        <div>
                            <dt>Devam eden servis</dt>
                            <dd>@_summary.InProgressServiceOrdersCount</dd>
                        </div>
                        <div class="is-total">
                            <dt>Tahsilat</dt>
                            <dd>@FormatMoney(_summary.TotalPaymentsToday)</dd>
                        </div>
                    </dl>
                </article>

                <article class="app-card">
                    <div class="section-title">Son Servis Kayıtları</div>
                    @if (_summary.RecentServiceOrders.Count == 0)
                    {
                        <p class="text-muted mt-3">Henüz servis kaydı yok.</p>
                    }
                    else
                    {
                        <div class="public-record-line-list mt-3">
                            @foreach (var order in _summary.RecentServiceOrders)
                            {
                                <article class="public-record-line-item">
                                    <div>
                                        <strong>@order.OrderNo</strong>
                                        <span>@FormatDateTime(order.OpenedAt) · @StatusText(order.Status)</span>
                                    </div>
                                    <strong>@FormatMoney(order.GrandTotal)</strong>
                                </article>
                            }
                        </div>
                    }
                </article>
            </section>
        }
    </div>
}

@code {
    private static readonly CultureInfo TurkishCulture = CultureInfo.GetCultureInfo("tr-TR");

    private bool _isLoading = true;
    private string? _error;
    private CurrentUserResponse? _user;
    private DailySummaryResponse? _summary;
    private DateTime _today;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (!await AuthService.IsAuthenticatedAsync())
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error = null;
        _today = DateTime.Today;
        await InvokeAsync(StateHasChanged);

        try
        {
            _user = await AuthService.GetCurrentUserAsync();
            if (_user is null)
            {
                NavigationManager.NavigateTo("/login");
                return;
            }

            _summary = await DashboardService.GetDailySummaryAsync();
            if (_summary is null)
            {
                _error = "Dashboard verisi boş döndü. Lütfen kısa süre sonra tekrar deneyin.";
            }
        }
        catch (ApiException ex) when (ex.StatusCode == HttpStatusCode.Unauthorized)
        {
            NavigationManager.NavigateTo("/login");
        }
        catch
        {
            _error = "Dashboard verileri şu anda alınamıyor. Lütfen kısa süre sonra tekrar deneyin.";
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static bool IsCompletelyEmpty(DailySummaryResponse summary)
        => summary.TotalCustomerCount == 0 &&
           summary.TotalVehicleCount == 0 &&
           summary.OpenServiceOrderCount == 0 &&
           summary.TodayAppointmentCount == 0 &&
           summary.RecentServiceOrders.Count == 0;

    private static string RoleText(string role) => role switch
    {
        "Owner" => "Sahip",
        "Admin" => "Yönetici",
        "Receptionist" => "Danışman",
        "Technician" => "Teknisyen",
        "Manager" => "Müdür",
        "Inspector" => "Ekspertiz",
        "Accountant" => "Muhasebe",
        "ReadOnly" => "Sadece Okuma",
        _ => role
    };

    private static string StatusText(string status) => status switch
    {
        "Open" => "Açık",
        "InProgress" => "İşlemde",
        "WaitingForParts" => "Parça bekliyor",
        "Completed" => "Tamamlandı",
        "Delivered" => "Teslim edildi",
        "Cancelled" => "İptal",
        _ => status
    };

    private static string FormatDateTime(DateTimeOffset value)
        => value.LocalDateTime.ToString("dd.MM.yyyy HH:mm", TurkishCulture);

    private static string FormatMoney(decimal value)
        => $"{value:N2} ₺";
}
