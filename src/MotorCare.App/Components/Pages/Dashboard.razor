@page "/dashboard"
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Dashboard - BakımSuite</PageTitle>

@if (_isLoading)
{
    <div class="page-shell">
        <section class="loading-state">
            <strong>Dashboard yükleniyor</strong>
            <p>Lütfen bekleyin.</p>
        </section>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="page-shell">
        <section class="error-state">
            <strong>Dashboard alınamadı</strong>
            <p>@_error</p>
        </section>
    </div>
}
else if (_user is null)
{
    <div class="page-shell">
        <section class="empty-state">
            <strong>Oturum bulunamadı</strong>
            <p>Devam etmek için tekrar giriş yapın.</p>
        </section>
    </div>
}
else
{
    <div class="page-shell">
        <section class="hero-panel">
            <div>
                <div class="eyebrow">Günlük operasyon</div>
                <h1 class="page-title">Günaydın, @_user.FullName</h1>
                <p class="page-description">
                    <strong>@_user.TenantIdentifier</strong> - bugünkü randevu yoğunluğunu, aktif iş emirlerini ve ciroyu tek ekrandan takip edin.
                </p>
            </div>

            <div class="quick-actions action-bar">
                <a class="app-btn-primary" href="/appointments/create">+ Yeni Randevu</a>
                <a class="app-btn-primary" href="/service-orders/create">+ Yeni Servis</a>
                <a class="app-btn-secondary" href="/customers/create">Müşteri Ekle</a>
                <a class="app-btn-secondary" href="/vehicles/create">Araç Ekle</a>
            </div>
        </section>

        <section class="metric-grid">
            <div class="metric-card mc-primary">
                <div class="metric-label">Bugünkü Randevular</div>
                <div class="metric-value">@(_summary?.TodayAppointmentsCount ?? 0)</div>
                <div class="metric-sub">Bugün başlayan planlar</div>
            </div>
            <div class="metric-card mc-warning">
                <div class="metric-label">Aktif İş Emirleri</div>
                <div class="metric-value">@(_summary?.ActiveServiceOrdersCount ?? 0)</div>
                <div class="metric-sub">Açık, işlemde veya parça bekliyor</div>
            </div>
            <div class="metric-card mc-success">
                <div class="metric-label">Teslim Bekleyen</div>
                <div class="metric-value">@(_summary?.DeliveryWaitingCount ?? 0)</div>
                <div class="metric-sub">Tamamlandı ama teslim edilmedi</div>
            </div>
            <div class="metric-card mc-teal">
                <div class="metric-label">Günlük Ciro</div>
                <div class="metric-value">@((_summary?.DailyRevenue ?? 0).ToString("N0")) ₺</div>
                <div class="metric-sub">Bugün tahsil edilen tutar</div>
            </div>
        </section>

        <section class="quick-link-grid">
            <a class="quick-link-card" href="/appointments/create">
                <span class="quick-link-icon">R</span>
                <div class="quick-link-title">Yeni Randevu</div>
                <div class="quick-link-copy">Bugün için servis planı oluştur</div>
            </a>
            <a class="quick-link-card" href="/service-orders/create">
                <span class="quick-link-icon">S</span>
                <div class="quick-link-title">Yeni Servis Kaydı</div>
                <div class="quick-link-copy">Araç kabulü ve iş emri başlat</div>
            </a>
            <a class="quick-link-card" href="/customers/create">
                <span class="quick-link-icon">M</span>
                <div class="quick-link-title">Müşteri Ekle</div>
                <div class="quick-link-copy">Yeni müşteri kartı oluştur</div>
            </a>
            <a class="quick-link-card" href="/vehicles/create">
                <span class="quick-link-icon">A</span>
                <div class="quick-link-title">Araç Ekle</div>
                <div class="quick-link-copy">Yeni araç veya motosiklet kaydet</div>
            </a>
        </section>

        <section class="content-grid">
            <div class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">Bugünün Randevuları</div>
                        <div class="section-subtitle">Bugün planlanan servis akışınız</div>
                    </div>
                    <a class="app-btn-secondary" href="/appointments">Tümünü Gör</a>
                </div>

                <div class="summary-list">
                    @if (_summary?.TodayAppointments.Count is not > 0)
                    {
                        <div class="summary-list-item">
                            <strong>Bugün için randevu yok</strong>
                            <span class="text-muted">Yeni randevu oluşturduğunuzda burada listelenecek.</span>
                        </div>
                    }
                    else
                    {
                        @foreach (var appointment in _summary.TodayAppointments.OrderBy(x => x.StartAt))
                        {
                            <a class="summary-list-item summary-link" href="/appointments/@appointment.Id">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <strong>@appointment.CustomerName</strong>
                                    <span class="@GetAppointmentStatusBadgeClass(appointment.Status)">@appointment.StatusText</span>
                                </div>
                                <span class="text-muted" style="font-size:0.82rem">
                                    @appointment.StartAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                    @if (!string.IsNullOrWhiteSpace(appointment.Plate))
                                    {
                                        <span> · @appointment.Plate</span>
                                    }
                                    <span> · @appointment.TypeText</span>
                                </span>
                            </a>
                        }
                    }
                </div>
            </div>

            <div class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">Son Servis Kayıtları</div>
                        <div class="section-subtitle">En son açılan iş emirleri</div>
                    </div>
                    <a class="app-btn-secondary" href="/service-orders">Tümünü Gör</a>
                </div>

                <div class="summary-list">
                    @if (_summary?.RecentServiceOrders.Count is not > 0)
                    {
                        <div class="summary-list-item">
                            <strong>Henüz servis kaydı yok</strong>
                            <span class="text-muted">İlk iş emri oluştuğunda burada görünecek.</span>
                        </div>
                    }
                    else
                    {
                        @foreach (var order in _summary.RecentServiceOrders)
                        {
                            <a class="summary-list-item summary-link" href="/service-orders/@order.Id">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <strong>@order.OrderNo</strong>
                                    <span class="@GetStatusBadgeClass(order.Status)">@order.StatusText</span>
                                </div>
                                <span class="text-muted" style="font-size:0.82rem">
                                    @if (!string.IsNullOrWhiteSpace(order.CustomerName))
                                    {
                                        <span>@order.CustomerName</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(order.VehiclePlate))
                                    {
                                        <span> · @order.VehiclePlate</span>
                                    }
                                    <span> · @order.OpenedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                                    <span> · @order.GrandTotal.ToString("N0") ₺</span>
                                </span>
                            </a>
                        }
                    }
                </div>
            </div>
        </section>

        <section class="content-grid mt-4">
            <div class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">Aktif Oturum</div>
                        <div class="section-subtitle">Yetkili kullanıcı bilgisi</div>
                    </div>
                </div>

                <dl class="detail-list">
                    <dt>Kullanıcı</dt>
                    <dd>@_user.FullName</dd>
                    <dt>E-posta</dt>
                    <dd>@_user.Email</dd>
                    <dt>Rol</dt>
                    <dd>@_user.Role</dd>
                    <dt>Tenant</dt>
                    <dd>@_user.TenantIdentifier</dd>
                </dl>
            </div>
        </section>
    </div>
}

@code {
    private bool _isLoading = true;
    private string? _error;
    private CurrentUserResponse? _user;
    private DailySummaryResponse? _summary;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (!await AuthService.IsAuthenticatedAsync())
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        try
        {
            _user = await AuthService.GetCurrentUserAsync();
            if (_user is null)
            {
                NavigationManager.NavigateTo("/login");
                return;
            }

            _summary = await AuthService.GetDailySummaryAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "Open" => "status-badge badge-open",
        "InProgress" => "status-badge badge-progress",
        "WaitingForParts" => "status-badge badge-waiting",
        "Completed" => "status-badge badge-completed",
        "Delivered" => "status-badge badge-delivered",
        "Cancelled" => "status-badge badge-cancelled",
        _ => "status-badge"
    };

    private static string GetAppointmentStatusBadgeClass(int status) => status switch
    {
        1 => "status-badge appt-scheduled",
        2 => "status-badge appt-confirmed",
        3 => "status-badge appt-checkedin",
        4 => "status-badge appt-converted",
        5 => "status-badge appt-cancelled",
        6 => "status-badge appt-noshow",
        7 => "status-badge appt-completed",
        _ => "status-badge"
    };
}
