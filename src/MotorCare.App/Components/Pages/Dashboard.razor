@page "/dashboard"
@inject AuthService AuthService
@inject ServiceOrdersService ServiceOrdersService
@inject NavigationManager NavigationManager

<PageTitle>Dashboard — MotorCare</PageTitle>

@if (_isLoading)
{
    <div class="page-shell">
        <section class="loading-state">
            <strong>Dashboard yükleniyor</strong>
            <p>Lütfen bekleyin.</p>
        </section>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="page-shell">
        <section class="error-state">
            <strong>Dashboard alınamadı</strong>
            <p>@_error</p>
        </section>
    </div>
}
else if (_user is null)
{
    <div class="page-shell">
        <section class="empty-state">
            <strong>Oturum bulunamadı</strong>
            <p>Devam etmek için tekrar giriş yapın.</p>
        </section>
    </div>
}
else
{
    <div class="page-shell">
        <section class="hero-panel">
            <div>
                <div class="eyebrow">Günlük operasyon</div>
                <h1 class="page-title">Günaydın, @_user.FullName</h1>
                <p class="page-description">
                    <strong>@_user.TenantIdentifier</strong> — bugünkü yoğunluğu, tahsilatları ve açık işleri anlık takip edin.
                </p>
            </div>

            <div class="quick-actions action-bar">
                <a class="app-btn-primary" href="/service-orders/create">+ Yeni Servis</a>
                <a class="app-btn-secondary" href="/customers/create">Müşteri Ekle</a>
                <a class="app-btn-secondary" href="/vehicles/create">Araç Ekle</a>
            </div>
        </section>

        <section class="metric-grid">
            <div class="metric-card mc-primary">
                <div class="metric-label">Bugünkü Servisler</div>
                <div class="metric-value">@(_summary?.TotalServiceOrdersToday ?? 0)</div>
                <div class="metric-sub">Bugün açılan kayıt</div>
            </div>
            <div class="metric-card mc-warning">
                <div class="metric-label">Açık İşler</div>
                <div class="metric-value">@(_summary?.OpenServiceOrders ?? 0)</div>
                <div class="metric-sub">İşlemde veya bekleyen</div>
            </div>
            <div class="metric-card mc-success">
                <div class="metric-label">Tamamlanan</div>
                <div class="metric-value">@(_summary?.CompletedServiceOrdersToday ?? 0)</div>
                <div class="metric-sub">Bugün kapanan</div>
            </div>
            <div class="metric-card mc-teal">
                <div class="metric-label">Bugünkü Tahsilat</div>
                <div class="metric-value">@((_summary?.TotalPaymentsToday ?? 0).ToString("N0")) ₺</div>
                <div class="metric-sub">Nakit + kart + EFT</div>
            </div>
        </section>

        <section class="quick-link-grid">
            <a class="quick-link-card" href="/service-orders/create">
                <span class="quick-link-icon">⚙</span>
                <div class="quick-link-title">Yeni Servis Kaydı</div>
                <div class="quick-link-copy">Araç kabulünü hızla başlat</div>
            </a>
            <a class="quick-link-card" href="/customers">
                <span class="quick-link-icon">◎</span>
                <div class="quick-link-title">Müşteriler</div>
                <div class="quick-link-copy">Müşteri kartlarını görüntüle</div>
            </a>
            <a class="quick-link-card" href="/vehicles">
                <span class="quick-link-icon">◈</span>
                <div class="quick-link-title">Araç Sorgula</div>
                <div class="quick-link-copy">Plakaya göre araç bul</div>
            </a>
            <a class="quick-link-card" href="/service-orders">
                <span class="quick-link-icon">▤</span>
                <div class="quick-link-title">Servis Listesi</div>
                <div class="quick-link-copy">Tüm işleri filtrele ve izle</div>
            </a>
        </section>

        <section class="content-grid">
            <div class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">Son Servis Kayıtları</div>
                        <div class="section-subtitle">Servis operasyonlarının son akışı</div>
                    </div>
                    <a class="app-btn-secondary" href="/service-orders">Tümünü Gör</a>
                </div>

                <div class="summary-list">
                    @if (_recentOrders.Count == 0)
                    {
                        <div class="summary-list-item">
                            <strong>Henüz servis kaydı yok</strong>
                            <span class="text-muted">İlk kayıt için "Yeni Servis Kaydı" butonunu kullanın.</span>
                        </div>
                    }
                    else
                    {
                        @foreach (var order in _recentOrders)
                        {
                            <a class="summary-list-item summary-link" href="/service-orders/@order.Id">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <strong>@order.OrderNo</strong>
                                    <span class="@GetStatusBadgeClass(order.Status)">@GetStatusLabel(order.Status)</span>
                                </div>
                                <span class="text-muted" style="font-size:0.82rem">@order.OpenedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</span>
                            </a>
                        }
                    }
                </div>
            </div>

            <div class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">Aktif Oturum</div>
                        <div class="section-subtitle">Yetkili kullanıcı bilgisi</div>
                    </div>
                </div>

                <dl class="detail-list">
                    <dt>Kullanıcı</dt>
                    <dd>@_user.FullName</dd>
                    <dt>E-posta</dt>
                    <dd>@_user.Email</dd>
                    <dt>Rol</dt>
                    <dd>@_user.Role</dd>
                    <dt>Tenant</dt>
                    <dd>@_user.TenantIdentifier</dd>
                </dl>
            </div>
        </section>
    </div>
}

@code {
    private bool _isLoading = true;
    private string? _error;
    private CurrentUserResponse? _user;
    private DailySummaryResponse? _summary;
    private readonly List<ServiceOrderListItem> _recentOrders = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (!await AuthService.IsAuthenticatedAsync())
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        try
        {
            _user = await AuthService.GetCurrentUserAsync();
            if (_user is null)
            {
                NavigationManager.NavigateTo("/login");
                return;
            }

            _summary = await AuthService.GetDailySummaryAsync();

            var orders = await ServiceOrdersService.GetServiceOrdersAsync(null, null, null, null);
            if (orders is not null)
            {
                _recentOrders.Clear();
                _recentOrders.AddRange(orders.OrderByDescending(x => x.OpenedAt).Take(5));
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "Open" => "status-badge badge-open",
        "InProgress" => "status-badge badge-progress",
        "WaitingForParts" => "status-badge badge-waiting",
        "Completed" => "status-badge badge-completed",
        "Delivered" => "status-badge badge-delivered",
        "Cancelled" => "status-badge badge-cancelled",
        _ => "status-badge"
    };

    private static string GetStatusLabel(string status) => status switch
    {
        "Open" => "Açık",
        "InProgress" => "İşlemde",
        "WaitingForParts" => "Parça Bekliyor",
        "Completed" => "Tamamlandı",
        "Delivered" => "Teslim Edildi",
        "Cancelled" => "İptal",
        _ => status
    };
}
