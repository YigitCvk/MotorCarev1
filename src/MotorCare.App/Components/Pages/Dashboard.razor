@page "/dashboard"
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Dashboard</PageTitle>

@if (_isLoading)
{
    <div class="page-shell">
        <p class="text-muted">Dashboard yukleniyor...</p>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="page-shell">
        <div class="alert alert-danger">@_error</div>
    </div>
}
else if (_user is null)
{
    <div class="page-shell">
        <div class="alert alert-warning">Devam etmek icin giris yapin.</div>
    </div>
}
else
{
    <div class="page-shell">
        <section class="hero-panel">
            <div>
                <div class="eyebrow">Gunluk operasyon ozeti</div>
                <h1 class="page-title">Servis gununuzu tek ekrandan yonetin</h1>
                <p class="page-description">
                    @(_user.TenantIdentifier) icin bugunku hareketleri, tahsilatlari ve acik isleri hizlica gorun.
                </p>
            </div>

            <div class="quick-actions">
                <a class="btn btn-primary" href="/service-orders/create">Yeni Servis Kaydi</a>
                <a class="btn btn-outline-dark" href="/customers">Musteri Ekle</a>
                <a class="btn btn-outline-secondary" href="/vehicles">Arac Ekle</a>
            </div>
        </section>

        <section class="metric-grid">
            <div class="metric-card">
                <div class="metric-label">Bugunku Servisler</div>
                <div class="metric-value">@(_summary?.TotalServiceOrdersToday ?? 0)</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Acik Servisler</div>
                <div class="metric-value">@(_summary?.OpenServiceOrders ?? 0)</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Tamamlananlar</div>
                <div class="metric-value">@(_summary?.CompletedServiceOrdersToday ?? 0)</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Gunluk Tahsilat</div>
                <div class="metric-value">@((_summary?.TotalPaymentsToday ?? 0).ToString("N2"))</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Gunluk Ciro</div>
                <div class="metric-value">@((_summary?.TotalRevenueToday ?? 0).ToString("N2"))</div>
            </div>
            <div class="metric-card">
                <div class="metric-label">Bekleyen Tutar</div>
                <div class="metric-value">@((_summary?.PendingAmount ?? 0).ToString("N2"))</div>
            </div>
        </section>

        <section class="content-grid">
            <div class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">Operasyon Notlari</div>
                        <div class="section-subtitle">Hizli takip icin bugunun odak alanlari</div>
                    </div>
                </div>

                <div class="summary-list">
                    <div class="summary-list-item">
                        <strong>Servis Islemleri</strong>
                        <span>Yeni kayit acmak ve mevcut kayitlari filtrelemek icin servis ekranini kullanin.</span>
                    </div>
                    <div class="summary-list-item">
                        <strong>Tahsilatlar</strong>
                        <span>Gunluk tahsilat ve bekleyen tutar, onboard ekip icin ana KPI olarak hazir.</span>
                    </div>
                    <div class="summary-list-item">
                        <strong>Musteri Akisi</strong>
                        <span>Kayit kabul sirasinda once musteri, sonra arac, sonra servis kaydi akisini izleyin.</span>
                    </div>
                </div>
            </div>

            <div class="surface-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">Aktif Oturum</div>
                        <div class="section-subtitle">Yetkili kullanici bilgisi</div>
                    </div>
                </div>

                <dl class="detail-list">
                    <dt>Kullanici</dt>
                    <dd>@_user.FullName</dd>
                    <dt>E-posta</dt>
                    <dd>@_user.Email</dd>
                    <dt>Rol</dt>
                    <dd>@_user.Role</dd>
                    <dt>Tenant</dt>
                    <dd>@_user.TenantIdentifier</dd>
                </dl>
            </div>
        </section>
    </div>
}

@code {
    private bool _isLoading = true;
    private string? _error;
    private CurrentUserResponse? _user;
    private DailySummaryResponse? _summary;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (!await AuthService.IsAuthenticatedAsync())
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        try
        {
            _user = await AuthService.GetCurrentUserAsync();
            if (_user is null)
            {
                NavigationManager.NavigateTo("/login");
                return;
            }

            _summary = await AuthService.GetDailySummaryAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }
}
