@page "/customers"
@inject AuthService AuthService
@inject CustomersService CustomersService
@inject NavigationManager NavigationManager

<PageTitle>Müşteriler</PageTitle>

<div class="page-shell">
    <section class="hero-panel compact">
        <div>
            <div class="eyebrow">Müşteri modülü</div>
            <h1 class="page-title">Müşteriler</h1>
            <p class="page-description">Müşterileri arayın, profillerini görüntüleyin veya yeni müşteri ekleyin.</p>
        </div>
        <div class="quick-actions">
            <a class="btn btn-primary" href="/customers/create">+ Yeni Müşteri</a>
        </div>
    </section>

    <section class="surface-card">
        <div class="filter-grid">
            <div>
                <label class="form-label">Arama</label>
                <InputText class="form-control" @bind-Value="_searchText" placeholder="Ad, telefon veya e-posta ile ara" @onkeyup="OnSearchKeyUpAsync" />
            </div>
            <div class="filter-actions">
                <button type="button" class="btn btn-dark" @onclick="SearchAsync" disabled="@_isLoading">
                    @(_isLoading ? "Aranıyor..." : "Ara")
                </button>
                <button type="button" class="btn btn-outline-secondary" @onclick="ResetAsync" disabled="@_isLoading">
                    Temizle
                </button>
            </div>
        </div>
    </section>

    @if (_isLoading)
    {
        <div class="surface-card mt-3 text-muted">Müşteriler yükleniyor...</div>
    }

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger mt-3">@_error</div>
    }

    <section class="surface-card mt-3 d-none d-lg-block">
        <div class="table-responsive">
            <table class="table modern-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Ad Soyad</th>
                        <th>Telefon</th>
                        <th>E-posta</th>
                        <th>WhatsApp</th>
                        <th>Not</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_customers.Count == 0 && !_isLoading)
                    {
                        <tr>
                            <td colspan="5" class="text-muted py-4">Kayıt bulunamadı.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var c in _customers)
                        {
                            <tr class="clickable-row" @onclick="() => OpenDetail(c.Id)">
                                <td class="fw-semibold">@c.FullName</td>
                                <td>@(c.Phone ?? "-")</td>
                                <td>@(c.Email ?? "-")</td>
                                <td>@(c.Whatsapp ?? "-")</td>
                                <td class="text-truncate" style="max-width:180px">@(string.IsNullOrWhiteSpace(c.Notes) ? "-" : c.Notes)</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="card-list d-lg-none">
        @if (_customers.Count == 0 && !_isLoading)
        {
            <div class="surface-card text-muted">Kayıt bulunamadı.</div>
        }
        @foreach (var c in _customers)
        {
            <div class="surface-card clickable-card" @onclick="() => OpenDetail(c.Id)">
                <div class="fw-semibold">@c.FullName</div>
                @if (!string.IsNullOrWhiteSpace(c.Phone))
                {
                    <div class="text-muted small">@c.Phone</div>
                }
                @if (!string.IsNullOrWhiteSpace(c.Email))
                {
                    <div class="text-muted small">@c.Email</div>
                }
            </div>
        }
    </section>
</div>

@code {
    private readonly List<CustomerLookupResponse> _customers = [];
    private string? _searchText;
    private bool _isLoading;
    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!await AuthService.IsAuthenticatedAsync())
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        await SearchAsync();
    }

    private async Task OnSearchKeyUpAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchAsync();
    }

    private async Task SearchAsync()
    {
        try
        {
            _isLoading = true;
            _error = null;
            _customers.Clear();
            var result = await CustomersService.SearchCustomersAsync(_searchText);
            if (result is not null) _customers.AddRange(result);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task ResetAsync()
    {
        _searchText = null;
        await SearchAsync();
    }

    private void OpenDetail(Guid id) => NavigationManager.NavigateTo($"/customers/{id}");
}
