@page "/customers"
@inject AuthService AuthService
@inject CustomersService CustomersService
@inject NavigationManager NavigationManager

<PageTitle>Müşteriler</PageTitle>

<div class="page-shell">
    <section class="hero-panel compact">
        <div>
            <div class="eyebrow">Müşteri modülü</div>
            <h1 class="page-title">Müşteriler</h1>
            <p class="page-description">Müşterileri arayın, profillerini görüntüleyin veya yeni müşteri ekleyin.</p>
        </div>
        <div class="quick-actions action-bar">
            <a class="app-btn-primary" href="/customers/create">+ Yeni Müşteri</a>
        </div>
    </section>

    <section class="filter-card">
        <div class="filter-grid">
            <div>
                <label class="form-label">Arama</label>
                <InputText class="form-control" @bind-Value="_searchText" placeholder="Ad, telefon veya e-posta ile ara" @onkeyup="OnSearchKeyUpAsync" />
            </div>
            <div class="filter-actions">
                <button type="button" class="app-btn-primary" @onclick="SearchAsync" disabled="@_isLoading">
                    @(_isLoading ? "Aranıyor..." : "Ara")
                </button>
                <button type="button" class="app-btn-secondary" @onclick="ResetAsync" disabled="@_isLoading">
                    Temizle
                </button>
                <select class="form-select page-size-select" @bind="_pageSize" @bind:after="SearchAsync">
                    <option value="10">10 / sayfa</option>
                    <option value="20">20 / sayfa</option>
                    <option value="50">50 / sayfa</option>
                </select>
            </div>
        </div>
    </section>

    @if (_isLoading)
    {
        <section class="loading-state">
            <strong>Müşteriler yükleniyor</strong>
            <p>Lütfen bekleyin.</p>
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <section class="error-state">
            <strong>Müşteriler alınamadı</strong>
            <p>@_error</p>
        </section>
    }

    <section class="surface-card mt-3 desktop-only">
        <div class="responsive-table">
            <table class="table modern-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Ad Soyad</th>
                        <th>Telefon</th>
                        <th>E-posta</th>
                        <th>WhatsApp</th>
                        <th>Not</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_customers.Count == 0 && !_isLoading)
                    {
                        <tr>
                            <td colspan="5" class="text-muted py-4">Kayıt bulunamadı.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var customer in _customers)
                        {
                            <tr class="clickable-row" @onclick="() => OpenDetail(customer.Id)">
                                <td class="fw-semibold">@customer.FullName</td>
                                <td>@(customer.Phone ?? "-")</td>
                                <td>@(customer.Email ?? "-")</td>
                                <td>@(customer.Whatsapp ?? "-")</td>
                                <td class="text-truncate" style="max-width:180px">@(string.IsNullOrWhiteSpace(customer.Notes) ? "-" : customer.Notes)</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="mobile-card-list mobile-only">
        @if (_customers.Count == 0 && !_isLoading)
        {
            <section class="empty-state">
                <strong>Kayıt bulunamadı</strong>
                <p>Filtreleri temizleyin veya yeni müşteri ekleyin.</p>
            </section>
        }

        @foreach (var customer in _customers)
        {
            <article class="app-card clickable-card" @onclick="() => OpenDetail(customer.Id)">
                <div class="fw-semibold">@customer.FullName</div>
                @if (!string.IsNullOrWhiteSpace(customer.Phone))
                {
                    <div class="text-muted small">@customer.Phone</div>
                }
                @if (!string.IsNullOrWhiteSpace(customer.Email))
                {
                    <div class="text-muted small">@customer.Email</div>
                }
                @if (!string.IsNullOrWhiteSpace(customer.Notes))
                {
                    <div class="text-muted small mt-2">@customer.Notes</div>
                }
            </article>
        }
    </section>

    @if (_totalPages > 1 || _totalCount > 0)
    {
        <div class="pagination-bar">
            <div class="pagination-info">
                Toplam kayıt: <strong>@_totalCount</strong> &nbsp;·&nbsp; Sayfa <strong>@_pageNumber</strong> / <strong>@_totalPages</strong>
            </div>
            <div class="pagination-actions">
                <button class="app-btn-secondary" @onclick="PrevPageAsync" disabled="@(!_hasPreviousPage || _isLoading)">Önceki</button>
                <button class="app-btn-secondary" @onclick="NextPageAsync" disabled="@(!_hasNextPage || _isLoading)">Sonraki</button>
            </div>
        </div>
    }
</div>

@code {
    private readonly List<CustomerLookupResponse> _customers = [];
    private string? _searchText;
    private bool _isLoading;
    private string? _error;

    private int _pageNumber = 1;
    private int _pageSize = 20;
    private int _totalCount;
    private int _totalPages;
    private bool _hasPreviousPage;
    private bool _hasNextPage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!await AuthService.IsAuthenticatedAsync())
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        await SearchAsync();
    }

    private async Task OnSearchKeyUpAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchAsync();
    }

    private async Task SearchAsync()
    {
        _pageNumber = 1;
        await LoadAsync();
    }

    private async Task PrevPageAsync()
    {
        if (_pageNumber > 1) { _pageNumber--; await LoadAsync(); }
    }

    private async Task NextPageAsync()
    {
        if (_hasNextPage) { _pageNumber++; await LoadAsync(); }
    }

    private async Task LoadAsync()
    {
        try
        {
            _isLoading = true;
            _error = null;
            _customers.Clear();
            await InvokeAsync(StateHasChanged);

            var result = await CustomersService.SearchCustomersAsync(_searchText, _pageNumber, _pageSize);
            if (result is not null)
            {
                _customers.AddRange(result.Items);
                _totalCount = result.TotalCount;
                _totalPages = result.TotalPages;
                _hasPreviousPage = result.HasPreviousPage;
                _hasNextPage = result.HasNextPage;
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task ResetAsync()
    {
        _searchText = null;
        await SearchAsync();
    }

    private void OpenDetail(Guid id) => NavigationManager.NavigateTo($"/customers/{id}");
}
