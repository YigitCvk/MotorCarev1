@page "/settings/subscription"

<PageTitle>Abonelik / Paket</PageTitle>

<div class="page-shell">
    <section class="page-header">
        <div>
            <div class="eyebrow">Ayarlar</div>
            <h1 class="page-title">Abonelik / Paket</h1>
            <p class="page-description">Plan bilgisi, modül kullanımı ve tenant kapasite özetinin yer alacağı başlangıç alanı.</p>
        </div>
        <div class="page-header-actions">
            <a class="app-btn-secondary" href="/settings">Ayarlara Dön</a>
            <button type="button" class="app-btn-secondary">Yakında</button>
        </div>
    </section>

    <section class="admin-grid">
        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Plan Özeti</div>
                    <div class="section-subtitle">Aktif paket, modüller ve limit bilgisi</div>
                </div>
                <span class="status-badge status-info">Yakında</span>
            </div>
            <p class="admin-card-copy">BakımSuite paket detayları, kullanıcı limitleri ve modül erişimleri ileride burada gösterilecek.</p>
            <div class="admin-card-actions">
                <button type="button" class="app-btn-secondary">Yakında</button>
            </div>
        </article>

        <article class="app-card admin-card">
            <div class="admin-card-top">
                <div>
                    <div class="section-title">Faturalama Geçmişi</div>
                    <div class="section-subtitle">Dönemsel kullanım ve fatura kayıtları</div>
                </div>
                <span class="status-badge status-info">Yakında</span>
            </div>
            <p class="admin-card-copy">Abonelik yenilemeleri, fatura geçmişi ve plan geçişleri için alan hazırlanmıştır.</p>
            <div class="admin-card-actions">
                <button type="button" class="app-btn-secondary">Yakında</button>
            </div>
        </article>
    </section>
</div>
