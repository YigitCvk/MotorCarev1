@page "/vehicles"
@inject AuthService AuthService
@inject VehiclesService VehiclesService
@inject NavigationManager NavigationManager

<PageTitle>Araçlar</PageTitle>

<div class="page-shell">
    <section class="hero-panel compact">
        <div>
            <div class="eyebrow">Araç modülü</div>
            <h1 class="page-title">Araç Sorgula</h1>
            <p class="page-description">Plakaya göre araç kaydını sorgulayın veya yeni araç ekleyin.</p>
        </div>
        <div class="quick-actions action-bar">
            <a class="app-btn-primary" href="/vehicles/create">+ Yeni Araç Ekle</a>
        </div>
    </section>

    <section class="filter-card">
        <div class="filter-grid">
            <div>
                <label class="form-label">Plaka</label>
                <InputText class="form-control" @bind-Value="_plate" placeholder="34ABC123" @onkeyup="OnKeyUpAsync" />
            </div>
            <div class="filter-actions">
                <button type="button" class="app-btn-primary" @onclick="LookupAsync" disabled="@_isSearching">
                    @(_isSearching ? "Aranıyor..." : "Sorgula")
                </button>
                <button type="button" class="app-btn-secondary" @onclick="Clear">
                    Temizle
                </button>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <section class="error-state">
            <strong>Araç bilgisi alınamadı</strong>
            <p>@_error</p>
        </section>
    }

    @if (_vehicle is not null)
    {
        <section class="surface-card mt-3">
            <div class="section-header">
                <div>
                    <div class="section-title">Araç Bilgisi</div>
                    <div class="section-subtitle">Plaka, model ve müşteri bilgileri</div>
                </div>
                <div class="action-bar">
                    <a class="app-btn-primary" href="/service-orders/create">Bu Araçla Servis Aç</a>
                    <a class="app-btn-secondary" href="@($"/vehicles/{_vehicle.Id}/history")">Servis Geçmişi</a>
                </div>
            </div>

            <div class="content-grid">
                <div class="surface-card">
                    <dl class="detail-list">
                        <dt>Plaka</dt>
                        <dd>@_vehicle.PlateOriginal</dd>
                        <dt>Marka</dt>
                        <dd>@_vehicle.Brand</dd>
                        <dt>Model</dt>
                        <dd>@_vehicle.Model</dd>
                        <dt>Yıl</dt>
                        <dd>@_vehicle.Year</dd>
                    </dl>
                </div>

                <div class="surface-card">
                    <dl class="detail-list">
                        <dt>Müşteri</dt>
                        <dd>@(string.IsNullOrWhiteSpace(_vehicle.CustomerName) ? "-" : _vehicle.CustomerName)</dd>
                        <dt>Kayıt Özeti</dt>
                        <dd>@_vehicle.VehicleDisplay</dd>
                    </dl>
                </div>
            </div>
        </section>
    }
</div>

@code {
    private string? _plate;
    private VehicleLookupResponse? _vehicle;
    private bool _isSearching;
    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (!await AuthService.IsAuthenticatedAsync())
        {
            NavigationManager.NavigateTo("/login");
        }
    }

    private async Task OnKeyUpAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LookupAsync();
        }
    }

    private async Task LookupAsync()
    {
        if (string.IsNullOrWhiteSpace(_plate))
        {
            return;
        }

        try
        {
            _isSearching = true;
            _error = null;
            _vehicle = null;
            _vehicle = await VehiclesService.GetByPlateAsync(_plate);
            if (_vehicle is null)
            {
                _error = "Bu plakaya ait araç kaydı bulunamadı.";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSearching = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void Clear()
    {
        _plate = null;
        _vehicle = null;
        _error = null;
    }
}
