@page "/vehicles"
@inject AuthService AuthService
@inject VehiclesService VehiclesService
@inject NavigationManager NavigationManager

<PageTitle>Araçlar</PageTitle>

<div class="page-shell">
    <section class="hero-panel compact">
        <div>
            <div class="eyebrow">Araç modülü</div>
            <h1 class="page-title">Araç Sorgula</h1>
            <p class="page-description">Plakaya göre araç kaydını sorgulayın veya yeni araç ekleyin.</p>
        </div>
        <div class="quick-actions">
            <a class="btn btn-primary" href="/vehicles/create">+ Yeni Araç Ekle</a>
        </div>
    </section>

    <section class="surface-card">
        <div class="filter-grid">
            <div>
                <label class="form-label">Plaka</label>
                <InputText class="form-control" @bind-Value="_plate" placeholder="34ABC123" @onkeyup="OnKeyUpAsync" />
            </div>
            <div class="filter-actions">
                <button type="button" class="btn btn-dark" @onclick="LookupAsync" disabled="@_isSearching">
                    @(_isSearching ? "Aranıyor..." : "Sorgula")
                </button>
                <button type="button" class="btn btn-outline-secondary" @onclick="Clear">Temizle</button>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger mt-3">@_error</div>
    }

    @if (_vehicle is not null)
    {
        <section class="surface-card mt-3">
            <div class="section-title">Araç Bilgisi</div>
            <table class="table table-borderless table-sm mb-0 mt-2">
                <tbody>
                    <tr>
                        <th class="text-muted fw-normal" style="width:120px">Plaka</th>
                        <td class="fw-semibold">@_vehicle.PlateOriginal</td>
                    </tr>
                    <tr>
                        <th class="text-muted fw-normal">Marka</th>
                        <td>@_vehicle.Brand</td>
                    </tr>
                    <tr>
                        <th class="text-muted fw-normal">Model</th>
                        <td>@_vehicle.Model</td>
                    </tr>
                    <tr>
                        <th class="text-muted fw-normal">Yıl</th>
                        <td>@_vehicle.Year</td>
                    </tr>
                </tbody>
            </table>
            <div class="mt-3 d-flex gap-2">
                <a class="btn btn-primary" href="/service-orders/create">Bu Araçla Servis Aç</a>
            </div>
        </section>
    }
</div>

@code {
    private string? _plate;
    private VehicleLookupResponse? _vehicle;
    private bool _isSearching;
    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!await AuthService.IsAuthenticatedAsync())
            NavigationManager.NavigateTo("/login");
    }

    private async Task OnKeyUpAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LookupAsync();
    }

    private async Task LookupAsync()
    {
        if (string.IsNullOrWhiteSpace(_plate)) return;
        try
        {
            _isSearching = true;
            _error = null;
            _vehicle = null;
            _vehicle = await VehiclesService.GetByPlateAsync(_plate);
            if (_vehicle is null)
                _error = "Bu plakaya ait araç kaydı bulunamadı.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isSearching = false;
        }
        await InvokeAsync(StateHasChanged);
    }

    private void Clear()
    {
        _plate = null;
        _vehicle = null;
        _error = null;
    }
}
