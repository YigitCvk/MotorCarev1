@page "/appointments"
@rendermode InteractiveServer
@using System.Net
@inject AppointmentsService AppointmentsService
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Randevular</PageTitle>

<div class="page-shell">
    <section class="page-header">
        <div>
            <h1 class="page-title">Randevular</h1>
            <p class="page-description">Servis öncesi planlamayı tek ekrandan yönetin, filtreleyin ve iş emrine dönüştürün.</p>
        </div>
        <div class="page-header-actions">
            <a href="/appointments/create" class="app-btn-primary">+ Yeni Randevu</a>
        </div>
    </section>

    <section class="filter-card">
        <div class="filter-grid">
            <div>
                <label class="form-label">Hızlı filtre</label>
                <div class="d-flex flex-wrap gap-2">
                    <button type="button" class="@GetQuickFilterButtonClass("today")" @onclick='@(() => SetQuickFilterAsync("today"))'>Bugün</button>
                    <button type="button" class="@GetQuickFilterButtonClass("week")" @onclick='@(() => SetQuickFilterAsync("week"))'>Bu hafta</button>
                    <button type="button" class="@GetQuickFilterButtonClass(string.Empty)" @onclick='@(() => SetQuickFilterAsync(string.Empty))'>Tümü</button>
                </div>
            </div>

            <div>
                <label class="form-label">Başlangıç tarihi</label>
                <InputDate class="form-control" @bind-Value="_startDate" @bind:after="LoadAsync" />
            </div>

            <div>
                <label class="form-label">Bitiş tarihi</label>
                <InputDate class="form-control" @bind-Value="_endDate" @bind:after="LoadAsync" />
            </div>

            <div>
                <label class="form-label">Durum</label>
                <InputSelect class="form-select" @bind-Value="_statusFilter" @bind:after="LoadAsync">
                    <option value="">Tümü</option>
                    @foreach (var status in Enum.GetValues<AppointmentStatus>())
                    {
                        <option value="@((int)status)">@GetStatusText(status)</option>
                    }
                </InputSelect>
            </div>

            <div>
                <label class="form-label">Tür</label>
                <InputSelect class="form-select" @bind-Value="_typeFilter" @bind:after="LoadAsync">
                    <option value="">Tümü</option>
                    @foreach (var type in Enum.GetValues<AppointmentType>())
                    {
                        <option value="@((int)type)">@GetTypeText(type)</option>
                    }
                </InputSelect>
            </div>

            <div class="full-span">
                <label class="form-label">Ara</label>
                <InputText class="form-control" @bind-Value="_searchText" @bind:event="oninput" @bind:after="LoadAsync" placeholder="Müşteri adı, telefon veya plaka ile ara" />
            </div>
        </div>
    </section>

    @if (_loading)
    {
        <section class="loading-state">
            <strong>Randevular yükleniyor</strong>
            <p>Lütfen bekleyin.</p>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <section class="error-state">
            <strong>Randevular alınamadı</strong>
            <p>@_error</p>
            @if (!string.IsNullOrWhiteSpace(_errorEndpoint))
            {
                <p class="small text-muted mt-2">İstek: @_errorEndpoint</p>
            }
        </section>
    }
    else if (_items.Count == 0)
    {
        <section class="empty-state">
            <strong>Randevu bulunamadı</strong>
            <p>Filtreleri temizleyin veya yeni bir randevu oluşturun.</p>
        </section>
    }
    else
    {
        <section class="surface-card desktop-only">
            <div class="responsive-table">
                <table class="table modern-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Müşteri</th>
                            <th>Plaka</th>
                            <th>Tür</th>
                            <th>Başlangıç</th>
                            <th>Bitiş</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _items)
                        {
                            <tr class="clickable-row" @onclick="@(() => OpenDetail(item.Id))">
                                <td>
                                    <div class="fw-semibold">@item.CustomerName</div>
                                    <div class="text-muted small">@item.Phone</div>
                                </td>
                                <td>@(string.IsNullOrWhiteSpace(item.Plate) ? "-" : item.Plate)</td>
                                <td><span class="type-badge">@GetTypeText(item.Type)</span></td>
                                <td>@item.StartAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@item.EndAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                <td><span class="status-badge @GetStatusClass(item.Status)">@GetStatusText(item.Status)</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="mobile-card-list mobile-only">
            @foreach (var item in _items)
            {
                <article class="app-card clickable-card" @onclick="@(() => OpenDetail(item.Id))">
                    <div class="d-flex justify-content-between gap-3 align-items-start">
                        <div>
                            <div class="fw-semibold">@item.CustomerName</div>
                            <div class="text-muted small">@item.Phone</div>
                        </div>
                        <span class="status-badge @GetStatusClass(item.Status)">@GetStatusText(item.Status)</span>
                    </div>
                    <div class="mt-3 d-flex flex-column gap-2 text-muted small">
                        <span>Plaka: @(string.IsNullOrWhiteSpace(item.Plate) ? "-" : item.Plate)</span>
                        <span>Başlangıç: @item.StartAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                        <span>Bitiş: @item.EndAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                    <div class="mt-3">
                        <span class="type-badge">@GetTypeText(item.Type)</span>
                    </div>
                </article>
            }
        </section>
    }
</div>

@code {
    private readonly List<AppointmentDto> _items = [];
    private bool _loading;
    private string? _error;
    private string? _errorEndpoint;
    private string _quickFilter = "today";
    private int? _statusFilter;
    private int? _typeFilter;
    private string? _searchText;
    private DateTime? _startDate;
    private DateTime? _endDate;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (!await AuthService.IsAuthenticatedAsync())
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        ApplyQuickFilterDates();
        await LoadAsync();
    }

    private async Task SetQuickFilterAsync(string filter)
    {
        _quickFilter = filter;
        ApplyQuickFilterDates();
        await LoadAsync();
    }

    private void ApplyQuickFilterDates()
    {
        var today = DateTime.Today;

        if (_quickFilter == "today")
        {
            _startDate = today;
            _endDate = today;
        }
        else if (_quickFilter == "week")
        {
            var diff = ((int)today.DayOfWeek + 6) % 7;
            var monday = today.AddDays(-diff);
            _startDate = monday;
            _endDate = monday.AddDays(6);
        }
        else
        {
            _startDate = null;
            _endDate = null;
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        _errorEndpoint = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            DateTimeOffset? startFrom = _startDate.HasValue ? ToStartOfDay(_startDate.Value) : null;
            DateTimeOffset? endTo = _endDate.HasValue ? ToEndOfDay(_endDate.Value) : null;
            var status = _statusFilter.HasValue ? (AppointmentStatus?)_statusFilter.Value : null;
            var type = _typeFilter.HasValue ? (AppointmentType?)_typeFilter.Value : null;

            var result = await AppointmentsService.GetAppointmentsAsync(startFrom, endTo, status, type, _searchText);
            _items.Clear();
            if (result is not null)
            {
                _items.AddRange(result);
            }
        }
        catch (ApiException ex) when (ex.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
            _errorEndpoint = ex.Endpoint;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OpenDetail(Guid id)
    {
        NavigationManager.NavigateTo($"/appointments/{id}");
    }

    private static DateTimeOffset ToStartOfDay(DateTime date)
    {
        var local = new DateTime(date.Year, date.Month, date.Day, 0, 0, 0, DateTimeKind.Local);
        return new DateTimeOffset(local);
    }

    private static DateTimeOffset ToEndOfDay(DateTime date)
    {
        var local = new DateTime(date.Year, date.Month, date.Day, 23, 59, 59, DateTimeKind.Local);
        return new DateTimeOffset(local);
    }

    private string GetQuickFilterButtonClass(string filter)
    {
        return _quickFilter == filter ? "app-btn-primary" : "app-btn-secondary";
    }

    private static string GetStatusClass(AppointmentStatus status) => status switch
    {
        AppointmentStatus.Scheduled => "appt-scheduled",
        AppointmentStatus.Confirmed => "appt-confirmed",
        AppointmentStatus.CheckedIn => "appt-checkedin",
        AppointmentStatus.ConvertedToOrder => "appt-converted",
        AppointmentStatus.Cancelled => "appt-cancelled",
        AppointmentStatus.NoShow => "appt-noshow",
        AppointmentStatus.Completed => "appt-completed",
        _ => string.Empty
    };

    private static string GetTypeText(AppointmentType type) => type switch
    {
        AppointmentType.Maintenance => "Bakım",
        AppointmentType.Repair => "Onarım",
        AppointmentType.Cleaning => "Temizlik",
        AppointmentType.Washing => "Yıkama",
        AppointmentType.Inspection => "Kontrol",
        AppointmentType.TireChange => "Lastik Değişimi",
        _ => "Diğer"
    };

    private static string GetStatusText(AppointmentStatus status) => status switch
    {
        AppointmentStatus.Scheduled => "Planlandı",
        AppointmentStatus.Confirmed => "Onaylandı",
        AppointmentStatus.CheckedIn => "Servise Geldi",
        AppointmentStatus.ConvertedToOrder => "İş Emrine Dönüştü",
        AppointmentStatus.Cancelled => "İptal",
        AppointmentStatus.NoShow => "Gelmedi",
        AppointmentStatus.Completed => "Tamamlandı",
        _ => status.ToString()
    };
}
