@page "/appointments"
@rendermode InteractiveServer
@inject AppointmentsService AppointmentsService
@inject NavigationManager NavigationManager

<PageTitle>Randevular — MotorCare</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Randevular</h1>
        <p class="page-subtitle">@_items.Count randevu listeleniyor</p>
    </div>
    <a href="/appointments/create" class="btn btn-primary">+ Yeni Randevu</a>
</div>

<div class="surface-card mb-4">
    <div class="filter-grid">
        <div class="form-group">
            <label class="form-label">Hızlı Filtre</label>
            <div class="quick-filter-group">
                <button class="btn btn-sm @(_quickFilter == "today" ? "btn-primary" : "btn-outline")" @onclick='() => SetQuickFilter("today")'>Bugün</button>
                <button class="btn btn-sm @(_quickFilter == "week" ? "btn-primary" : "btn-outline")" @onclick='() => SetQuickFilter("week")'>Bu Hafta</button>
                <button class="btn btn-sm @(_quickFilter == "" ? "btn-primary" : "btn-outline")" @onclick='() => SetQuickFilter("")'>Tümü</button>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">Durum</label>
            <select class="form-control" @bind="_statusFilter" @bind:after="LoadAsync">
                <option value="">Tümü</option>
                <option value="1">Planlandı</option>
                <option value="2">Onaylandı</option>
                <option value="3">Giriş Yapıldı</option>
                <option value="4">Siparişe Dönüştürüldü</option>
                <option value="5">İptal Edildi</option>
                <option value="6">Gelmedi</option>
                <option value="7">Tamamlandı</option>
            </select>
        </div>

        <div class="form-group">
            <label class="form-label">Tür</label>
            <select class="form-control" @bind="_typeFilter" @bind:after="LoadAsync">
                <option value="">Tümü</option>
                <option value="1">Bakım</option>
                <option value="2">Tamir</option>
                <option value="3">Temizlik</option>
                <option value="4">Yıkama</option>
                <option value="5">Muayene</option>
                <option value="6">Lastik Değişimi</option>
                <option value="7">Diğer</option>
            </select>
        </div>

        <div class="form-group">
            <label class="form-label">Ara</label>
            <input class="form-control" placeholder="Müşteri adı veya plaka..." @bind="_searchText" @bind:event="oninput" @bind:after="LoadAsync" />
        </div>
    </div>
</div>

@if (_loading)
{
    <div class="loading-state">Yükleniyor...</div>
}
else if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_items.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">◷</div>
        <div class="empty-title">Randevu bulunamadı</div>
        <div class="empty-desc">Yeni randevu eklemek için butona tıklayın.</div>
    </div>
}
else
{
    <!-- Desktop table -->
    <div class="surface-card d-none d-lg-block">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Müşteri</th>
                    <th>Plaka</th>
                    <th>Tür</th>
                    <th>Başlangıç</th>
                    <th>Bitiş</th>
                    <th>Durum</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in _items)
                {
                    <tr class="clickable-row" @onclick="@(() => OpenDetail(item.Id))">
                        <td>
                            <div class="fw-600">@item.CustomerName</div>
                            <div class="text-muted small">@item.Phone</div>
                        </td>
                        <td>@(item.Plate ?? "—")</td>
                        <td><span class="type-badge">@item.TypeText</span></td>
                        <td>@item.StartAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@item.EndAt.LocalDateTime.ToString("HH:mm")</td>
                        <td><span class="status-badge @GetStatusClass(item.Status)">@item.StatusText</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Mobile cards -->
    <div class="d-lg-none">
        @foreach (var item in _items)
        {
            <div class="surface-card mb-3 clickable-row" @onclick="@(() => OpenDetail(item.Id))">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <div class="fw-600">@item.CustomerName</div>
                        <div class="text-muted small">@item.Phone</div>
                    </div>
                    <span class="status-badge @GetStatusClass(item.Status)">@item.StatusText</span>
                </div>
                <div class="d-flex gap-3 text-muted small">
                    <span>@(item.Plate ?? "Plakasız")</span>
                    <span>@item.StartAt.LocalDateTime.ToString("dd.MM HH:mm")</span>
                    <span class="type-badge">@item.TypeText</span>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<AppointmentDto> _items = [];
    private bool _loading;
    private string? _error;
    private string _quickFilter = "today";
    private string _statusFilter = "";
    private string _typeFilter = "";
    private string _searchText = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await LoadAsync();
    }

    private async Task SetQuickFilter(string filter)
    {
        _quickFilter = filter;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            DateTimeOffset? startFrom = null;
            DateTimeOffset? endTo = null;

            if (_quickFilter == "today")
            {
                var today = DateTimeOffset.Now.Date;
                startFrom = new DateTimeOffset(today, TimeSpan.Zero);
                endTo = startFrom.Value.AddDays(1).AddSeconds(-1);
            }
            else if (_quickFilter == "week")
            {
                var monday = DateTimeOffset.Now.Date.AddDays(-(int)DateTimeOffset.Now.DayOfWeek + 1);
                startFrom = new DateTimeOffset(monday, TimeSpan.Zero);
                endTo = startFrom.Value.AddDays(7).AddSeconds(-1);
            }

            AppointmentStatus? status = int.TryParse(_statusFilter, out var sv) && sv > 0
                ? (AppointmentStatus)sv : null;
            AppointmentType? type = int.TryParse(_typeFilter, out var tv) && tv > 0
                ? (AppointmentType)tv : null;

            var result = await AppointmentsService.GetAppointmentsAsync(startFrom, endTo, status, type, _searchText);
            _items = result?.ToList() ?? [];
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void OpenDetail(Guid id) => NavigationManager.NavigateTo($"/appointments/{id}");

    private static string GetStatusClass(AppointmentStatus s) => s switch
    {
        AppointmentStatus.Scheduled => "appt-scheduled",
        AppointmentStatus.Confirmed => "appt-confirmed",
        AppointmentStatus.CheckedIn => "appt-checkedin",
        AppointmentStatus.ConvertedToOrder => "appt-converted",
        AppointmentStatus.Cancelled => "appt-cancelled",
        AppointmentStatus.NoShow => "appt-noshow",
        AppointmentStatus.Completed => "appt-completed",
        _ => ""
    };
}
