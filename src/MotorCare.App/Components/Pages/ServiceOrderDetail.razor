@page "/service-orders/{Id:guid}"
@using System.Globalization
@using System.Net
@using MotorCare.Application.ServiceOrders
@using ServiceOrderDetailModel = MotorCare.App.Models.ServiceOrders.ServiceOrderDetail
@inject AuthService AuthService
@inject ServiceOrdersService ServiceOrdersService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Servis Detayı</PageTitle>

<div class="page-shell service-order-detail-page">
    @if (_isLoading)
    {
        <section class="loading-state">
            <strong>Servis detayı yükleniyor</strong>
            <p>Lütfen bekleyin.</p>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <section class="error-state">
            <strong>Servis detayı alınamadı</strong>
            <p>@_error</p>
            @if (!string.IsNullOrWhiteSpace(_errorEndpoint))
            {
                <p class="small text-muted mt-2">İstek: @_errorEndpoint</p>
            }
        </section>
    }
    else if (_order is null)
    {
        <section class="empty-state">
            <strong>Servis kaydı bulunamadı</strong>
            <p>Listeye dönüp tekrar deneyin.</p>
        </section>
    }
    else
    {
        <section class="page-header service-order-detail-header">
            <div class="service-order-detail-title">
                <h1 class="page-title">@_order.OrderNo</h1>
                <div class="page-description service-order-detail-meta">
                    <span class="@GetStatusBadgeClass(_order.Status)">@GetStatusLabel(_order.Status)</span>
                    @if (!string.IsNullOrWhiteSpace(_order.CustomerName))
                    {
                        <span>@_order.CustomerName</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(_order.VehiclePlate))
                    {
                        <span>@_order.VehiclePlate</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(_order.VehicleDisplay))
                    {
                        <span>@_order.VehicleDisplay</span>
                    }
                </div>
            </div>

            <div class="page-header-actions action-bar">
                <a class="app-btn-secondary" href="@($"/service-orders/{Id}/print")">Yazdır / PDF Al</a>
                <button type="button" class="app-btn-secondary" @onclick="BackToList">Listeye Dön</button>
                <button type="button" class="app-btn-secondary" @onclick="@(() => ScrollToAsync("operations-section"))">İşçilik</button>
                <button type="button" class="app-btn-secondary" @onclick="@(() => ScrollToAsync("parts-section"))">Parça</button>
                <button type="button" class="app-btn-secondary" @onclick="@(() => ScrollToAsync("consumables-section"))">Sarf Ürün</button>
                <button type="button" class="app-btn-secondary" @onclick="@(() => ScrollToAsync("attachments-section"))">Dosyalar</button>
                <button type="button" class="app-btn-secondary" @onclick="@(() => ScrollToAsync("payments-section"))">Tahsilat</button>
                <button type="button" class="app-btn-primary" @onclick="@(() => ScrollToAsync("status-section"))">Durum Güncelle</button>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(_actionMessage))
        {
            <section class="empty-state">
                <strong>İşlem başarılı</strong>
                <p>@_actionMessage</p>
            </section>
        }

        @if (_order.PaidTotal > _order.GrandTotal)
        {
            <section class="error-state">
                <strong>Fazla ödeme uyarısı</strong>
                <p>Bu kayıtta alınan ödeme toplam tutarı aşıyor. Yeni silme veya indirim işlemleri backend tarafında engellenir.</p>
            </section>
        }

        <section class="metric-grid service-order-metrics">
            <div class="metric-card mc-primary">
                <div class="metric-label">Toplam Tutar</div>
                <div class="metric-value">@_order.GrandTotal.ToString("N2") ₺</div>
                <div class="metric-sub">İşçilik + parça + sarf - indirim</div>
            </div>
            <div class="metric-card mc-success">
                <div class="metric-label">Tahsil Edilen</div>
                <div class="metric-value">@_order.PaidTotal.ToString("N2") ₺</div>
                <div class="metric-sub">Toplam ödeme</div>
            </div>
            <div class="metric-card @(_order.RemainingTotal > 0 ? "mc-warning" : "mc-success")">
                <div class="metric-label">Kalan Bakiye</div>
                <div class="metric-value">@Math.Max(0, _order.RemainingTotal).ToString("N2") ₺</div>
                <div class="metric-sub">@(_order.RemainingTotal > 0 ? "Ödeme bekliyor" : "Tahsilat tamamlandı")</div>
            </div>
            <div class="metric-card mc-teal">
                <div class="metric-label">Araç KM</div>
                <div class="metric-value">@_order.VehicleKm.ToString("N0")</div>
                <div class="metric-sub">Kabul sırasındaki kilometre</div>
            </div>
        </section>

        <section class="content-grid service-order-summary-grid">
            <section class="app-card service-order-summary-card">
                <div class="section-header">
                    <div>
                        <div class="section-title">Servis Özeti</div>
                        <div class="section-subtitle">Müşteri, araç ve kabul bilgileri</div>
                    </div>
                </div>

                <dl class="detail-list">
                    @if (!string.IsNullOrWhiteSpace(_order.CustomerName))
                    {
                        <dt>Müşteri</dt>
                        <dd>@_order.CustomerName</dd>
                    }
                    @if (!string.IsNullOrWhiteSpace(_order.VehiclePlate))
                    {
                        <dt>Plaka</dt>
                        <dd>@_order.VehiclePlate</dd>
                    }
                    @if (!string.IsNullOrWhiteSpace(_order.VehicleDisplay))
                    {
                        <dt>Araç</dt>
                        <dd>@_order.VehicleDisplay</dd>
                    }
                    <dt>Açılış</dt>
                    <dd>@_order.OpenedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</dd>
                    <dt>Güncelleme</dt>
                    <dd>@(_order.UpdatedAt?.LocalDateTime.ToString("dd.MM.yyyy HH:mm") ?? "-")</dd>
                    <dt>Kapanış</dt>
                    <dd>@(_order.ClosedAt?.LocalDateTime.ToString("dd.MM.yyyy HH:mm") ?? "-")</dd>
                    <dt>Şikayet</dt>
                    <dd>@(string.IsNullOrWhiteSpace(_order.Complaint) ? "-" : _order.Complaint)</dd>
                    @if (!string.IsNullOrWhiteSpace(_order.WorkDescription))
                    {
                        <dt>Yapılan İş</dt>
                        <dd>@_order.WorkDescription</dd>
                    }
                    @if (!string.IsNullOrWhiteSpace(_order.InternalNote))
                    {
                        <dt>İç Not</dt>
                        <dd>@_order.InternalNote</dd>
                    }
                </dl>
            </section>

            <section class="app-card service-order-status-card" id="status-section">
                <div class="section-header">
                    <div>
                        <div class="section-title">Durum ve Finansal</div>
                        <div class="section-subtitle">Durum güncelleme ve toplamlar</div>
                    </div>
                </div>

                <dl class="detail-list service-order-totals-list">
                    <dt>İşçilik</dt>
                    <dd>@_order.LaborTotal.ToString("N2") ₺</dd>
                    <dt>Parça</dt>
                    <dd>@_order.PartsTotal.ToString("N2") ₺</dd>
                    <dt>Sarf Ürün</dt>
                    <dd>@_order.ConsumablesTotal.ToString("N2") ₺</dd>
                    <dt>İndirim</dt>
                    <dd>@_order.DiscountTotal.ToString("N2") ₺</dd>
                    <dt>Genel Toplam</dt>
                    <dd>@_order.GrandTotal.ToString("N2") ₺</dd>
                    <dt>Tahsil Edilen</dt>
                    <dd>@_order.PaidTotal.ToString("N2") ₺</dd>
                    <dt>Kalan</dt>
                    <dd>@_order.RemainingTotal.ToString("N2") ₺</dd>
                </dl>

                <div class="inline-form sticky-mobile-action">
                    <label class="form-label fw-semibold">Yeni Durum</label>
                    <div class="inline-form-row">
                        <InputSelect class="form-select" @bind-Value="_statusRequest.Status">
                            <option value="InProgress">İşlemde</option>
                            <option value="WaitingForParts">Parça Bekliyor</option>
                            <option value="Completed">Teslime Hazır</option>
                            <option value="Delivered">Teslim Edildi</option>
                            <option value="Cancelled">İptal</option>
                        </InputSelect>
                        <button type="button" class="app-btn-primary" @onclick="UpdateStatusAsync" disabled="@_isWorking">
                            Kaydet
                        </button>
                    </div>
                    <div class="mt-3">
                        <label class="form-label">Açıklama</label>
                        <InputTextArea class="form-control" @bind-Value="_statusRequest.Note" maxlength="500" placeholder="Durum değişikliği ile ilgili kısa not ekleyin..." />
                        <div class="text-muted small mt-1">En fazla 500 karakter.</div>
                    </div>
                </div>
            </section>
        </section>

        <section class="app-card service-order-attachments-card" id="attachments-section">
            <div class="section-header">
                <div>
                    <div class="section-title">Dosyalar ve Fotoğraflar</div>
                    <div class="section-subtitle">Servis emri fotoğrafları, evraklar ve faturalar</div>
                </div>
            </div>

            <div class="service-order-attachments-form">
                <div>
                    <label class="form-label fw-semibold">Dosya seç</label>
                    <InputFile @key="_attachmentInputKey"
                               class="form-control"
                               OnChange="OnAttachmentFileChanged"
                               accept=".jpg,.jpeg,.png,.webp,.pdf,image/jpeg,image/png,image/webp,application/pdf" />
                    <div class="text-muted small mt-1">JPG, PNG, WEBP veya PDF. En fazla 5 MB.</div>
                    @if (_selectedAttachmentFile is not null)
                    {
                        <div class="text-muted small mt-1">@_selectedAttachmentFile.Name (@FormatFileSize(_selectedAttachmentFile.Size))</div>
                    }
                </div>
                <div>
                    <label class="form-label fw-semibold">Dosya türü</label>
                    <InputSelect class="form-select" @bind-Value="_attachmentType">
                        @foreach (var option in AttachmentTypeOptions)
                        {
                            <option value="@option.Value">@option.Text</option>
                        }
                    </InputSelect>
                </div>
                <div class="full-span">
                    <label class="form-label fw-semibold">Açıklama</label>
                    <InputTextArea class="form-control"
                                   @bind-Value="_attachmentDescription"
                                   maxlength="500"
                                   placeholder="Dosya ile ilgili kısa açıklama..." />
                    <div class="text-muted small mt-1">En fazla 500 karakter.</div>
                </div>
                <div class="full-span filter-actions">
                    <button type="button"
                            class="app-btn-primary"
                            @onclick="UploadAttachmentAsync"
                            disabled="@(_isWorking || _isUploadingAttachment || _selectedAttachmentFile is null)">
                        @(_isUploadingAttachment ? "Yükleniyor..." : "Yükle")
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_attachmentsError))
            {
                <div class="error-state compact mt-3">
                    <strong>Dosya işlemi tamamlanamadı</strong>
                    <p>@_attachmentsError</p>
                </div>
            }

            @if (_isAttachmentsLoading)
            {
                <div class="loading-state compact mt-3">
                    <strong>Dosyalar yükleniyor</strong>
                    <p>Lütfen bekleyin.</p>
                </div>
            }
            else if (_attachments.Count == 0)
            {
                <div class="empty-state compact mt-3">
                    <strong>Bu servis emrine henüz dosya eklenmemiş.</strong>
                    <p>Fotoğraf veya evrak eklemek için yukarıdaki formu kullanın.</p>
                </div>
            }
            else
            {
                <div class="service-order-attachments-grid mt-3">
                    @foreach (var attachment in _attachments)
                    {
                        <article class="service-order-attachment-card">
                            <div class="service-order-attachment-thumb">
                                @if (attachment.IsImage)
                                {
                                    <img id="@GetAttachmentImageElementId(attachment.Id)" alt="@attachment.OriginalFileName" />
                                }
                                else
                                {
                                    <div class="service-order-attachment-doc">
                                        <span>@(attachment.IsPdf ? "PDF" : "DOSYA")</span>
                                    </div>
                                }
                            </div>
                            <div class="service-order-attachment-body">
                                <div class="service-order-attachment-title-row">
                                    <strong>@attachment.OriginalFileName</strong>
                                    <span class="status-badge status-info">@attachment.AttachmentTypeText</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(attachment.Description))
                                {
                                    <p>@attachment.Description</p>
                                }
                                <div class="service-order-attachment-meta">
                                    <span>@FormatFileSize(attachment.FileSize)</span>
                                    <span>@(string.IsNullOrWhiteSpace(attachment.UploadedByUserName) ? "Sistem" : attachment.UploadedByUserName)</span>
                                    <span>@attachment.CreatedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</span>
                                </div>
                                <div class="service-order-attachment-actions">
                                    <button type="button" class="app-btn-secondary" @onclick="() => ViewAttachmentAsync(attachment)">Görüntüle</button>
                                    <button type="button" class="app-btn-secondary" @onclick="() => DownloadAttachmentAsync(attachment)">İndir</button>
                                    <button type="button"
                                            class="app-btn-secondary danger-action"
                                            @onclick="() => DeleteAttachmentAsync(attachment.Id)"
                                            disabled="@(_isWorking || _deletingAttachmentId == attachment.Id)">
                                        @(_deletingAttachmentId == attachment.Id ? "Siliniyor..." : "Sil")
                                    </button>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>

        <section class="content-grid service-order-work-grid">
            <section class="app-card" id="operations-section">
                <div class="section-header">
                    <div>
                        <div class="section-title">İşçilik / Operasyonlar</div>
                        <div class="section-subtitle">Yapılan işçilik kalemleri</div>
                    </div>
                </div>

                <div class="summary-list mb-4">
                    @if (_order.Operations.Count == 0)
                    {
                        <div class="summary-list-item text-muted">
                            <span>Henüz operasyon eklenmedi.</span>
                        </div>
                    }
                    else
                    {
                        @foreach (var op in _order.Operations)
                        {
                            <div class="summary-list-item service-order-line-item">
                                <div class="service-order-line-row">
                                    <div class="service-order-line-copy">
                                        <strong>@op.Description</strong>
                                    </div>
                                    <div class="service-order-line-actions">
                                        <span class="fw-bold">@op.Price.ToString("N2") ₺</span>
                                        <button type="button" class="app-btn-secondary" @onclick="() => RemoveOperationAsync(op.Id)" disabled="@(_isWorking || !CanRemoveOperation(op))">Sil</button>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>

                <div class="inline-form sticky-mobile-action">
                    <label class="form-label fw-semibold">Operasyon Ekle</label>
                    <div class="form-grid compact-grid">
                        <div class="full-span">
                            <InputText class="form-control" @bind-Value="_operationRequest.Description" placeholder="Yapılan işçilik veya operasyon" />
                        </div>
                        <div>
                            <label class="form-label">Fiyat (₺)</label>
                            <InputNumber class="form-control" @bind-Value="_operationRequest.Price" />
                        </div>
                        <div class="filter-actions">
                            <button type="button" class="app-btn-primary" @onclick="AddOperationAsync" disabled="@_isWorking">Ekle</button>
                        </div>
                    </div>
                </div>
            </section>

            <section class="app-card" id="parts-section">
                <div class="section-header">
                    <div>
                        <div class="section-title">Parçalar</div>
                        <div class="section-subtitle">Değişen veya kullanılan malzemeler</div>
                    </div>
                </div>

                <div class="summary-list mb-4">
                    @if (_order.Parts.Count == 0)
                    {
                        <div class="summary-list-item text-muted">
                            <span>Henüz parça eklenmedi.</span>
                        </div>
                    }
                    else
                    {
                        @foreach (var part in _order.Parts)
                        {
                            <div class="summary-list-item service-order-line-item">
                                <div class="service-order-line-row">
                                    <div class="service-order-line-copy">
                                        <strong>@part.PartName</strong>
                                        @if (!string.IsNullOrWhiteSpace(part.PartNumber))
                                        {
                                            <span class="text-muted ms-1 small">@part.PartNumber</span>
                                        }
                                        <div class="text-muted small">@part.Quantity x @part.UnitPrice.ToString("N2") ₺</div>
                                    </div>
                                    <div class="service-order-line-actions">
                                        <span class="fw-bold">@part.TotalPrice.ToString("N2") ₺</span>
                                        <button type="button" class="app-btn-secondary" @onclick="() => RemovePartAsync(part.Id)" disabled="@(_isWorking || !CanRemovePart(part))">Sil</button>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>

                <div class="inline-form sticky-mobile-action">
                    <label class="form-label fw-semibold">Parça Ekle</label>
                    <div class="form-grid compact-grid">
                        <div>
                            <label class="form-label">Parça Adı</label>
                            <InputText class="form-control" @bind-Value="_partRequest.PartName" placeholder="Fren balatası" />
                        </div>
                        <div>
                            <label class="form-label">Parça Kodu</label>
                            <InputText class="form-control" @bind-Value="_partRequest.PartNumber" placeholder="Opsiyonel" />
                        </div>
                        <div>
                            <label class="form-label">Birim Fiyat (₺)</label>
                            <InputNumber class="form-control" @bind-Value="_partRequest.UnitPrice" />
                        </div>
                        <div>
                            <label class="form-label">Adet</label>
                            <InputNumber class="form-control" @bind-Value="_partRequest.Quantity" />
                        </div>
                        <div class="full-span filter-actions">
                            <button type="button" class="app-btn-primary" @onclick="AddPartAsync" disabled="@_isWorking">Parça Ekle</button>
                        </div>
                    </div>
                </div>
            </section>
        </section>

        <section class="app-card" id="consumables-section">
            <div class="section-header">
                <div>
                    <div class="section-title">Kullanilan Sarf Ürünleri</div>
                    <div class="section-subtitle">Servis emriyle birlikte kaydedilen sarf ve tuketim kalemleri</div>
                </div>
            </div>

            <div class="summary-list">
                @if (_order.Consumables.Count == 0)
                {
                    <div class="summary-list-item text-muted">
                        <span>Bu servis emrinde kayıtlı sarf ürünu yok.</span>
                    </div>
                }
                else
                {
                    @foreach (var consumable in _order.Consumables)
                    {
                        <div class="summary-list-item service-order-line-item">
                            <div class="service-order-line-row">
                                <div class="service-order-line-copy">
                                    <strong>@consumable.ProductName</strong>
                                    @if (!string.IsNullOrWhiteSpace(consumable.Brand))
                                    {
                                        <span class="text-muted ms-1 small">@consumable.Brand</span>
                                    }
                                    <div class="text-muted small">
                                        @consumable.Category
                                        @if (!string.IsNullOrWhiteSpace(consumable.SubCategory))
                                        {
                                            <span> / @consumable.SubCategory</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(consumable.Specification) || !string.IsNullOrWhiteSpace(consumable.Notes))
                                    {
                                        <div class="text-muted small">
                                            @if (!string.IsNullOrWhiteSpace(consumable.Specification))
                                            {
                                                <span>Ozellik: @consumable.Specification</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(consumable.Notes))
                                            {
                                                <span> | Not: @consumable.Notes</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </section>

        <section class="app-card">
            <div class="section-header">
                <div>
                    <div class="section-title">Aktivite Akışı</div>
                    <div class="section-subtitle">Servis emri üzerinde gerçekleşen işlemler</div>
                </div>
            </div>

            @if (_isActivityFeedLoading)
            {
                <div class="loading-state compact">
                    <strong>Aktivite akışı yükleniyor</strong>
                    <p>Lütfen bekleyin.</p>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_activityFeedError))
            {
                <div class="error-state compact">
                    <strong>Aktivite akışı yüklenemedi.</strong>
                    <p>@_activityFeedError</p>
                </div>
            }
            else if (_activityFeed.Count == 0)
            {
                <div class="empty-state compact">
                    <strong>Bu servis emri için henüz aktivite bulunmuyor.</strong>
                </div>
            }
            else
            {
                <div class="service-order-timeline activity-feed-timeline">
                    @foreach (var activity in _activityFeed)
                    {
                        <article class="service-order-timeline-item activity-feed-item">
                            <div class="@GetActivityMarkerClass(activity.Severity)">
                                <span>@GetActivityIconText(activity.IconName)</span>
                            </div>
                            <div class="service-order-timeline-content activity-feed-content">
                                <div class="activity-feed-title-row">
                                    <div>
                                        <strong>@activity.Title</strong>
                                        <div class="text-muted small">@activity.CreatedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</div>
                                    </div>
                                    <span class="@GetActivityBadgeClass(activity.Severity)">@activity.ActivityTypeText</span>
                                </div>
                                <p>@(string.IsNullOrWhiteSpace(activity.Description) ? "Detay bulunmuyor." : activity.Description)</p>
                                <div class="activity-feed-meta">
                                    <span>Kullanıcı: @(string.IsNullOrWhiteSpace(activity.ActorName) ? "Sistem" : activity.ActorName)</span>
                                    @if (activity.Amount.HasValue)
                                    {
                                        <strong>@FormatActivityAmount(activity.Amount.Value, activity.Currency)</strong>
                                    }
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>

        <section class="app-card">
            <div class="section-header">
                <div>
                    <div class="section-title">Notlar</div>
                    <div class="section-subtitle">Müşteri şikayeti, servis notu ve iç notlar</div>
                </div>
            </div>

            <dl class="detail-list">
                <dt>Müşteri Şikayeti</dt>
                <dd>@(string.IsNullOrWhiteSpace(_order.Complaint) ? "-" : _order.Complaint)</dd>
                <dt>Servis Notu / Yapılan İş</dt>
                <dd>@(string.IsNullOrWhiteSpace(_order.WorkDescription) ? "-" : _order.WorkDescription)</dd>
                <dt>Usta / İç Not</dt>
                <dd>@(string.IsNullOrWhiteSpace(_order.InternalNote) ? "-" : _order.InternalNote)</dd>
            </dl>
        </section>

        <section class="app-card">
            <div class="section-header">
                <div>
                    <div class="section-title">Durum Geçmişi</div>
                    <div class="section-subtitle">Servis emri yaşam döngüsü ve değişiklik notları</div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_statusHistoryError))
            {
                <div class="summary-list-item text-muted">
                    <span>@_statusHistoryError</span>
                </div>
            }
            else if (_statusHistory.Count == 0)
            {
                <div class="summary-list-item text-muted">
                    <span>Henüz durum geçmişi bulunmuyor.</span>
                </div>
            }
            else
            {
                <div class="service-order-timeline">
                    @foreach (var item in _statusHistory)
                    {
                        <article class="service-order-timeline-item">
                            <div class="service-order-timeline-marker"></div>
                            <div class="service-order-timeline-content">
                                <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                                    <div>
                                        <strong>@GetStatusChangeText(item)</strong>
                                        <div class="text-muted small">@item.CreatedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</div>
                                    </div>
                                    <span class="@GetStatusBadgeClass(item.ToStatus)">@item.ToStatusText</span>
                                </div>
                                <div class="text-muted small mt-2">
                                    Kullanıcı: @(string.IsNullOrWhiteSpace(item.ChangedByUserName) ? "Sistem" : item.ChangedByUserName)
                                </div>
                                @if (!string.IsNullOrWhiteSpace(item.Note))
                                {
                                    <div class="mt-2">@item.Note</div>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        </section>

        <section class="app-card service-order-payments-card" id="payments-section">
            <div class="section-header">
                <div>
                    <div class="section-title">Tahsilatlar</div>
                    <div class="section-subtitle">Ödeme hareketleri ve tahsilat kayıtları</div>
                </div>
            </div>

            <div class="summary-list mb-4">
                @if (_order.Payments.Count == 0)
                {
                    <div class="summary-list-item text-muted">
                        <span>Henüz tahsilat kaydı yok.</span>
                    </div>
                }
                else
                {
                    @foreach (var payment in _order.Payments)
                    {
                        <div class="summary-list-item service-order-line-item">
                            <div class="service-order-line-row">
                                <div class="service-order-line-copy">
                                    <strong>@GetPaymentLabel(payment.Method)</strong>
                                    <div class="text-muted small">@payment.PaymentDate.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</div>
                                </div>
                                <span class="fw-bold text-success">@payment.Amount.ToString("N2") ₺</span>
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="form-grid compact-grid sticky-mobile-action">
                <div>
                    <label class="form-label">Tutar (₺)</label>
                    <InputNumber class="form-control" @bind-Value="_paymentRequest.Amount" />
                </div>
                <div>
                    <label class="form-label">Yöntem</label>
                    <InputSelect class="form-select" @bind-Value="_paymentRequest.Method">
                        <option value="Cash">Nakit</option>
                        <option value="CreditCard">Kredi Kartı</option>
                        <option value="BankTransfer">Havale / EFT</option>
                    </InputSelect>
                </div>
                <div>
                    <label class="form-label">Ödeme Tarihi</label>
                    <InputDate class="form-control" @bind-Value="_paymentDate" />
                </div>
                <div class="filter-actions">
                    <button type="button" class="app-btn-primary" @onclick="AddPaymentAsync" disabled="@_isWorking">Tahsilat Ekle</button>
                </div>
            </div>
        </section>
    }
</div>

@if (_previewAttachment is not null)
{
    <div class="attachment-preview-backdrop" @onclick="CloseAttachmentPreview">
        <section class="attachment-preview-dialog" @onclick:stopPropagation="true">
            <header>
                <div>
                    <strong>@_previewAttachment.OriginalFileName</strong>
                    <span>@_previewAttachment.AttachmentTypeText</span>
                </div>
                <button type="button" class="app-btn-secondary" @onclick="CloseAttachmentPreview">Kapat</button>
            </header>
            <div class="attachment-preview-stage">
                <img id="@GetAttachmentPreviewElementId(_previewAttachment.Id)" alt="@_previewAttachment.OriginalFileName" />
            </div>
            <footer>
                <button type="button" class="app-btn-primary" @onclick="() => DownloadAttachmentAsync(_previewAttachment!)">İndir</button>
            </footer>
        </section>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _isLoading = true;
    private bool _isWorking;
    private bool _isActivityFeedLoading;
    private bool _isAttachmentsLoading;
    private bool _isUploadingAttachment;
    private bool _shouldRefreshAttachmentImages;
    private bool _shouldRefreshPreviewImage;
    private string? _error;
    private string? _errorEndpoint;
    private string? _actionMessage;
    private ServiceOrderDetailModel? _order;
    private readonly List<ServiceOrderActivityFeedItem> _activityFeed = [];
    private readonly List<ServiceOrderStatusHistoryItem> _statusHistory = [];
    private readonly List<ServiceOrderAttachment> _attachments = [];
    private string? _activityFeedError;
    private string? _statusHistoryError;
    private string? _attachmentsError;
    private readonly AddOperationRequest _operationRequest = new();
    private readonly AddPartRequest _partRequest = new() { Quantity = 1 };
    private readonly AddPaymentRequest _paymentRequest = new() { Method = "Cash" };
    private readonly UpdateServiceOrderStatusRequest _statusRequest = new() { Status = "InProgress" };
    private IBrowserFile? _selectedAttachmentFile;
    private string _attachmentType = "BeforeServicePhoto";
    private string? _attachmentDescription;
    private Guid _attachmentInputKey = Guid.NewGuid();
    private Guid? _deletingAttachmentId;
    private ServiceOrderAttachment? _previewAttachment;
    private DateTime? _paymentDate = DateTime.Today;

    private static readonly IReadOnlyList<AttachmentTypeOption> AttachmentTypeOptions =
    [
        new("BeforeServicePhoto", "İşlem Öncesi Fotoğraf"),
        new("AfterServicePhoto", "İşlem Sonrası Fotoğraf"),
        new("DamagePhoto", "Hasar Fotoğrafı"),
        new("PartInvoice", "Parça Faturası"),
        new("ServiceDocument", "Servis Evrakı"),
        new("InspectionPhoto", "Ekspertiz Fotoğrafı"),
        new("Other", "Diğer")
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (!await AuthService.IsAuthenticatedAsync())
            {
                NavigationManager.NavigateTo("/login");
                return;
            }

            await LoadAsync();
            return;
        }

        if (_shouldRefreshAttachmentImages)
        {
            _shouldRefreshAttachmentImages = false;
            await LoadAttachmentImagesAsync();
        }

        if (_shouldRefreshPreviewImage && _previewAttachment is not null)
        {
            _shouldRefreshPreviewImage = false;
            await LoadAttachmentPreviewImageAsync(_previewAttachment);
        }
    }

    private async Task LoadAsync(bool resetMessages = true)
    {
        try
        {
            _isLoading = true;
            _error = null;
            _errorEndpoint = null;
            if (resetMessages)
            {
                _actionMessage = null;
            }

            _order = await ServiceOrdersService.GetServiceOrderByIdAsync(Id);
            if (_order is not null)
            {
                _statusRequest.Status = _order.Status is "Open" ? "InProgress" : _order.Status;
                await LoadActivityFeedAsync();
                await LoadStatusHistoryAsync();
                await LoadAttachmentsAsync();
            }
        }
        catch (ApiException ex) when (ex.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
            _errorEndpoint = ex.Endpoint;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task UpdateStatusAsync()
    {
        await ExecuteActionAsync(
            () => ServiceOrdersService.UpdateStatusAsync(Id, _statusRequest),
            "Servis durumu güncellendi.");
        _statusRequest.Note = null;
    }

    private async Task LoadActivityFeedAsync()
    {
        try
        {
            _isActivityFeedLoading = true;
            _activityFeedError = null;
            _activityFeed.Clear();

            var feed = await ServiceOrdersService.GetActivityFeedAsync(Id);
            if (feed is not null)
            {
                _activityFeed.AddRange(feed);
            }
        }
        catch (ApiException ex) when (ex.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
        {
            NavigationManager.NavigateTo("/login");
        }
        catch
        {
            _activityFeedError = "Aktivite akışı yüklenemedi.";
        }
        finally
        {
            _isActivityFeedLoading = false;
        }
    }

    private async Task LoadStatusHistoryAsync()
    {
        try
        {
            _statusHistoryError = null;
            _statusHistory.Clear();

            var history = await ServiceOrdersService.GetStatusHistoryAsync(Id);
            if (history is not null)
            {
                _statusHistory.AddRange(history);
            }
        }
        catch
        {
            _statusHistoryError = "Durum geçmişi şu anda alınamıyor. Servis detayını kullanmaya devam edebilirsiniz.";
        }
    }

    private async Task LoadAttachmentsAsync()
    {
        try
        {
            _isAttachmentsLoading = true;
            _attachmentsError = null;
            _attachments.Clear();
            _previewAttachment = null;

            var attachments = await ServiceOrdersService.GetAttachmentsAsync(Id);
            if (attachments is not null)
            {
                _attachments.AddRange(attachments);
            }

            _shouldRefreshAttachmentImages = _attachments.Any(x => x.IsImage);
        }
        catch (ApiException ex) when (ex.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
        {
            NavigationManager.NavigateTo("/login");
        }
        catch (ApiException ex)
        {
            _attachmentsError = ex.Message;
        }
        catch
        {
            _attachmentsError = "Dosyalar şu anda alınamıyor. Servis detayını kullanmaya devam edebilirsiniz.";
        }
        finally
        {
            _isAttachmentsLoading = false;
        }
    }

    private void OnAttachmentFileChanged(InputFileChangeEventArgs args)
    {
        _selectedAttachmentFile = args.File;
        _attachmentsError = null;

        if (_selectedAttachmentFile.Size > ServiceOrderAttachmentFileRules.MaxFileSizeBytes)
        {
            _attachmentsError = "Dosya boyutu 5 MB sınırını aşamaz.";
            return;
        }

        if (!ServiceOrderAttachmentFileRules.IsAllowedExtensionContentTypePair(_selectedAttachmentFile.Name, _selectedAttachmentFile.ContentType))
        {
            _attachmentsError = "Yalnızca jpg, jpeg, png, webp veya pdf dosyaları yüklenebilir.";
        }
    }

    private async Task UploadAttachmentAsync()
    {
        if (_selectedAttachmentFile is null)
        {
            _attachmentsError = "Lütfen bir dosya seçin.";
            return;
        }

        if (_selectedAttachmentFile.Size > ServiceOrderAttachmentFileRules.MaxFileSizeBytes)
        {
            _attachmentsError = "Dosya boyutu 5 MB sınırını aşamaz.";
            return;
        }

        if (!ServiceOrderAttachmentFileRules.IsAllowedExtensionContentTypePair(_selectedAttachmentFile.Name, _selectedAttachmentFile.ContentType))
        {
            _attachmentsError = "Dosya uzantısı ve içerik tipi desteklenmiyor.";
            return;
        }

        try
        {
            _isUploadingAttachment = true;
            _attachmentsError = null;
            _error = null;
            _errorEndpoint = null;
            _actionMessage = null;

            await ServiceOrdersService.UploadAttachmentAsync(
                Id,
                _selectedAttachmentFile,
                _attachmentType,
                _attachmentDescription);

            _actionMessage = "Dosya yüklendi.";
            _selectedAttachmentFile = null;
            _attachmentDescription = null;
            _attachmentInputKey = Guid.NewGuid();
            await LoadAttachmentsAsync();
            await LoadActivityFeedAsync();
        }
        catch (ApiException ex) when (ex.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
        {
            NavigationManager.NavigateTo("/login");
        }
        catch (ApiException ex)
        {
            _attachmentsError = ex.Message;
            _errorEndpoint = ex.Endpoint;
        }
        catch (Exception ex)
        {
            _attachmentsError = ex.Message;
        }
        finally
        {
            _isUploadingAttachment = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task DeleteAttachmentAsync(Guid attachmentId)
    {
        try
        {
            _deletingAttachmentId = attachmentId;
            _attachmentsError = null;
            _actionMessage = null;

            await ServiceOrdersService.DeleteAttachmentAsync(Id, attachmentId);
            _actionMessage = "Dosya pasife alındı.";
            await LoadAttachmentsAsync();
            await LoadActivityFeedAsync();
        }
        catch (ApiException ex) when (ex.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
        {
            NavigationManager.NavigateTo("/login");
        }
        catch (ApiException ex)
        {
            _attachmentsError = ex.Message;
            _errorEndpoint = ex.Endpoint;
        }
        catch (Exception ex)
        {
            _attachmentsError = ex.Message;
        }
        finally
        {
            _deletingAttachmentId = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ViewAttachmentAsync(ServiceOrderAttachment attachment)
    {
        if (attachment.IsImage)
        {
            _previewAttachment = attachment;
            _shouldRefreshPreviewImage = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        await OpenAttachmentAsync(attachment, download: false);
    }

    private Task DownloadAttachmentAsync(ServiceOrderAttachment attachment)
        => OpenAttachmentAsync(attachment, download: true);

    private async Task OpenAttachmentAsync(ServiceOrderAttachment attachment, bool download)
    {
        try
        {
            _attachmentsError = null;
            await JSRuntime.InvokeVoidAsync(
                "motorCareUi.openAuthorizedFile",
                attachment.FileUrl,
                TokenStorageService.AccessTokenKey,
                download,
                attachment.OriginalFileName);
        }
        catch (Exception ex) when (IsRecoverableUiException(ex))
        {
            _attachmentsError = "Dosya açılamadı. Lütfen tekrar deneyin.";
        }
    }

    private async Task LoadAttachmentImagesAsync()
    {
        foreach (var attachment in _attachments.Where(x => x.IsImage))
        {
            try
            {
                await JSRuntime.InvokeVoidAsync(
                    "motorCareUi.loadAuthorizedImage",
                    GetAttachmentImageElementId(attachment.Id),
                    attachment.FileUrl,
                    TokenStorageService.AccessTokenKey);
            }
            catch (Exception ex) when (IsRecoverableUiException(ex))
            {
                _attachmentsError ??= "Bazı görsel önizlemeleri yüklenemedi.";
            }
        }
    }

    private async Task LoadAttachmentPreviewImageAsync(ServiceOrderAttachment attachment)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync(
                "motorCareUi.loadAuthorizedImage",
                GetAttachmentPreviewElementId(attachment.Id),
                attachment.FileUrl,
                TokenStorageService.AccessTokenKey);
        }
        catch (Exception ex) when (IsRecoverableUiException(ex))
        {
            _attachmentsError = "Görsel önizleme yüklenemedi.";
        }
    }

    private void CloseAttachmentPreview()
    {
        _previewAttachment = null;
    }

    private async Task AddOperationAsync()
    {
        if (string.IsNullOrWhiteSpace(_operationRequest.Description))
        {
            _error = "İşlem açıklaması zorunludur.";
            return;
        }

        if (_operationRequest.Price < 0)
        {
            _error = "Tutar geçersiz.";
            return;
        }

        await ExecuteActionAsync(
            () => ServiceOrdersService.AddOperationAsync(Id, _operationRequest),
            "Operasyon eklendi.");

        _operationRequest.Description = string.Empty;
        _operationRequest.Price = 0;
    }

    private async Task RemoveOperationAsync(Guid operationId)
    {
        await ExecuteActionAsync(
            () => ServiceOrdersService.RemoveOperationAsync(Id, operationId),
            "Operasyon kaldırıldı.");
    }

    private async Task AddPartAsync()
    {
        if (string.IsNullOrWhiteSpace(_partRequest.PartName))
        {
            _error = "Parça adı zorunludur.";
            return;
        }

        if (_partRequest.UnitPrice < 0 || _partRequest.Quantity <= 0)
        {
            _error = "Tutar geçersiz.";
            return;
        }

        await ExecuteActionAsync(
            () => ServiceOrdersService.AddPartAsync(Id, _partRequest),
            "Parça eklendi.");

        _partRequest.PartName = string.Empty;
        _partRequest.PartNumber = null;
        _partRequest.UnitPrice = 0;
        _partRequest.Quantity = 1;
    }

    private async Task RemovePartAsync(Guid partId)
    {
        await ExecuteActionAsync(
            () => ServiceOrdersService.RemovePartAsync(Id, partId),
            "Parça kaldırıldı.");
    }

    private async Task AddPaymentAsync()
    {
        if (_paymentRequest.Amount <= 0)
        {
            _error = "Tutar geçersiz.";
            return;
        }

        _paymentRequest.PaymentDate = _paymentDate.HasValue
            ? new DateTimeOffset(DateTime.SpecifyKind(_paymentDate.Value, DateTimeKind.Local))
            : null;

        await ExecuteActionAsync(
            () => ServiceOrdersService.AddPaymentAsync(Id, _paymentRequest),
            "Tahsilat eklendi.");

        _paymentRequest.Amount = 0;
        _paymentRequest.Method = "Cash";
        _paymentDate = DateTime.Today;
    }

    private async Task ExecuteActionAsync(Func<Task> action, string successMessage)
    {
        try
        {
            _isWorking = true;
            _error = null;
            _errorEndpoint = null;
            _actionMessage = null;

            await action();
            _actionMessage = successMessage;
            await LoadAsync(resetMessages: false);
        }
        catch (ApiException ex) when (ex.StatusCode is HttpStatusCode.Unauthorized or HttpStatusCode.Forbidden)
        {
            NavigationManager.NavigateTo("/login");
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
            _errorEndpoint = ex.Endpoint;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isWorking = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void BackToList()
    {
        TryNavigateTo("/service-orders");
    }

    private async Task ScrollToAsync(string id)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("motorCareUi.scrollToElement", id);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or InvalidOperationException or ObjectDisposedException or TaskCanceledException or OperationCanceledException)
        {
            TryNavigateTo($"/service-orders/{Id}#{id}", replace: true);
        }
    }

    private void TryNavigateTo(string uri, bool replace = false)
    {
        try
        {
            NavigationManager.NavigateTo(uri, replace: replace);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or InvalidOperationException or ObjectDisposedException or TaskCanceledException or OperationCanceledException)
        {
            _error = "Sayfa gecisi tamamlanamadi. Lutfen tekrar deneyin.";
        }
    }

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "Open" => "status-badge badge-open",
        "InProgress" => "status-badge badge-progress",
        "WaitingForParts" => "status-badge badge-waiting",
        "Completed" => "status-badge badge-completed",
        "Delivered" => "status-badge badge-delivered",
        "Cancelled" => "status-badge badge-cancelled",
        _ => "status-badge"
    };

    private static string GetStatusLabel(string status) => status switch
    {
        "Open" => "Açık",
        "InProgress" => "İşlemde",
        "WaitingForParts" => "Parça Bekliyor",
        "Completed" => "Teslime Hazır",
        "Delivered" => "Teslim Edildi",
        "Cancelled" => "İptal",
        _ => status
    };

    private static string GetPaymentLabel(string method) => method switch
    {
        "Cash" => "Nakit",
        "CreditCard" => "Kredi Kartı",
        "BankTransfer" => "Havale / EFT",
        _ => method
    };

    private static string GetActivityMarkerClass(string severity)
        => $"service-order-timeline-marker activity-feed-marker activity-feed-marker-{NormalizeActivitySeverity(severity)}";

    private static string GetActivityBadgeClass(string severity)
        => $"status-badge activity-feed-badge activity-feed-badge-{NormalizeActivitySeverity(severity)}";

    private static string NormalizeActivitySeverity(string? severity) => severity switch
    {
        "success" => "success",
        "warning" => "warning",
        "danger" => "danger",
        _ => "info"
    };

    private static string GetActivityIconText(string? iconName) => iconName switch
    {
        "wrench" => "IS",
        "package" => "PR",
        "credit-card" => "TL",
        "file" => "DF",
        "note" => "NT",
        _ => "AK"
    };

    private static string FormatActivityAmount(decimal amount, string? currency)
    {
        var formattedAmount = amount.ToString("N2", CultureInfo.GetCultureInfo("tr-TR"));
        return string.Equals(currency, "TRY", StringComparison.OrdinalIgnoreCase)
            ? $"{formattedAmount} TL"
            : $"{formattedAmount} {currency}";
    }

    private static string GetStatusChangeText(ServiceOrderStatusHistoryItem item)
        => string.IsNullOrWhiteSpace(item.FromStatusText)
            ? item.ToStatusText
            : $"{item.FromStatusText} → {item.ToStatusText}";

    private static string GetAttachmentImageElementId(Guid id) => $"attachment-img-{id:N}";

    private static string GetAttachmentPreviewElementId(Guid id) => $"attachment-preview-{id:N}";

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024)
        {
            return $"{bytes} B";
        }

        if (bytes < 1024 * 1024)
        {
            return $"{bytes / 1024d:N1} KB";
        }

        return $"{bytes / 1024d / 1024d:N1} MB";
    }

    private static bool IsRecoverableUiException(Exception exception)
        => exception is JSException or JSDisconnectedException or InvalidOperationException or ObjectDisposedException or TaskCanceledException or OperationCanceledException;

    private bool CanRemoveOperation(ServiceOrderOperation operation)
        => _order is not null && _order.PaidTotal <= Math.Max(0, _order.GrandTotal - operation.Price);

    private bool CanRemovePart(ServiceOrderPart part)
        => _order is not null && _order.PaidTotal <= Math.Max(0, _order.GrandTotal - part.TotalPrice);

    private sealed record AttachmentTypeOption(string Value, string Text);
}
