<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="@AssetPath("/bootstrap/bootstrap.min.css")" />
    <link rel="stylesheet" href="@AssetPath("/app.css")" />
    <link rel="stylesheet" href="@AssetPath("/MotorCare.App.styles.css")" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <StaticSeoHead />
    <HeadOutlet @rendermode="@(new InteractiveServerRenderMode(prerender: true))" />
</head>

<body>
    <Routes @rendermode="@(new InteractiveServerRenderMode(prerender: true))" />
    <script>
        window.motorCareStorage = window.motorCareStorage || {
            setTokens: function (accessKey, accessToken, refreshKey, refreshToken) {
                localStorage.setItem(accessKey, accessToken);
                localStorage.setItem(refreshKey, refreshToken);
            },
            get: function (key) {
                return localStorage.getItem(key);
            },
            clearTokens: function (accessKey, refreshKey) {
                localStorage.removeItem(accessKey);
                localStorage.removeItem(refreshKey);
            }
        };
        window.motorCareUi = window.motorCareUi || {
            scrollToElement: function (id) {
                var element = document.getElementById(id);
                if (element) {
                    element.scrollIntoView({ behavior: "smooth", block: "start" });
                }
            },
            loadAuthorizedImage: async function (elementId, url, tokenKey) {
                var element = document.getElementById(elementId);
                if (!element) {
                    return;
                }

                var token = localStorage.getItem(tokenKey);
                var headers = token ? { "Authorization": "Bearer " + token } : {};
                var response = await fetch(url, { headers: headers });
                if (!response.ok) {
                    return;
                }

                var blob = await response.blob();
                var previousUrl = element.dataset.objectUrl;
                var objectUrl = URL.createObjectURL(blob);
                element.src = objectUrl;
                element.dataset.objectUrl = objectUrl;

                if (previousUrl) {
                    URL.revokeObjectURL(previousUrl);
                }
            },
            openAuthorizedFile: async function (url, tokenKey, download, fileName) {
                var token = localStorage.getItem(tokenKey);
                var headers = token ? { "Authorization": "Bearer " + token } : {};
                var requestUrl = new URL(url, window.location.origin);
                if (download) {
                    requestUrl.searchParams.set("download", "true");
                }

                var response = await fetch(requestUrl.toString(), { headers: headers });
                if (!response.ok) {
                    throw new Error("Dosya alınamadı.");
                }

                var blob = await response.blob();
                var objectUrl = URL.createObjectURL(blob);
                var anchor = document.createElement("a");
                anchor.href = objectUrl;

                if (download) {
                    anchor.download = fileName || "dosya";
                    document.body.appendChild(anchor);
                    anchor.click();
                    anchor.remove();
                } else {
                    anchor.target = "_blank";
                    anchor.rel = "noopener";
                    document.body.appendChild(anchor);
                    anchor.click();
                    anchor.remove();
                }

                window.setTimeout(function () {
                    URL.revokeObjectURL(objectUrl);
                }, 60000);
            },
            copyText: async function (value) {
                if (!value) {
                    return false;
                }

                if (navigator.clipboard && window.isSecureContext) {
                    try {
                        await navigator.clipboard.writeText(value);
                        return true;
                    } catch (error) {
                    }
                }

                var textArea = document.createElement("textarea");
                textArea.value = value;
                textArea.setAttribute("readonly", "");
                textArea.style.position = "fixed";
                textArea.style.opacity = "0";
                document.body.appendChild(textArea);
                textArea.select();

                try {
                    return document.execCommand("copy");
                } finally {
                    textArea.remove();
                }
            }
        };
    </script>
    <script src="@AssetPath("/js/storage.js")"></script>
    <script src="@AssetPath("/_framework/blazor.web.js")"></script>
</body>

</html>

@code {
    private static readonly string AssetVersion = typeof(App).Module.ModuleVersionId.ToString("N");

    private static string AssetPath(string path) => $"{path}?v={AssetVersion}";
}
