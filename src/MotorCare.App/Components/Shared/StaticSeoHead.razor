@using System.Text.Json
@using Microsoft.AspNetCore.Http
@using Microsoft.Extensions.Options
@using MotorCare.App.Configuration
@inject IHttpContextAccessor HttpContextAccessor
@inject IOptions<SeoOptions> SeoOptionsAccessor

@if (IsLandingPage)
{
    <title>@Seo.DefaultTitle</title>
    <meta name="description" content="@Seo.DefaultDescription" />
    <meta name="keywords" content="servis yönetim sistemi, oto servis yazılımı, motosiklet servis yazılımı, ekspertiz yazılımı, araç geçmişi, servis emri takip, randevu yönetimi" />
    <meta name="robots" content="@LandingRobots" />
    <link rel="canonical" href="@LandingUrl" />
    <meta property="og:title" content="GarajPass | Servis ve Ekspertiz Yönetim Platformu" />
    <meta property="og:description" content="Servis operasyonlarını, araç kayıtlarını, randevuları, servis emirlerini ve ekspertiz süreçlerini tek panelden yönetin." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@LandingUrl" />
    @if (!string.IsNullOrWhiteSpace(OgImageUrl))
    {
        <meta property="og:image" content="@OgImageUrl" />
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="GarajPass | Servis ve Ekspertiz Yönetim Platformu" />
    <meta name="twitter:description" content="Servis operasyonlarını, araç kayıtlarını, randevuları, servis emirlerini ve ekspertiz süreçlerini tek panelden yönetin." />
    @if (!string.IsNullOrWhiteSpace(OgImageUrl))
    {
        <meta name="twitter:image" content="@OgImageUrl" />
    }
    <script type="application/ld+json">@((MarkupString)SoftwareApplicationJsonLd)</script>
    <script type="application/ld+json">@((MarkupString)OrganizationJsonLd)</script>
}
else if (IsServiceRecordPage)
{
    <title>GarajPass Dijital Servis Kaydı</title>
    <meta name="description" content="Bu kayıt GarajPass üzerinden doğrulanabilir dijital kayıt olarak oluşturulmuştur." />
    <meta name="robots" content="noindex,nofollow" />
    <meta property="og:title" content="GarajPass Dijital Servis Kaydı" />
    <meta property="og:description" content="Bu kayıt GarajPass üzerinden doğrulanabilir dijital kayıt olarak oluşturulmuştur." />
    <meta property="og:type" content="article" />
    @if (!string.IsNullOrWhiteSpace(OgImageUrl))
    {
        <meta property="og:image" content="@OgImageUrl" />
    }
    <meta name="twitter:card" content="summary_large_image" />
}
else if (IsInspectionReportPage)
{
    <title>GarajPass Dijital Ekspertiz Kaydı</title>
    <meta name="description" content="Bu kayıt GarajPass üzerinden doğrulanabilir dijital kayıt olarak oluşturulmuştur." />
    <meta name="robots" content="noindex,nofollow" />
    <meta property="og:title" content="GarajPass Dijital Ekspertiz Kaydı" />
    <meta property="og:description" content="Bu kayıt GarajPass üzerinden doğrulanabilir dijital kayıt olarak oluşturulmuştur." />
    <meta property="og:type" content="article" />
    @if (!string.IsNullOrWhiteSpace(OgImageUrl))
    {
        <meta property="og:image" content="@OgImageUrl" />
    }
    <meta name="twitter:card" content="summary_large_image" />
}
else if (ShouldNoIndex)
{
    <meta name="robots" content="noindex,nofollow" />
}

@code {
    private SeoOptions Seo => SeoOptionsAccessor.Value;

    private string RequestPath
    {
        get
        {
            var path = HttpContextAccessor.HttpContext?.Request.Path.Value;
            return string.IsNullOrWhiteSpace(path) ? "/" : path;
        }
    }

    private bool IsLandingPage => RequestPath is "/" or "";
    private bool IsServiceRecordPage => RequestPath.StartsWith("/public/service-record/", StringComparison.OrdinalIgnoreCase);
    private bool IsInspectionReportPage => RequestPath.StartsWith("/public/inspection-report/", StringComparison.OrdinalIgnoreCase);
    private bool ShouldNoIndex => !IsLandingPage;
    private string LandingRobots => Seo.RobotsIndexEnabled ? "index,follow" : "noindex,nofollow";
    private string LandingUrl => AbsoluteUrl("/");
    private string OgImageUrl => AbsoluteUrl(Seo.OgImageUrl);

    private string SoftwareApplicationJsonLd => JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "SoftwareApplication",
        ["name"] = Seo.SiteName,
        ["applicationCategory"] = "BusinessApplication",
        ["operatingSystem"] = "Web",
        ["url"] = AbsoluteUrl("/"),
        ["description"] = Seo.DefaultDescription
    });

    private string OrganizationJsonLd => JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "Organization",
        ["name"] = Seo.SiteName,
        ["url"] = AbsoluteUrl("/"),
        ["logo"] = OgImageUrl
    });

    private string AbsoluteUrl(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return string.Empty;
        }

        if (Uri.TryCreate(path, UriKind.Absolute, out var absolute))
        {
            return absolute.ToString();
        }

        var baseUrl = string.IsNullOrWhiteSpace(Seo.SiteBaseUrl)
            ? "http://46.225.166.254"
            : Seo.SiteBaseUrl.Trim().TrimEnd('/');
        var normalizedPath = path.StartsWith('/') ? path : "/" + path;

        return baseUrl + normalizedPath;
    }
}
