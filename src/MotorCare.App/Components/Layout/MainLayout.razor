@inherits LayoutComponentBase
@implements IDisposable
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<div class="app-shell">
    <AppSidebar />

    <div class="app-main">
        <header class="app-topbar">
            <div class="app-topbar-search">
                <input type="text" class="app-search-input" placeholder="Ara, plaka, müşteri veya servis no" />
            </div>

            <div class="app-topbar-actions">
                <a class="app-btn-primary" href="/service-orders/create">+ Yeni</a>

                @if (_currentUser is not null)
                {
                    <div class="app-user-chip">
                        <div class="app-user-chip-label">@_currentUser.TenantIdentifier</div>
                        <div class="app-user-chip-value">@_currentUser.FullName · @_currentUser.Role</div>
                    </div>

                    <button type="button" class="app-btn-secondary" @onclick="LogoutAsync">Çıkış Yap</button>
                }
                else
                {
                    <div class="app-user-chip app-user-chip-muted">
                        <div class="app-user-chip-label">Oturum</div>
                        <div class="app-user-chip-value">Bağlı değil</div>
                    </div>
                }
            </div>
        </header>

        <main class="app-content">
            @Body
        </main>
    </div>
</div>

<nav class="mobile-bottom-nav">
    <NavLink href="/dashboard" Match="NavLinkMatch.Prefix">
        <span class="nav-icon">DB</span>
        <span>Dashboard</span>
    </NavLink>
    <NavLink href="/appointments" Match="NavLinkMatch.Prefix">
        <span class="nav-icon">RD</span>
        <span>Randevu</span>
    </NavLink>
    <NavLink href="/service-orders" Match="NavLinkMatch.Prefix">
        <span class="nav-icon">IS</span>
        <span>İşler</span>
    </NavLink>
    <NavLink href="/vehicles" Match="NavLinkMatch.Prefix">
        <span class="nav-icon">AR</span>
        <span>Araçlar</span>
    </NavLink>
    <NavLink href="/settings" Match="NavLinkMatch.Prefix">
        <span class="nav-icon">MN</span>
        <span>Menü</span>
    </NavLink>
</nav>

<div id="blazor-error-ui">
    Beklenmedik bir hata oluştu.
    <a href="" class="reload">Yenile</a>
    <a class="dismiss">×</a>
</div>

@code {
    private CurrentUserResponse? _currentUser;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        AuthService.AuthenticationStateChanged += HandleAuthenticationStateChanged;
        await RefreshCurrentUserAsync();
    }

    private async void HandleAuthenticationStateChanged()
    {
        await RefreshCurrentUserAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshCurrentUserAsync()
    {
        if (!await AuthService.IsAuthenticatedAsync())
        {
            _currentUser = null;
            return;
        }

        _currentUser = await AuthService.GetCurrentUserAsync();
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/login");
    }

    public void Dispose()
    {
        AuthService.AuthenticationStateChanged -= HandleAuthenticationStateChanged;
    }
}
