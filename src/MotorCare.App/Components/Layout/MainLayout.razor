@inherits LayoutComponentBase
@implements IDisposable
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<div class="app-shell">
    <aside class="sidebar">
        <NavMenu />
    </aside>

    <div class="workspace">
        <header class="app-topbar">
            <div class="topbar-brand">
                <div class="topbar-logo">MC</div>
                <div>
                    <div class="topbar-title">MotorCare</div>
                    <div class="topbar-subtitle">Servis Operasyon Merkezi</div>
                </div>
            </div>

            <div class="topbar-actions">
                @if (_currentUser is not null)
                {
                    <div class="tenant-chip">
                        <div class="tenant-chip-label">@_currentUser.TenantIdentifier</div>
                        <div class="tenant-chip-value">@_currentUser.FullName · @_currentUser.Role</div>
                    </div>

                    <button type="button" class="btn btn-outline-secondary topbar-logout" @onclick="LogoutAsync">
                        Çıkış Yap
                    </button>
                }
                else
                {
                    <div class="tenant-chip tenant-chip-muted">
                        <div class="tenant-chip-label">Oturum</div>
                        <div class="tenant-chip-value">Bağlı değil</div>
                    </div>
                }
            </div>
        </header>

        <main class="workspace-main">
            @Body
        </main>
    </div>
</div>

<nav class="mobile-bottom-nav">
    <a href="/dashboard">
        <span class="nav-icon">◉</span>
        <span>Dashboard</span>
    </a>
    <a href="/service-orders">
        <span class="nav-icon">⚙</span>
        <span>Servis</span>
    </a>
    <a href="/customers">
        <span class="nav-icon">◎</span>
        <span>Müşteriler</span>
    </a>
    <a href="/settings">
        <span class="nav-icon">≡</span>
        <span>Ayarlar</span>
    </a>
</nav>

<div id="blazor-error-ui">
    Beklenmedik bir hata oluştu.
    <a href="" class="reload">Yenile</a>
    <a class="dismiss">✕</a>
</div>

@code {
    private CurrentUserResponse? _currentUser;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        AuthService.AuthenticationStateChanged += HandleAuthenticationStateChanged;
        await RefreshCurrentUserAsync();
    }

    private async void HandleAuthenticationStateChanged()
    {
        await RefreshCurrentUserAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshCurrentUserAsync()
    {
        if (!await AuthService.IsAuthenticatedAsync())
        {
            _currentUser = null;
            return;
        }

        _currentUser = await AuthService.GetCurrentUserAsync();
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/login");
    }

    public void Dispose()
    {
        AuthService.AuthenticationStateChanged -= HandleAuthenticationStateChanged;
    }
}
