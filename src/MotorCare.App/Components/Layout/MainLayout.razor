@inherits LayoutComponentBase
@implements IDisposable
@using MotorCare.Application.Common
@using MotorCare.App.Authorization
@using Microsoft.AspNetCore.Components.Web
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject ILogger<MainLayout> Logger

<HeadContent>
    <meta name="robots" content="noindex,nofollow" />
</HeadContent>

<div class="app-shell">
    <AppSidebar />

    <div class="app-main">
        <header class="app-topbar">
            <div class="app-topbar-search" @onfocusout="HandleSearchFocusOutAsync">
                <input type="text"
                       class="app-search-input"
                       placeholder="Ara, plaka, müşteri veya servis no"
                       value="@_searchQuery"
                       @oninput="HandleSearchInput"
                       @onkeydown="HandleSearchKeyDownAsync"
                       @onfocus="HandleSearchFocus" />

                @if (_isSearchOpen)
                {
                    <div class="app-topbar-panel app-search-panel">
                        @if (!string.IsNullOrWhiteSpace(_searchError))
                        {
                            <div class="app-topbar-panel-state app-topbar-panel-error">@_searchError</div>
                        }
                        else if (SearchShortcuts.Count == 0)
                        {
                            <div class="app-topbar-panel-state">En az 2 karakter girin.</div>
                        }
                        else
                        {
                            <div class="app-topbar-panel-title">Hızlı arama</div>

                            @foreach (var shortcut in SearchShortcuts)
                            {
                                <button type="button"
                                        class="app-search-link"
                                        @onclick="@(() => NavigateTo(shortcut.Href))">
                                    <span class="app-search-link-title">@shortcut.Title</span>
                                    <span class="app-search-link-copy">@shortcut.Description</span>
                                </button>
                            }
                        }
                    </div>
                }
            </div>

            <div class="app-topbar-actions" @onfocusout="HandleCreateMenuFocusOutAsync">
                @if (CreateActions.Count > 0)
                {
                    <div class="app-topbar-menu-wrap">
                        <button type="button" class="app-btn-primary" @onclick="ToggleCreateMenu">
                            + Yeni
                        </button>

                        @if (_isCreateMenuOpen)
                        {
                            <div class="app-topbar-panel app-create-menu">
                                @foreach (var createAction in CreateActions)
                                {
                                    <button type="button"
                                            class="app-menu-link"
                                            @onclick="@(() => NavigateTo(createAction.Href))">
                                        <span class="app-menu-link-title">@createAction.Title</span>
                                        <span class="app-menu-link-copy">@createAction.Description</span>
                                    </button>
                                }
                            </div>
                        }
                    </div>
                }

                @if (_currentUser is not null)
                {
                    <div class="app-user-chip">
                        <div class="app-user-chip-label">@_currentUser.TenantIdentifier</div>
                        <div class="app-user-chip-value">@_currentUser.FullName · @_currentUser.Role</div>
                    </div>

                    <button type="button" class="app-btn-secondary" @onclick="LogoutAsync">Çıkış Yap</button>
                }
                else
                {
                    <div class="app-user-chip app-user-chip-muted">
                        <div class="app-user-chip-label">Oturum</div>
                        <div class="app-user-chip-value">Bağlı değil</div>
                    </div>
                }
            </div>
        </header>

        <main class="app-content">
            @Body
        </main>
    </div>
</div>

<nav class="mobile-bottom-nav">
    @if (AppRoleAccess.CanReadDashboard(_currentUser?.Role))
    {
        <NavLink href="/dashboard" Match="NavLinkMatch.Prefix">
            <span class="nav-icon">DB</span>
            <span>Dashboard</span>
        </NavLink>
    }
    <NavLink href="/appointments" Match="NavLinkMatch.Prefix">
        <span class="nav-icon">RD</span>
        <span>Randevu</span>
    </NavLink>
    @if (AppRoleAccess.CanReadServiceOrders(_currentUser?.Role))
    {
        <NavLink href="/service-orders" Match="NavLinkMatch.Prefix">
            <span class="nav-icon">IS</span>
            <span>İşler</span>
        </NavLink>
    }
    <NavLink href="/vehicles" Match="NavLinkMatch.Prefix">
        <span class="nav-icon">AR</span>
        <span>Araçlar</span>
    </NavLink>
    <NavLink href="/settings" Match="NavLinkMatch.Prefix">
        <span class="nav-icon">MN</span>
        <span>Menü</span>
    </NavLink>
</nav>

<div id="blazor-error-ui">
    Beklenmedik bir hata oluştu.
    <a href="" class="reload">Yenile</a>
    <a class="dismiss">×</a>
</div>

@code {
    private CurrentUserResponse? _currentUser;
    private string _searchQuery = string.Empty;
    private string? _searchError;
    private bool _isSearchOpen;
    private bool _isCreateMenuOpen;
    private bool _isDisposed;

    private IReadOnlyList<SearchShortcut> SearchShortcuts =>
        string.IsNullOrWhiteSpace(_searchQuery) || _searchQuery.Trim().Length < 2
            ? Array.Empty<SearchShortcut>()
            : new[]
            {
                new SearchShortcut(
                    "Müşterilerde ara",
                    "Ad, telefon veya e-posta içinde ara",
                    $"/customers?q={Uri.EscapeDataString(_searchQuery.Trim())}"),
                new SearchShortcut(
                    "Servislerde ara",
                    "Servis no, plaka veya müşteri üzerinden devam et",
                    $"/service-orders?q={Uri.EscapeDataString(_searchQuery.Trim())}"),
                new SearchShortcut(
                    "Randevularda ara",
                    "Bugünkü ve geçmiş randevular içinde ara",
                    $"/appointments?q={Uri.EscapeDataString(_searchQuery.Trim())}")
            };

    private IReadOnlyList<QuickActionLink> CreateActions
    {
        get
        {
            var role = _currentUser?.Role;
            var actions = new List<QuickActionLink>();

            if (AppRoleAccess.CanWriteServiceOrders(role))
            {
                actions.Add(new("Yeni Randevu", "Yeni kabul ve randevu kaydı oluştur", "/appointments/create"));
                actions.Add(new("Yeni Servis", "Yeni servis emri aç", "/service-orders/create"));
            }

            if (AppRoleAccess.CanWriteCustomers(role))
            {
                actions.Add(new("Yeni Müşteri", "Yeni müşteri kartı oluştur", "/customers/create"));
                actions.Add(new("Yeni Araç", "Yeni araç veya motosiklet ekle", "/vehicles/create"));
            }

            if (AppRoleAccess.CanWriteCustomers(role))
            {
                actions.Add(new("Yeni Hizmet", "Hizmet kataloğuna yeni kalem ekle", "/services/create"));
            }

            return actions;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            AuthService.AuthenticationStateChanged += HandleAuthenticationStateChanged;
            await RefreshCurrentUserAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Main layout authentication state refresh failed during first render.");
            _currentUser = null;
            await SafeStateHasChangedAsync();
        }
    }

    private void HandleAuthenticationStateChanged()
    {
        _ = HandleAuthenticationStateChangedAsync();
    }

    private async Task RefreshCurrentUserAsync()
    {
        var isAuthenticated = await AuthService.IsAuthenticatedAsync();
        if (!isAuthenticated)
        {
            _currentUser = null;
            return;
        }

        _currentUser = await AuthService.GetCurrentUserAsync();
    }

    private void HandleSearchFocus()
    {
        if (!string.IsNullOrWhiteSpace(_searchQuery) && _searchQuery.Trim().Length >= 2)
        {
            _searchError = null;
            _isSearchOpen = true;
        }
    }

    private void HandleSearchInput(ChangeEventArgs args)
    {
        try
        {
            _searchQuery = args.Value?.ToString() ?? string.Empty;
            _searchError = null;
            _isSearchOpen = _searchQuery.Trim().Length >= 2;
        }
        catch
        {
            _searchError = "Arama sırasında hata oluştu.";
            _isSearchOpen = true;
        }
    }

    private Task HandleSearchKeyDownAsync(KeyboardEventArgs args)
    {
        if (args.Key is "Enter")
        {
            var query = _searchQuery.Trim();
            if (query.Length >= 2)
            {
                NavigateTo($"/service-orders?q={Uri.EscapeDataString(query)}");
            }
        }
        else if (args.Key is "Escape")
        {
            CloseSearch();
        }

        return Task.CompletedTask;
    }

    private async Task HandleSearchFocusOutAsync(FocusEventArgs _)
    {
        await Task.Delay(120);
        if (_isDisposed)
        {
            return;
        }

        _isSearchOpen = false;
        await SafeStateHasChangedAsync();
    }

    private void ToggleCreateMenu()
    {
        _isCreateMenuOpen = !_isCreateMenuOpen;
        _isSearchOpen = false;
    }

    private async Task HandleCreateMenuFocusOutAsync(FocusEventArgs _)
    {
        if (!_isCreateMenuOpen)
        {
            return;
        }

        await Task.Delay(120);
        if (_isDisposed)
        {
            return;
        }

        _isCreateMenuOpen = false;
        await SafeStateHasChangedAsync();
    }

    private void NavigateTo(string href)
    {
        _isCreateMenuOpen = false;
        CloseSearch();
        NavigationManager.NavigateTo(href);
    }

    private void CloseSearch()
    {
        _isSearchOpen = false;
        _searchError = null;
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        TryNavigateTo("/login");
    }

    public void Dispose()
    {
        if (_isDisposed)
        {
            return;
        }

        _isDisposed = true;
        AuthService.AuthenticationStateChanged -= HandleAuthenticationStateChanged;
    }

    private async Task HandleAuthenticationStateChangedAsync()
    {
        try
        {
            if (_isDisposed)
            {
                Logger.LogDebug(EventIdStore.Common.AuthRecoverySkippedDueToDisposedCircuit,
                    "Main layout auth recovery skipped because component is disposed.");
                return;
            }

            await RefreshCurrentUserAsync();
            await SafeStateHasChangedAsync();
        }
        catch (Exception ex) when (_isDisposed || ex is ObjectDisposedException or InvalidOperationException or Microsoft.JSInterop.JSDisconnectedException or TaskCanceledException or OperationCanceledException)
        {
            _currentUser = null;
            Logger.LogDebug(EventIdStore.Common.AuthRecoverySkippedDueToDisposedCircuit,
                "Main layout auth recovery skipped because circuit is disposed or disconnected. ExceptionType={ExceptionType}",
                ex.GetType().Name);
        }
    }

    private async Task SafeStateHasChangedAsync()
    {
        if (_isDisposed)
        {
            return;
        }

        try
        {
            await InvokeAsync(() =>
            {
                if (!_isDisposed)
                {
                    StateHasChanged();
                }
            });
        }
        catch (ObjectDisposedException)
        {
        }
        catch (InvalidOperationException) when (_isDisposed)
        {
        }
    }

    private void TryNavigateTo(string uri)
    {
        if (_isDisposed)
        {
            Logger.LogInformation(EventIdStore.Common.NavigationSkippedDueToDisconnectedCircuit,
                "Navigation skipped because main layout is disposed. Target={Target}", uri);
            return;
        }

        try
        {
            NavigationManager.NavigateTo(uri);
        }
        catch (Exception ex) when (ex is ObjectDisposedException or InvalidOperationException or Microsoft.JSInterop.JSDisconnectedException or TaskCanceledException or OperationCanceledException)
        {
            Logger.LogDebug(EventIdStore.Common.NavigationSkippedDueToDisconnectedCircuit,
                "Navigation skipped because main layout circuit is disconnected. Target={Target} ExceptionType={ExceptionType}",
                uri,
                ex.GetType().Name);
        }
    }

    private sealed record SearchShortcut(string Title, string Description, string Href);
    private sealed record QuickActionLink(string Title, string Description, string Href);
}
