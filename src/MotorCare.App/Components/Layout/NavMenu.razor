@implements IDisposable
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<div class="brand-block">
    <div class="brand-mark">MC</div>
    <div>
        <div class="brand-title">MotorCare</div>
        <div class="brand-subtitle">Modern servis yönetimi</div>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="menu-stack">
        <NavLink class="menu-link" href="/dashboard" Match="NavLinkMatch.All">
            <span class="nav-icon">◉</span>
            Dashboard
        </NavLink>

        <NavLink class="menu-link" href="/service-orders">
            <span class="nav-icon">⚙</span>
            Servis İşlemleri
        </NavLink>

        <NavLink class="menu-link" href="/appointments">
            <span class="nav-icon">◷</span>
            Randevular
        </NavLink>

        <NavLink class="menu-link" href="/customers">
            <span class="nav-icon">◎</span>
            Müşteriler
        </NavLink>

        <NavLink class="menu-link" href="/vehicles">
            <span class="nav-icon">◈</span>
            Araçlar
        </NavLink>

        <NavLink class="menu-link" href="/collections">
            <span class="nav-icon">◇</span>
            Tahsilatlar
        </NavLink>

        <NavLink class="menu-link" href="/reports">
            <span class="nav-icon">▤</span>
            Raporlar
        </NavLink>

        <NavLink class="menu-link" href="/settings">
            <span class="nav-icon">≡</span>
            Ayarlar
        </NavLink>

        <div class="menu-divider"></div>

        @if (_isAuthenticated)
        {
            <button type="button" class="logout-button" @onclick="LogoutAsync">
                <span class="nav-icon">→</span>
                Çıkış Yap
            </button>
        }
        else
        {
            <NavLink class="menu-link subtle-link" href="/login">
                <span class="nav-icon">→</span>
                Giriş Yap
            </NavLink>
            <NavLink class="menu-link subtle-link" href="/register">
                <span class="nav-icon">+</span>
                Kayıt Ol
            </NavLink>
        }
    </nav>
</div>

@code {
    private bool _isAuthenticated;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        AuthService.AuthenticationStateChanged += HandleAuthenticationStateChanged;
        _isAuthenticated = await AuthService.IsAuthenticatedAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async void HandleAuthenticationStateChanged()
    {
        _isAuthenticated = await AuthService.IsAuthenticatedAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/login");
    }

    public void Dispose()
    {
        AuthService.AuthenticationStateChanged -= HandleAuthenticationStateChanged;
    }
}
