@implements IDisposable
@using MotorCare.Application.Common
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject ILogger<NavMenu> Logger

<div class="brand-block">
    <div class="brand-mark">GP</div>
    <div>
        <div class="brand-title">GarajPass</div>
        <div class="brand-subtitle">Servis & Ekspertiz OS</div>
    </div>
</div>

<div class="nav-scrollable">
    <nav class="menu-stack">
        <NavLink class="menu-link" href="/dashboard" Match="NavLinkMatch.All">
            <span class="nav-icon">DB</span>
            <span>Dashboard</span>
        </NavLink>

        <NavLink class="menu-link" href="/appointments">
            <span class="nav-icon">RD</span>
            <span>Randevular</span>
        </NavLink>

        <NavLink class="menu-link" href="/service-orders">
            <span class="nav-icon">SE</span>
            <span>Servis Emirleri</span>
        </NavLink>

        <NavLink class="menu-link" href="/customers">
            <span class="nav-icon">MS</span>
            <span>Müşteriler</span>
        </NavLink>

        <NavLink class="menu-link" href="/vehicles">
            <span class="nav-icon">AR</span>
            <span>Araçlar</span>
        </NavLink>

        <NavLink class="menu-link" href="/appointments/create">
            <span class="nav-icon">HZ</span>
            <span>Hizmetler</span>
        </NavLink>

        <NavLink class="menu-link" href="/service-orders/create">
            <span class="nav-icon">ST</span>
            <span>Stok / Parça</span>
        </NavLink>

        <NavLink class="menu-link" href="/collections">
            <span class="nav-icon">KS</span>
            <span>Finans / Kasa</span>
        </NavLink>

        <NavLink class="menu-link" href="/reports">
            <span class="nav-icon">RP</span>
            <span>Raporlar</span>
        </NavLink>

        <NavLink class="menu-link" href="/settings">
            <span class="nav-icon">AY</span>
            <span>Ayarlar</span>
        </NavLink>

        <div class="menu-divider"></div>

        @if (_isAuthenticated)
        {
            <button type="button" class="logout-button" @onclick="LogoutAsync">
                <span class="nav-icon">CI</span>
                <span>Çıkış Yap</span>
            </button>
        }
        else
        {
            <NavLink class="menu-link subtle-link" href="/login">
                <span class="nav-icon">GY</span>
                <span>Giriş Yap</span>
            </NavLink>
            <NavLink class="menu-link subtle-link" href="/register">
                <span class="nav-icon">DA</span>
                <span>Demo Al</span>
            </NavLink>
        }
    </nav>
</div>

@code {
    private bool _isAuthenticated;
    private bool _isDisposed;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        AuthService.AuthenticationStateChanged += HandleAuthenticationStateChanged;
        _isAuthenticated = await AuthService.IsAuthenticatedAsync();
        await SafeStateHasChangedAsync();
    }

    private void HandleAuthenticationStateChanged()
    {
        _ = HandleAuthenticationStateChangedAsync();
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        TryNavigateTo("/login");
    }

    public void Dispose()
    {
        if (_isDisposed)
        {
            return;
        }

        _isDisposed = true;
        AuthService.AuthenticationStateChanged -= HandleAuthenticationStateChanged;
    }

    private async Task HandleAuthenticationStateChangedAsync()
    {
        try
        {
            if (_isDisposed)
            {
                Logger.LogDebug(EventIdStore.Common.AuthRecoverySkippedDueToDisposedCircuit,
                    "Nav menu auth recovery skipped because component is disposed.");
                return;
            }

            _isAuthenticated = await AuthService.IsAuthenticatedAsync();
            await SafeStateHasChangedAsync();
        }
        catch (Exception ex) when (_isDisposed || ex is ObjectDisposedException or InvalidOperationException or Microsoft.JSInterop.JSDisconnectedException or TaskCanceledException or OperationCanceledException)
        {
            Logger.LogDebug(EventIdStore.Common.AuthRecoverySkippedDueToDisposedCircuit,
                "Nav menu auth recovery skipped because circuit is disposed or disconnected. ExceptionType={ExceptionType}",
                ex.GetType().Name);
        }
    }

    private async Task SafeStateHasChangedAsync()
    {
        if (_isDisposed)
        {
            return;
        }

        try
        {
            await InvokeAsync(() =>
            {
                if (!_isDisposed)
                {
                    StateHasChanged();
                }
            });
        }
        catch (ObjectDisposedException)
        {
        }
        catch (InvalidOperationException) when (_isDisposed)
        {
        }
    }

    private void TryNavigateTo(string uri)
    {
        if (_isDisposed)
        {
            Logger.LogDebug(EventIdStore.Common.NavigationSkippedDueToDisconnectedCircuit,
                "Navigation skipped because nav menu is disposed. Target={Target}", uri);
            return;
        }

        try
        {
            NavigationManager.NavigateTo(uri);
        }
        catch (Exception ex) when (ex is ObjectDisposedException or InvalidOperationException or Microsoft.JSInterop.JSDisconnectedException or TaskCanceledException or OperationCanceledException)
        {
            Logger.LogDebug(EventIdStore.Common.NavigationSkippedDueToDisconnectedCircuit,
                "Navigation skipped because nav menu circuit is disconnected. Target={Target} ExceptionType={ExceptionType}",
                uri,
                ex.GetType().Name);
        }
    }
}
