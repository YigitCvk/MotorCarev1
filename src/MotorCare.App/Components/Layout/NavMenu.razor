@implements IDisposable
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<div class="brand-block">
    <div class="brand-mark">MC</div>
    <div>
        <div class="brand-title">MotorCare</div>
        <div class="brand-subtitle">Modern servis yonetimi</div>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="menu-stack">
        <NavLink class="menu-link" href="/dashboard">Dashboard</NavLink>
        <NavLink class="menu-link" href="/service-orders">Servis Islemleri</NavLink>
        <NavLink class="menu-link" href="/customers">Musteriler</NavLink>
        <NavLink class="menu-link" href="/vehicles">Araclar</NavLink>
        <NavLink class="menu-link" href="/collections">Tahsilatlar</NavLink>
        <NavLink class="menu-link" href="/reports">Raporlar</NavLink>
        <NavLink class="menu-link" href="/settings">Ayarlar</NavLink>

        <div class="menu-divider"></div>

        @if (_isAuthenticated)
        {
            <button type="button" class="logout-button" @onclick="LogoutAsync">Logout</button>
        }
        else
        {
            <NavLink class="menu-link subtle-link" href="/login">Login</NavLink>
            <NavLink class="menu-link subtle-link" href="/register">Register</NavLink>
        }
    </nav>
</div>

@code {
    private bool _isAuthenticated;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        AuthService.AuthenticationStateChanged += HandleAuthenticationStateChanged;
        _isAuthenticated = await AuthService.IsAuthenticatedAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async void HandleAuthenticationStateChanged()
    {
        _isAuthenticated = await AuthService.IsAuthenticatedAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/login");
    }

    public void Dispose()
    {
        AuthService.AuthenticationStateChanged -= HandleAuthenticationStateChanged;
    }
}
